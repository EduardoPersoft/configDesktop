select
    itemestoque.codigo,
    itemestoque.descricao,
    CADCLI.NOME,
    NOTAFISCAL.NRNOTAFORNECEDOR,
    mercadoriasnota.idpedido,
    mercadoriasnota.IDMERCPEDIDO,
    mercadoriasnota.cfop,    
    mercadoriasnota.QUANTIDADE,
    mercadoriasnota.unidade,
    case mercadoriasnota.unidade when 'KG' 
    then mercadoriasnota.quantidade
    else mercadoriasnota.QUANTIDADE*itemestoque.C_PESOMPPOREMBALAGEM
    end as peso
from
    NOTACOMPRA NOTAFISCAL
inner join
    MERCADORIASNOTACOMPRA mercadoriasnota on
        notafiscal.filial=mercadoriasnota.filial and
        notafiscal.idnota=mercadoriasnota.IDNOTA
inner join
    itemestoque on
        itemestoque.codigo=mercadoriasnota.codigo
inner join
    cadastroparceiros cadcli on
        cadcli.cadastro=notafiscal.destinatario
where
    notafiscal.filial=110 and
    notafiscal.DATAEMISSAO between '01.10.2023' and '31.10.2023' and
    itemestoque.tipoproduto='4' and
    mercadoriasnota.cfop not in ('6116')
order by
    mercadoriasnota.cfop
