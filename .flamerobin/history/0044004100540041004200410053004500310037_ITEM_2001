SET TERM ^ ;
ALTER PROCEDURE ESTATPEDIDO
RETURNS (
    FILIAL integer,
    IDNOTA integer,
    IDMERCSERV smallint,
    ANO smallint,
    MES smallint,
    CODCLIENTE integer,
    VALOR double precision,
    CODMERC varchar(15),
    GRUPO smallint,
    DESCR varchar(240),
    CLIENTE varchar(40),
    ITEMBASE varchar(15),
    ITEMBASEDESC varchar(240),
    TIPO varchar(10),
    QUANTIDADE double precision,
    QUANTIDADEUNIDADE double precision,
    DATAINICIAL timestamp,
    DATAFINAL timestamp,
    MATERIALINICIAL varchar(15),
    MATERIALFINAL varchar(15),
    CONSOLIDADO char(1),
    DESCRICAO_ESTSIN varchar(85),
    NOME varchar(40),
    SERVICOINICIAL smallint,
    SERVICOFINAL smallint,
    DESCRGRUPO varchar(40),
    COMIPI char(1),
    DATAINICIO1 timestamp,
    DATAFIM1 timestamp,
    VALOR1 double precision,
    DATAINICIO2 timestamp,
    DATAFIM2 timestamp,
    VALOR2 double precision,
    DATAINICIO3 timestamp,
    DATAFIM3 timestamp,
    VALOR3 double precision,
    DATAINICIO4 timestamp,
    DATAFIM4 timestamp,
    VALOR4 double precision,
    DATAINICIO5 timestamp,
    DATAFIM5 timestamp,
    VALOR5 double precision,
    DATAINICIO6 timestamp,
    DATAFIM6 timestamp,
    VALOR6 double precision,
    DATAINICIO7 timestamp,
    DATAFIM7 timestamp,
    VALOR7 double precision,
    DATAINICIO8 timestamp,
    DATAFIM8 timestamp,
    VALOR8 double precision,
    DATAINICIO9 timestamp,
    DATAFIM9 timestamp,
    VALOR9 double precision,
    DATAINICIO10 timestamp,
    DATAFIM10 timestamp,
    VALOR10 double precision,
    DATAINICIO11 timestamp,
    DATAFIM11 timestamp,
    VALOR11 double precision,
    DATAINICIO12 timestamp,
    DATAFIM12 timestamp,
    VALOR12 double precision,
    OPCAO smallint,
    IDITEMCOMP varchar(15),
    QUANTCOMP double precision,
    TOTALCOMP double precision,
    QUANTCOMPUNIDADE double precision,
    VALORCOMP1 double precision,
    VALORCOMP2 double precision,
    VALORCOMP3 double precision,
    VALORCOMP4 double precision,
    VALORCOMP5 double precision,
    VALORCOMP6 double precision,
    VALORCOMP7 double precision,
    VALORCOMP8 double precision,
    VALORCOMP9 double precision,
    VALORCOMP10 double precision,
    VALORCOMP11 double precision,
    VALORCOMP12 double precision,
    VALORCOMP double precision,
    DESCRCOMP varchar(240),
    DETALHADOPOR varchar(40),
    SEPARADOPOR varchar(40),
    VENDEDOR integer,
    FAMILIA integer,
    FAMILIADESCRICAO varchar(30),
    CANALRELACIONADO integer,
    CFOP varchar(4),
    UF varchar(2),
    NUMERONOTA integer,
    DATAEMISSAO timestamp )

AS
declare variable datanota timestamp;
declare variable valorretorna double precision;
declare variable status integer;
declare variable zn char(1);
declare variable subustituicao char(1);
declare variable ipi double precision;
declare variable ipinota double precision;
declare variable icmssubst double precision;
declare variable icms double precision;
declare variable fcliente integer;
declare variable fareageografica smallint;
declare variable framoatividade smallint;
declare variable fcanaldistribuicao smallint;
declare variable fgrupo smallint;
declare variable fgruposervico smallint;
declare variable fproduto varchar(8);
declare variable fservico varchar(8);
declare variable fvendedor integer;
declare variable ffamilia integer;
declare variable festado char(2);
declare VARIABLE FCFOP  varchar (4) ;
declare variable movimentaestoque char(1);
declare variable fatura char(1);
declare variable valoricmsrecolhido double precision;
declare variable filialnaoentra char(1);
declare variable qtdfilial integer;
declare variable consumo char(1);
declare variable valorfrete double precision;
declare variable valorseguro double precision;
declare variable vlroutdespacessoria double precision;
declare variable ffilial integer;
BEGIN

SELECT
    ESTSIN.DATAINICIAL, ESTSIN.DATAFINAL, 
    ESTSIN.MATERIALINICIAL, ESTSIN.MATERIALFINAL, 
    ESTSIN.CONSOLIDADO, ESTSIN.DESCRICAO, ESTAB.NOME,
    CAST(ESTSIN.SERVICOINICIAL AS VARCHAR(8)),
    CAST(ESTSIN.SERVICOFINAL AS VARCHAR(8)),
    estsin.consumo, ESTSIN.INC, ESTSIN.OPCAO,
    ESTSIN.aoscuidados,ESTSIN.vertical, ESTSIN.ESTABELECIMENTO
FROM  
    ESTSIN
INNER JOIN 
    CADASTROPARCEIROS ESTAB ON ESTAB.CADASTRO=ESTSIN.ESTABELECIMENTO
WHERE 
    ESTSIN.RELATORIO ='ESTATSIN'

INTO 
    :DATAINICIAL, :DATAFINAL, :MATERIALINICIAL, :MATERIALFINAL,
    :CONSOLIDADO, :detalhadopor, :NOME, :SERVICOINICIAL, :SERVICOFINAL,
    :consumo, :COMIPI, :OPCAO, :SEPARADOPOR, :filialnaoentra, FFILIAL;



SELECT DATAINICIO1, DATAFIM1, DATAINICIO2, DATAFIM2, DATAINICIO3, DATAFIM3, DATAINICIO4,
       DATAFIM4, DATAINICIO5, DATAFIM5, DATAINICIO6, DATAFIM6, DATAINICIO7, DATAFIM7,
       DATAINICIO8, DATAFIM8, DATAINICIO9, DATAFIM9, DATAINICIO10, DATAFIM10, DATAINICIO11,
       DATAFIM11, DATAINICIO12, DATAFIM12, FCLIENTE, FAREAGEOGRAFICA, FRAMOATIVIDADE,
       FCANALDISTRIBUICAO, FGRUPO, FGRUPOSERVICO, FPRODUTO, FSERVICO, FVENDEDOR,
       FESTADO, ffamilia, FCFOP
FROM FILTRO_ESTATISTICA
WHERE FILTRO_ESTATISTICA.RELATORIO='ESTATSIN'
INTO :DATAINICIO1, :DATAFIM1, :DATAINICIO2, :DATAFIM2, :DATAINICIO3, :DATAFIM3,
        :DATAINICIO4, :DATAFIM4, :DATAINICIO5, :DATAFIM5, :DATAINICIO6, :DATAFIM6,
        :DATAINICIO7, :DATAFIM7, :DATAINICIO8, :DATAFIM8, :DATAINICIO9, :DATAFIM9,
        :DATAINICIO10, :DATAFIM10, :DATAINICIO11, :DATAFIM11, :DATAINICIO12, :DATAFIM12,
        :FCLIENTE, :FAREAGEOGRAFICA,  :FRAMOATIVIDADE, :FCANALDISTRIBUICAO, :FGRUPO,
        :FGRUPOSERVICO, :FPRODUTO, :FSERVICO, :FVENDEDOR, :FESTADO, :ffamilia, FCFOP;

FOR SELECT
      notafiscal.filial, NOTAFISCAL.IDNOTA,
      notafiscal.numeronota,
      notafiscal.datareferencia,
      CAST(NATUREZAOPERACAO.cfop AS VARCHAR(4)),
      MERCADORIASNOTA.IDMERCADORIA AS IDMERCSERV,
      EXTRACT(YEAR FROM NOTAFISCAL.DATACADASTRO) ANO,
      EXTRACT(MONTH FROM NOTAFISCAL.DATACADASTRO) MES,
      NOTAFISCAL.DESTINATARIO, (
      (MERCADORIASNOTA.VLRFINALMERCAD+MERCADORIASNOTA.ACRESCIMONOTA)-MERCADORIASNOTA.DESCONTONOTA) 
      VLRFINALMERCAD,
      MERCADORIASNOTA.CODIGO, ITEM.GRUPO,
      item.familia,
      item.itembase,
      (select item2.descricao from itemestoque item2 where item2.codigo=item.itembase) as itembasedesc, 
      CAST(ITEM.DESCRICAO AS VARCHAR(240)) AS DESCRICAO,
      CLIENTE.NOME, 'PRODUTO' AS TIPO,
      MERCADORIASNOTA.QUANTIDADE, MERCADORIASNOTA.QUANTIDADE*coalesce(ITEM.QUANTIDADEUNIDADE,1), 
    mercadoriasnota.frete,
    mercadoriasnota.seguro,
    mercadoriasnota.outdespacessor,
    NOTAFISCAL.VALORIPI,MERCADORIASNOTA.VALORIPI,MERCADORIASNOTA.VALORICMS,
      NOTAFISCAL.ZONAFRANCA, MERCADORIASNOTA.VLRICMSSUBST, 
      notafiscal.datareferencia, NATUREZAOPERACAO.estatisticaestoque,
      notafiscal.substributaria,
      MERCADORIASNOTA.VLRICMSRECOLHIDO,
      NATUREZAOPERACAO.FATURA,
      notafiscal.uf
FROM  PEDIDO  as NOTAFISCAL
INNER JOIN MERCADORIASPED MERCADORIASNOTA ON (NOTAFISCAL.FILIAL = MERCADORIASNOTA.FILIAL
                           AND   NOTAFISCAL.IDNOTA = MERCADORIASNOTA.IDNOTA)
INNER JOIN ITEMESTOQUE ITEM ON (MERCADORIASNOTA.CODIGO = ITEM.CODIGO)
INNER JOIN CADASTROPARCEIROS CLIENTE ON (NOTAFISCAL.DESTINATARIO = CLIENTE.CADASTRO)
INNER JOIN NATUREZAOPERACAO ON (NOTAFISCAL.OPERACAO = NATUREZAOPERACAO.ID)
WHERE NOTAFISCAL.DATAREFERENCIA BETWEEN :datainicial AND :datafinal
AND   NOT NOTAFISCAL.DATAEMISSAO IS NULL
AND   ((:consolidado = 2) OR (NOTAFISCAL.FILIAL = :ffilial))
AND   (NATUREZAOPERACAO.FATURA = 'S' or naturezaoperacao.estatisticaestoque='S')
AND   MERCADORIASNOTA.CODIGO BETWEEN :MATERIALINICIAL AND :MATERIALFINAL
AND  ((NOTAFISCAL.CANCELAMENTO = 'N') OR (NOTAFISCAL.CANCELAMENTO IS NULL))
AND  MERCADORIASNOTA.CFOP NOT IN ('5949','6949','5922','6922','5902','6902','5903','6903' )
INTO :FILIAL,:IDNOTA, :NUMERONOTA, :DATAEMISSAO, :CFOP,
:IDMERCSERV,:ANO,:MES,:CODCLIENTE,:VALOR,:CODMERC,:GRUPO, :familia,
:itembase,  :itembasedesc, :DESCR,
:CLIENTE,:TIPO,:QUANTIDADE,:QUANTIDADEUNIDADE, :valorfrete, :valorseguro, 
:vlroutdespacessoria, :IPINOTA, :IPI,:ICMS,:ZN,:ICMSSUBST,:DATANOTA,
:MOVIMENTAESTOQUE,:subustituicao,:VALORICMSRECOLHIDO,:FATURA,:uf

 DO BEGIN



   descricao_estsin = detalhadopor;
   if (:separadopor<>'Sem Separa????o') then
       descricao_estsin = descricao_estsin||' '||' por '||separadopor;

   descrgrupo = NULL;
   select grupomercadoria.descricao FROM GRUPOMERCADORIA
   WHERE GRUPOMERCADORIA.grupo=:grupo
   INTO :DESCRGRUPO;

   familiadescricao = NULL;
   if (:familia IS NULL ) then
   familiadescricao='SEM FAM??LIA';
   ELSE
   select coalesce ( FAMILIA.descricao,'SEM FAM??LIA') FROM FAMILIA
   WHERE FAMILIA.id=:FAMILIA
   INTO :familiadescricao;


   SELECT first 1 VENDEDORESNOTA.vendedor from vendedoresped VENDEDORESNOTA
   WHERE VENDEDORESNOTA.FILIAL=:filial
   AND VENDEDORESNOTA.IDNOTA=:idnota
   INTO :vendedor;

   SELECT vendedor.canalrelacionado from VENDEDOR
   WHERE VENDEDOR.cadastro=:vendedor
   INTO :canalrelacionado;

   IDITEMCOMP = :CODMERC;
   QUANTCOMP = :QUANTIDADE;
   TOTALCOMP = :VALOR;
   QUANTCOMPUNIDADE = :QUANTIDADEUNIDADE;
   DESCRCOMP = :DESCR;

   IF (:OPCAO=0) THEN
      IF (:FATURA='S') THEN
         STATUS=1;
      ELSE
         STATUS=0;
   ELSE
      IF (:MOVIMENTAESTOQUE='S') THEN
         STATUS=1;
      ELSE
         STATUS=0;

   IF(STATUS>0 AND :filialnaoentra='S') THEN BEGIN
       QTDFILIAL=0;
       SELECT COUNT(CADASTRO) FROM ESTABELECIMENTO WHERE ESTABELECIMENTO.CADASTRO=:codcliente
       INTO QTDFILIAL;
       if (COALESCE(QTDFILIAL,0)>0) then
         STATUS=0;
   END

   IF (:FCLIENTE=1 AND :STATUS>0) THEN
      SELECT COUNT(FCLIENTE.CADASTRO) FROM FCLIENTE WHERE FCLIENTE.CADASTRO=:CODCLIENTE INTO :STATUS;

   IF (:FAREAGEOGRAFICA=1 AND :STATUS>0) THEN
      SELECT COUNT(CADASTROPARCEIROS.CADASTRO) FROM CADASTROPARCEIROS
      INNER JOIN FAREAGEOGRAFICA ON (FAREAGEOGRAFICA.CODIGO=CADASTROPARCEIROS.AREAGEOGRAFICA)
      WHERE CADASTROPARCEIROS.CADASTRO=:CODCLIENTE INTO :STATUS;

   IF (:FRAMOATIVIDADE=1 AND :STATUS>0) THEN
      SELECT COUNT(CADASTROPARCEIROS.CADASTRO) FROM CADASTROPARCEIROS
      INNER JOIN FRAMOATIVIDADE ON (FRAMOATIVIDADE.CODIGO=CADASTROPARCEIROS.RAMOATIVIDADE)
      WHERE CADASTROPARCEIROS.CADASTRO=:CODCLIENTE INTO :STATUS;

   IF (:FESTADO=1 AND :STATUS>0) THEN
      SELECT COUNT(CADASTROPARCEIROS.CADASTRO) FROM CADASTROPARCEIROS
      INNER JOIN FESTADO ON (FESTADO.UF=CADASTROPARCEIROS.UF)
      WHERE CADASTROPARCEIROS.CADASTRO=:CODCLIENTE INTO :STATUS;

   IF (:FCANALDISTRIBUICAO=1 AND :STATUS>0) THEN
      SELECT COUNT(CLIENTES.CADASTRO) FROM CLIENTES
      INNER JOIN FCANALDISTRIBUICAO ON (FCANALDISTRIBUICAO.CODIGO=CLIENTES.CANALDISTRIBUICAO)
      WHERE CLIENTES.CADASTRO=:CODCLIENTE INTO :STATUS;

   IF (:FPRODUTO=1 AND :STATUS>0) THEN
      SELECT COUNT(FPRODUTO.CODIGO) FROM FPRODUTO WHERE FPRODUTO.CODIGO=:CODMERC INTO :STATUS;

   IF (:FGRUPO=1 AND :STATUS>0) THEN
      SELECT COUNT(FGRUPO.CODIGO) FROM FGRUPO WHERE FGRUPO.CODIGO=:GRUPO INTO :STATUS;

   IF (:ffamilia=1 AND :STATUS>0) THEN
      SELECT COUNT(ffamilia.codigo) FROM ffamilia WHERE ffamilia.codigo=:familia INTO :STATUS;

   IF (:FCFOP=1 AND :STATUS>0) THEN
      SELECT COUNT(FCFOP.CFOP) FROM FCFOP WHERE FCFOP.CFOP=:CFOP INTO :STATUS;

   IF (:FVENDEDOR=1 AND :STATUS>0) THEN
      SELECT COUNT(FVENDEDOR.CADASTRO) FROM VENDEDORESPED
      INNER JOIN FVENDEDOR ON (FVENDEDOR.CADASTRO=VENDEDORESPED.VENDEDOR)
      WHERE VENDEDORESPED.FILIAL=:FILIAL AND VENDEDORESPED.IDNOTA=:IDNOTA
      INTO :STATUS;


   IF (:STATUS>0) THEN BEGIN
      IF (COMIPI='S') THEN
        IF (IPINOTA>0 AND ZN='N') THEN
          VALOR=:VALOR+COALESCE(:IPI,0);

      IF (ZN='S' /*OR ((:subustituicao='S') AND (COMIPI='S') )*/ )THEN
        VALOR=:VALOR-COALESCE(:ICMS,0);
      IF ((:subustituicao='S') AND (COMIPI='S') AND (VALORICMSRECOLHIDO>0)) THEN
         VALOR=:VALOR+COALESCE(VALORICMSRECOLHIDO,0);

      IF (CONSUMO='S') THEN
      VALOR=:VALOR+coalesce(valorfrete,0)+coalesce(valorseguro,0)+coalesce(vlroutdespacessoria,0);

      IF (:OPCAO = 0) THEN
         VALORRETORNA =:VALOR;

      IF (:OPCAO = 1) THEN
         VALORRETORNA =:QUANTIDADEUNIDADE;

      IF (:OPCAO = 2) THEN
        VALORRETORNA =:QUANTIDADE;

      VALOR1=0;
      VALOR2=0;
      VALOR3=0;
      VALOR4=0;
      VALOR5=0;
      VALOR6=0;
      VALOR7=0;
      VALOR8=0;
      VALOR9=0;
      VALOR10=0;
      VALOR11=0;
      VALOR12=0;
      VALORCOMP1=0;
      VALORCOMP2=0;
      VALORCOMP3=0;
      VALORCOMP4=0;
      VALORCOMP5=0;
      VALORCOMP6=0;
      VALORCOMP7=0;
      VALORCOMP8=0;
      VALORCOMP9=0;
      VALORCOMP10=0;
      VALORCOMP11=0;
      VALORCOMP12=0;

      IF (:DATANOTA >= :DATAINICIO1 AND :DATANOTA <= :DATAFIM1) THEN
         VALOR1=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO2 AND :DATANOTA <= :DATAFIM2) THEN
         VALOR2=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO3 AND :DATANOTA <= :DATAFIM3) THEN
         VALOR3=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO4 AND :DATANOTA <= :DATAFIM4) THEN
         VALOR4=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO5 AND :DATANOTA <= :DATAFIM5) THEN
         VALOR5=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO6 AND :DATANOTA <= :DATAFIM6) THEN
         VALOR6=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO7 AND :DATANOTA <= :DATAFIM7) THEN
         VALOR7=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO8 AND :DATANOTA <= :DATAFIM8) THEN
         VALOR8=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO9 AND :DATANOTA <= :DATAFIM9) THEN
         VALOR9=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO10 AND :DATANOTA <= :DATAFIM10) THEN
         VALOR10=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO11 AND :DATANOTA <= :DATAFIM11) THEN
         VALOR11=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO12 AND :DATANOTA <= :DATAFIM12) THEN
         VALOR12=:VALORRETORNA;

      IF (COMIPI='S') THEN
        IF (IPINOTA>0 AND ZN='N') THEN
          VALORCOMP=:VALORCOMP+:IPI;

      IF (ZN='S') THEN
        VALOR=:VALOR-:ICMS;
        VALORCOMP=:VALORCOMP+ICMSSUBST;

      IF (CONSUMO='S') THEN
      VALORCOMP=:VALORCOMP+coalesce(valorfrete,0)+coalesce(valorseguro,0)+coalesce(vlroutdespacessoria,0);


      IF (:OPCAO = 0) THEN
      VALORRETORNA =:VALORCOMP;

      IF (:OPCAO = 1) THEN
      VALORRETORNA =:QUANTCOMPUNIDADE;

      IF (:OPCAO = 2) THEN
      VALORRETORNA =:QUANTCOMP;

      IF (:DATANOTA >= :DATAINICIO1 AND :DATANOTA <= :DATAFIM1) THEN
         VALORCOMP1=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO2 AND :DATANOTA <= :DATAFIM2) THEN
         VALORCOMP2=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO3 AND :DATANOTA <= :DATAFIM3) THEN
         VALORCOMP3=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO4 AND :DATANOTA <= :DATAFIM4) THEN
         VALORCOMP4=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO5 AND :DATANOTA <= :DATAFIM5) THEN
         VALORCOMP5=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO6 AND :DATANOTA <= :DATAFIM6) THEN
         VALORCOMP6=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO7 AND :DATANOTA <= :DATAFIM7) THEN
         VALORCOMP7=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO8 AND :DATANOTA <= :DATAFIM8) THEN
         VALORCOMP8=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO9 AND :DATANOTA <= :DATAFIM9) THEN
         VALORCOMP9=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO10 AND :DATANOTA <= :DATAFIM10) THEN
         VALORCOMP10=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO11 AND :DATANOTA <= :DATAFIM11) THEN
         VALORCOMP11=:VALORRETORNA;

      IF (:DATANOTA >= :DATAINICIO12 AND :DATANOTA <= :DATAFIM12) THEN
         VALORCOMP12=:VALORRETORNA;
     if(:consolidado='2') then begin
        filial=0;
        nome='Consolidado';
     end

      SUSPEND;
   END
END

VALORCOMP1=0;
VALORCOMP2=0;
VALORCOMP3=0;
VALORCOMP4=0;
VALORCOMP5=0;
VALORCOMP6=0;
VALORCOMP7=0;
VALORCOMP8=0;
VALORCOMP9=0;
VALORCOMP10=0;
VALORCOMP11=0;
VALORCOMP12=0;
IDITEMCOMP=NULL;
QUANTCOMP=NULL;
TOTALCOMP=NULL;
QUANTCOMPUNIDADE=NULL;
DESCRCOMP=NULL;
itembase=null;
itembasedesc=null;

FOR SELECT
      notafiscal.filial, NOTAFISCAL.IDNOTA,
      SERVICOSNOTA.IDSERVICO AS IDMERCSERV,
      EXTRACT(YEAR FROM NOTAFISCAL.DATACADASTRO) ANO,
      EXTRACT(MONTH FROM NOTAFISCAL.DATACADASTRO) MES,
      NOTAFISCAL.DESTINATARIO, (SERVICOSNOTA.VLRFINALSERVICO+SERVICOSNOTA.ACRESCIMONOTA-SERVICOSNOTA.DESCONTONOTA) VLRFINALSERVICO,
      CAST(SERVICOSNOTA.CODIGO AS VARCHAR(15)), SERVICO.GRUPOSERVICO AS GRUPO,
      CAST(SERVICO.DESCRICAO  AS VARCHAR(240)) AS DESCRICAO,
      CLIENTE.NOME, 'SERVICO' AS TIPO,
      SERVICOSNOTA.QUANTIDADE, 
      SERVICOSNOTA.QUANTIDADE, 
      notafiscal.datareferencia
FROM  pedido NOTAFISCAL
INNER JOIN servicosped SERVICOSNOTA ON (NOTAFISCAL.FILIAL = SERVICOSNOTA.FILIAL
                        AND NOTAFISCAL.IDNOTA = SERVICOSNOTA.IDNOTA)
INNER JOIN SERVICO ON (SERVICOSNOTA.CODIGO = SERVICO.CODIGO)
INNER JOIN CADASTROPARCEIROS CLIENTE ON (NOTAFISCAL.DESTINATARIO = CLIENTE.CADASTRO)
INNER JOIN NATUREZAOPERACAO ON (NOTAFISCAL.OPERACAO = NATUREZAOPERACAO.ID)
WHERE notafiscal.datareferencia BETWEEN :datainicial AND :datafinal
AND NOT NOTAFISCAL.DATAEMISSAO IS NULL
AND ((:consolidado = 2) OR (NOTAFISCAL.FILIAL = :ffilial))
AND NATUREZAOPERACAO.FATURA = 'S'
AND SERVICOSNOTA.CODIGO BETWEEN :SERVICOINICIAL AND :SERVICOFINAL
AND ((NOTAFISCAL.CANCELAMENTO = 'N') OR (NOTAFISCAL.CANCELAMENTO IS NULL))
INTO :FILIAL,:IDNOTA,:IDMERCSERV,:ANO,:MES,:CODCLIENTE,:VALOR,:CODMERC,:GRUPO,:DESCR,
:CLIENTE,:TIPO,:QUANTIDADE,:QUANTIDADEUNIDADE, :DATANOTA DO BEGIN
   STATUS=1;
   descricao_estsin = detalhadopor;
   if (:separadopor<>'Sem Separa????o') then
       descricao_estsin = descricao_estsin||' '||' por '||separadopor;

   SELECT first 1 VENDEDORESNOTA.vendedor from vendedoresped VENDEDORESNOTA
   WHERE VENDEDORESNOTA.FILIAL=:filial
   AND VENDEDORESNOTA.IDNOTA=:idnota
   INTO :vendedor;

   descrgrupo = NULL;
   SELECT GRUPOSERVICO.descricao FROM GRUPOSERVICO
   WHERE GRUPOSERVICO.grupo=:grupo
   INTO :descrgrupo;

   IF (:OPCAO = 0) THEN
      VALORRETORNA= :VALOR;
   IF (:OPCAO = 1) THEN
      VALORRETORNA = :QUANTIDADEUNIDADE;
   IF (:OPCAO = 2) THEN
      VALORRETORNA = :QUANTIDADE;

   IF(STATUS>0 AND :filialnaoentra='S') THEN BEGIN
       QTDFILIAL=0;
       SELECT COUNT(CADASTRO) FROM ESTABELECIMENTO WHERE ESTABELECIMENTO.CADASTRO=:codcliente
       INTO QTDFILIAL;
       if (COALESCE(QTDFILIAL,0)>0) then
         STATUS=0;
   END

   IF (:FCLIENTE=1 AND STATUS>0) THEN
      SELECT COUNT(FCLIENTE.CADASTRO) FROM FCLIENTE WHERE FCLIENTE.CADASTRO=:CODCLIENTE INTO :STATUS;

   IF (:FAREAGEOGRAFICA=1 AND :STATUS>0) THEN
      SELECT COUNT(CADASTROPARCEIROS.CADASTRO) FROM CADASTROPARCEIROS
      INNER JOIN FAREAGEOGRAFICA ON (FAREAGEOGRAFICA.CODIGO=CADASTROPARCEIROS.AREAGEOGRAFICA)
      WHERE CADASTROPARCEIROS.CADASTRO=:CODCLIENTE INTO :STATUS;

   IF (:FRAMOATIVIDADE=1 AND :STATUS>0) THEN
      SELECT COUNT(CADASTROPARCEIROS.CADASTRO) FROM CADASTROPARCEIROS
      INNER JOIN FRAMOATIVIDADE ON (FRAMOATIVIDADE.CODIGO=CADASTROPARCEIROS.RAMOATIVIDADE)
      WHERE CADASTROPARCEIROS.CADASTRO=:CODCLIENTE INTO :STATUS;

   IF (:FESTADO=1 AND :STATUS>0) THEN
