select 
    movimentoestoque.documento,
    cadcli.nome,
    produto.codigo codProduto,    
    produto.descricao desProduto,   
    materialmovimentoestoque.iditem codSaida,
    saida.descricao as descricaoSaida,
    componente.codigo componenteCodigo,
    componente.descricao componenteDescricao,
    composicaoop.GRAMATURA,
    composicaoop.LARGURA,
    composicaoop.quantidade
from
    MOVIMENTOESTOQUE
inner join
    materialmovimentoestoque on
        materialmovimentoestoque.filial=movimentoestoque.filial and
        materialmovimentoestoque.idmovimento=movimentoestoque.idmovimento
inner join
    itemestoque saida on
        saida.codigo=MATERIALMOVIMENTOESTOQUE.iditem
inner join
    pedido on
        pedido.filial=materialmovimentoestoque.filial and
        pedido.idnota=materialmovimentoestoque.idpedido
inner join
    mercadoriasped on
        mercadoriasped.filial=materialmovimentoestoque.filial and
        mercadoriasped.idnota=materialmovimentoestoque.idpedido and
        mercadoriasped.idmercadoria=materialmovimentoestoque.IDMERCADORIA
inner join
    itemestoque produto on
        produto.codigo=mercadoriasped.codigo
inner join 
    cadastroparceiros cadcli on
        cadcli.cadastro=pedido.DESTINATARIO
inner join
    composicaoop on
        composicaoop.filial=materialmovimentoestoque.filial and
        composicaoop.idmovimento=materialmovimentoestoque.IDMOVIMENTO and
        composicaoop.IDMOVIMENTOMATERIAL=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL
inner join
    itemestoque componente on
        componente.codigo=composicaoop.codigo
where 
    movimentoestoque.filial=110 and
    movimentoestoque.tipomovimento='12' and 
    materialmovimentoestoque.concluido='N' and
    mercadoriasped.baixa='N' and
    componente.TIPOPRODUTO='1'