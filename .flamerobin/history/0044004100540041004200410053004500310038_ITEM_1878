SELECT DISTINCT
        MERCADORIASPED.FILIAL,
        MERCADORIASPED.IDNOTA,
        MERCADORIASPED.IDMERCADORIA,
        COALESCE(MATERIALMOVIMENTOESTOQUE.C_GRUPOCOMISSAO,
                COALESCE(ITEMESTOQUE.C_GRUPOCOMISSAO, 1)),
        cast(MERCADORIASPED.VLRFINALMERCAD as numeric(12, 2))*
         C_PEDIDODATAFIN.SINAL,
        MERCADORIASPED.C_COMISSAO AS COMISSAOITEM,
        CAST(NULL AS NUMERIC(12, 2)) AS COMISSAOPEDIDO,
        CAST(COALESCE(MERCADORIASPED.QUANTIDADE, 0)*
             COALESCE(MERCADORIASPED.C_VALORSERVICO, 0)*
             C_PEDIDODATAFIN.SINAL AS NUMERIC(12, 2))
                AS VALORSERVICO,
        CAST(MERCADORIASPED.COMISSAO AS NUMERIC(12, 2)) AS COMISSAO,
        COALESCE(PEDIDO.C_DESCONTORT, 'N')  C_RT,
        case PEDIDO.VLRTOTALNOTA when 0 then 1 else
            CAST(COALESCE(PEDIDO.C_CREDITOCLIENTE, 0) / 
                PEDIDO.VLRTOTALNOTA *
                C_PEDIDODATAFIN.SINAL AS NUMERIC(12, 5)) end AS PCREDITO,
        COALESCE(
            (SELECT
                COUNT(VENDEDORESPED.VENDEDOR)
             FROM
                VENDEDORESPED
             INNER JOIN
                VENDEDOR ON
                    VENDEDORESPED.VENDEDOR = VENDEDOR.CADASTRO
             WHERE
                VENDEDORESPED.FILIAL = MERCADORIASPED.FILIAL
                AND VENDEDORESPED.IDNOTA = MERCADORIASPED.IDNOTA
                AND VENDEDOR.TIPOVENDEDOR IN (5, 6)), 0) AS QTDAGENTES,
        CASE C_PEDIDODATAFIN.TABELA WHEN 3 THEN 'D' ELSE 'F' END
    FROM
        C_PEDIDODATAFINCOMFIL(3) C_PEDIDODATAFIN
    INNER JOIN
        MERCADORIASPED ON
            (MERCADORIASPED.FILIAL=C_PEDIDODATAFIN.FILIAL
             AND MERCADORIASPED.IDNOTA=C_PEDIDODATAFIN.IDNOTA)
    INNER JOIN
        PEDIDO ON
            (PEDIDO.FILIAL=MERCADORIASPED.FILIAL
             AND PEDIDO.IDNOTA=MERCADORIASPED.IDNOTA)
    LEFT JOIN
        MOVIMENTOESTOQUE ON
            (MOVIMENTOESTOQUE.FILIAL=PEDIDO.FILIAL
            AND MOVIMENTOESTOQUE.IDPEDIDO = PEDIDO.IDNOTA
            AND MOVIMENTOESTOQUE.TIPOMOVIMENTO=12)
    LEFT JOIN
        MATERIALMOVIMENTOESTOQUE ON
            MATERIALMOVIMENTOESTOQUE.FILIAL=MOVIMENTOESTOQUE.FILIAL
            AND MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO=MOVIMENTOESTOQUE.IDMOVIMENTO
            AND MATERIALMOVIMENTOESTOQUE.IDMERCADORIA=MERCADORIASPED.IDMERCADORIA
    INNER JOIN
        ITEMESTOQUE ON
            (ITEMESTOQUE.CODIGO=COALESCE(MATERIALMOVIMENTOESTOQUE.IDITEM,MERCADORIASPED.CODIGO))    
    order by
        1, 2, 3