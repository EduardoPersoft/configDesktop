select
C_COMISSAORECIBO.ID,
C_COMISSAORECIBO.VENDEDOR,
C_COMISSAORECIBO.FILIAL,
C_COMISSAORECIBO.IDNOTA,
sum (C_COMISSAORECIBO.VALORCOMISSAO) as VALORCOMISSAO,
C_COMISSAORECIBO.DATALIMITE,
C_COMISSAORECIBO.DOCUMENTOFILIAL,
C_COMISSAORECIBO.RAZAOFILIAL,
C_COMISSAORECIBO.DOCUMENTOVENDEDOR,
C_COMISSAORECIBO.RAZAOVENDEDOR,
C_COMISSAORECIBO.LOGRADOURO,
C_COMISSAORECIBO.NUMERO,
C_COMISSAORECIBO.COMPLEMENTO,
C_COMISSAORECIBO.BAIRRO,
C_COMISSAORECIBO.CIDADE,
C_COMISSAORECIBO.UF,
C_COMISSAORECIBO.INSCESTADUAL,
C_COMISSAORECIBO.INSCMUNICIPAL,
C_COMISSAORECIBO.RAZAOCLIENTE,
C_COMISSAORECIBO.C_CCTITULAR,
C_COMISSAORECIBO.C_CCBANCO,
C_COMISSAORECIBO.C_CCAGENCIA,
C_COMISSAORECIBO.C_CCNUMERO,
CASE WHEN 
COALESCE((SELECT SUM(C_COMISSAORECIBO.VALORIRRF) 
          FROM C_COMISSAORECIBO ('C_COMISSAOAUTONOMO')),0) > 10 
THEN
 SUM(C_COMISSAORECIBO.VALORIRRF)  
ELSE 0 END  as VALORIRRF,
sum (C_COMISSAORECIBO.valorinss) as VALORINSS,
sum (C_COMISSAORECIBO.valorcsll) as VALORCSLL,
sum (C_COMISSAORECIBO.valorpis) as VALORPIS,
sum (C_COMISSAORECIBO.valorcofins) as VALORCOFINS,
sum (C_COMISSAORECIBO.VALORISS) as valorISS,
sum (C_COMISSAORECIBO.VALORCOMISSAO) -
  CASE WHEN 
COALESCE((SELECT SUM(C_COMISSAORECIBO.VALORIRRF) 
          FROM C_COMISSAORECIBO ('C_COMISSAOAUTONOMO')),0) > 10 
THEN
SUM(C_COMISSAORECIBO.VALORIRRF) 
     
ELSE 0 END -
    sum (C_COMISSAORECIBO.valorinss) -
    sum (C_COMISSAORECIBO.valorcsll) -
    sum (C_COMISSAORECIBO.valorpis)  -
    sum (C_COMISSAORECIBO.valoriss)  -
    sum (C_COMISSAORECIBO.valorcofins) AS VALORLIQUIDO

from C_COMISSAORECIBO ('C_COMISSAOAUTONOMO')
group by
C_COMISSAORECIBO.ID,
C_COMISSAORECIBO.VENDEDOR,
C_COMISSAORECIBO.FILIAL,
C_COMISSAORECIBO.IDNOTA,
C_COMISSAORECIBO.DATALIMITE,
C_COMISSAORECIBO.DOCUMENTOFILIAL,
C_COMISSAORECIBO.RAZAOFILIAL,
C_COMISSAORECIBO.DOCUMENTOVENDEDOR,
C_COMISSAORECIBO.RAZAOVENDEDOR,
C_COMISSAORECIBO.LOGRADOURO,
C_COMISSAORECIBO.NUMERO,
C_COMISSAORECIBO.COMPLEMENTO,
C_COMISSAORECIBO.BAIRRO,
C_COMISSAORECIBO.CIDADE,
C_COMISSAORECIBO.UF,
C_COMISSAORECIBO.INSCESTADUAL,
C_COMISSAORECIBO.INSCMUNICIPAL,
C_COMISSAORECIBO.RAZAOCLIENTE,
C_COMISSAORECIBO.C_CCTITULAR,
C_COMISSAORECIBO.C_CCBANCO,
C_COMISSAORECIBO.C_CCAGENCIA,
C_COMISSAORECIBO.C_CCNUMERO