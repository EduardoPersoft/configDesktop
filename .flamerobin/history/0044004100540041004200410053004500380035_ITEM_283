reCREATE VIEW RELMOVPAGOPAG (FILIAL, RAZAOSOCIAL, IDTITULO, IDMOVIMENTO, TITULO, PARCEIRO, NOME, EMISSAO, VENCIMENTO, PROVAVEL, BAIXA, DATAPAGAMENTO, CONTACORRENTE, TIPOTRANSACAO, NUMERONOBANCO, VALORTITULO, FATURA, DATAINICIAL, DATAFINAL, DESCRICAO, SIGLA, TOTALJUROS, TOTALDESCONTO, TOTAL, VALORCOFINS, VALORCSLL, VALORINSS, VALORPIS, VALORIR, TIPOTITULO)
AS 
SELECT MOVTITULOREC.FILIAL, ESTAB.NOME AS RAZAOSOCIAL, MOVTITULOREC.IDTITULO, MOVTITULOREC.IDMOVIMENTO,
       MOVTITULOREC.TITULO, MOVTITULOREC.PARCEIRO,
       CASE (SELECT CONFIGURACOESGERAIS.NOMERAZAOSOCIAL
            FROM CONFIGURACOESGERAIS) WHEN 'N' THEN PARCEIRO.NOME
            ELSE PARCEIRO.RAZAOSOCIAL END,
       MOVTITULOREC.EMISSAO,
       MOVTITULOREC.VENCIMENTO, MOVTITULOREC.PROGRAMACAO AS PROVAVEL, MOVTITULOREC.DTMOVTOTITULO AS BAIXA, MOVTITULOREC.DTMOVTOBANCARIO AS DATAPAGAMENTO,
       MOVTITULOREC.CONTACORRENTE, MOVTITULOREC.TIPOTRANSACAO,
       ' ' AS NUMERONOBANCO, MOVTITULOREC.VALORPAGO AS VALORTITULO,
       MOVTITULOREC.FATURA, ESTSIN.DATAINICIAL, ESTSIN.DATAFINAL, ESTSIN.DESCRICAO, MOEDA.SIGLA,
       (coalesce(MOVTITULOREC.valorjurosmovto, 0) + coalesce(movtitulorec.mvlracrescimoeletron, 0)) AS TOTALJUROS,
       (coalesce(MOVTITULOREC.VALORDESCONTOMOVTO, 0) + coalesce(movtitulorec.mvlrdescontoeletron, 0) + coalesce(movtitulorec.moutrosdescontos, 0)) AS TOTALDESCONTO,
       (coalesce(MOVTITULOREC.VALORPAGO,0)+coalesce(MOVTITULOREC.VALORJUROSMOVTO, 0) + coalesce(movtitulorec.mvlracrescimoeletron, 0)-(coalesce(MOVTITULOREC.VALORDESCONTOMOVTO, 0) + coalesce(movtitulorec.mvlrdescontoeletron, 0) + coalesce(movtitulorec.moutrosdescontos, 0))) AS TOTAL,
       MOVTITULOREC.valorcofins,MOVTITULOREC.valorcsll,movtitulorec.valorinss,
       MOVTITULOREC.valorpis,MOVTITULOREC.valorir,
       CASE movtitulorec.tipotitulo WHEN '2' THEN '2-DOC'
       WHEN '3' THEN '3-DARF'
       WHEN '4' THEN '4-GPS'
       WHEN '5' THEN '5-ISS'
       WHEN '6' THEN '6-IR'
       WHEN '7' THEN '7-CRED'
       ELSE '1-DUPL' END

FROM MOVTOTITULOPAG MOVTITULOREC
INNER JOIN TITULOPAG TITULOREC ON (MOVTITULOREC.FILIAL=TITULOREC.FILIAL AND
                                   MOVTITULOREC.idtitulo=TITULOREC.IDTITULO)
INNER JOIN CADASTROPARCEIROS ESTAB ON (ESTAB.CADASTRO = MOVTITULOREC.FILIAL)
INNER JOIN CADASTROPARCEIROS PARCEIRO ON (PARCEIRO.CADASTRO = MOVTITULOREC.PARCEIRO)
INNER JOIN ESTSIN ON (ESTSIN.ESTABELECIMENTO = MOVTITULOREC.FILIAL AND
                      MOVTITULOREC.DTMOVTOTITULO BETWEEN ESTSIN.DATAINICIAL AND ESTSIN.DATAFINAL AND
                      ESTSIN.RELATORIO = 'PMOVPAGOS')
INNER JOIN RCONTACORRENTE ON (RCONTACORRENTE.CONTACORRENTE = MOVTITULOREC.CONTACORRENTE AND
                              RCONTACORRENTE.RELATORIO = 'PMOVPAGOS')
INNER JOIN RTIPOPAGAMENTO RTIPOCOBRANCA ON (RTIPOCOBRANCA.TIPOPAGAMENTO = MOVTITULOREC.TIPOTRANSACAO AND
                              RTIPOCOBRANCA.RELATORIO = 'PMOVPAGOS')
LEFT JOIN MOEDA ON (MOEDA.MOEDA = MOVTITULOREC.MOEDA)
WHERE MOVTITULOREC.TIPOMOVTO='D'
AND (TITULOREC.tipobaixa<>'E' OR TITULOREC.TIPOBAIXA IS NULL)
UNION
SELECT MOVTITULOREC.FILIAL,
       ESTAB.NOME AS RAZAOSOCIAL,
       MOVTITULOREC.IDTITULO,
       MOVTITULOREC.idmovimento,
       MOVTITULOREC.TITULO,
       MOVTITULOREC.PARCEIRO,
       CASE (SELECT CONFIGURACOESGERAIS.NOMERAZAOSOCIAL
            FROM CONFIGURACOESGERAIS) WHEN 'N' THEN PARCEIRO.NOME
            ELSE PARCEIRO.RAZAOSOCIAL END,
       MOVTITULOREC.EMISSAO,
       MOVTITULOREC.VENCIMENTO,
       MOVTITULOREC.PROGRAMACAO AS PROVAVEL,
       MOVTITULOREC.DTMOVTOTITULO AS BAIXA,
       MOVTITULOREC.DTMOVTOBANCARIO AS DATAPAGAMENTO,
       MOVTITULOREC.CONTACORRENTE,
       MOVTITULOREC.TIPOTRANSACAO,
       ' '  AS NUMERONOBANCO,
       coalesce(MOVTITULOREC.VALORPAGO, 0) *(-1) AS VALORTITULO,
       MOVTITULOREC.FATURA,
       ESTSIN.DATAINICIAL,
       ESTSIN.DATAFINAL,
       ESTSIN.DESCRICAO,
       MOEDA.SIGLA,
       (coalesce(MOVTITULOREC.VALORJUROSMOVTO, 0) + coalesce(movtitulorec.mvlracrescimoeletron, 0))*(-1) AS TOTALJUROS,
       (coalesce(MOVTITULOREC.VALORDESCONTOMOVTO, 0) + coalesce(movtitulorec.mvlrdescontoeletron, 0) + coalesce(movtitulorec.moutrosdescontos, 0))*(-1) AS TOTALDESCONTO,
       (coalesce(MOVTITULOREC.VALORPAGO,0)+coalesce(MOVTITULOREC.VALORJUROSMOVTO, 0) + coalesce(movtitulorec.mvlracrescimoeletron, 0)-(coalesce(MOVTITULOREC.VALORDESCONTOMOVTO, 0) + coalesce(movtitulorec.mvlrdescontoeletron, 0) + coalesce(movtitulorec.moutrosdescontos, 0)))*(-1) AS TOTAL,
       coalesce(MOVTITULOREC.valorcofins, 0) *(-1),
       coalesce(MOVTITULOREC.valorcsll, 0) *(-1),
       coalesce(movtitulorec.valorinss, 0) *(-1),
       coalesce(MOVTITULOREC.valorpis, 0) *(-1),
       coalesce(MOVTITULOREC.valorir, 0) *(-1),
       CASE movtitulorec.tipotitulo WHEN '2' THEN '2-DOC'
       WHEN '3' THEN '3-DARF'
       WHEN '4' THEN '4-GPS'
       WHEN '5' THEN '5-ISS'
       ELSE '1-DUPL' END

FROM MOVTOTITULOPAG MOVTITULOREC
INNER JOIN TITULOPAG TITULOREC ON (MOVTITULOREC.FILIAL=TITULOREC.FILIAL AND
                                   MOVTITULOREC.idtitulo=TITULOREC.IDTITULO)
INNER JOIN CADASTROPARCEIROS ESTAB ON (ESTAB.CADASTRO = MOVTITULOREC.FILIAL)
INNER JOIN CADASTROPARCEIROS PARCEIRO ON (PARCEIRO.CADASTRO = MOVTITULOREC.PARCEIRO)
INNER JOIN ESTSIN ON (ESTSIN.ESTABELECIMENTO = MOVTITULOREC.FILIAL AND
                      MOVTITULOREC.DTMOVTOTITULO BETWEEN ESTSIN.DATAINICIAL AND ESTSIN.DATAFINAL AND
                      ESTSIN.RELATORIO = 'PMOVPAGOS')
INNER JOIN RCONTACORRENTE ON (RCONTACORRENTE.CONTACORRENTE = MOVTITULOREC.CONTACORRENTE AND
                              RCONTACORRENTE.RELATORIO = 'PMOVPAGOS')
INNER JOIN RTIPOPAGAMENTO RTIPOCOBRANCA ON (RTIPOCOBRANCA.TIPOPAGAMENTO = MOVTITULOREC.TIPOTRANSACAO AND
                              RTIPOCOBRANCA.RELATORIO = 'PMOVPAGOS')
LEFT JOIN MOEDA ON (MOEDA.MOEDA = MOVTITULOREC.MOEDA)
WHERE MOVTITULOREC.TIPOMOVTO='F'
AND (TITULOREC.tipobaixa<>'E' OR TITULOREC.TIPOBAIXA IS NULL)
;

GRANT DELETE, INSERT, REFERENCES, SELECT, UPDATE
 ON RELMOVPAGOPAG TO  SYSDBA WITH GRANT OPTION;

