UPDATE
    MERCADORIASNOTA m1
SET
    m1.precolista= (select 
                        mp.precolista-m2.precolista 
                    from 
                        mercadoriasnota m2
                    inner join 
                        MERCADORIASPED mp on
                            mp.filial=m2.filialped AND
                            mp.idnota=m2.idnota AND
                            mp.IDMERCADORIA=m2.IDMERCPEDIDO
                    where m2.filial=5 AND
                    m2.idnota=26011)
                    
where 
    mercadoriasnota.filial=5 
    and mercadoriasnota.idnota=26012