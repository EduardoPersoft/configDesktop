select
    itemestoque.codigo,
    GRUPOMERCADORIA.descricao GRUPO,
    CADASTROPARCEIROS.NOME AS FABRICANTE,
    ITEMESTOQUE.C_NOMENOFORNECEDOR,
    itemestoque.descricao,
    c_especificacoes.DESCRICAO AS ESPECIFICACAO
from 
    ITEMESTOQUE
INNER join
    GRUPOMERCADORIA ON
        GRUPOMERCADORIA.GRUPO=ITEMESTOQUE.GRUPO
INNER join
    CADASTROPARCEIROS ON
        CADASTROPARCEIROS.CADASTRO=ITEMESTOQUE.FABRICANTE
left join
    C_ESPECIFICACOES ON
        C_eSPECIFICACOES.IDITEM=ITEMESTOQUE.CODIGO and
        UPPER(C_eSPECIFICACOES.DESCRICAO)<>'MEDIDAS'
where
    GRUPOMERCADORIA.grupo<90 and
    ITEMESTOQUE.TIPOPRODUTO<>5 and
    COALESCE(ITEMESTOQUE.C_DIMENSOES,'')=''
order by
    GRUPOMERCADORIA.descricao,
    3,
    ITEMESTOQUE.descricao
        