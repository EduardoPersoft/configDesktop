SELECT 
    MATERIALMOVIMENTOESTOQUE.FILIAL,
    MATERIALMOVIMENTOESTOQUE.IDITEM,
    ITEMESTOQUE.DESCRICAO,
    SUM(MATERIALMOVIMENTOESTOQUE.QUANTIDADE*
        MATERIALMOVIMENTOESTOQUE.SINAL),
    SUM(MATERIALMOVIMENTOESTOQUE.VALOR*
        MATERIALMOVIMENTOESTOQUE.SINAL)
from
    MATERIALMOVIMENTOESTOQUE
INNER join
    MOVIMENTOESTOQUE ON
        MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL and
        MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
LEFT join  
    ITEMESTOQUE ON
        ITEMESTOQUE.CODIGO=MATERIALMOVIMENTOESTOQUE.IDITEM
where
    MOVIMENTOESTOQUE.FILIAL=1 and
    MOVIMENTOESTOQUE.EMISSAO<='31.12.2023' 
GROUP BY    
    MATERIALMOVIMENTOESTOQUE.FILIAL,
    MATERIALMOVIMENTOESTOQUE.IDITEM,
    ITEMESTOQUE.DESCRICAO
HAVING 
    SUM(MATERIALMOVIMENTOESTOQUE.QUANTIDADE*
        MATERIALMOVIMENTOESTOQUE.SINAL)<0 
