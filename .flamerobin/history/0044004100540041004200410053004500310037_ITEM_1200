update 
    notacompra
set
    notacompra.valorcofins = (select sum(mercadoriasnotacompra.VLRCOFINS) from mercadoriasnotacompra
                              where mercadoriasnotacompra.filial=notacompra.filial and
                              mercadoriasnotacompra.idnota=notacompra.idnota),
    notacompra.valorpis = (select sum(mercadoriasnotacompra.VLRPISPASEP) from mercadoriasnotacompra
                              where mercadoriasnotacompra.filial=notacompra.filial and
                              mercadoriasnotacompra.idnota=notacompra.idnota) 
where
    MERCADORIASNOTACOMPRA.filial=1 and 
    mercadoriasnotacompra.idnota>=5219 