update
    ITEMESTOQUE
set
    ITEMESTOQUE.VALORULTIMACOMPRA=
        (SELECT 
            T_ULTIMOCUSTO.CUSTO 
         FROM  
            T_ULTIMOCUSTO 
         WHERE T_ULTIMOCUSTO.CODIGO=ITEMESTOQUE.CODIGO)
where
    EXISTS (SELECT 
            T_ULTIMOCUSTO.CUSTO 
         FROM  
            T_ULTIMOCUSTO 
         WHERE T_ULTIMOCUSTO.CODIGO=ITEMESTOQUE.CODIGO)