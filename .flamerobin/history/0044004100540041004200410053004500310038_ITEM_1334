select MATERIALMOVIMENTOESTOQUE.VALOR*MATERIALMOVIMENTOESTOQUE.SINAL, 
MATERIALMOVIMENTOESTOQUE.QUANTIDADE*MATERIALMOVIMENTOESTOQUE.SINAL,
MATERIALMOVIMENTOESTOQUE.* from MATERIALMOVIMENTOESTOQUE
INNER JOIN MOVIMENTOESTOQUE ON MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL
AND MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
where MATERIALMOVIMENTOESTOQUE.filial=1
and MATERIALMOVIMENTOESTOQUE.IDITEM='01.12.0595'
