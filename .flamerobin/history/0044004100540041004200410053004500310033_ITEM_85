SELECT
    materialmovimentoestoque.filial,
    materialmovimentoestoque.idmovimento,
    materialmovimentoestoque.IDMOVIMENTOMATERIAL,
    movimentoestoque.emissao,
    movimentoestoque.documento,
    itemestoque.codigo,
    itemestoque.descricao,
    materialmovimentoestoque.quantidade,
    materialmovimentoestoque.valor,
    mercadoriasped.precolista,
    mercadoriasped.vlrfinalmercad
FROM
    MOVIMENTOESTOQUE
inner JOIN
    materialmovimentoestoque on
        movimentoestoque.filial=materialmovimentoestoque.filial AND
        movimentoestoque.idmovimento=materialmovimentoestoque.idmovimento
inner JOIN
    itemestoque on
        itemestoque.codigo=MATERIALMOVIMENTOESTOQUE.iditem
inner JOIN
    mercadoriasped on
        mercadoriasped.filial=materialmovimentoestoque.filial AND
        mercadoriasped.idnota=movimentoestoque.documento AND
        mercadoriasped.codigo=materialmovimentoestoque.iditem
where 
    movimentoestoque.filial=1 AND
    movimentoestoque.TIPOMOVIMENTO='04' AND
    movimentoestoque.emissao between '01.07.2021' and '31.12.2021' AND
    MATERIALMOVIMENTOESTOQUE.iditem='37721-1103'