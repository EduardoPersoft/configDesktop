SELECT
    first 60
    TITULOREC.FILIAL,
    TITULOREC.IDTITULO,
    TITULOREC.titulo,
    TITULOREC.FATURA,
    TITULOREC.EMISSAO,
    TITULOREC.VENCIMENTO,
    TITULOREC.VALORTITULO,
    TITULOREC.LINHADIGITAVEL,
    CADCLI.CADASTRO,
    CADCLI.NOME,
    CADCLI.TIPOPESSOA,
    CADCLI.DOCUMENTO,
    CADCLI.RAZAOSOCIAL,
    COALESCE(CLIENTES.EMAILCOBRANCA,COALESCE(CADCLI.EMAILNFE, CADCLI.EMAIL)) AS EMAIL,
    (select first 1 usuario.email from usuario where usuario.SERNOTIFICADO like '%TITREC_BCC;%' ) as Bcc,
    coalesce(cadven.email,'') as CC,
    cast(null as varchar(20)) as subject,
    cast(nll as varchar(100)) as body
SELECT  
    *
FROM
        TITULOREC
WHERE
    titulorec.DATAENVIO is null
    and titulorec.baixa is null 
	and titulorec.linhadigitavel is not null 
	and coalesce(titulorec.codretorno,'03') <> '03'

order by
    titulorec.filial,
    titulorec.titulo,
    titulorec.fatura
