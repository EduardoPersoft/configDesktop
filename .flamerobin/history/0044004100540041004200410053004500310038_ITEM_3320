select 
    *
from
    PEDIDO
where 
    pedido.filia=1 and 
    pedido.c_malote is null and
    pedido.CANCELAMENTO='N' and
    pedido.DATAEMISSAO is not null and 
    pedido.dataemissao>'01.01.2025' and
    exists (select * from C_FATURASPED
            where c_faturasped.filial=pedido.filial and
            c_faturasped.idnota=pedido.idnota and
            c_faturasped.C_MALOTE is not null)
    
    