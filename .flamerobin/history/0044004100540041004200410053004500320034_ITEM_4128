SELECT 
    CADASTROCLIENTES.CADASTRO CADASTROCLIENTES_CADASTRO,
    CADASTROCLIENTES.NOME  CADASTROCLIENTES_NOME,
	CADASTROCLIENTES.APROVADO CADASTROCLIENTES_APROVADO,
    COALESCE(CADASTROCLIENTES.CONTRIBUINTE,'N')  CADASTROCLIENTES_CONTRIBUINTE,
    COALESCE(CLIENTES.consumidorfinal,'N') CLIENTES_CONSUMIDORFINAL,
    cadastroclientes.principalcontato        	  CADASTROCLIENTES_CONTATO,
    CADASTROCLIENTES.TELEFONE          CADASTROCLIENTES_TELEFONE,    
    cadastroclientes.email               CADASTROCLIENTES_EMAIL,
    CADASTROCLIENTES.logradouro  CADASTROCLIENTES_LOGRADOURO,
    CADASTROCLIENTES.numero  CADASTROCLIENTES_NUMERO,
    CADASTROCLIENTES.complemento  CADASTROCLIENTES_COMPLEMENTO,
    CADASTROCLIENTES.BAIRRO  CADASTROCLIENTES_BAIRRO,
    CADASTROCLIENTES.cidade  CADASTROCLIENTES_CIDADE,
    CADASTROCLIENTES.UF  CADASTROCLIENTES_UF,
    CADASTROCLIENTES.CEP  CADASTROCLIENTES_CEP,
     
    CLIENTES.listaprecodefault CLIENTES_LISTAPRECO,
    CADASTROCLIENTES.naturezasaidadefault AS CADASTROCLIENTES_OPERACAO,

    CLIENTES.tipocobranca CLIENTES_TIPOCOBRANCA,
    CLIENTES.ccorrentecobranca CLIENTES_CCORRENTECOBRANCA,
    CLIENTES.condicaopagamento CLIENTES_CONDICAOPAGAMENTO,	   

    CADASTROCLIENTES.TRANSPORTADORA CADASTROCLIENTES_CODIGOTRANSP           ,
    CADASTROTRANSP.NOME CADASTROTRANSP_NOME,  

    CADASTROCLIENTES.LOGRADOUROENTREGA CADASTROCLIENTES_LOGENTREGA      ,
    CADASTROCLIENTES.NUMEROENTREGA CADASTROCLIENTES_NUMEROENTREGA          ,
    CADASTROCLIENTES.COMPLEMENTOENTREGA CADASTROCLIENTES_COMPLENTREGA    ,
    CADASTROCLIENTES.BAIRROENTREGA CADASTROCLIENTES_BAIRROENTREGA          ,
    CADASTROCLIENTES.CIDADEENTREGA,
    CADASTROCLIENTES.UFENTREGA,
    CADASTROCLIENTES.CEPENTREGA CADASTROCLIENTES_CEPENTREGA             ,    
    
    COALESCE(CLIENTES.VENDEDOR,0) CLIENTES_VENDEDOR,
    CADASTROVENDEDOR.nome CLIENTES_VENDEDORNOME,
    case COALESCE(CLIENTES.COMISSAORECEBIMENTO,0) when 0 then VENDEDOR.comissaorecebimento else CLIENTES.COMISSAORECEBIMENTO end CLIENTES_COMISSAORECEBIMENTO ,
    case COALESCE(CLIENTES.COMISSAOVENDA,0) when 0 then VENDEDOR.comissaovenda else CLIENTES.COMISSAOVENDA end AS CLIENTES_COMISSAOVENDA,


    CADASTROCLIENTES.OBSERVACOESENTREGA,
	CADASTROCLIENTES.OBSERVACOESFISCAIS,


	(SELECT SUM(TITULOREC.VALOREMABERTO) 
	 FROM TITULOREC
	 INNER JOIN ESTABELECIMENTO ON 
	 	(TITULOREC.FILIAL=ESTABELECIMENTO.CADASTRO)
	 WHERE TITULOREC.FILIAL=ESTABELECIMENTO.CADASTRO
	 AND TITULOREC.PARCEIRO=CADASTROCLIENTES.CADASTRO
	 AND TITULOREC.VENCIMENTO+ESTABELECIMENTO.DIASATRASO < CAST('NOW' AS DATE)
	 AND TITULOREC.TIPOBAIXA IS NULL
	 AND TITULOREC.NAOLIMITEFINANCEIRO='N') AS CADASTROCLIENTES_VALOREMATRASO,		
	 CASE CADASTROCLIENTES.AVISOVENDAS WHEN 'S' 
	 THEN CADASTROCLIENTES.AVISOMSG ELSE NULL END CADASTROCLIENTES_AVISOVENDA
from CADASTROPARCEIROS CADASTROCLIENTES
INNER JOIN CLIENTES  ON (CADASTROCLIENTES.CADASTRO=CLIENTES.CADASTRO)
LEFT JOIN CADASTROPARCEIROS CADASTROTRANSP ON (CADASTROTRANSP.CADASTRO=CADASTROCLIENTES.TRANSPORTADORA)
LEFT JOIN VENDEDOR ON (VENDEDOR.CADASTRO=CLIENTES.vendedor)
LEFT JOIN CADASTROPARCEIROS CADASTROVENDEDOR ON (CADASTROVENDEDOR.CADASTRO=CLIENTES.VENDEDOR)
where CADASTROCLIENTES.CADASTRO = 166