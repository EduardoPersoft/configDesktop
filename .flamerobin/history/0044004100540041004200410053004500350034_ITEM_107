select
    MATERIALMOVIMENTOESTOQUE.FILIAL,
    MATERIALMOVIMENTOESTOQUE.IDITEM,    
    MATERIALMOVIMENTOESTOQUE.QUANTIDADE*(-1),
    MATERIALMOVIMENTOESTOQUE.QUANTIDADE*ITEMESTOQUE.VALORULTIMACOMPRA*(-1),
    MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO,
    MATERIALMOVIMENTOESTOQUE.LOTE
from
    MATERIALMOVIMENTOESTOQUE
INNER join
    ITEMESTOQUE ON
        ITEMESTOQUE.CODIGO=MATERIALMOVIMENTOESTOQUE.IDITEM
WHERE 
    MATERIALMOVIMENTOESTOQUE.FILIAL=1 and
    MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO=105697 AND
    MATERIALMOVIMENTOESTOQUE.QUANTIDADE<0