update MATERIALMOVIMENTOESTOQUE
set materialmovimentoestoque.concluido='S'
where exists
(select
    *
from
    MOVIMENTOESTOQUE
where 
    MATERIALMOVIMENTOESTOQUE.filial=movimentoestoque.FILIAL
    and MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO=movimentoestoque.idmovimento
    and movimentoestoque.TIPOMOVIMENTO='12' 
    and movimentoestoque.filial=233)