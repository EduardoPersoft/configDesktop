update 
    PEDIDO
set 
    pedido.VBRUTOFATURA=coalesce((select sum(fatped.VALORFATURA) from fatped 
                                 where fatped.filial=pedido.FILIAL
                                 and fatped.idnota=pedido.idnota),0),
    pedido.VliquidoFATURA=coalesce((select sum(fatped.VALORFATURA) from fatped 
                                 where fatped.filial=pedido.FILIAL
                                 and fatped.idnota=pedido.idnota),0);
where exists
(select * from MERCADORIASPED
where mercadoriasped.filial=pedido.FILIAL
and mercadoriasped.idnota=pedido.IDNOTA
and mercadoriasped.baixa='N')