SELECT 

       MODELODOCTO.MODELO,
       cast(NOTAFISCAL.DATAEMISSAO as date) AS DATA,
       CAST(NOTAFISCAL.NUMERONOTA AS VARCHAR(10)) AS NUMERONOTA,
       MERCADORIASNOTA.IDMERCADORIA,
       mercadoriasnota.cfop,
       mercadoriasnota.idpedido,
       CLIENTES.CADASTRO,
       CLIENTES.NOME,
       (COALESCE(mercadoriasnota.VLRTOTALMERCAD,0)+
           COALESCE(mercadoriasnota.VALORIPI,0)+
           COALESCE(MERCADORIASNOTA.VLRICMSRECOLHIDO,0)+
           COALESCE(mercadoriasnota.ICMSSTFCPVALOR,0)+
           mercadoriasnota.frete+
           mercadoriasnota.seguro+
           mercadoriasnota.OUTDESPACESSOR-
           (coalesce(mercadoriasnota.DESCONTONOTA,0)+
            coalesce(mercadoriasnota.VLRDESCPRODUTO,0)+
            case notafiscal.ZONAFRANCA when 'S' then mercadoriasnota.valoricms else 0 end))   as VLRTOTALNOTA,
        (COALESCE(mercadoriasnota.VALORIPI,0)) AS VALORIPI,
       (COALESCE(mercadoriasnota.VLRTOTALMERCAD,0)) AS VLRSEMIPI,

       coalesce(cadven.nome, 'SEM VENDEDOR'),     
       itemestoque.descricao,
       mercadoriasnota.unidade,
       mercadoriasnota.quantidade,    
       itemestoque.c_pesoporembalagem,
       CASE ITEMESTOQUE.CODIGO WHEN 'APARAS' THEN 0 ELSE     
        case mercadoriasnota.unidade when 'MIL' then mercadoriasnota.QUANTIDADE*itemestoque.C_PESOPOREMBALAGEM
        else mercadoriasnota.quantidade end END qtdKg
FROM 
    NOTAFISCAL
INNER JOIN 
    NATUREZAOPERACAO ON 
        (NOTAFISCAL.OPERACAO=NATUREZAOPERACAO.ID)
INNER JOIN 
    CADASTROPARCEIROS ESTAB ON 
        (NOTAFISCAL.FILIAL = ESTAB.CADASTRO)
INNER JOIN 
    CADASTROPARCEIROS CLIENTES 
        ON (NOTAFISCAL.DESTINATARIO=CLIENTES.CADASTRO)
INNER JOIN MODELODOCTO ON 
    (NOTAFISCAL.MODELO = MODELODOCTO.ID)
INNER join 
        mercadoriasnota  on
           (mercadoriasnota.filial=notafiscal.filial and 
             mercadoriasnota.idnota=notafiscal.idnota)
INNER join 
        itemestoque on 
            (itemestoque.codigo=mercadoriasnota.codigo)
            
left join
    pedido on
        pedido.filial=mercadoriasnota.filialped and
        pedido.idnota=mercadoriasnota.IDPEDIDO
left join
    CADASTROPARCEIROS cadven on
        cadven.cadastro = pedido.vendedor
WHERE 
    NOTAFISCAL.FILIAL=110 AND
    NOTAFISCAL.DATAEMISSAO BETWEEN '01.08.2024' and '31.08.2024'
    AND NOTAFISCAL.CANCELAMENTO = 'N'
                 and NATUREZAOPERACAO.id<>1061

AND case when   mercadoriasnota.cfop not in ('5922','6922') and
                   (exists (select 
                        * 
                    from 
                        faturas
                    where notafiscal.filial=faturas.filial
                    and notafiscal.idnota=faturas.idnota)  or 
            mercadoriasnota.cfop in ('5116', '5117', '6116', '6117', '2201', '1201', '2202', '1202', '2203',
                                     '2204', '1204', '1203'))
          then 'S'
            else 'N'
       end = 'S'  
and case when exists (select 
                            * 
                         from 
                            ESTABELECIMENTO
                         where estabelecimento.CADASTRO=clientes.cadastro) 
        then 'S' else 'N' end = 'N'

and coalesce(NOTAFISCAL.DEVOLUCAO,'N') ='N'


order by
       MODELODOCTO.MODELO,
       NOTAFISCAL.DATAEMISSAO,
       NOTAFISCAL.NUMERONOTA, 
       mercadoriasnota.CFOP,
       mercadoriasnota.idpedido



