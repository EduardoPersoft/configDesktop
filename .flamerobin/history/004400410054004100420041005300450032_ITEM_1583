SELECT
    CADASTROPARCEIROS.CADASTRO,
    CADASTROPARCEIROS.RAZAOSOCIAL,
    CADASTROPARCEIROS.CIDADE,
    NOTAFISCAL.NUMERONOTA,
    NOTAFISCAL.DATAEMISSAO,
    SUM(MERCADORIASNOTA.VLRTOTALMERCAD) AS VALOR,
    SUM(MATERIALMOVIMENTOESTOQUE.VALOR) AS CUSTO,
    SUM(COALESCE(MERCADORIASNOTA.VALORICMS, 0)) AS ICMS,
    SUM(COALESCe(MERCADORIASNOTA.VLRPISPASEP, 0)) AS PIS,
    SUM(COALESCe(MERCADORIASNOTA.VLRCOFINS, 0)) AS COFINS,
    SUM(MERCADORIASNOTA.VLRTOTALMERCAD) - 
    (SUM(MATERIALMOVIMENTOESTOQUE.VALOR) +
    SUM(COALESCE(MERCADORIASNOTA.VALORICMS, 0)) +
    SUM(COALESCe(MERCADORIASNOTA.VLRPISPASEP, 0)) +
    SUM(COALESCe(MERCADORIASNOTA.VLRCOFINS, 0))) AS MARGEM,
    (SUM(MERCADORIASNOTA.VLRTOTALMERCAD) - 
    (SUM(MATERIALMOVIMENTOESTOQUE.VALOR) +
    SUM(COALESCE(MERCADORIASNOTA.VALORICMS, 0)) +
    SUM(COALESCe(MERCADORIASNOTA.VLRPISPASEP, 0)) +
    SUM(COALESCe(MERCADORIASNOTA.VLRCOFINS, 0)))) / SUM(MERCADORIASNOTA.VLRTOTALMERCAD) * 100 AS PMARGEM,
    SUM(MERCADORIASNOTA.VLRTOTALMERCAD)*0.05 as comissao
    

FROM
    NOTAFISCAL
INNER JOIN
    MERCADORIASNOTA ON
        NOTAFISCAL.FILIAL=MERCADORIASNOTA.FILIAL AND
        NOTAFISCAL.IDNOTA=MERCADORIASNOTA.IDNOTA
INNER JOIN
    CADASTROPARCEIROS ON
        NOTAFISCAL.DESTINATARIO=CADASTROPARCEIROS.CADASTRO
INNER JOIN
    VENDEDORESNOTA ON
        VENDEDORESNOTA.FILIAL=NOTAFISCAL.FILIAL AND
        VENDEDORESNOTA.IDNOTA=NOTAFISCAL.IDNOTA 
LEFT JOIN
    MATERIALMOVIMENTOESTOQUE ON
        MATERIALMOVIMENTOESTOQUE.FILIAL=MERCADORIASNOTA.FILIAL AND
        MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO=MERCADORIASNOTA.IDNOTA AND
        MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL=MERCADORIASNOTA.IDMERCADORIA
WHERE 
    NOTAFISCAL.FILIAL=5 AND
    NOTAFISCAL.DATAEMISSAO BETWEEN '01.03.2021' AND '31.03.2021' AND
    NOTAFISCAL.CANCELAMENTO = 'N' AND
    VENDEDORESNOTA.VENDEDOR=1004
GROUP BY
    CADASTROPARCEIROS.RAZAOSOCIAL,
    CADASTROPARCEIROS.CADASTRO,
    
    CADASTROPARCEIROS.CIDADE,
    NOTAFISCAL.NUMERONOTA,
    NOTAFISCAL.DATAEMISSAO