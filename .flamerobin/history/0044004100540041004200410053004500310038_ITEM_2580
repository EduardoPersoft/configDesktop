        order by  servicosped.idservico
        into :iditem,
             :codigo,
             :descricao,
             :descricaoreduzida,
             :quantidade,
             :unidade,
             :prunitario,:prlista,
             :vlrtotitem
             do begin
                pvlrtotal = pvlrtotal+vlrtotitem;
                pqtditem = pqtditem+1;
                condpag = condpagmateriais;

           suspend;

       end

       iditem=null;
       codigo = null;
       descricao = null;
       descricaoreduzida = null;
