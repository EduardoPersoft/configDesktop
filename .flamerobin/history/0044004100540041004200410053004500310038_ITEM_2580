    EMAILTRANSP varchar(50),
    NOMECONTATOTRANSP varchar(40),
    QTDEVOLUME double precision,
    PESOLIQUIDO double precision,
    PESOBRUTO double precision,
    DETALHECF varchar(400),
    DETALHEENTREGA varchar(600),
    DETALHEENTREGA2 varchar(600),
    COMENTARIO blob sub_type 0,
    OBSERVACAO blob sub_type 0,
    MSGADICIONAL blob sub_type 0,
    TIPODETALHE varchar(15),
    ORDEM integer,
    IDITEM integer,
    CODIGO varchar(15),
    DESCRICAO blob sub_type 0,
    DESCRICAOREDUZIDA varchar(240),
    DESCRICAODETALHE varchar(50),
    DESCRICAOTOTAL varchar(50),
    QUANTIDADE double precision,
    UNIDADE varchar(3),
    PRUNITARIO double precision,
    PRLISTA double precision,
    PIPIMERC double precision,
    VLRIPIMERC double precision,
    VLRTOTITEM double precision,
    PICMS double precision,
    CF varchar(12),
    CODCF char(3),
    SEUNUMERO varchar(20),
    DIAHOJE integer,
    MESHOJEEXTENSO varchar(15),
    ANOHOJE integer,
    MSGDESCRMERCADORIAS varchar(150),
    VLRDESCINDSERVICOS double precision,
    VLRACRESCSERVICOS double precision,
    VLRDESCSERVICOS double precision,
    MSGDESCINDSERVICOS varchar(150),
    MSGDESCSERVICOS varchar(150),
    VLRFINALSERVICOS double precision,
    MSGACRESCSERVICOS varchar(150),
    MSGDESCRSERVICOS varchar(150),
    VALORTOTCOMIPI double precision,
    C_LARGURA double precision,
    C_COMPRIMENTO double precision,
    C_M2 double precision,
    C_MODELO integer,
    C_ACABAMENTO integer,
    C_QTDCORES integer,
    C_ESPESSURA varchar(20),
    CONDPAG varchar(2000),
    CONDPAG2 varchar(2000),
    FILIALESTSIN integer,
    TERMOPLANTA varchar(1),
    TERMOCORES varchar(1),
    TERMOESPESSURA varchar(1),
    TERMODESENHO varchar(1),
    TERMODIMENSAO varchar(1),
    TERMOMODELO varchar(1),
    LOGO blob sub_type 0,
    C_MENSAGEM1 blob sub_type 0,
    C_CONCORDANCIA varchar(500),
    C_MENSAGEM2 varchar(500),
    C_MENSAGEM3 blob sub_type 0,
    C_PRAZO integer,
    CONSIGNACAO char(1),
    DATADEVOLUCAOPREVISTA2 timestamp,
    MSGOBSERVACAO varchar(400),
    DATADEVOLUCAO timestamp,
    VLRDESCONTOFINAL double precision,
    TODOSVENDEDORES varchar(200),
    C_CONTATOENTREGA varchar(40),
    C_TELEFONEENTREGA varchar(20),
    ITEMDESCRICAO varchar(255),
    P_PRODUTOENCOMENDAACABADO char(1),
    REFERENCIA varchar(50),
    C_PRECODE decimal(10,2),
    C_DEVOLUCAO integer,
    C_DEVOLUCAO2 varchar(100),
    C_DEVOLUCAO3 varchar(100),
    MSGDESCONTOFINAL varchar(50),
    C_CREDITOCLIENTE double precision,
    MSGCREDITOCLIENTE varchar(50),
    PEDIDOSUBSTITUTO varchar(100),
    PEDIDOSUBSTITUIDO varchar(100),
    C_PEDIDOSUBSTITUTO integer,
    TIPOPEDIDO varchar(20),
    C_TIPOPRODUTO smallint,
    C_MSGENTREGA varchar(100),
    DATADEVOLUCAOPREVISTA varchar(20),
    AGENTE integer,
    RAZAOAGENTE varchar(60),
    TODOSAGENTES varchar(200),
    DIAREFERENCIA integer,
    MESREFERENCIA varchar(15),
    ANOREFERENCIA integer,
    DATAREFERENCIA date )

AS
declare variable pdatahoje timestamp;
declare variable pqtditem integer;
declare variable pidinicial integer;
declare variable pidfinal integer;
declare variable pcf varchar(12);
declare variable pcodcf char(3);
declare variable pdias integer;
declare variable piditem integer;
declare variable pqtd integer;
declare variable punidade varchar(3);
declare variable pqtdtotal varchar(10);
declare variable pqtdprazos varchar(10);
declare variable pdiaanterior integer;
declare variable pvlrtotal double precision;
declare variable ppipi decimal(2,2);
declare variable servicosrealizados double precision;
declare variable condpagservico varchar(2000);
declare variable condpagmateriais varchar(2000);
declare variable jafaturado varchar(1);
declare variable pfilial integer;
declare variable c_mensagemservico blob sub_type 0 segment size 80;
declare variable vdescfinanceiro double precision;
declare variable vdesccomercial double precision;
declare variable vdescmercadorias double precision;
declare variable vdesccomitem double precision;
declare variable vdescpromocional double precision;
declare variable p_itemdescricao varchar(255);
declare variable p_pedidosubstituido varchar(100);
declare variable p_creditocliente double precision;
declare variable pEstabServico integer;
DECLARE VARIABLE LOGINUSUARIO VARCHAR(20);
BEGIN

  pEstabServico = null;

  pdatahoje = cast('now' as timestamp);
  diahoje = extract(day from pdatahoje);
  anohoje = extract(year from pdatahoje);
  meshojeExtenso = case extract(month from pdatahoje)
                when 1 then 'Janeiro'
                WHEN 2 then 'Fevereiro'
                WHEN 3 then 'Marco'
                WHEN 4 then 'Abril'
                WHEN 5 then 'Maio'
                WHEN 6 then 'Junho'
                WHEN 7 then 'Julho'
                WHEN 8 then 'Agosto'
                WHEN 9 then 'Setembro'
                WHEN 10 then 'Outubro'
                WHEN 11 then 'Novembro'
                WHEN 12 then 'Dezembro' end;
                
                

    select

        cadastroparceiros.cadastro,

         estsin.idnotainicial,
         estsin.idnotafinal,
         usuario.nomecompleto,
         usuario.telefone,
         usuario.fax,
         usuario.email,
         usuario.departamento,
         usuario.cargo,
         ESTABELECIMENTO.LOGO,
         USUARIO.USUARIO

  from estsin

  inner join cadastroparceiros on
      (cadastroparceiros.cadastro=estsin.estabelecimento)
     INNER JOIN estabelecimento ON (ESTABELECIMENTO.cadastro=CADASTROPARCEIROS.CADASTRO)
     LEFT join usuario on
      (usuario.usuario=estsin.usuario)
  where estsin.relatorio=:relatorio

  into   :FILIAL, :PIDINICIAL, :PIDFINAL, :NOMEUSUARIO, :TELEFONEUSUARIO,
         :FAXUSUARIO, :EMAILUSUARIO, :DEPARTAMENTOUSUARIO, :CARGOUSUARIO, :LOGO, :LOGINUSUARIO;

  insert into C_IMPRESSOES(DATAHORA,DOCUMENTO,USUARIO,FILIAL,IDNOTA)
  values (cast('now' as timestamp),'PEDIDO',:LOGINUSUARIO,:FILIAL,:PIDINICIAL);

  c_concordancia =
  'Concordo com o aqui estabelecido, bem como as condicoes descritas no formulario de informacoes ao cliente.';

  FOR SELECT pedido.idnota,
             pedido.numeronota,
             pedido.dataemissao,
             pedido.datacadastro,
             cadastroparceiros.razaosocial,
             cadastroparceiros.nome,
             cadastroparceiros.logradouro,
             cadastroparceiros.numero,
             cadastroparceiros.complemento,
             cadastroparceiros.bairro,
             cadastroparceiros.cidade,
             cadastroparceiros.uf,
             substring(cadastroparceiros.cep from 1 for 5)||'-'||
             substring(cadastroparceiros.cep from 6 for 3),
             CASE WHEN (CADASTROPARCEIROS.DOCUMENTO<>'') AND
                   (NOT CADASTROPARCEIROS.DOCUMENTO IS NULL) THEN
             CASE CADASTROPARCEIROS.TIPOPESSOA WHEN 'F' THEN
             CAST(SUBSTRING(CADASTROPARCEIROS.DOCUMENTO FROM 1 FOR 3)||'.'||
             SUBSTRING(CADASTROPARCEIROS.DOCUMENTO FROM 4 FOR 3)||'.'||
             SUBSTRING(CADASTROPARCEIROS.DOCUMENTO FROM 7 FOR 3)||'-'||
             SUBSTRING(CADASTROPARCEIROS.DOCUMENTO FROM 10 FOR 2) AS VARCHAR(18))
               WHEN 'J' THEN
             CAST(SUBSTRING(CADASTROPARCEIROS.DOCUMENTO FROM 1 FOR 2)||'.'||
             SUBSTRING(CADASTROPARCEIROS.DOCUMENTO FROM 3 FOR 3)||'.'||
             SUBSTRING(CADASTROPARCEIROS.DOCUMENTO FROM 6 FOR 3)||'/'||
             SUBSTRING(CADASTROPARCEIROS.DOCUMENTO FROM 9 FOR 4)||'-'||
             SUBSTRING(CADASTROPARCEIROS.DOCUMENTO FROM 13 FOR 2) AS VARCHAR(18))
             ELSE NULL END
             ELSE NULL END AS DOCUMENTO,
             cadastroparceiros.inscestadual,
             cadastroparceiros.inscmunicipal,
             case when coalesce(pedido.email,'')<>'' then pedido.email
             else cadastroparceiros.email end,
             cadastroparceiros.telefone,
             cadastroparceiros.telefonecomercial,
             cadastroparceiros.celular,
             cadastroparceiros.fax,
             case when coalesce(pedido.contato,'')<>'' then pedido.contato
             else cadastroparceiros.principalcontato end,
             pedido.logradouroentrega,
             pedido.numeroentrega,
             pedido.complementoentrega,
             pedido.bairroentrega,
             pedido.cidadeentrega,
             pedido.ufentrega,
             substring(pedido.cepentrega from 1 for 5)||'-'||
             substring(pedido.cepentrega from 6 for 3),
             usuario.nomecompleto,
             usuario.telefone,
             usuario.fax,
             usuario.email,
             usuario.departamento,
             usuario.cargo,
             pedido.cfop,
             pedido.naturezaoperacao,
             tipocobranca.descricao,
             condicaopagamento.descricao,
             pedido.vlrdescmercadorias,
             pedido.msgdescmercadorias,
             pedido.vlrdescindproduto,
             pedido.msgdescprodutos,
             pedido.vlracrescmercad,
             pedido.msgacrescmercadoria,
             pedido.vlrfinalmercadorias ,
             case pedido.zonafranca when 'S' then 0 else pedido.totvaloricms end,
             case pedido.zonafranca when 'N' then 0 else pedido.totvaloricms end,
             pedido.valoripi,
             pedido.vlricmsrecolhido,
             pedido.valorfrete,
             pedido.valorseguro,
             pedido.vlroutdespacessoria,
             pedido.vlrfinalservicos,
             pedido.vlrtotalnota,
             pedido.codigotransp,
             pedido.quantidadevolume,
             pedido.pesoliquido,
             pedido.pesobruto,
             case pedido.frete when '0' then 'CIF' ELSE 'FOB' END,
             pedido.msgdadosadicionais,
             pedido.comentario,
                               
             pedido.c_mensagem1,
             pedido.numpedidocliente,
             pedido.msgdescrmercadorias,
             pedido.vlrdescindservicos,
             pedido.vlracrescservicos,
             pedido.vlrdescservicos,
             pedido.msgdescindservicos,
             pedido.msgdescservicos,
             pedido.vlrfinalservicos,
             pedido.msgacrescservicos,
             PEDIDO.msgdescrservicos,
             pedido.destinatario,
             0,
             pedido.c_condicaomateriais,
             pedido.c_condicaoservicos,
             pedido.c_servicojafaturado,

             case when pedido.c_planta='S' then 'X' else ' ' end ,
             case when pedido.c_cores='S' then 'X' else ' ' end ,
             case when pedido.c_espessura='S' then 'X' else ' ' end ,
             case when pedido.c_desenhos='S' then 'X' else ' ' end ,
             case when pedido.c_dimensoes='S' then 'X' else ' ' end ,
             case when pedido.c_modelos='S' then 'X' else ' ' end ,
             pedido.c_mensagem1,
             pedido.c_prazo,
             pedido.c_mensagemservico,
             pedido.c_consignacao,
             --pedido.c_datadevolucao,
            
             extract (day from pedido.c_datadevolucao)||'/'||
             extract (month from  pedido.c_datadevolucao)||'/'||
             extract (year from pedido.c_datadevolucao) as c_datadevolucao2,
             
             pedido.c_contatoentrega,
             pedido.c_telefoneentrega,
             pedido.C_PRODUTOENCOMENDAACABADO,
             coalesce (PEDIDO.c_devolucao,0),
             pedido.c_pedidosubstituido ,
             coalesce (pedido.c_creditocliente,0),
             PEDIDO.C_Loja,
             PEDIDO.datareferencia,
             case COALESCE(pedido.c_tipo,0)
                     WHEN 1 THEN ''
                     -- '***VENDA INTERNA***'
                     WHEN 2 THEN '***AMOSTRA***'
                     WHEN 3 THEN '***DEMONSTRACAO***'
                     when 4 THEN '***REPOSICAO***'
                     WHEN 5 THEN '***ESTOQUE***'
                     ELSE ''
                     -- '***VENDA***'
             END,
             pedido.C_ESTABSERVICO

      from pedido
      inner join usuario on (pedido.usuarioemissao=usuario.usuario)
      inner join cadastroparceiros on
                (pedido.destinatario=cadastroparceiros.cadastro)

      left join tipocobranca on (tipocobranca.tipocobranca=pedido.tipocobranca)
      left join condicaopagamento on
                  (condicaopagamento.id=pedido.condicaopagamento)

      where pedido.filial=:filial
      and pedido.idnota between :pidinicial and :pidfinal
      and (pedido.dataemissao is not null /*or :psoaprovado='N'*/)
      and pedido.datacancelamento is null
      into :IDNOTA, :NUMEROPEDIDO, :DATAEMISSAO, :DATACADASTRO,
           :RAZAO, :NOME, :LOGRADOURO, :NUMERO, :COMPLEMENTO, :BAIRRO, :CIDADE, :UF, :CEP,
           :DOCUMENTO, :INSCESTADUAL, :INSCMUNICIPAL,
           :EMAIL, :TELEFONE, :TELEFONECOMERCIAL, :CELULAR, :FAX, :PRINCIPALCONTATO,
           :LOGRADOUROENTREGA, :NUMEROENTREGA, :COMPLEMENTOENTREGA, :BAIRROENTREGA,
           :CIDADEENTREGA, :UFENTREGA, :CEPENTREGA, :NOMEUSUARIOAPROVACAO, :TELEFONEUSUARIOAPROVACAO,
           :FAXUSUARIOAPROVACAO, :EMAILUSUARIOAPROVACAO, :DEPARTAMENTOUSUARIOAPROVACAO,
           :CARGOUSUARIOAPROVACAO, :CFOP, :NATUREZAOPERACAO, :TIPOPAGTO, :CONDICAOPAGTO,
           :VLRDESCONTO, :MSGDESCMERCADORIAS, :VLRDESCINDPRODUTO, :MSGDESCPRODUTOS, :VLRACRESCIMO,
           :MSGACRESCMERCADORIA, :VLRMERCADORIAS, :VLRICMS, :VLRZONAFRANCA, :VLRIPITOTAL, :VLRSUBSTRIB,
           :VLRFRETE, :VLRSEGURO, :VLRDESPESAS, :VLRSERVICO, :VLRTOTAPEDIDO, :CODTRANSP, :QTDEVOLUME,
           :PESOLIQUIDO, :PESOBRUTO, :TIPOFRETE, :MSGADICIONAL, :COMENTARIO, :OBSERVACAO, :SEUNUMERO,
           :MSGDESCRMERCADORIAS, :VLRDESCINDSERVICOS, :VLRACRESCSERVICOS, :VLRDESCSERVICOS,
           :MSGDESCINDSERVICOS, :MSGDESCSERVICOS, :VLRFINALSERVICOS, :MSGACRESCSERVICOS,
           :MSGDESCRSERVICOS, :DESTINATARIO, :SERVICOSREALIZADOS, :CONDPAGMATERIAIS,
           :CONDPAGSERVICO, :JAFATURADO, :TERMOPLANTA, :TERMOCORES, :TERMOESPESSURA,
           :TERMODESENHO, :TERMODIMENSAO, :TERMOMODELO, :C_MENSAGEM1, :C_PRAZO,
           :C_MENSAGEMSERVICO, :CONSIGNACAO, :DATADEVOLUCAOPREVISTA, :C_CONTATOENTREGA,
           :C_TELEFONEENTREGA, :P_PRODUTOENCOMENDAACABADO, :C_DEVOLUCAO, :P_PEDIDOSUBSTITUIDO, :P_CREDITOCLIENTE, :FILIALESTSIN,
           :DATAREFERENCIA, :TIPOPEDIDO, :pestabServico
            do begin

        diaREFERENCIA= extract(day from :DATAREFERENCIA);
        anoREFERENCIA = extract(year from :DATAREFERENCIA);
        mesREFERENCIA = case extract(month from DATAREFERENCIA)
                when 1 then 'Janeiro'
                WHEN 2 then 'Fevereiro'
                WHEN 3 then 'Marco'
                WHEN 4 then 'Abril'
                WHEN 5 then 'Maio'
                WHEN 6 then 'Junho'
                WHEN 7 then 'Julho'
                WHEN 8 then 'Agosto'
                WHEN 9 then 'Setembro'
                WHEN 10 then 'Outubro'
                WHEN 11 then 'Novembro'
                WHEN 12 then 'Dezembro' end;


        select
         cadastroparceiros.razaosocial,
         cadastroparceiros.nome,
         CASE WHEN (CADASTROPARCEIROS.DOCUMENTO<>'') AND
                 (NOT CADASTROPARCEIROS.DOCUMENTO IS NULL) THEN
            CASE CADASTROPARCEIROS.TIPOPESSOA WHEN 'F' THEN
            CAST(SUBSTRING(CADASTROPARCEIROS.DOCUMENTO FROM 1 FOR 3)||'.'||
            SUBSTRING(CADASTROPARCEIROS.DOCUMENTO FROM 4 FOR 3)||'.'||
            SUBSTRING(CADASTROPARCEIROS.DOCUMENTO FROM 7 FOR 3)||'-'||
            SUBSTRING(CADASTROPARCEIROS.DOCUMENTO FROM 10 FOR 2) AS VARCHAR(18))
              WHEN 'J' THEN
            CAST(SUBSTRING(CADASTROPARCEIROS.DOCUMENTO FROM 1 FOR 2)||'.'||
            SUBSTRING(CADASTROPARCEIROS.DOCUMENTO FROM 3 FOR 3)||'.'||
            SUBSTRING(CADASTROPARCEIROS.DOCUMENTO FROM 6 FOR 3)||'/'||
            SUBSTRING(CADASTROPARCEIROS.DOCUMENTO FROM 9 FOR 4)||'-'||
            SUBSTRING(CADASTROPARCEIROS.DOCUMENTO FROM 13 FOR 2) AS VARCHAR(18))
         ELSE NULL END
         ELSE NULL END AS DOCUMENTO,
         cadastroparceiros.inscestadual,
         cadastroparceiros.inscmunicipal,
         cadastroparceiros.logradouro,
         cadastroparceiros.numero,
         cadastroparceiros.complemento,
         cadastroparceiros.bairro,
         cadastroparceiros.cidade,
         cadastroparceiros.uf,
         substring(cadastroparceiros.cep from 1 for 5)||'-'||
         substring(cadastroparceiros.cep from 6 for 3),
         cadastroparceiros.telefone,
         cadastroparceiros.telefonecomercial,
         cadastroparceiros.fax,
         cadastroparceiros.principalcontato,
         cadastroparceiros.email,
         cadastroparceiros.web


   from cadastroparceiros
   where cadastroparceiros.CADASTRO=:filialestsin
   into

       :razaofilial,
       :nomefilial,
       :documentofilial,
       :inscestadualfilial,
       :inscmunicipalfilial,
       :logradourofilial,
       :numerofilial,
       :complementofilial,
       :bairrofilial,
       :cidadefilial,
       :uffilial,
       :cepfilial,
       :telefonefilial,
       :telefonecomercialfilial,
       :faxfilial,
       :principalcontatofilial,
       :emailfilial,
       :webfilial;

            if (coalesce(c_devolucao,0)=0) then begin
                c_devolucao2='';
                c_devolucao3=''; end
            else begin
                c_devolucao2='Recebemos os itens acima descritos como devolucao do pedido: '||C_DEVOLUCAO;
                c_devolucao3='Devolucao do Pedido: '||C_DEVOLUCAO;
            end


            if (coalesce(:logradouroentrega,'')='') then begin
                localentrega='O MESMO';
                logradouroentrega=logradouro;
                numeroentrega=numero;
                complementoentrega=complemento;
                bairroentrega=bairro;
                cidadeentrega=cidade;
                ufentrega=uf;
                cepentrega=cep;
            end else
                localentrega = COALESCE(logradouroentrega,'') || ', ' ||
                                COALESCE(numeroentrega,'') || ' '||
                                COALESCE(complementoentrega,'') || ' '||
                                COALESCE(bairroentrega,'') || ' '||
