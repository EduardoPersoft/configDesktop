select 
    cadcli.cadastro,
    cadcli.nome,
    cadven.nome vendedor,

    (select 
        count(mercadoriasorc.idnota) 
     from 
        ORCAMENTO
     INNER JOIN
        MERCADORIASORC ON
            ORCAMENTO.FILIAL=MERCADORIASORC.FILIAL and
            ORCAMENTO.IDNOTA=MERCADORIASORC.IDNOTA
     where
        orcamento.destinatario=CADASTROPARCEIROS.cadastro and
        orcamento.DATACADASTRO between '01.01.2024' and '31.08.2024' and
        orcamento.CANCELAMENTO='N') qtdOrcamento     


    (select 
        count(mercadoriasorc.idnota) 
     from 
        PEDIDO ORCAMENTO
     INNER JOIN
        MERCADORIASPED MERCADORIASORC ON
            ORCAMENTO.FILIAL=MERCADORIASORC.FILIAL and
            ORCAMENTO.IDNOTA=MERCADORIASORC.IDNOTA
     where
        orcamento.destinatario=CADASTROPARCEIROS.cadastro and
        orcamento.DATACADASTRO between '01.01.2024' and '31.08.2024' and
        orcamento.CANCELAMENTO='N') qtdConversao
    --sum(case when pedConvertido.idnota is null then 0 else 1 end)  / count(ORCAMENTO.idnota)  * 100 as pConversao
from 
    CADASTROPARCEIROS cadcli
inner join
    clientes on 
        cadcli.cadastro=clientes.CADASTRO
inner join
    CADASTROPARCEIROS cadven on
        cadven.cadastro=clientes.vendedor

    
group by    
    cadcli.cadastro,
    cadcli.nome,
    cadven.nome
order by 5 desc,4 desc
