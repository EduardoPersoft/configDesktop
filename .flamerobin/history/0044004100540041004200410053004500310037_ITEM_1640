insert into ITEMESTOQUECODIGOS(CODIGO, CODIGOALTERNATIVO)
select 
    ITEMESTOQUE.CODIGO,
    ITEMESTOQUE.C_MRFORNECEDOR   
from
    ITEMESTOQUE
where
    NOT EXISTS (
        SELECT 
            *
        FROM 
            ITEMESTOQUECODIGOS
        where
            ITEMESTOQUECODIGOS.CODIGO=ITEMESTOQUE.CODIGO and
            ITEMESTOQUECODIGOS.CODIGOALTERNATIVO=ITEMESTOQUE.C_MRFORNECEDOR)
    