select
    local.descricao,
    local.EAN,
    itemestoque.codigo,
    itemestoque.codigobarra,
    itemestoque.descricao,
    locallote.QUANTIDADE
from
    LOCALLOTE
inner join
    local on
        local.id=locallote.local
inner join 
    itemestoque on
        itemestoque.codigo=locallote.IDITEM
where
    locallote.quantidade>0 and
    local.descricao like 'Z2-A%'
order by 
    local.descricao,
    itemestoque.codigo