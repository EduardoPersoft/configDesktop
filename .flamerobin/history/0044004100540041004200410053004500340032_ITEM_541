SELECT
    TITULOREC.PARCEIRO,
    TITULOREC.IDTITULO,
    TITULOREC.TITULO,
    TITULOREC.FATURA,
    TITULOREC.EMISSAO,
    TITULOREC.BAIXA,
    CADASTROPARCEIROS.NOME,
    CADASTROPARCEIROS.RAZAOSOCIAL,
    TITULOREC.VALORTITULO,
    TITULOREC.FILIAL,
    TITULOREC.VENCIMENTO,
    CONTACORRENTE.DESCRICAOCONTA,
    TITULOREC.NUMBOLBANCO,
    TIPOCOBRANCA.DESCRICAO,
    'N' AS P_MARCA,
    CASE WHEN TITULOREC.BAIXA IS NOT NULL THEN 8421504
    WHEN TITULOREC.VENCIMENTO<CAST('NOW' AS DATE) THEN 255
   ELSE 0 END AS P_STATUSCOR,


 TITULOREC.CONTACORRENTE,
   CASE TITULOREC.TIPOTITULO 
   WHEN '2' THEN '2-DOC'
   WHEN '3' THEN '3-DARF'
   WHEN '4' THEN '4-GPS'
   WHEN '5' THEN '5-ISS'
   WHEN '6' THEN '6-IR'
   WHEN '7' THEN '7-CRED'
   ELSE '1-DUPL'   END AS  TIPOTITULO, 
  CASE WHEN ( SELECT COUNT(IDTITULO) FROM TITULOSANEXADOSDOC 
               INNER JOIN DOCTOBANCARIOS ON (TITULOSANEXADOSDOC.FILIAL=DOCTOBANCARIOS.FILIAL
                                                                  AND TITULOSANEXADOSDOC.IDCONTACORRENTE=DOCTOBANCARIOS.IDCONTACORRENTE
                                                                  AND TITULOSANEXADOSDOC.IDMOVTOBANC=DOCTOBANCARIOS.IDMOVTOBANCARIO)
               WHERE TITULOSANEXADOSDOC.FILIAL=TITULOREC.FILIAL
               AND TITULOSANEXADOSDOC.IDTITULO = TITULOREC.IDTITULO
               AND TITULOSANEXADOSDOC.TIPOTITULO='R' 
               AND DOCTOBANCARIOS.COMPENSACAO IS NULL
               AND DOCTOBANCARIOS.CANCELAMENTO IS NULL) > 0 THEN '*' ELSE ' ' END AS TITULOSANEXADOS,     
 'N' as P_MARCA 
   
FROM TITULOREC

INNER JOIN CADASTROPARCEIROS ON (TITULOREC.PARCEIRO = CADASTROPARCEIROS.CADASTRO)
INNER JOIN CONTACORRENTE ON(TITULOREC.FILIAL=CONTACORRENTE.FILIAL AND
                                                          TITULOREC.CONTACORRENTE=CONTACORRENTE.CODIGO)
INNER JOIN TIPOCOBRANCA ON (TITULOREC.TIPOTRANSACAO=TIPOCOBRANCA.TIPOCOBRANCA)

WHERE
    TITULOREC.FILIAL=:FILIAL AND
    TITULOREC.TIPOBAIXA = 'P' AND
    TITULOREC.BAIXA BETWEEN  :DATAINICIAL AND :DATAFINAL