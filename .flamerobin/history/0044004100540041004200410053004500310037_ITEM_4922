SELECT TITULOREC.VALORTITULO,
              TITULOREC.VENCIMENTO,
              TITULOREC.TIPOBAIXA,
              TITULOREC.BAIXA,
              TITULOREC.DATAPAGAMENTO,
              TITULOREC.valoremaberto,
              TITULOREC.totalpago
   FROM
       TITULOREC
   WHERE
       TITULOREC.PARCEIRO=712 AND
       TITULOREC.EMISSAO BETWEEN '01.01.2020' AND '31.12.2025' and
       ( NOT COALESCE(TITULOREC.TIPOBAIXA,'') IN ('C','E') )