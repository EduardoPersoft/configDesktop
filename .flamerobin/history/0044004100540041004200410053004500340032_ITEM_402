SET TERM ^ ;
ALTER PROCEDURE ULTIMACOMPRA (
    PDATA timestamp )

AS
begin

---apagando a partir da data do ?ltimom rec?lculo

delete from RESUMOCOMPRAS where resumocompras.EMISSAO > :pdata;

---inserindo a partir da data do ?ltimom rec?lculo
INSERT INTO RESUMOCOMPRAS(item,emissao,fornecedor, quantidade,custo,preco)
 SELECT
    MATERIALMOVIMENTOESTOQUE.IDITEM,
    MOVIMENTOESTOQUE.EMISSAO,
    NOTACOMPRA.DESTINATARIO,
    SUM(MATERIALMOVIMENTOESTOQUE.QUANTIDADE) AS QUANTIDADE,
    CAST(SUM(MATERIALMOVIMENTOESTOQUE.VALOR)/SUM(MATERIALMOVIMENTOESTOQUE.QUANTIDADE) AS DECIMAL(12,3)) AS CUSTOUNITARIO,
    CAST(SUM(MERCADORIASNOTACOMPRA.VLRFINALMERCAD+
        COALESCE(MERCADORIASNOTACOMPRA.VALORIPI,0)+
        COALESCE(MERCADORIASNOTACOMPRA.VLRICMSRECOLHIDO,0)+
        COALESCE(MERCADORIASNOTACOMPRA.FRETE,0)+
        COALESCE(MERCADORIASNOTACOMPRA.SEGURO,0)+
        COALESCE(MERCADORIASNOTACOMPRA.OUTDESPACESSOR,0)+
        COALESCE(MERCADORIASNOTACOMPRA.ACRESCIMONOTA,0)-
        COALESCE(MERCADORIASNOTACOMPRA.DESCONTONOTA,0))/    
            SUM(MATERIALMOVIMENTOESTOQUE.QUANTIDADE) AS DECIMAL(12,3)) AS PRECOUNITARIO
FROM
    MATERIALMOVIMENTOESTOQUE
INNER JOIN
    MOVIMENTOESTOQUE ON
        MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL AND
        MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
INNER JOIN
    NOTACOMPRA ON
        NOTACOMPRA.FILIAL=MOVIMENTOESTOQUE.FILIAL AND
        NOTACOMPRA.IDNOTA=MOVIMENTOESTOQUE.IDNOTACOMPRA
INNER JOIN
    MERCADORIASNOTACOMPRA ON
        MERCADORIASNOTACOMPRA.FILIAL=NOTACOMPRA.FILIAL AND
        MERCADORIASNOTACOMPRA.IDNOTA=NOTACOMPRA.IDNOTA AND
        MERCADORIASNOTACOMPRA.IDMERCADORIA=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL
INNER JOIN
    CADASTROPARCEIROS ON
        CADASTROPARCEIROS.CADASTRO=NOTACOMPRA.DESTINATARIO
LEFT join
    NATUREZAOPERACAO ON
        NATUREZAOPERACAO.ID=NOTACOMPRA.OPERACAO
WHERE 
    MOVIMENTOESTOQUE.EMISSAO > :PDATA and
    MOVIMENTOESTOQUE.TIPOMOVIMENTO IN ('01','05') and
    NATUREZAOPERACAO.FATURA = 'S'
GROUP BY
    MATERIALMOVIMENTOESTOQUE.IDITEM,
    MOVIMENTOESTOQUE.EMISSAO,
    NOTACOMPRA.DESTINATARIO
HAVING 
    SUM(MATERIALMOVIMENTOESTOQUE.QUANTIDADE)>0
ORDER BY
    MOVIMENTOESTOQUE.EMISSAO DESC;

--- Atualizando datas

UPDATE
      MATERIALFILIAL
set
      MATERIALFILIAL.ULTIMACOMPRA= (select max (RESUMOCOMPRAS.EMISSAO) from resumocompras
                                      where
                                           resumocompras.ITEM=materialfilial.IDITEM );


 end
^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE ULTIMACOMPRA TO  SYSDBA WITH GRANT OPTION;

