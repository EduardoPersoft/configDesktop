SET TERM ^ ;
ALTER PROCEDURE PREPARATITULOREC

AS
DECLARE VARIABLE V_ID INTEGER;
DECLARE VARIABLE TITULO VARCHAR(20);
DECLARE VARIABLE DESDOB VARCHAR(4);
DECLARE VARIABLE EMPRESA INTEGER;
DECLARE VARIABLE TIPODOCUMENTO INTEGER;
DECLARE VARIABLE SERIE CHAR(2);
 
begin
/*
    UPDATE 
        T_TITULOREC
    SET
        CADASTRO = (SELECT FIRST 1 CADASTROPARCEIROS.CADASTRO FROM CADASTROPARCEIROS WHERE SUBSTRING(CADASTROPARCEIROS.RAZAOSOCIAL FROM 1 FOR 39) = T_TITULOREC.CLIENTE)
    where
        T_TITULOREC.IMPORTADO IS NULL;

    UPDATE 
        T_TITULOREC
    SET
        CADASTROANTIGO = (SELECT FIRST 1 CADASTROPARCEIROS.CADASTRO FROM CADASTROPARCEIROS WHERE CADASTROPARCEIROS.C_CODVENDEDORANTIGO=T_TITULOREC.VENDEDOR)
    where
        T_TITULOREC.IMPORTADO IS NULL;
*/
    --SELECT MAX(T1.IDTITULO) FROM T_TITULOREC T1  WHERE T1.EMPRESA=5 and t1.idtitulo<200000
    SELECT ESTABELECIMENTO.IDTITULORECEBER FROM ESTABELECIMENTO WHERE ESTABELECIMENTO.CADASTRO=5
    INTO V_ID;

    FOR SELECT    
        T_TITULOREC.TITULO,
        T_TITULOREC.DESDOB,
        T_TITULOREC.EMPRESA,
        T_TITULOREC.TIPODOCUMENTO,
        T_TITULOREC.SERIE
    FROM
        T_TITULOREC
    WHERE
        T_TITULOREC.IMPORTADO IS NULL
    INTO TITULO, DESDOB, EMPRESA, TIPODOCUMENTO, SERIE DO BEGIN
        V_ID = V_ID + 1;
        UPDATE
            T_TITULOREC T2
        SET 
            T2.IDTITULO = :V_ID
        where
            T2.TITULO = :TITULO AND
            T2.DESDOB = :DESDOB AND
            T2.EMPRESA = :EMPRESA AND
            T2.TIPODOCUMENTO = :TIPODOCUMENTO AND
            T2.SERIE = :SERIE;
    END


/*
    UPDATE
        T_TITULOREC
    SET 
        IDTITULO = IDTITULO + (SELECT MAX(TITULOREC.IDTITULO) FROM TITULOREC WHERE TITULOREC.FILIAL=5)
    where
        T_TITULOREC.IMPORTADO IS NULL;
  */  

end
^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE PREPARATITULOREC TO  SYSDBA;

