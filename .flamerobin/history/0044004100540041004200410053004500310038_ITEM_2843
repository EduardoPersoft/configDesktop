select
    cast(pedido.DATAREFERENCIA as date),
    cadloja.NOME,
    pedido.idnota,
    pedido.IDORCAMENTO,
    cadcli.nome,
    pedido.vlrtotalnota vlrpedido,
    coalesce(orcamento.VLRTOTALNOTA,
             pedido.vlrtotalnota) vlrorcamento,
    vendedoresped.COMISSAOVENDA,
    vendedoresped.COMISSAORECEBIMENTO
from
    PEDIDO
inner join 
    CADASTROPARCEIROS cadcli on
        cadcli.cadastro=pedido.destinatario
inner join
    CADASTROPARCEIROS cadloja on
        cadloja.cadastro=pedido.C_LOJA
left join
    orcamento on
        orcamento.filial=pedido.filial and
        orcamento.idnota=pedido.IDORCAMENTO
left join
    vendedoresped on
        vendedoresped.filial=pedido.filial and
        vendedoresped.idnota=pedido.idnota