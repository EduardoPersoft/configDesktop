select 
    itemestoque.codigo,
    itemestoque.descricao,
    itemestoque.c_up,
    itemestoque.C_PESOCONSUMO,
    itemestoque.c_pesofaturamento,
    itemestoque.C_PESOLATEX,
    itemestoque.c_pesom2,
    itemestoque.PESOLIQUIDO,
    itemestoque.PESOBRUTO
from
    ITEMESTOQUE
where 
    itemestoque.TIPOPRODUTO='4' and 
    itemestoque.codigo between '1000' and '3'
order by
        itemestoque.codigo
    