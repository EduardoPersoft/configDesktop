SELECT 
    PEDIDOCOMPRA.UUID,
    COUNT(PEDIDOCOMPRA.IDNOTA)
FROM 
    PEDIDOCOMPRA
where   
    EXISTS (SELECT 
                *
            FROM 
                MERCADORIASPEDCOMPRA
            where
                MERCADORIASPEDCOMPRA.FILIAL=PEDIDOCOMPRA.FILIAL and
                MERCADORIASPEDCOMPRA.IDNOTA=PEDIDOCOMPRA.IDNOTA and
                MERCADORIASPEDCOMPRA.BAIXA='N')
GROUP BY
    PEDIDOCOMPRA.UUID
having
    COUNT(PEDIDOCOMPRA.UUID)>1