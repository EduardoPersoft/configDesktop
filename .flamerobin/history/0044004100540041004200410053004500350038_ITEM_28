update 
    NOTAFISCAL
    set 
        NOTAFISCAL.TOTBASEICMS=NOTAFISCAL.ICMSORIGEMBASE,
        NOTAFISCAL.TOTVALORICMS=(case (NOTAFISCAL.ICMSDESTINOVALOR)
                        when 0 THEN ICMSORIGEMVALOR
                        ELSE ICMSDESTINOVALOR END),
        NOTAFISCAL.TOTOUTROSICMS=TOTOUTROSICMS - ICMSORIGEMBASE
where 
    NOTAFISCAL.filial=1 and 
    NOTAFISCAL.DATAEMISSAO> '01.01.2026' AND
    NOTAFISCAL.TOTBASEICMS=0 and 
    NOTAFISCAL.ICMSORIGEMBASE>0 AND
    tiponota <> 2 and
    NOTAFISCAL.idnota=52823;