select   
    mapaProducao.*, materialmovimentoestoque.IDPEDIDO, MATERIALMOVIMENTOESTOQUE.IDMERCADORIA
from
    materialMovimentoEstoque
    /*
inner join 
    mercadoriasped on 
    MATERIALMOVIMENTOESTOQUE.FILIAL=MERCADORIASPED.FILIAL and 
    MATERIALMOVIMENTOESTOQUE.IDPEDIDO=MERCADORIASPED.IDNOTA and 
    MATERIALMOVIMENTOESTOQUE.IDMERCADORIA=MERCADORIASPED.IDMERCADORIA */
inner JOIN
    movimentoestoque on 
        movimentoestoque.filial=materialmovimentoestoque.filial AND
        movimentoestoque.idmovimento=materialmovimentoestoque.idmovimento
inner join
    mapaProducao on
        materialMovimentoEstoque.filial = mapaProducao.filial and
        materialMovimentoEstoque.idMovimento = mapaProducao.idMovimento --and
        --materialMovimentoEstoque.idMovimentoMaterial = mapaProducao.idMovimentoMaterial
where 
    materialmovimentoestoque.filial=110 and materialmovimentoestoque.idmovimento=14717
