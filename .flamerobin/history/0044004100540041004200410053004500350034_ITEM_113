INSERT INTO materialmovimentoestoque(
    FILIAL,
    idmovimento,
    idmovimentomaterial,
    iditem,
    quantidade,
    valor,
    sinal,
    recalculo,
    localarmazenamento,
    lote,
    concluido)   
SELECT 
    MATERIALMOVIMENTOESTOQUE.FILIAL,
    105699,
    row_number() over(),
    MATERIALMOVIMENTOESTOQUE.IDITEM,    
    MATERIALMOVIMENTOESTOQUE.QUANTIDADE*(-1),
    MATERIALMOVIMENTOESTOQUE.QUANTIDADE*COALESCE(ITEMESTOQUE.VALORULTIMACOMPRA,0)*(-1),
    1,
    'N',
    MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO,
    MATERIALMOVIMENTOESTOQUE.LOTE,   
    'N'
from
    MATERIALMOVIMENTOESTOQUE
INNER join
    MOVIMENTOESTOQUE ON
        MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL and
        MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
INNER join
    ITEMESTOQUE ON
        ITEMESTOQUE.CODIGO=MATERIALMOVIMENTOESTOQUE.IDITEM
WHERE 
    MATERIALMOVIMENTOESTOQUE.FILIAL=1 and
    MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO=105697 AND
    MATERIALMOVIMENTOESTOQUE.QUANTIDADE<0 
