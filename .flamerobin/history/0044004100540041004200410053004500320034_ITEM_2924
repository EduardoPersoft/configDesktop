--insert into
    --ITEMESTOQUECODIGOS
select
    DISTINCT
    I1.CODIGO,
    I1.CODIGO
from
    ITEMESTOQUECODIGOS I1
where 
    I1.CODIGO=I1.CODIGOALTERNATIVO AND
    NOT EXISTS 
    (SELECT 
        * 
     FROM 
        ITEMESTOQUECODIGOS I2
     WHERE   
        I2.CODIGO=I1.CODIGO AND
        I2.CODIGOALTERNATIVO=I1.CODIGO)