delete 
from 
    materiallocal 
where 
    materiallocal.filial=1
    and materiallocal.idlocal=1 
    and materiallocal.saldototal<0
    and exists (
        SELECT 
            *   
        FROM    
            MATERIALMOVIMENTOESTOQUE
        where 
            materialmovimentoestoque.filial=materiallocal.FILIAL
            and materialmovimentoestoque.idmovimento between 266000 and 266360) 