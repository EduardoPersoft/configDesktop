SELECT
    DISTINCT
    ORCAMENTO.uuid,
    ORCAMENTO.FILIAL,
    ORCAMENTO.IDNOTA,
    ORCAMENTO.DATACADASTRO,
    CADCLI.NOME,
    ORCAMENTO.VLRTOTALNOTA,
    CASE WHEN ORCAMENTO.cancelamento ='S' THEN 'Cancelado'
       WHEN EXISTS
       (SELECT * FROM PEDIDO
        WHERE PEDIDO.FILIAL=ORCAMENTO.FILIAL
        AND PEDIDO.IDORCAMENTO=ORCAMENTO.IDNOTA) THEN 'Pedido '||
            (SELECT max(PEDIDO.IDNOTA) FROM PEDIDO
             WHERE PEDIDO.FILIAL=ORCAMENTO.FILIAL
             AND PEDIDO.IDORCAMENTO=ORCAMENTO.IDNOTA)
       WHEN ORCAMENTO.DATAPERDA IS NOT NULL THEN 'Perdido '||coalesce(motivoPerda.descricao, '')
       WHEN ORCAMENTO.dataemissao IS NOT NULL THEN 'Pronto'
       ELSE case when orcamento.pedirAprovacao='S' then 'Autorizar'
                 when orcamento.pedirLiberacao='S' then 'Financeiro' 
                else 'Rascunho' end
     END AS STATUS
FROM 
    ORCAMENTO 
INNER JOIN 
    CADASTROPARCEIROS CADCLI ON
        CADCLI.CADASTRO = ORCAMENTO.DESTINATARIO
LEFT JOIN 
    CADASTROPARCEIROS CADTRANS ON   
        CADTRANS.CADASTRO = ORCAMENTO.CODIGOTRANSP
LEFT JOIN
    ORCMOTIVOSPERDA motivoPerda ON
        motivoPerda.ID=ORCAMENTO.MOTIVOPERDA
WHERE
    SELECT
    DISTINCT
    ORCAMENTO.uuid,
    ORCAMENTO.FILIAL,
    ORCAMENTO.IDNOTA,
    ORCAMENTO.DATACADASTRO,
    CADCLI.NOME,
    ORCAMENTO.VLRTOTALNOTA,
    CASE WHEN ORCAMENTO.cancelamento ='S' THEN 'Cancelado'
       WHEN EXISTS
       (SELECT * FROM PEDIDO
        WHERE PEDIDO.FILIAL=ORCAMENTO.FILIAL
        AND PEDIDO.IDORCAMENTO=ORCAMENTO.IDNOTA) THEN 'Pedido '||
            (SELECT max(PEDIDO.IDNOTA) FROM PEDIDO
             WHERE PEDIDO.FILIAL=ORCAMENTO.FILIAL
             AND PEDIDO.IDORCAMENTO=ORCAMENTO.IDNOTA)
       WHEN ORCAMENTO.DATAPERDA IS NOT NULL THEN 'Perdido '||coalesce(motivoPerda.descricao, '')
       WHEN ORCAMENTO.dataemissao IS NOT NULL THEN 'Pronto'
       ELSE case when orcamento.pedirAprovacao='S' then 'Autorizar'
                 when orcamento.pedirLiberacao='S' then 'Financeiro' 
                else 'Rascunho' end
     END AS STATUS
FROM 
    ORCAMENTO 
INNER JOIN 
    CADASTROPARCEIROS CADCLI ON
        CADCLI.CADASTRO = ORCAMENTO.DESTINATARIO
LEFT JOIN 
    CADASTROPARCEIROS CADTRANS ON   
        CADTRANS.CADASTRO = ORCAMENTO.CODIGOTRANSP
LEFT JOIN
    ORCMOTIVOSPERDA motivoPerda ON
        motivoPerda.ID=ORCAMENTO.MOTIVOPERDA
WHERE
    ORCAMENTO.FILIAL=1 AND ORCAMENTO.DATACADASTRO>=CAST('NOW' AS DATE)-60 
    and (orcamento.atendente=1 or 
         exists(select * from vendedoresorc 
                where vendedoresorc.filial=orcamento.filial 
                and vendedoresorc.idnota=orcamento.IDNOTA
                and vendedoresorc.vendedor=1))
