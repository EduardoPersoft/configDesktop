SELECT
    COMPOSICAOOP.codigo,
    MAT.DESCRICAO,
    COMPOSICAOOP.quantidade AS QUANTIDADE,
    movimentoestoque.idmovimento,
    movimentoestoque.documento,
    movimentoestoque.emissao,
    movimentoestoque.c_empenho ,
    MATERIALMOVIMENTOESTOQUE.IDITEM,
    PROD.DESCRICAO,
    MATERIALMOVIMENTOESTOQUE.C_PESOCONSUMO,
    materialmovimentoestoque.quantidade,
    COMPOSICAOOP.IDCOMPOSICAO,
    MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL,
    MATERIALMOVIMENTOESTOQUE.C_UP,
    pedido.ENTREGA

    FROM COMPOSICAOOP
    INNER JOIN MOVIMENTOESTOQUE ON (MOVIMENTOESTOQUE.FILIAL=COMPOSICAOOP.filial AND
            MOVIMENTOESTOQUE.idmovimento=COMPOSICAOOP.idmovimento)
    INNER JOIN MATERIALMOVIMENTOESTOQUE ON (MATERIALMOVIMENTOESTOQUE.filial=COMPOSICAOOP.FILIAL
        AND MATERIALMOVIMENTOESTOQUE.idmovimento=COMPOSICAOOP.IDMOVIMENTO
        AND MATERIALMOVIMENTOESTOQUE.idmovimentomaterial=COMPOSICAOOP.idmovimentomaterial)
    INNER JOIN ITEMESTOQUE PROD ON (PROD.CODIGO=MATERIALMOVIMENTOESTOQUE.iditem)
    INNER JOIN ITEMESTOQUE MAT ON (MAT.CODIGO=COMPOSICAOOP.codigo)
    INNER JOIN MERCADORIASPED ON (
        MERCADORIASPED.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL AND
        MERCADORIASPED.IDNOTA=MATERIALMOVIMENTOESTOQUE.Idpedido AND
        MERCADORIASPED.IDMERCADORIA=MATERIALMOVIMENTOESTOQUE.Idmercadoria)
    INNER JOIN PEDIDO ON (
        PEDIDO.FILIAL=MERCADORIASPED.FILIAL AND
        PEDIDO.IDNOTA=MERCADORIASPED.IDNOTA)
    
    WHERE MOVIMENTOESTOQUE.TIPOMOVIMENTO = '12'
    AND MATERIALMOVIMENTOESTOQUE.CONCLUIDO='N'
    
    AND COMPOSICAOOP.CODIGO BETWEEN '' AND 'z'
    and not exists (select * from pedido 
                    where pedido.filial=materialmovimentoestoque.filial and 
                          pedido.C_PEDIDOSUBSTITUIDO=materialmovimentoestoque.idpedido)