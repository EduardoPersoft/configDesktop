SELECT 
       NOTAFISCAL.FILIAL, 
       MODELODOCTO.MODELO,
       'E',
       NOTAFISCAL.DATAEMISSAO AS DATA,
       NOTAfiscal.NRNOTAFORNECEDOR AS NUMERONOTA,
       NOTAfiscal.NRNOTAFORNECEDOR AS ORDEMNOTA,
       mercadoriasnota.cfop,
       mercadoriasnota.idpedido,
       CLIENTES.CADASTRO,
       CLIENTES.NOME,
       'N',
       NOTAFISCAL.DEVOLUCAO,
       case notafiscal.entradasaida when 'S' 
            then NATUREZAOPERACAO.FATURA 
            else NATUREZAOPERACAO.DEVOLUCAOFATURAMENTO 
            end fatura,
       
       case when   (mercadoriasnota.cfop not in ('5922','6922') and
                   exists (select 
                        * 
                    from 
                        faturas
                    where notafiscal.filial=faturas.filial
                    and notafiscal.idnota=faturas.idnota) ) or mercadoriasnota.cfop in ('5116', '5117', '6116', '6117')
                    
            then 'S'
            else 'N'
       end as receita,
       
       case when exists (select 
                            * 
                         from 
                            ESTABELECIMENTO
                         where estabelecimento.CADASTRO=clientes.cadastro) 
        then 'S' else 'N' end entreFiliais,

 --      GRUPOMERCADORIA.DESCRICAO,
       sum(COALESCE(mercadoriasnota.VLRTOTALMERCAD,0)+
           COALESCE(mercadoriasnota.VALORIPI,0)+
           COALESCE(MERCADORIASNOTA.VLRICMSRECOLHIDO,0)+
           COALESCE(mercadoriasnota.ICMSSTFCPVALOR,0)+
           mercadoriasnota.frete+
           mercadoriasnota.seguro+
           mercadoriasnota.OUTDESPACESSOR-
           (coalesce(mercadoriasnota.DESCONTONOTA,0)+
            coalesce(mercadoriasnota.VLRDESCPRODUTO,0)+
            case notafiscal.ZONAFRANCA when 'S' then mercadoriasnota.valoricms else 0 end))   as VLRTOTALNOTA,
       sum (COALESCE(mercadoriasnota.VALORIPI,0)) AS VALORIPI,
       sum (COALESCE(mercadoriasnota.VLRTOTALMERCAD,0)) AS VLRSEMIPI,
       NOTAFISCAL.FILIAL,
       ESTAB.RAZAOSOCIAL,
       sum (MERCADORIASNOTA.VLRICMSRECOLHIDO) AS VLRICMSRECOLHIDO,

       sum(mercadoriasnota.frete) + sum(mercadoriasnota.seguro) +
          sum(mercadoriasnota.OUTDESPACESSOR) AS DESPACESSORIAS,
       

        sum (mercadoriasnota.VLRTOTALMERCAD-
            (coalesce(mercadoriasnota.DESCONTONOTA,0)+
             coalesce(mercadoriasnota.VLRDESCPRODUTO,0)+
             case notafiscal.ZONAFRANCA when 'S' then mercadoriasnota.valoricms else 0 end))  AS VLRFINALMERCADORIAS,
         
        CASE NOTAFISCAL.ZONAFRANCA 
            WHEN 'S' THEN 0
            ELSE SUM (MERCADORIASNOTA.valoricms) end AS TOTVALORICMS,
        CASE NOTAFISCAL.ZONAFRANCA 
            WHEN 'S' THEN 0
            ELSE SUM (mercadoriasnota.valoricms) end AS ICMSORIGEMVALOR,
        0 ICMSDESTINOVALOR,  

        sum(mercadoriasnota.VLRPISPASEP) as pis,            
        sum(mercadoriasnota.VLRCOFINS) as cofins,        
            
       
        sum(COALESCE(mercadoriasnota.VLRFINALMERCAD,0)) - sum(COALESCE(mercadoriasnota.VALORICMS,0)) AS VALORLIQUIDO,
       CAST ('0' AS NUMERIC (12,2))AS VLRFINALSERVICOS,
       CAST ('0' AS NUMERIC (12,2)) AS ISS,
       0 AS simples,
       MODELODOCTO.ID,     
     
       'ENTRADA' as emissaoentrada
    
FROM 
    NOTACOMPRA NOTAFISCAL
INNER JOIN 
    NATUREZAOPERACAO ON 
        (NOTAFISCAL.OPERACAO=NATUREZAOPERACAO.ID)
INNER JOIN 
    CADASTROPARCEIROS ESTAB ON 
        (NOTAFISCAL.FILIAL = ESTAB.CADASTRO)
INNER JOIN 
    CADASTROPARCEIROS CLIENTES 
        ON (NOTAFISCAL.DESTINATARIO=CLIENTES.CADASTRO)
INNER JOIN MODELODOCTO ON 
    (NOTAFISCAL.MODELO = MODELODOCTO.ID)
INNER join 
        mercadoriasnotaCompra mercadoriasnota  on
           ( mercadoriasnota.filial=notafiscal.filial and 
             mercadoriasnota.idnota=notafiscal.idnota)
INNER join 
        itemestoque on 
            (itemestoque.codigo=mercadoriasnota.codigo)
            

WHERE 
    DATAEMISSAO BETWEEN '01.01.2024' and '31.01.2024'
    AND NOT NOTAFISCAL.DATAEMISSAO IS NULL
--    AND NOTAFISCAL.CANCELAMENTO = 'N'
--    AND NOTAFISCAL.ENTRADASAIDA='S'
        

group by 
       NOTAFISCAL.ZONAFRANCA , 
       notafiscal.simples, 
       MODELODOCTO.MODELO,
       NOTAFISCAL.DATAEMISSAO,
       NOTAFISCAL.NUMERONOTA ,
       NOTAFISCAL.entradaSaida,
       mercadoriasnota.CFOP,
       mercadoriasnota.idpedido,
       CLIENTES.CADASTRO,
       CLIENTES.NOME,
       NOTAFISCAL.CANCELAMENTO,
       NOTAFISCAL.DEVOLUCAO,
       NATUREZAOPERACAO.FATURA,
       NATUREZAOPERACAO.DEVOLUCAOFATURAMENTO,
       NOTAFISCAL.VLRTOTALNOTA,
       NOTAFISCAL.VALORIPI,
       NOTAFISCAL.FILIAL,
       notafiscal.idnota,
       ESTAB.RAZAOSOCIAL,
       NOTAFISCAL.VLRICMSRECOLHIDO,
       NOTAFISCAL.CANCELAMENTO,
       NOTAFISCAL.ISS,
       NOTAFISCAL.psimples,
       MODELODOCTO.ID


