select 
    CADFIL.NOME AS FILIAL,
    CLICHERIA.NOME CLICHERIA,    
    SERVICOSPEDCOMPRA.IDNOTA IDPEDIDO,
    PEDIDOCOMPRA.DATACADASTRO,
    SERVICOSPEDCOMPRA.IDSERVICO AS ITEM,
    SERVICOSPEDCOMPRA.C_CODIGO PRODUTO,
    SERVICOSPEDCOMPRA.DESCRICAO,
    SERVICOSPEDCOMPRA.VLRFINALSERVICO
    
from 
    SERVICOSPEDCOMPRA
INNER join
    CADASTROPARCEIROS CADFIL ON
            CADFIL.CADASTRO=SERVICOSPEDCOMPRA.FILIAL
INNER join
    PEDIDOCOMPRA ON
        PEDIDOCOMPRA.FILIAL=SERVICOSPEDCOMPRA.FILIAL and
        PEDIDOCOMPRA.IDNOTA=SERVICOSPEDCOMPRA.IDNOTA
INNER join
    CADASTROPARCEIROS CLICHERIA
        CLICHERIA.CADASTRO=PEDIDOCOMPRA.DESTINATARIO
where  
SERVICOSPEDCOMPRA.filial in (110,3941)
and SERVICOSPEDCOMPRA.baixa='N'
and SERVICOSPEDCOMPRA.C_CODIGO  is not null