update pedido set vendedor = 
(select first 1 
vendedoresped.vendedor 
from vendedoresped 
where vendedoresped.filial=pedido.filial
and vendedoresped.idnota=pedido.idnota),
atendente = 
(select first 1 
vendedoresped.vendedor 
from vendedoresped
where vendedoresped.filial=pedido.filial
and vendedoresped.idnota=pedido.idnota)
where (select * from pedido where pedido.filial=vendedoresped.filial and pedido.DATACADASTRO>='01.01.2023')

