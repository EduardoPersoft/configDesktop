select 
    MODELODOCTO.modelo,
    count(notafiscal.idnota) as idnota,
    sum  (NOTAFISCAL.VLRTOTALNOTA) as vlrtotal
from 
    NOTAFISCAL
inner join 
    modelodocto on 
        (modelodocto.id = NOTAFISCAL.modelo)
inner join 
    NATUREZAOPERACAO on 
        (NOTAFISCAL.cfop = NATUREZAOPERACAO.CFOP)
where 
    NOTAFISCAL.filial = 5 and
    NOTAFISCAL.DATAEMISSAO between '01.07.2022' and '31.07.2022' and
    NOTAFISCAL.DATACANCELAMENTO is null and 
    coalesce (NATUREZAOPERACAO.FATURA, 'N')='S' and/*
    coalesce(naturezaoperacao.ENTRADASAIDA, 'S') = 'S*/'

group by 
    MODELODOCTO.modelo