SELECT DISTINCT
    PEDIDO.FILIAL,
    PEDIDO.IDNOTA,
    PEDIDO.uuid,
    PEDIDO.DATAREFERENCIA,
    PEDIDO.ENTREGA,
    CADCLI.NOME,
    CASE 
        COALESCE(PEDIDO.LOGRADOUROENTREGA, '') WHEN ''
        THEN CADCLI.LOGRADOURO 
        ELSE PEDIDO.LOGRADOUROENTREGA 
    END AS LOGRADOURO,
    CASE 
        COALESCE(PEDIDO.LOGRADOUROENTREGA, '') WHEN ''
        THEN CADCLI.NUMERO
        ELSE PEDIDO.NUMEROENTREGA 
    END AS NUMERO,
    CASE 
        COALESCE(PEDIDO.LOGRADOUROENTREGA, '') WHEN ''
        THEN CADCLI.COMPLEMENTO
        ELSE PEDIDO.COMPLEMENTOENTREGA 
    END AS COMPLEMENTO,
    CASE 
        COALESCE(PEDIDO.LOGRADOUROENTREGA, '') WHEN ''
        THEN CADCLI.BAIRRO
        ELSE PEDIDO.BAIRROENTREGA 
    END AS BAIRRO,
    CASE 
        COALESCE(PEDIDO.LOGRADOUROENTREGA, '') WHEN ''
        THEN CADCLI.CIDADE
        ELSE PEDIDO.CIDADEENTREGA 
    END AS CIDADE,
    CASE 
        COALESCE(PEDIDO.LOGRADOUROENTREGA, '') WHEN ''
        THEN CADCLI.UF
        ELSE PEDIDO.UFENTREGA 
    END AS UF,
    CASE 
        COALESCE(PEDIDO.LOGRADOUROENTREGA, '') WHEN ''
        THEN CADCLI.CEP
        ELSE PEDIDO.CEPENTREGA 
    END AS CEP,
    CASE
        COALESCE(PEDIDO.CONTATOENTREGA, '') WHEN ''
        THEN CADCLI.PRINCIPALCONTATO
        ELSE PEDIDO.CONTATOENTREGA
    END AS CONTATOENTREGA,
    CASE
        COALESCE(PEDIDO.CONTATOENTREGA, '') WHEN ''
        THEN CADCLI.TELEFONE
        ELSE PEDIDO.TELEFONEENTREGA
    END AS TELEFONEENTREGA,
    CASE
        COALESCE(PEDIDO.CONTATOENTREGA, '') WHEN ''
        THEN CADCLI.EMAIL
        ELSE PEDIDO.EMAIL
    END AS EMAIL,
    CADTRANS.NOME,
    CADTRANS.TELEFONE,
    CADTRANS.EMAIL,   
    cast(substring(PEDIDO.OBSERVACAO from 1 for 1000) as varchar(1000)),
    cast(substring(PEDIDO.COMENTARIO from 1 for 1000) as varchar(1000)),    
    PEDIDO.CODSERVICOENTREGA,
    PEDIDO.DESCRICAOSERVICOENTREGA,
    PEDIDO.VLRTOTALNOTA,
    CASE WHEN EXISTS (
        SELECT 
            * 
        FROM 
            MERCADORIASPED
        WHERE
            PEDIDO.FILIAL = MERCADORIASPED.FILIAL
            AND PEDIDO.IDNOTA = MERCADORIASPED.IDNOTA
            AND MERCADORIASPED.BAIXA='N'
            AND NOT EXISTS (
                SELECT * FROM MATERIALMOVIMENTOESTOQUE
                inner join
                    MOVIMENTOESTOQUE ON
                        MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL
                        AND MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
                WHERE MATERIALMOVIMENTOESTOQUE.FILIAL=MERCADORIASPED.FILIAL
                AND MATERIALMOVIMENTOESTOQUE.IDPEDIDO=MERCADORIASPED.IDNOTA
                AND MATERIALMOVIMENTOESTOQUE.IDMERCADORIA=MERCADORIASPED.IDMERCADORIA
                AND MOVIMENTOESTOQUE.TIPOMOVIMENTO='13'
            )
        ) THEN 'S' ELSE 'N' END,
    PEDIDO.VLRFINALMERCADORIAS,
    PEDIDO.VLRFINALSERVICOS,
    CASE WHEN EXISTS (
        SELECT 
            * 
        FROM 
            SERVICOSPED
        WHERE
            PEDIDO.FILIAL = SERVICOSPED.FILIAL
            AND PEDIDO.IDNOTA = SERVICOSPED.IDNOTA
            AND SERVICOSPED.BAIXA='N'
            AND NOT EXISTS (
                SELECT 
                    * 
                FROM 
                    MOVIMENTOESTOQUE 
                WHERE 
                    MOVIMENTOESTOQUE.FILIAL=SERVICOSPED.FILIAL
                AND MOVIMENTOESTOQUE.IDPEDIDO=SERVICOSPED.IDNOTA
                AND MOVIMENTOESTOQUE.TIPOMOVIMENTO='13'
                AND COALESCE(MOVIMENTOESTOQUE.MERCADORIASERVICO,'N') = 'S'
            )
        ) THEN 'S' ELSE 'N' END,
        (SELECT 
            count(mercadoriasped.idnota) 
        FROM 
            MERCADORIASPED
        WHERE
            PEDIDO.FILIAL = MERCADORIASPED.FILIAL
            AND PEDIDO.IDNOTA = MERCADORIASPED.IDNOTA
            AND MERCADORIASPED.BAIXA='N'
            AND NOT EXISTS (
                SELECT * FROM MATERIALMOVIMENTOESTOQUE
                inner join
                    MOVIMENTOESTOQUE ON
                        MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL
                        AND MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
                WHERE MATERIALMOVIMENTOESTOQUE.FILIAL=MERCADORIASPED.FILIAL
                AND MATERIALMOVIMENTOESTOQUE.IDPEDIDO=MERCADORIASPED.IDNOTA
                AND MATERIALMOVIMENTOESTOQUE.IDMERCADORIA=MERCADORIASPED.IDMERCADORIA
                AND MOVIMENTOESTOQUE.TIPOMOVIMENTO='13'
            )
        ) ,
        cast('N' as char(1)) as p_check
FROM 
    MERCADORIASPED
INNER JOIN
    PEDIDO ON
        PEDIDO.FILIAL = MERCADORIASPED.FILIAL
        AND PEDIDO.IDNOTA = MERCADORIASPED.IDNOTA
INNER JOIN 
    CADASTROPARCEIROS CADCLI ON
        CADCLI.CADASTRO = PEDIDO.DESTINATARIO
LEFT JOIN 
    CADASTROPARCEIROS CADTRANS ON   
        CADTRANS.CADASTRO = PEDIDO.CODIGOTRANSP

WHERE
    PEDIDO.FILIAL = 5
    AND MERCADORIASPED.BAIXA = 'N'
    AND PEDIDO.CANCELAMENTO = 'N'
    AND NOT EXISTS (
        SELECT 
            *
        FROM
            MATERIALMOVIMENTOESTOQUE
        inneR join
            movimentoestoque on
                movimentoestoque.filial=materialmovimentoestoque.filial and
                movimentoestoque.idmovimento=materialmovimentoestoque.idmovimento
        WHERE
            MATERIALMOVIMENTOESTOQUE.FILIAL=MERCADORIASPED.FILIAL AND
            MATERIALMOVIMENTOESTOQUE.IDPEDIDO=MERCADORIASPED.idnota AND
            MATERIALMOVIMENTOESTOQUE.IDMERCPED=MERCADORIASPED.IDMERCadoria and
            movimentoestoque.tipomoviento='13'
    ) 

