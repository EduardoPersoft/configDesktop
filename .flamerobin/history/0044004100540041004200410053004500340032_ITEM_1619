select 
    MERCADORIASPED.FILIAL,
    MERCADORIASPED.IDNOTA,
    MERCADORIASPED.IDMERCADORIA,
    NOTAFISCAL.DATAEMISSAO,
    NOTAFISCAL.NUMERONOTA,
    CADCLI.CADASTRO,
    CADCLI.NOME,
    coalesce(CADVEN.CADASTRO,-1),
    coalesce(cadven.nome, 'SEM VENDEDOR'),
    ITEMESTOQUE.CODIGO, 
    ITEMESTOQUE.DESCRICAO,
    COALESCE(mercadoriasnota.VLRTOTALMERCAD,0)+
           COALESCE(mercadoriasnota.VALORIPI,0)+
           COALESCE(MERCADORIASNOTA.VLRICMSRECOLHIDO,0)+
           COALESCE(mercadoriasnota.ICMSSTFCPVALOR,0)+
           mercadoriasnota.frete+
           mercadoriasnota.seguro+
           mercadoriasnota.OUTDESPACESSOR-
           (coalesce(mercadoriasnota.DESCONTONOTA,0)+
            coalesce(mercadoriasnota.VLRDESCPRODUTO,0)+
            case notafiscal.ZONAFRANCA when 'S' then mercadoriasnota.valoricms else 0 end)
    
from 
    NOTAFISCAL
inner join 
    MERCADORIASNOTA on 
    NOTAFISCAL.FILIAL=MERCADORIASNOTA.FILIAL and 
    NOTAFISCAL.IDNOTA=MERCADORIASNOTA.IDNOTA
inner join 
    MERCADORIASPED ON 
    MERCADORIASPED.FILIAL=MERCADORIASNOTA.FILIAL AND 
    MERCADORIASPED.IDNOTA=MERCADORIASNOTA.IDPEDIDO AND 
    MERCADORIASPED.IDMERCADORIA=MERCADORIASNOTA.IDMERCPEDIDO
inner join 
    CADASTROPARCEIROS AS CADCLI on 
    NOTAFISCAL.DESTINATARIO=CADCLI.CADASTRO
inner join 
    ITEMESTOQUE on 
    MERCADORIASPED.CODIGO=ITEMESTOQUE.CODIGO
left join 
    VENDEDORESPED on 
    MERCADORIASPED.FILIAL=VENDEDORESPED.FILIAL and 
    MERCADORIASPED.IDNOTA=VENDEDORESPED.IDNOTA
left join 
    CADASTROPARCEIROS CADVEN ON 
    VENDEDORESPED.VENDEDOR=CADVEN.CADASTRO
where 
    NOTAFISCAL.FILIAL =110  
    AND NOTAFISCAL.DATAEMISSAO  BETWEEN     '01.01.2024'     AND '31.01.2024'
    AND NOT NOTAFISCAL.DATAEMISSAO IS NULL
    AND NOTAFISCAL.CANCELAMENTO = 'N'
    AND NOTAFISCAL.ENTRADASAIDA='S'
