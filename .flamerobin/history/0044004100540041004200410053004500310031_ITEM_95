select 
    cast(titulopag.PROVAVEL as date) programacao,
    lantoContPag.centroCusto,
    CENTROCUSTOS.descricao,
    sum(lantocontpag.VALOR / titulopag.VALORTITULO * titulopag.valoremaberto) ValorEmAberto,
    cadastroparceiros.RAZAOSOCIAL,
    TITULOPAG.IDTITULO,
    titulopag.titulo,
    titulopag.FATURA,
    cast ('Receber' as varchar(10)),
    titulopag.FILIAL
from 
    TITULOREC titulopag
inner join 
    LANTOCONTREC LANTOCONTPAG on 
    titulopag.FILIAL = LANTOCONTPAG.FILIAL and
    titulopag.IDTITULO= LANTOCONTPAG.idmovtobanc
inner join 
    ESTABELECIMENTO on 
    titulopag.FILIAL = ESTABELECIMENTO.CADASTRO
inner join 
    CADASTROPARCEIROS on 
    TITULOPAG.PARCEIRO= CADASTROPARCEIROS.CADASTRO
inner join
    RCONTACORRENTE on 
    rcontacorrente.relatorio='FLUXOCAIXA' and
    rcontacorrente.contacorrente=titulopag.contacorrente
inner join
    centrocustos on
        CENTROCUSTOS.IDPLANO=ESTABELECIMENTO.PLANOCONTAS and
        centrocustos.CENTROCUSTO=lantocontpag.centrocusto
where 
    titulopag.baixa is null and 
    titulopag.filial = 2098 and
    titulopag.provavel between '01.11.2024' and '31.12.2024' and
    titulopag.baixa is null
group by
    titulopag.provavel,
    LANTOCONTPAG.centrocusto,
    centrocustos.descricao,    
    cadastroparceiros.RAZAOSOCIAL,
    TITULOPAG.IDTITULO,
    titulopag.titulo,
    titulopag.FATURA,
    titulopag.FILIAL
UNION
select 
    cast(titulopag.programacao as date),
    LANTOCONTPAG.centrocusto,
    centrocustos.descricao,    
    sum(lantocontpag.VALOR / titulopag.VALORTITULO * titulopag.valoremaberto) * (-1) ValorEmAberto,
    cadastroparceiros.RAZAOSOCIAL,
    TITULOPAG.IDTITULO,
    titulopag.titulo,
    titulopag.FATURA,
    cast ('Pagar' as varchar(10)),
    titulopag.FILIAL
from 
    titulopag
inner join 
    LANTOCONTPAG on 
    titulopag.FILIAL = LANTOCONTPAG.FILIAL and
    titulopag.IDTITULO= LANTOCONTPAG.idmovtobanc
