select 
    CADASTROPARCEIROS.CADASTRO, 
    CADASTROPARCEIROS.RAZAOSOCIAL, 
    CADASTROPARCEIROS.NOME, 
    CADASTROPARCEIROS.DOCUMENTO, 
    NOTAFISCAL.IDNOTA,
    NOTAFISCAL.NUMERONOTA, 
    NOTAFISCAL.VLRTOTALNOTA, 
    NOTAFISCAL.DATACADASTRO,
    NOTAFISCAL.DATAEMISSAO,
    NOTAFISCAL.CFOP,
    NOTAFISCAL.NATUREZAOPERACAO,
    NOTAFISCAL.UUID, 
    NOTAFISCAL.FILIAL,
    NOTAFISCAL.IDNOTA,
    NOTAFISCAL.TIPOCOBRANCA,
    NOTAFISCAL.CONTACORRENTECOBRAN,
    CONTACORRENTE.CODIGO,
    CONTACORRENTE.DESCRICAOCONTA,
    (SELECT FIRST 1
        TITULOREC.NUMBOLBANCO
     from
        FATURAS
     INNER join
        TITULOREC ON
            TITULOREC.FILIAL=FATURAS.FILIAL and
            TITULOREC.IDTITULO=FATURAS.IDTITULO
    WHERE 
        FATURAS.FILIAL=NOTAFISCAL.FILIAL and
        FATURAS.IDNOTA=NOTAFISCAL.IDNOTA) AS NUMERODOCUMENTO,
        
    CAST('N' AS CHAR (1)) P_CHECK
FROM 
    NOTAFISCAL
INNER JOIN 
    CADASTROPARCEIROS ON 
    NOTAFISCAL.DESTINATARIO=CADASTROPARCEIROS.CADASTRO
INNER JOIN 
    TIPOCOBRANCA ON 
    TIPOCOBRANCA.TIPOCOBRANCA=NOTAFISCAL.TIPOCOBRANCA
INNER JOIN 
    CONTACORRENTE ON 
    CONTACORRENTE.FILIAL=NOTAFISCAL.FILIAL AND 
    CONTACORRENTE.CODIGO=NOTAFISCAL.CONTACORRENTECOBRAN
WHERE 
    NOTAFISCAL.FILIAL=? AND 
    NOTAFISCAL.DATACADASTRO between ? AND ?