select 
    c_coletas.idcoleta,
    c_coletas.DATACOLETA,
    c_coletas.QTDEXPEDICOES,
    C_COLETAS.VALOR,
    c_Coletas.VALORMEDIO,
    MOVIMENTOestoque.idmovimento
from 
    C_COLETAS
inner join 
    movimentoestoque on
        c_coletas.COLETA=movimentoestoque.COLETA

where
    c_coletas.DATACOLETA between '30.05.2025' and '27.06.2025' 
