select
    coalesce  (DRE.CONTADRE,'') as CONTADRE
    coalesce  (DRE.DESCRICAO,'') AS DREDESCRICAO,
    C_PLANCTOCONTABEISPAGOS.CONTACONTABIL, 
    (select 
        CONTASCONTABEIS.DESCRICAO
     FROM
        estabelecimento, CONTASCONTABEIS
     where  
        estabelecimento.CADASTRO=C_PLANCTOCONTABEISPAGOS.FILIAL
        and contascontabeis.IDPLANO=estabelecimento.PLANOCONTAS
        and CONTASCONTABEIS.CONTACONTABIL=C_PLANCTOCONTABEISPAGOS.CONTACONTABIL) as descricaoconta,        
    C_PLANCTOCONTABEISPAGOS.CENTROCUSTO,
    (select 
        CENTROCUSTOS.DESCRICAO
     FROM
        estabelecimento, CENTROCUSTOS
     where  
        estabelecimento.CADASTRO=C_PLANCTOCONTABEISPAGOS.FILIAL
        and CENTROCUSTOS.IDPLANO=estabelecimento.PLANOCENTROCUSTOS
        and CENTROCUSTOS.CENTROCUSTO=C_PLANCTOCONTABEISPAGOS.CENTROCUSTO) as descricaocusto,
    sum (C_PLANCTOCONTABEISPAGOS.SALDO) as valor,
    C_PLANCTOCONTABEISPAGOS.FILIAL,
    C_PLANCTOCONTABEISPAGOS.DATAINICIAL,
    C_PLANCTOCONTABEISPAGOS.DATAFINAL,
    cast('N' as char(1)) as P_Marca
from
    C_PLANCTOCONTABEISPAGOS ('LANCTOPAG')
left join 
    DREXCONTACONTABIL on
        C_PLANCTOCONTABEISPAGOS.CONTACONTABIL like DREXCONTACONTABIL.CONTACONTABIL AND
        DREXCONTACONTABIL.CENTROCUSTO=C_PLANCTOCONTABEISPAGOS.CENTROCUSTO

left JOIN 
    DRE ON
        DRE.CONTADRE=DREXCONTACONTABIL.DRE
group by
    DRE.CONTADRE,
    DRE.DESCRICAO,
    C_PLANCTOCONTABEISPAGOS.CONTACONTABIL, 
    C_PLANCTOCONTABEISPAGOS.CENTROCUSTO, 
    C_PLANCTOCONTABEISPAGOS.filial, 
    C_PLANCTOCONTABEISPAGOS.DATAINICIAL,  
    C_PLANCTOCONTABEISPAGOS.datafinal