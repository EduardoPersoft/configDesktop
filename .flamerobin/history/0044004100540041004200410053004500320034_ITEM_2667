SELECT
    notafiscal.NUMERONOTA,
    notafiscal.DATAEMISSAO,
    cadcli.documento documento,
    cadcli.nome nomeClientes,
    cadcli.RAZAOSOCIAL razaosocial,
    cadcli.cidade,
    cadcli.uf,
    cadven.nome nomeVendedor,
    cadate.nome nomeAtendente,
    (notafiscal.custo+
     notafiscal.valorpis+
     notafiscal.valorcofins+
     notafiscal.TOTVALORICMS+
     sum(mercadoriasnota.VLRFINALMERCAD*mercadoriasnota.COMISSAO/100)) as custo,       
    (notafiscal.custo+
     notafiscal.valorpis+
     notafiscal.valorcofins+
     notafiscal.TOTVALORICMS+
     sum(mercadoriasnota.VLRFINALMERCAD*mercadoriasnota.COMISSAO/100))/sum(mercadoriasnota.VLRFINALMERCAD)*100 as margem,      
     notafiscal.valorpis,notafiscal.valorcofins,notafical.totvaloricms,
    notafiscal.MARGEMCONTRIBUICAO, 
    sum(mercadoriasnota.vlrFinalMercad) valorVenda,
    sum(mercadoriasnota.vlrfinalmercad*mercadoriasnota.comissao/100) comissao,
    cast(sum(mercadoriasnota.vlrfinalmercad*mercadoriasnota.comissao/100)/ 
         sum(mercadoriasnota.vlrFinalMercad)*100 as decimal(7,4)) pcomissao
    
from
    NOTAFISCAL
inner JOIN
    mercadoriasnota on
        mercadoriasnota.filial=notafiscal.filial AND
        mercadoriasnota.idnota=notafiscal.idnota
inner JOIN
    cadastroparceiros cadcli on
        cadcli.cadastro=notafiscal.DESTINATARIO
inner JOIN
    vendedoresnota on
        vendedoresnota.filial=notafiscal.filial AND
        vendedoresnota.idnota=notafiscal.IDNOTA
left JOIN
    cadastroparceiros cadven on 
        cadven.cadastro=vendedoresnota.vendedor
left JOIN
    cadastroparceiros cadate on
        cadate.cadastro=notafiscal.ATENDENTE
where
    notafiscal.filial= 5 and
    notafiscal.dataemissao between '01.06.2022' and '30.06.2022' and
    notafiscal.dataCancelamento is null and
    notafiscal.calculada = 'S' and 
    notafiscal.vlrtotalNota >0
group by                       
    notafiscal.NUMERONOTA,
    notafiscal.DATAEMISSAO,
    cadcli.documento,
    cadcli.nome,
    cadcli.razaosocial,
    cadcli.cidade,
    cadcli.uf,
    cadven.nome,
    cadate.nome,
    notafiscal.VLRFINALMERCADORIAS,
    notafiscal.MARGEMCONTRIBUICAO,
    notafiscal.custo,
    notafiscal.valorpis,
    notafiscal.valorcofins,
    notafiscal.TOTVALORICMS

