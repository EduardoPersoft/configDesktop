UPDATE

    MATERIALFILIAL
SET
    MATERIALFILIAL.CONSUMOMEDIO = 
        (SELECT SUM(COALESCE(CONSUMOITENSESTOQUE.QUANTIDADE,0))
         FROM CONSUMOITENSESTOQUE
         WHERE CONSUMOITENSESTOQUE.CODIGO=MATERIALFILIAL.IDITEM AND
         CONSUMOITENSESTOQUE.FILIAL=MATERIALFILIAL.FILIAL  AND
         CONSUMOITENSESTOQUE.ANO*12+CONSUMOITENSESTOQUE.MES>=24245)/12,
    MATERIALFILIAL.CONSUMOMEDIOESTIMADO = 
        (SELECT SUM(COALESCE(CONSUMOITENSESTOQUE.QUANTIDADEESTIMADO,0))
         FROM CONSUMOITENSESTOQUE
         WHERE CONSUMOITENSESTOQUE.CODIGO=MATERIALFILIAL.IDITEM AND
         CONSUMOITENSESTOQUE.FILIAL=MATERIALFILIAL.FILIAL  AND
         CONSUMOITENSESTOQUE.ANO*12+CONSUMOITENSESTOQUE.MES>=24245)/12       