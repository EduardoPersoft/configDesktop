UPDATE 
    LANTOCONTPAG
set
    LANTOCONTPAG.CONTACONTABIL='1120302'
where
    LANTOCONTPAG.FILIAL=110 and
    EXISTS (SELECT * FROM TITULOPAG
     WHERE TITULOPAG.FILIAL=LANTOCONTPAG.FILIAL 
     and TITULOPAG.IDTITULO=LANTOCONTPAG.IDMOVTOBANC 
     AND TITULOPAG.PARCEIRO IN (4232,4120,4655,4661,
                                184,4338,4351,4314,4645,4506,4390,4332,3962,4663

     ))