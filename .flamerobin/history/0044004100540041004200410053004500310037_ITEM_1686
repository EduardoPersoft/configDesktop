*/
update 
    mercadoriasnotacompra 
set
    mercadoriasnotacompra.CSTPIS=case mercadoriasnotacompra.CSTPIS when 70 then 98 else mercadoriasnotacompra.CSTPIS end,
    mercadoriasnotacompra.cstcofins=case mercadoriasnotacompra.cstcofins when 70 then 98 else mercadoriasnotacompra.cstcofins end 
where 
    MERCADORIASNOTACOMPRA.filial=1 and 
    mercadoriasnotacompra.idnota>=5219;

update 
    mercadoriasnotacompra 
set
    mercadoriasnotacompra.ppis=0,
    mercadoriasnotacompra.basepis=0,    
    mercadoriasnotacompra.VLRPISPASEP=0,
    mercadoriasnotacompra.pcofins=0,
    mercadoriasnotacompra.basecofins=0,    
    mercadoriasnotacompra.vlrcofins=0
where 
    MERCADORIASNOTACOMPRA.filial=1 and 
    mercadoriasnotacompra.idnota>=5219 and
    mercadoriasnotacompra.cstpis<>50;
    
update 
    notacompra
set
    notacompra.valorcofins = (select sum(mercadoriasnotacompra.VLRCOFINS) from mercadoriasnotacompra
                              where mercadoriasnotacompra.filial=notacompra.filial and
                              mercadoriasnotacompra.idnota=notacompra.idnota),
    notacompra.valorpis = (select sum(mercadoriasnotacompra.VLRPISPASEP) from mercadoriasnotacompra
                              where mercadoriasnotacompra.filial=notacompra.filial and
                              mercadoriasnotacompra.idnota=notacompra.idnota) 
where
    notacompra.filial=1 and 
    notacompra.idnota>=5219 ;

update 
    mercadoriasnota
set
    mercadoriasnota.CSTCOFINS=50,
    mercadoriasnota.CSTpis=50
where 
    MERCADORIASNOTA.filial=1 and 
    mercadoriasnota.cstpis=2 and
    mercadoriasnota.cfop in ('1915', '2915', '2202', '1202', '1411', '2411') and
    mercadoriasnota.idnota>=302332;

