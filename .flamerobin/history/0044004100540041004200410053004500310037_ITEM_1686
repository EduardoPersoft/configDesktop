update
    MERCADORIASNOTA
set 
    mercadoriasnota.ppis=0
where    
    mercadoriasnota.filial=1 and
    mercadoriasnota.idnota>=306406 and
    mercadoriasnota.cstpi in (4,98);

update 
    notafiscal
set
    notafiscal.BASECOFINSMERC=(
        select 
            sum(mercadoriasnota.basecofins)
        from
            MERCADORIASNOTA
        where
            mercadoriasnota.filial=notafiscal.filial and
            mercadoriasnota.idnota=notafiscal.idnota),
    notafiscal.VALORCOFINS=(
        select 
            sum(mercadoriasnota.vlrcofins)
        from
            MERCADORIASNOTA
        where
            mercadoriasnota.filial=notafiscal.filial and
            mercadoriasnota.idnota=notafiscal.idnota),
    notafiscal.VLRCOFINSMERC=(
        select 
            sum(mercadoriasnota.vlrcofins)
        from
            MERCADORIASNOTA
        where
            mercadoriasnota.filial=notafiscal.filial and
            mercadoriasnota.idnota=notafiscal.idnota),

    notafiscal.BASEPISPASEPMERC=(
        select 
            sum(mercadoriasnota.BASEPIS)
        from
            MERCADORIASNOTA
        where
            mercadoriasnota.filial=notafiscal.filial and
            mercadoriasnota.idnota=notafiscal.idnota),
    notafiscal.valorpis=(
        select 
            sum(mercadoriasnota.VLRPISPASEP)
        from
            MERCADORIASNOTA
        where
            mercadoriasnota.filial=notafiscal.filial and
            mercadoriasnota.idnota=notafiscal.idnota),
    notafiscal.VLRPISPASEPMERC=(
        select 
            sum(mercadoriasnota.VLRPISPASEP)
        from
            MERCADORIASNOTA
        where
            mercadoriasnota.filial=notafiscal.filial and
            mercadoriasnota.idnota=notafiscal.idnota)
            
where
    notafiscal.filial=1 and
    notafiscal.idnota>=306406 ;
    
update 
    mercadoriasnota
set
    mercadoriasnota.ppis=0
where
    mercadoriasnota.filial=1 and
    mercadoriasnota.idnota>=306406 and
    mercadoriasnota.cstpis=4 ;
    
update
    MERCADORIASNOTA
set
    mercadoriasnota.cstipi=49
where
    mercadoriasnota.cstipi=0 and
    mercadoriasnota.valoripi=0;
    
update
    MERCADORIASNOTAcompra
set
    MERCADORIASNOTAcompra.cstipi=49
where
    MERCADORIASNOTAcompra.cstipi=0 and
    MERCADORIASNOTAcompra.valoripi=0    ;
    
