select
    notafiscal.*
from 
    NOTAFISCAL
where
    notafiscal.DATAEMISSAO between '01.08.2023' and '31.08.2023'
    and notafiscal.CANCELAMENTO is not null 
    and notafiscal.ENTRADASAIDA = 'S'
    and notafiscal.destinatario not exists (select
                                            *
                                        from
                                            ESTABELECIMENTO
                                        where
                                            estabelecimento.cadastro=notafiscal.filial)
    and exists (select 
                    *
                from
                    faturas
                where
                    faturas.filial=notafiscal.filial and
                    faturas.idnota=notafiscal.idnota)
                    