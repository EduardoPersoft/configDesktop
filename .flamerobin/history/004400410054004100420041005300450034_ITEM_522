
SELECT
    *
from 
    COMPOSICAOOP
INNER JOIN
    MATERIALMOVIMENTOESTOQUE ON
        MATERIALMOVIMENTOESTOQUE.FILIAL=COMPOSICAOOP.FILIAL AND
        MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO=COMPOSICAOOP.IDMOVIMENTO AND
        MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL=
            COMPOSICAOOP.IDMOVIMENTOMATERIAL
WHERE
    COMPOSICAOOP.FILIAL=1 AND
    COMPOSICAOOP.CODIGO='M-LYNCH.65495' AND
    COMPOSICAOOP.LOTE='136 .003' AND
    MATERIALMOVIMENTOESTOQUE.CONCLUIDO = 'N'
    