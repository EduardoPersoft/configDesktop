select
    COMPOSICAOOP.CODIGO,
    APONTAMENTOCOMP.LOTE,
    SUM(APONTAMENTOCOMP.QUANTIDADE)
from
    materialmovimentoestoque
inner join 
     movimentoestoque on
        movimentoestoque.filial=MATERIALMOVIMENTOESTOQUE.filial and
        movimentoestoque.idmovimento=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
INNER join
    COMPOSICAOOP ON
        COMPOSICAOOP.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL and
        COMPOSICAOOP.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO and
        COMPOSICAOOP.IDMOVIMENTOMATERIAL=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL
INNER join
    APONTAMENTOCOMP ON
        APONTAMENTOCOMP.FILIAL=COMPOSICAOOP.FILIAL and
        APONTAMENTOCOMP.IDMOVIMENTO=COMPOSICAOOP.IDMOVIMENTO and
        APONTAMENTOCOMP.IDMATERIAL=COMPOSICAOOP.IDMOVIMENTOMATERIAL and
        APONTAMENTOCOMP.IDCOMPOSICAO=COMPOSICAOOP.IDCOMPOSICAO    
where
    MATERIALMOVIMENTOESTOQUE.filial=110 and
    MATERIALMOVIMENTOESTOQUE.concluido='N' and
    MOVIMENTOESTOQUE.TIPOMOVIMENTO='12'
GROUP BY    
    COMPOSICAOOP.CODIGO,
    APONTAMENTOCOMP.LOTE
