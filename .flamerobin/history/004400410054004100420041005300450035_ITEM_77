SET TERM ^ ;

ALTER PROCEDURE C_MERCPED2EXPEDICAO( 
                EXPEDICAO INTEGER, FILIAL INTEGER, IDNOTA INTEGER ) 
AS 
DECLARE VARIABLE IDMERCADORIA INTEGER;
DECLARE VARIABLE IDMOVIMENTOMATERIAL INTEGER;
DECLARE VARIABLE CODIGO VARCHAR(15);
DECLARE VARIABLE QUANTIDADE DECIMAL(12,2);
DECLARE VARIABLE IDLOCAL INTEGER;
DECLARE VARIABLE QUANTIDADELOCAL DECIMAL(12,2);
DECLARE VARIABLE QUANTIDADEEXPEDICAO DECIMAL(12,2);
DECLARE VARIABLE QUANTIDADETOTAL DECIMAL(12,2); 
BEGIN
    
    FOR SELECT
        MERCADORIASPED.IDMERCADORIA,
        MERCADORIASPED.CODIGO,
        MERCADORIASPED.QUANTIDADE - MERCADORIASPED.QTDEENVIADA
    FROM 
        MERCADORIASPED
    WHERE
        MERCADORIASPED.FILIAL = :filial
        AND MERCADORIASPED.IDNOTA = :idnota
        AND MERCADORIASPED.BAIXA = 'N'
    INTO
        :IDMERCADORIA,
        :CODIGO,
        :QUANTIDADE DO BEGIN
        
        IDMOVIMENTOMATERIAL = 1;
        QUANTIDADETOTAL = 0;
        
        FOR SELECT
            MATERIALLOCAL.IDLOCAL,
            MATERIALLOCAL.SALDOTOTAL-
            COALESCE(
            (SELECT MATERIALMOVIMENTOESTOQUE.QUANTIDADE
             FROM MATERIALMOVIMENTOESTOQUE
             INNER JOIN MOVIMENTOESTOQUE ON 
                MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL AND
                MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
             WHERE MATERIALMOVIMENTOESTOQUE.FILIAL=MATERIALLOCAL.FILIAL
             AND MATERIALMOVIMENTOESTOQUE.IDITEM=:CODIGO
             AND MATERIALMOVIMENTOESTOQUE.BAIXA='N'
             AND MOVIMENTOESTOQUE.TIPOMOVIMENTO='13'),0)
        FROM
            MATERIALLOCAL
        WHERE 
            MATERIALLOCAL.FILIAL=:FILIAL AND
            MATERIALLOCAL.IDITEM=:CODIGO AND
            MATERIALLOCAL.SALDOTOTAL-
            COALESCE(
                (SELECT MATERIALMOVIMENTOESTOQUE.QUANTIDADE
                 FROM MATERIALMOVIMENTOESTOQUE
                 INNER JOIN MOVIMENTOESTOQUE ON 
                    MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL AND
                    MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
                 WHERE MATERIALMOVIMENTOESTOQUE.FILIAL=MATERIALLOCAL.FILIAL
                 AND MATERIALMOVIMENTOESTOQUE.IDITEM=:CODIGO
                 AND MATERIALMOVIMENTOESTOQUE.BAIXA='N'
                 AND MOVIMENTOESTOQUE.TIPOMOVIMENTO='13'),0)>0            
        ORDER BY
            SALDOTOTAL DESC
        INTO :IDLOCAL, :QUANTIDADELOCAL DO BEGIN
        
            IF(QUANTIDADETOTAL<QUANTIDADE) THEN BEGIN
                
                IF(QUANTIDADE<QUANTIDADELOCAL) THEN
                    QUANTIDADEEXPEDICAO = QUANTIDADE;
                ELSE
                    QUANTIDADEEXPEDICAO = QUANTIDADELOCAL;
                
                QUANTIDADETOTAL = QUANTIDADETOTAL + QUANTIDADEEXPEDICAO;
                
                INSERT INTO MATERIALMOVIMENTOESTOQUE (
                    FILIAL,IDMOVIMENTO, IDMOVIMENTOMATERIAL, IDITEM, QUANTIDADE,
                    VALOR, SINAL, RECALCULO, LOCALARMAZENAMENTO, IDMERCADORIA, 
                    LOTE, GRADEVERTICAL, GRADEHORIZONTAL, IDCOMPOSICAO, 
                    IDPEDIDO, CONCLUIDO)
                VALUES (:FILIAL, :EXPEDICAO, :IDMOVIMENTOMATERIAL, :CODIGO,
                     :QUANTIDADEEXPEDICAO, 0, 0, 'N', :IDLOCAL, :IDMERCADORIA,
                     '.', '', '', 1, :IDNOTA, 'N'); 
                     
                IDMOVIMENTOMATERIAL = IDMOVIMENTOMATERIAL + 1;
         
            END
        END
    END
END^

SET TERM ; ^
