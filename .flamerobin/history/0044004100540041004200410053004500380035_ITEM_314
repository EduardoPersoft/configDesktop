SELECT
       I1.CODIGO,
       I1.REFERENCIA,
       I1.DESCRICAO,
       I1.unidade,
       ARQ1.NOMESALVO,
       GRUPOMERCADORIA.DESCRICAO GRUPO,
       FAMILIA.DESCRICAO FAMILIA, 
        I1.DEFINICAO,
        coalesce(I1.metatag, '') as metatag,

       cast((select 
            sum(locallote.quantidade)
        from 
            locallote
        inner JOIN
            local on
                local.ID=locallote.local
        where
            locallote.IDITEM=case i1.estocado when 'N'
                                 then coalesce(i1.itembase, i1.codigo)
                                 else i1.codigo end and
            local.DISPONIVEL='S') as decimal(12,3)) -
        coalesce((select 
            sum(m2.quantidade - coalesce(m2.qtdeenviada,0))
         FROM
            MERCADORIASPED m2
         INNER JOIN
            PEDIDO p2 ON
                p2.FILIAL=m2.FILIAL AND
                p2.IDNOTA=m2.IDNOTA and
                p2.cancelamento='N' and
                p2.dataemissao is not null 
         WHERE
            m2.baixa='N' AND
            m2.codigo=case itemestoque.estocado when 'N'
                                 then coalesce(itemestoque.itembase, itemestoque.codigo)
                                 else itemestoque.codigo end 
                         ),0) saldo,

       (SELECT FIRST 1 LISTAPRECOPRODUTO.preco 
         FROM LISTAPRECOPRODUTO
        WHERE LISTAPRECOPRODUTO.LISTA=(select first 1 listapreco.lista from listapreco where listapreco.listapadrao='S')
        AND LISTAPRECOPRODUTO.PRODUTO=I1.CODIGO
        order by quantidade) AS PRECO
      
        
      
        
FROM itemestoque i1
LEFT JOIN CLASSIFICACAOFISCAL ON (CLASSIFICACAOFISCAL.CFISCAL=I1.CLASSIFISCAL)
LEFT JOIN ITEMESTOQUEXARQUIVO ARQ1 ON (ARQ1.CODIGO=I1.CODIGO AND ARQ1.ORDEM=0)
LEFT JOIN ITEMESTOQUEXARQUIVO ARQ2 ON (ARQ2.CODIGO=I1.CODIGO AND ARQ2.ORDEM=0)
LEFT JOIN UNIDADE ON (UNIDADE.UNIDADE=CASE COALESCE(I1.UNIDADE2, '') WHEN ''
                                      THEN I1.UNIDADE
                                      ELSE I1.UNIDADE2 END)  
LEFT JOIN 
    GRUPOMERCADORIA ON 
        GRUPOMERCADORIA.GRUPO=I1.GRUPO
LEFT JOIN 
    FAMILIA ON 
        FAMILIA.ID=I1.FAMILIA

