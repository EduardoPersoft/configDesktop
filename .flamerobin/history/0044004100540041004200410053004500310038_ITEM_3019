select 
    pedido.filial,
    pedido.idnota,
    pedido.datacadastro,
    pedido.DATAREFERENCIA,
    pedido.C_DATACOMISSAO,
    (select 
        first 1
        C_FATURASPED.LIBERACAO
     from 
        C_FATURASPED
     where
        c_faturasped.filial=pedido.filial and
        c_faturasped.idnota=pedido.idnota
     order by
        c_faturasped.liberacao)
from
    PEDIDO
where
    pedido.filial=184
order by 
    pedido.idnota desc