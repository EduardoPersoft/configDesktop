select
    cast(pedido.DATAREFERENCIA as date),
    cadloja.NOME,
    pedido.idnota,
    pedido.IDORCAMENTO,
    cadcli.nome,
    cast(pedido.vlrtotalnota*vendedoresped.COMISSAOVENDA/100 as decimal(12,2)) vlrpedido,
    cast(coalesce(orcamento.VLRTOTALNOTA,
             pedido.vlrtotalnota)*vendedoresped.COMISSAOVENDA/100 as decimal(12,2)) vlrorcamento
from
    PEDIDO
inner join 
    CADASTROPARCEIROS cadcli on
        cadcli.cadastro=pedido.destinatario
inner join
    CADASTROPARCEIROS cadloja on
        cadloja.cadastro=pedido.C_LOJA
left join
    orcamento on
        orcamento.filial=pedido.filial and
        orcamento.idnota=pedido.IDORCAMENTO
left join
    vendedoresped on
        vendedoresped.filial=pedido.filial and
        vendedoresped.idnota=pedido.idnota
left join   
    CADASTROPARCEIROS cadven on
        cadven.cadastro=vendedoresped.vendedor
left join
    vendedor on
        vendedor.CADASTRO=vendedoresped.vendedor
where
    vendedor.TIPOVENDEDOR<=4 and
    pedido.DATAcadastro>='01.01.2021'