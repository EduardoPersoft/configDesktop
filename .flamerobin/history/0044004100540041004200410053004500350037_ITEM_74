SELECT 
    HISTORIA.ID,
    HISTORIA.UUID,
    HISTORIA.DATAHORA,
    HISTORIA.MENSAGEM,    
    HISTORIA.uuidassunto,
    ASSUNTOHISTORIA.TIPO,
    TIPOASSUNTO.DESCRICAO TIPODESCRICAO,
    ASSUNTOHISTORIA.DESCRICAO DESCRICAOASSUNTO,
    HISTORIA.PARCEIRO,
    CADASTROPARCEIROS.NOME,
    HISTORIA.CONTATO,
    HISTORIA.DATAHORAALTERACAO,
    HISTORIA.USUARIOALTERACAO,
    USUARIOALTERACAO.USUARIO,
    HISTORIA.USUARIO,
    USUARIOHISTORIA.USUARIO,
    ORIGEMHISTORIA.ID,
    ORIGEMHISTORIA.DESCRICAO
FROM 
    HISTORIA
INNER JOIN 
    USUARIO USUARIOHISTORIA ON 
        HISTORIA.USUARIO = USUARIOHISTORIA.ID
LEFT JOIN 
    CADASTROPARCEIROS ON 
        HISTORIA.PARCEIRO = CADASTROPARCEIROS.CADASTRO
LEFT JOIN 
    USUARIO USUARIOALTERACAO ON 
        historia.usuarioAlteracao = usuarioalteracao.id AND 
        CADASTROPARCEIROS.NOME = USUARIOALTERACAO.NOMECOMPLETO
LEFT JOIN 
    ORIGEMHISTORIA ON 
        HISTORIA.ID=ORIGEMHISTORIA.ID
LEFT join
    ASSUNTOHISTORIA ON
        ASSUNTOHISTORIA.UUID=HISTORIA.UUIDASSUNTO
LEFT join
    TIPOASSUNTO ON


order by
    historia.datahora,
    historia.id
