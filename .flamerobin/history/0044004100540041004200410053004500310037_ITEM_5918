select 
    itemestoque.codigo,
    itemestoque.descricao,
    itemestoque.referencia,
    itemestoque.C_MRFORNECEDOR,
    itemestoque.SISCOMEXID,
    itemestoque.SISCOMEXDESCRICAO,
    itemestoque.SISCOMEXINTEGRADO 
from itemestoque 
where
    itemestoque.SISCOMEXid is not null
order by
    itemestoque.SISCOMEXID
