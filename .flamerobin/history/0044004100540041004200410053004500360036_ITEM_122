
update 
    notafiscal pedido
set 
    pedido.VBRUTOFATURA=coalesce((select sum(fatped.VALORFATURA) from FATURAS fatped 
                                 where fatped.filial=pedido.FILIAL
                                 and fatped.idnota=pedido.idnota),0),
    pedido.VliquidoFATURA=coalesce((select sum(fatped.VALORFATURA) from FATURAS fatped 
                                 where fatped.filial=pedido.FILIAL
                                 and fatped.idnota=pedido.idnota),0)
where coalesce(notafiscal.emissaodata,cast('now' as date))>'01.01.2024';