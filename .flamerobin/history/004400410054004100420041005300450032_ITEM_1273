SELECT 
    CADASTROPARCEIROS.CADASTRO,
    CADASTROPARCEIROS.RAZAOSOCIAL,
    CADASTROPARCEIROS.NOME,
    CADASTROPARCEIROS.DOCUMENTO,
    T_CADASTRO.DOCUMENTO,
    T_CADASTRO.RAZAO
FROM 
    T_CADASTRO 
INNER JOIN  
    CADASTROPARCEIROS ON
        CADASTROPARCEIROS.CADASTRO=T_CADASTRO.CADASTRO
WHERE  
    CADASTROPARCEIROS.DOCUMENTO<>T_CADASTRO.DOCUMENTO