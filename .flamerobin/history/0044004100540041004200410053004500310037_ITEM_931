select  
    * 
from 
    notafiscal
where 
    filial=12826 and 
    notafiscal.DATAEMISSAO between '01.09.2021' and '30.09.2021' AND
    notafiscal.valorpis=0 AND
    exists (
        select 
            *
        FROM
            MERCADORIASNOTA
        where 
            mercadoriasnota.filial=notafiscal.filial AND
            mercadoriasnota.idnota=notafiscal.idnota AND
            mercadoriasnota.VLRPISPASEP>0)