SET TERM ^ ;
ALTER PROCEDURE C_MOVIMENTOBANCARIOCONTABIL (
    RELATORIO VARCHAR(50) )
RETURNS (
    MODO SMALLINT,
    MOVIMENTACAO TIMESTAMP,
    VALORMOVIMENTO DOUBLE PRECISION,
    TIPOMOVIMENTO CHAR(1),
    FILIAL INTEGER,
    RAZAOSOCIAL VARCHAR(60),
    CODIGO SMALLINT,
    AGENCIA VARCHAR(6),
    DIGITOAGENCIA CHAR(1),
    NUMCCORRENTE VARCHAR(10),
    DIGITOCCORRENTE CHAR(1),
    BANCO SMALLINT,
    DESCRICAO VARCHAR(30),
    SALDOBLOQUEADO DOUBLE PRECISION,
    SALDOEXTRATO DOUBLE PRECISION,
    DEBITOSACOMP DOUBLE PRECISION,
    HISTORICOEXTRATO VARCHAR(150),
    NRDOCUMENTO VARCHAR(15),
    IDMOVTOBANCARIO INTEGER,
    DATAEXTRATO TIMESTAMP,
    DATAINICIAL TIMESTAMP,
    DATAFINAL TIMESTAMP,
    DESCRICAOCONTA VARCHAR(30),
    DEBITO DOUBLE PRECISION,
    CREDITO DOUBLE PRECISION,
    CONTACONTABIL VARCHAR(15),
    DESCRICAOCONTACONTABIL VARCHAR(50),
    CONTACONTABILI VARCHAR(15),
    CONTACONTABILF VARCHAR(15) )

AS
DECLARE VARIABLE CENTROCUSTOI VARCHAR(8);
DECLARE VARIABLE CENTROCUSTOF VARCHAR(8);

DECLARE VARIABLE TRANSFERENCIA CHAR(1);
DECLARE VARIABLE CONTACORRENTETRANSFERENCIA INTEGER;
DECLARE VARIABLE DESCRICAOCONTATRANSFERENCIA VARCHAR(30);
DECLARE VARIABLE IDTITULO INTEGER;
DECLARE VARIABLE DOCUMENTO VARCHAR(10);
DECLARE VARIABLE FATURA VARCHAR(2);
DECLARE VARIABLE NOMEMOVIMENTO VARCHAR(60);
DECLARE VARIABLE VALORLANCAMENTO DOUBLE PRECISION;
DECLARE VARIABLE VALORTITULO DOUBLE PRECISION;
DECLARE VARIABLE PHISTORICOEXTRATO VARCHAR(150);
DECLARE VARIABLE VCONTADESCONTOFINANCEIRORECEBER VARCHAR(15);
DECLARE VARIABLE VCONTADESCONTOTAXAPAGAMENTORECEBER VARCHAR(15);
DECLARE VARIABLE VCONTAOUTROSDESCONTOSRECEBER VARCHAR(15);
DECLARE VARIABLE VCONTAJUROSFINANCEIRORECEBER VARCHAR(15);
DECLARE VARIABLE VCONTAACRESCIMOTAXAPAGAMENTORECEBER VARCHAR(15);
DECLARE VARIABLE VCONTADESCONTOFINANCEIROPAGAR VARCHAR(15);
DECLARE VARIABLE VCONTADESCONTOTAXAPAGAMENTOPAGAR VARCHAR(15);
DECLARE VARIABLE VCONTAOUTROSDESCONTOSPAGAR VARCHAR(15);
DECLARE VARIABLE VCONTAJUROSFINANCEIROPAGAR VARCHAR(15);
DECLARE VARIABLE VCONTAACRESCIMOTAXAPAGAMENTOPAGAR VARCHAR(15);
DECLARE VARIABLE VDESCRICAODESCONTOFINANCEIRORECEBER VARCHAR(50);
DECLARE VARIABLE VDESCRICAODESCONTOTAXAPAGAMENTORECEBER VARCHAR(50);
DECLARE VARIABLE VDESCRICAOOUTROSDESCONTOSRECEBER VARCHAR(50);
DECLARE VARIABLE VDESCRICAOJUROSFINANCEIRORECEBER VARCHAR(50);
DECLARE VARIABLE VDESCRICAOACRESCIMOTAXAPAGAMENTORECEBER VARCHAR(50);
DECLARE VARIABLE VDESCRICAODESCONTOFINANCEIROPAGAR VARCHAR(50);
DECLARE VARIABLE VDESCRICAODESCONTOTAXAPAGAMENTOPAGAR VARCHAR(50);
DECLARE VARIABLE VDESCRICAOOUTROSDESCONTOSPAGAR VARCHAR(50);
DECLARE VARIABLE VDESCRICAOJUROSFINANCEIROPAGAR VARCHAR(50);
DECLARE VARIABLE VDESCRICAOACRESCIMOTAXAPAGAMENTOPAGAR VARCHAR(50);
DECLARE VARIABLE VVALORDESCONTOFINANCEIRORECEBER DOUBLE PRECISION;
DECLARE VARIABLE VVALORDESCONTOTAXAPAGAMENTORECEBER DOUBLE PRECISION;
DECLARE VARIABLE VVALOROUTROSDESCONTOSRECEBER DOUBLE PRECISION;
DECLARE VARIABLE VVALORJUROSFINANCEIRORECEBER DOUBLE PRECISION;
DECLARE VARIABLE VVALORACRESCIMOTAXAPAGAMENTORECEBER DOUBLE PRECISION;
DECLARE VARIABLE VVALORDESCONTOFINANCEIROPAGAR DOUBLE PRECISION;
DECLARE VARIABLE VVALORDESCONTOTAXAPAGAMENTOPAGAR DOUBLE PRECISION;
DECLARE VARIABLE VVALOROUTROSDESCONTOSPAGAR DOUBLE PRECISION;
DECLARE VARIABLE VVALORJUROSFINANCEIROPAGAR DOUBLE PRECISION;
DECLARE VARIABLE VVALORACRESCIMOTAXAPAGAMENTOPAGAR DOUBLE PRECISION;
begin

    SELECT ESTSIN.Estabelecimento,
           ESTSIN.Datainicial,
           ESTSIN.Datafinal,
           ESTSIN.Contacontabili,
           ESTSIN.Contacontabilf,
           substring(ESTSIN.CENTROCUSTOI from 1 for 8) centrocustoi,
           substring(ESTSIN.CENTROCUSTOF from 1 for 8) centrocustof
    FROM ESTSIN
    WHERE RELATORIO=:RELATORIO
    INTO FILIAL,DATAINICIAL,DATAFINAL,contacontabili,contacontabilf, CENTROCUSTOI, CENTROCUSTOF;

    FOR select  MOVIMENTACAO,
                VALORMOVIMENTO,
                TIPOMOVIMENTO,
                FILIAL,
                RAZAOSOCIAL,
                CODIGO,
                AGENCIA,
                DIGITOAGENCIA ,
                NUMCCORRENTE,
                DIGITOCCORRENTE,
                BANCO ,
                DESCRICAO,
                SALDOBLOQUEADO ,
                SALDOEXTRATO,
                DEBITOSACOMP,
                HISTORICOEXTRATO,
                NRDOCUMENTO,
                IDMOVTOBANCARIO,
                DATAEXTRATO ,
                DATAINICIAL ,
                DATAFINAL ,
                DESCRICAOCONTA ,
                case movimentobancario.Tipomovimento
                when 'D' then VALORMOVIMENTO*(-1) else 0 end DEBITO ,
                case movimentobancario.Tipomovimento
                when 'C' then VALORMOVIMENTO else 0 end CREDITO ,
                CONTACONTABIL,
                DESCRICAOCONTACONTABIL

    From movimentobancario  (:filial, :dataINICIAL, :datafinal)
    WHERE   MOVIMENTOBANCARIO.contacontabil BETWEEN :contacontabili AND :contacontabilf
    AND MOVIMENTOBANCARIO.CENTROCUSTO BETWEEN :CENTROCUSTOI AND :CENTROCUSTOF 
    into MOVIMENTACAO,
         VALORMOVIMENTO,
        TIPOMOVIMENTO,
        FILIAL,
        RAZAOSOCIAL,
        CODIGO,
        AGENCIA,
        DIGITOAGENCIA ,
        NUMCCORRENTE,
        DIGITOCCORRENTE,
        BANCO ,
        DESCRICAO,
        SALDOBLOQUEADO ,
        SALDOEXTRATO,
        DEBITOSACOMP,
        HISTORICOEXTRATO,
        NRDOCUMENTO,
        IDMOVTOBANCARIO,
        DATAEXTRATO ,
        DATAINICIAL ,
        DATAFINAL ,
        DESCRICAOCONTA ,
        DEBITO ,
        CREDITO,
        CONTACONTABIL,
        DESCRICAOCONTACONTABIL
    DO BEGIN
        suspend;
   END
end
^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE C_MOVIMENTOBANCARIOCONTABIL TO  SYSDBA;

