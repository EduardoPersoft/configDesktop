--insert into
    --ITEMESTOQUECODIGOS
select
    DISTINCT
    ITEMESTOQUECODIGOS.CODIGO,
    ITEMESTOQUECODIGOS.CODIGO
from
    ITEMESTQOUTCOD
where 
    NOT EXISTS 
    (SELECT 
        * 
     FROM 
        ITEMESTOQUECODIGOS
     WHERE   
        ITEMESTOQUECODIGOS.CODIGOALTERNATIVO=ITEMESTOQUECODIGOS.CODIGO)