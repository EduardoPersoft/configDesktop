update 
    MATERIALFILIAL
set
    materialfilial.CUSTOMEDIO=(select itemcustodata.CUSTOUNITARIO from ITEMCUSTODATA
                                where itemcustodata.FILIAL=materialfilial and
                                itemcustodata.codigo=materialfilial.iditem and
                                itemcustodata.DATAINVENTARIO='2024-11-30'),
    materialfilial.VALORTOTALESTOCADO=(select itemcustodata.CUSTOtotal from ITEMCUSTODATA
                                where itemcustodata.FILIAL=materialfilial and
                                itemcustodata.codigo=materialfilial.iditem and
                                itemcustodata.DATAINVENTARIO='2024-11-30')