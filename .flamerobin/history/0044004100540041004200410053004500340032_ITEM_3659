select
    MERCADORIASPED.FILIAL,
    MERCADORIASPED.IDNOTA IDPEDIDO,
    MERCADORIASPED.IDMERCADORIA IDMERCADORIAPED,
    PEDIDO.DATAREFERENCIA,
    PEDIDO.ENTREGA,
    --MOVIMENTOESTOQUE.PREVISAOFIMPRODUCAO,
    CADASTROPARCEIROS.NOME,

    MERCADORIASPED.CODIGO,
    ITEMESTOQUE.descricao DESCRICAOPRODUTO,
    MERCADORIASPED.C_NOVOREPETICAOALTERADO NOVOREPETICAOALTERACAO,
   -- COALESCE(MATERIALMOVIMENTOESTOQUE.quantidade, mercadoriasped.quantidade) quantidadeproduzir,

    mercadoriasped.unidade,
    mercadoriasped.C_ARTE,/*

    C_PEDIDOSEMABERTOPRODUCAO.DATAPREVISTAARTE,
    C_PEDIDOSEMABERTOPRODUCAO.CLICHEOK,

    C_PEDIDOSEMABERTOPRODUCAO.DATAPREVISTACLICHE,
    C_PEDIDOSEMABERTOPRODUCAO.OP,

    --C_PEDIDOSEMABERTOPRODUCAO.IMPRESSAOTEM,
    --C_PEDIDOSEMABERTOPRODUCAO.IMPRESSAOCONCLUIDO,
    C_PEDIDOSEMABERTOPRODUCAO.C_STATUSARTE,
    --C_PEDIDOSEMABERTOPRODUCAO.IMPRESSAOID,
    --C_PEDIDOSEMABERTOPRODUCAO.itemImpresso,
    --C_PEDIDOSEMABERTOPRODUCAO.dtmpimpressao,
    C_PEDIDOSEMABERTOPRODUCAO.ESTRUTURA,
    C_PEDIDOSEMABERTOPRODUCAO.ARQUIVO,
    C_PEDIDOSEMABERTOPRODUCAO.ITEMAPROVADO,
    --C_PEDIDOSEMABERTOPRODUCAO.OPATRASADA,
*/
    servicospedcompra.C_FILIALPEDVEN FILIALPEDCLICHE,
    servicospedcompra.C_IDPEDVEN IDPEDIDOCLICHE,
    servicospedcompra.C_IDMERCVEN IDMERCPEDCLICHE,
    servicospedcompra.VLRFINALSERVICO VALORCLICHE,
    
    servicosped.C_FILIALPEDVEN FILIALPEDCLICHEVEN,
    servicosped.C_IDPEDVEN IDPEDIDOCLICHEVEN,
    servicosped.C_IDMERCVEN IDMERCPEDCLICHEVEN,
    servicosped.VLRFINALSERVICO VALORCLICHEVEN
from 
    SERVICOSPEDCOMPRA
inner join
    mercadoriasped on
          MERCADORIASPED.filial=SERVICOSPEDCOMPRA.C_FILIALPEDVEN and
          MERCADORIASPED.idnota=SERVICOSPEDCOMPRA.C_IDPEDVEN and
          MERCADORIASPED.IDMERCADORIA=SERVICOSPEDCOMPRA.C_IDMERCVEN
inner join 
    ITEMESTOQUE on 
    MERCADORIASPED.CODIGO=ITEMESTOQUE.CODIGO

inner join
    pedido on
        pedido.filial=mercadoriasped.filial and
        pedido.idnota=mercadoriasped.idnota
inner join
    CADASTROPARCEIROS on
        CADASTROPARCEIROS.cadastro=pedido.destinatario
        
left join 
    MATERIALMOVIMENTOESTOQUE on
        MATERIALMOVIMENTOESTOQUE.filial=mercadoriasped.filial and
        MATERIALMOVIMENTOESTOQUE.IDPEDIDO=mercadoriasped.idnota and
        MATERIALMOVIMENTOESTOQUE.IDMERCADORIA=mercadoriasped.IDMERCADORIA and
        MATERIALMOVIMENTOESTOQUE.PRODUTO=MATERIALMOVIMENTOESTOQUE.iditem and
        MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL=1
        /*
left join 
    MOVIMENTOESTOQUE on 
    MOVIMENTOESTOQUE.filial=movimentoestoque.filial and
    MOVIMENTOESTOQUE.IDMOVIMENTO=movimentoestoque.IDMOVIMENTO and
    MOVIMENTOESTOQUE.TIPOMOVIMENTO='12'
 */
left join 
    servicosped on 
    servicosped.c_filialpedven = mercadoriasped.filial and   
    servicosped.c_idpedven = mercadoriasped.idnota and  
    servicosped.c_idmercven = mercadoriasped.idmercadoria   
    
where 
    SERVICOSPEDCOMPRA.FILIAL=110 and 
    SERVICOSPEDCOMPRA.BAIXA='N' 

