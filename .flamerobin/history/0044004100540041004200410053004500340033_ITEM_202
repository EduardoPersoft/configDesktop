select * from LANTOCONTPAG

where filial in (110,3941) and
and titulopag.baixa is null
and not exists (
    select 
        * 
    from 
        CONTASCONTABEIS
    where 
        contascontabeis.idplano=5 
        and contascontabeis.CONTACONTABIL=lantocontpag.CONTACONTABIL)
order by filial,idmovtobanc        