select
    SUM((COALESCE(MOVIMENTOESTOQUE.SAIDAPRODUCAO, CAST('NOW' AS TIMESTAMP)) -
    MOVIMENTOESTOQUE.ENTRADAPRODUCAO)*24*60)/COUNT(MOVIMENTOESTOQUE.IDMOVIMENTO)
from
    MOVIMENTOESTOQUE
INNER join
    PEDIDO ON
        MOVIMENTOESTOQUE.FILIAL=PEDIDO.FILIAL and
        MOVIMENTOESTOQUE.IDPEDIDO=PEDIDO.IDNOTA
where
    MOVIMENTOESTOQUE.EMISSAO = '18.07.2023' and
    MOVIMENTOESTOQUE.TIPOMOVIMENTO='13'