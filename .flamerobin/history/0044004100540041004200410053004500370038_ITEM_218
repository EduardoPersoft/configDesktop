update MATERIALMOVIMENTOESTOQUE
set MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO=1
where exists
(select * from MOVIMENTOESTOQUE
where movimentoestoque.filial=materialmovimentoestoque.filial and
movimentoestoque.idmovimento=MATERIALMOVIMENTOESTOQUE.idmovimento and
movimentoestoque.emissao>'31.10.2025')