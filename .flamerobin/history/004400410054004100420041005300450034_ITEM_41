SELECT CAST(contacorrente.filial AS INTEGER),
       estab.razaosocial,
       0 as saldoanterior,
       'R' as tipo,
       sum(contacorrente.saldoreal) as recebimentos,

       CAST(0 AS DOUBLE PRECISION) as pagamentos,
       estsin.datainicial-1 as vencimento,
       estsin.descricao,
       estsin.datainicial,
       estsin.datafinal
FROM contacorrente
INNER JOIN estsin on(estsin.estabelecimento = contacorrente.filial and
                     estsin.relatorio = 'FLUXOCAIXA')
INNER JOIN cadastroparceiros estab on (estab.cadastro = contacorrente.filial)
INNER JOIN rcontacorrente on (rcontacorrente.contacorrente = contacorrente.codigo and
                              rcontacorrente.relatorio = 'FLUXOCAIXA')
GROUP BY filial, razaosocial, descricao, datainicial, datafinal
having sum(contacorrente.saldoreal)>=0

UNION

SELECT CAST(contacorrente.filial AS INTEGER),
       estab.razaosocial,
       0 as saldoanterior,
       'R' as tipo,
       sum(contacorrente.saldoreal) as recebimentos,
       CAST(0 AS DOUBLE PRECISION) as  pagamentos,
       estsin.datainicial-1 as vencimento,
       estsin.descricao,
       estsin.datainicial ,
       estsin.datafinal
FROM contacorrente
INNER JOIN estsin on(estsin.estabelecimento = contacorrente.filial and
                     estsin.relatorio = 'FLUXOCAIXA')
INNER JOIN cadastroparceiros estab on (estab.cadastro = contacorrente.filial)
INNER JOIN rcontacorrente on (rcontacorrente.contacorrente = contacorrente.codigo and
                              rcontacorrente.relatorio = 'FLUXOCAIXA')
GROUP BY filial, razaosocial, descricao, datainicial, datafinal
having sum(contacorrente.saldoreal)<0;

