select distinct
    NOTAFISCAL.FILIAL,
    NOTAFISCAL.NUMERONOTA, 
    NOTAFISCAL.DATAEMISSAO,
    NOTAFISCAL.VLRTOTALNOTA,
    NOTAFISCAL.UUID
FROM 
    NOTAFISCAL
WHERE 
    NOTAFISCAL.DESTINATARIO = ? AND
    not exists (
        select * from movimentoestoque
        where movimentoestoque.filial=notafiscal.filial and
        movimentoestoque.idnotaexpedicao=notafiscal.idnota
    )
ORDER BY 
    NOTAFISCAL.DATAEMISSAO DESC;
