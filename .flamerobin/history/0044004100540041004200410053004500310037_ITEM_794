SELECT MOVTO.FILIAL,
       MOVTO.IDMOVIMENTO,
       MOVTO.PRIORIDADE,
       MOVTO.EMISSAO,
       MOVTO.DOCUMENTO,
       ITEMESTOQUE.unidade,
       TIPOMOVIMENTOESTOQUE.DESCRICAO,
       localorigem.descricao as descricaolocal,
       SUM(MATERIAL.QUANTIDADE*MATERIAL.SINAL) AS QUANTIDADE,
       SUM(MATERIAL.VALOR*MATERIAL.SINAL) AS VALOR,
       SUM(MATERIAL.VALOR) /
          case  coalesce(SUM(MATERIAL.QUANTIDADE),0) when 0 then 1 else SUM(MATERIAL.QUANTIDADE) end  AS UNITARIO ,
       MOVTO.processamento
FROM MOVIMENTOESTOQUE MOVTO
INNER JOIN MATERIALMOVIMENTOESTOQUE MATERIAL ON (MOVTO.FILIAL=MATERIAL.FILIAL 
                                                                              AND MOVTO.IDMOVIMENTO=MATERIAL.IDMOVIMENTO)
INNER JOIN TIPOMOVIMENTOESTOQUE ON (MOVTO.TIPOMOVIMENTO=TIPOMOVIMENTOESTOQUE.ID)
inner JOIN ITEMESTOQUE ON (ITEMESTOQUE.codigo=MATERIAL.iditem)
inner join local localorigem on (localorigem.id=MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO)
WHERE MOVTO.FILIAL=1  AND MATERIAL.IDITEM='1451505'
AND MOVTO.EMISSAO BETWEEN '01.01.2020' AND '31.12.2021'
and movto.TIPOMOVIMENTO<>'11'
GROUP BY MOVTO.FILIAL,
         MOVTO.IDMOVIMENTO,
         MOVTO.PRIORIDADE,
         MOVTO.EMISSAO,
         MOVTO.DOCUMENTO,
         TIPOMOVIMENTOESTOQUE.DESCRICAO,
         MOVTO.processamento,
         ITEMESTOQUE.unidade