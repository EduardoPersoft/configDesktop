 SELECT
    ITEMESTOQUE.CODIGO,
    ITEMESTOQUE.DESCRICAO,
    coalesce((SELECT 
        cast(LISTAPRECOPRODUTO.PRECO as numeric(12,2))
     FROM
            LISTAPRECOPRODUTO
     WHERE
        LISTAPRECOPRODUTO.LISTA = 2 AND
        LISTAPRECOPRODUTO.PRODUTO = ITEMESTOQUE.CODIGO),0),
    coalesce((SELECT 
        cast(LISTAPRECOPRODUTO.PRECO as numeric(12,2))
     FROM
            LISTAPRECOPRODUTO
     WHERE
        LISTAPRECOPRODUTO.LISTA = 3 AND
            LISTAPRECOPRODUTO.PRODUTO = ITEMESTOQUE.CODIGO), 0),        
    coalesce((SELECT 
        cast(LISTAPRECOPRODUTO.PRECO as numeric(12,2))
     FROM
            LISTAPRECOPRODUTO
     WHERE
        LISTAPRECOPRODUTO.LISTA = 4 AND
        LISTAPRECOPRODUTO.PRODUTO = ITEMESTOQUE.CODIGO), 0),      
    ITEMESTOQUE.DESCRICAO,
    ITEMESTOQUE.C_MRFORNECEDOR,
    ITEMESTOQUE.FAMILIA,
    C_LOGPRODUTOECOMMERCE.INCLUSAO,
    C_LOGPRODUTOECOMMERCE.ENVIADO,
    C_LOGPRODUTOECOMMERCE.STATUS_CODE,
    C_LOGPRODUTOECOMMERCE.CONTENT 
FROM
    C_LOGPRODUTOECOMMERCE
INNER JOIN    
    ITEMESTOQUE ON
       C_LOGPRODUTOECOMMERCE.CODIGO = ITEMESTOQUE.CODIGO
WHERE
    enviado > '21.07.2021'
