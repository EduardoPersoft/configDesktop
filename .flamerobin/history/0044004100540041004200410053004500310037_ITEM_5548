select
    extract(year from pedido.DATACADASTRO) ano,
    extract(month from pedido.DATACADASTRO) mes,
    count(distinct pedido.idnota) pedidos,
    count(mercadoriasped.idnota) as ITENS,
    SUM(MERCADORIASPED.VLRTOTALMERCAD) AS VALOR 
from
    PEDIDO
INNER join
    MERCADORIASPED ON
        PEDIDO.FILIAL=MERCADORIASPED.FILIAL and
        PEDIDO.IDNOTA=MERCADORIASPED.IDNOTA
WHERE  
    PEDIDO.DATACADASTRO BETWEEN '01.01.2024' AND '31.12.2025'
    AND PEDIDO.CANCELAMENTO = 'N'
GROUP BY 
    1,2