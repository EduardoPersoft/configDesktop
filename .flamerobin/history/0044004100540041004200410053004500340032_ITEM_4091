SELECT 
       extract(year from notafiscal.DATAEMISSAO) as ano,
       extract(MONTH from notafiscal.DATAEMISSAO) as mes,    
       ITEMESTOQUE.GRUPO,
       grupomercadoria.DESCRICAO,
        

       sum(COALESCE(mercadoriasnota.VLRTOTALMERCAD,0)+
           COALESCE(mercadoriasnota.VALORIPI,0)+
           COALESCE(MERCADORIASNOTA.VLRICMSRECOLHIDO,0)+
           COALESCE(mercadoriasnota.ICMSSTFCPVALOR,0)+
           mercadoriasnota.frete+
           mercadoriasnota.seguro+
           mercadoriasnota.OUTDESPACESSOR-
           (coalesce(mercadoriasnota.DESCONTONOTA,0)+
            coalesce(mercadoriasnota.VLRDESCPRODUTO,0)+
            case notafiscal.ZONAFRANCA when 'S' then mercadoriasnota.valoricms else 0 end))   as VLRTOTALNOTA,

      sum(CASE when ITEMESTOQUE.GRUPO IN (4,5,6) THEN COALESCE(mercadoriasnota.VLRTOTALMERCAD,0) ELSE 0 END) AS VLRSEMIPI,
       
      sum(CASE WHEN ITEMESTOQUE.GRUPO IN (4,5,6) THEN  CASE WHEN ITEMESTOQUE.CODIGO= 'APARAS' or substring(itemestoque.codigo from 1 for 3)='CIC' THEN 0 ELSE     
      case mercadoriasnota.unidade when 'MIL' then mercadoriasnota.QUANTIDADE*itemestoque.quantidadeUnidade
      else mercadoriasnota.quantidade end END ELSE 0 end ) qtdPorUnidade,
      
      sum(CASE WHEN ITEMESTOQUE.GRUPO IN (4,5,6) THEN COALESCE(mercadoriasnota.VLRTOTALMERCAD,0) ELSE 0 END) AS VLRSEMIPI,
       
      sum(CASE WHEN ITEMESTOQUE.GRUPO IN (4,5,6) THEN  CASE WHEN ITEMESTOQUE.CODIGO= 'APARAS' or substring(itemestoque.codigo from 1 for 3)='CIC' THEN 0 ELSE     
      case mercadoriasnota.unidade when 'MIL' then mercadoriasnota.QUANTIDADE*itemestoque.quantidadeUnidade
      else mercadoriasnota.quantidade end END ELSE 0 end) qtdPorUnidade

    
FROM 
    NOTAFISCAL
INNER JOIN 
    NATUREZAOPERACAO ON 
        (NOTAFISCAL.OPERACAO=NATUREZAOPERACAO.ID)
INNER JOIN 
    CADASTROPARCEIROS ESTAB ON 
        (NOTAFISCAL.FILIAL = ESTAB.CADASTRO)
INNER JOIN 
    CADASTROPARCEIROS CLIENTES 
        ON (NOTAFISCAL.DESTINATARIO=CLIENTES.CADASTRO)
INNER JOIN MODELODOCTO ON 
    (NOTAFISCAL.MODELO = MODELODOCTO.ID)
INNER join 
        mercadoriasnota  on
           (mercadoriasnota.filial=notafiscal.filial and 
             mercadoriasnota.idnota=notafiscal.idnota)
INNER join 
        itemestoque on 
            (itemestoque.codigo=mercadoriasnota.codigo)
            
left join
    pedido on
        pedido.filial=mercadoriasnota.filialped and
        pedido.idnota=mercadoriasnota.IDPEDIDO
left join
    CADASTROPARCEIROS cadven on
        cadven.cadastro = pedido.vendedor
left join
    grupomercadoria on
        grupomercadoria.grupo=itemestoque.grupo
WHERE 
    NOTAFISCAL.FILIAL = 110
    AND NOTAFISCAL.DATAEMISSAO BETWEEN '2024-01-01' and '2025-05-31'
    AND NOTAFISCAL.CANCELAMENTO = 'N'
    AND naturezaoperacao.receita='S'
    AND NOTAFISCAL.ENTRADASAIDA='S'
    AND NOTAFISCAL.DEVOLUCAO='N'
    and itemestoque.grupo in (4,5,6)
    AND NOT exists (select 
                            * 
                         from 
                            ESTABELECIMENTO
                         where estabelecimento.CADASTRO=clientes.cadastro) 


GROUP BY
 1,2,3,4
