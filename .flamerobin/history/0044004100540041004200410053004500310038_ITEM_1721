SELECT 
    PEDIDO.IDNOTA,
    PEDIDO.DATAREFERENCIA,
    CADVEN.RAZAOSOCIAL vendedor,    
    CADCLI.RAZAOSOCIAL cliente,
    pedido.vlrtotalnota,
    5 AS PCOMISSAO,
    cast(pedido.vlrtotalnota * 0.05 as decimal(12,2)) VLRCOMISSAO,
    PEDIDO.ENTREGA,
    PEDIDO.UUID
FROM 
    PEDIDO

INNER JOIN 
    CADASTROPARCEIROS CADCLI ON 
        (CADCLI.CADASTRO = PEDIDO.DESTINATARIO)        
left join  
    VENDEDORESPED ON 
        (VENDEDORESPED.FILIAL=PEDIDO.FILIAL AND 
         VENDEDORESPED.IDNOTA=PEDIDO.IDNOTA)
left JOIN 
    CADASTROPARCEIROS CADVEN ON 
        (CADVEN.CADASTRO = VENDEDORESPED.VENDEDOR)
WHERE 
    PEDIDO.FILIAL=184 AND    
     PEDIDO.DATAREFERENCIA BETWEEN '01.07.2023' and '31.07.2023' and 
    pedido.DATAEMISSAO is not null and 
    pedido.DATACANCELAMENTO is null and 
   coalesce(VENDEDORESPED.VENDEDOR,-1) = 185
union
SELECT 
    SUBSTITUIDO.IDNOTA,
    SUBSTITUIDO.DATAREFERENCIA,
    CADVEN.RAZAOSOCIAL vendedor,    
    CADCLI.RAZAOSOCIAL cliente,
    SUBSTITUIDO.vlrtotalnota*(-1),
    5 AS PCOMISSAO,
    cast(SUBSTITUIDO.vlrtotalnota *(-1) * 0.05 as decimal(12,2)) VLRCOMISSAO,
    SUBSTITUIDO.ENTREGA,
    SUBSTITUIDO.UUID
FROM 
    PEDIDO ORIGINAL
INNER join
    PEDIDO SUBSTITUIDO ON
        ORIGINAL.FILIAL=SUBSTITUIDO.FILIAL and
        ORIGINAL.C_PEDIDOSUBSTITUIDO=SUBSTITUIDO.IDNOTA
INNER JOIN 
    CADASTROPARCEIROS CADCLI ON 
        (CADCLI.CADASTRO = SUBSTITUIDO.DESTINATARIO)        
left join  
    VENDEDORESPED ON 
        (VENDEDORESPED.FILIAL=SUBSTITUIDO.FILIAL AND 
         VENDEDORESPED.IDNOTA=SUBSTITUIDO.IDNOTA)
left JOIN 
    CADASTROPARCEIROS CADVEN ON 
        (CADVEN.CADASTRO = VENDEDORESPED.VENDEDOR)
WHERE 
    ORIGINAL.FILIAL=184 AND    
     ORIGINAL.DATAREFERENCIA BETWEEN '01.07.2023' and '31.07.2023' and 
    ORIGINAL.DATAEMISSAO is not null and 
    ORIGINAL.DATACANCELAMENTO is null and 
   coalesce(VENDEDORESPED.VENDEDOR,-1) = 185