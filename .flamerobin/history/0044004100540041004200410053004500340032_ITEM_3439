SELECT 

    FORNECEDORESITEM.ID,
    FORNECEDORESITEM.FORNECEDOR, 
    FORNECEDORESITEM.CODIGOFORNEC, 
    FORNECEDORESITEM.INDUSTRIAOUIMPORTADOR,    
    FORNECEDORESITEM.STATUS,    
    CASE WHEN ITEMESTOQUE.FORNECEDORPADRAO = FORNECEDORESITEM.FORNECEDOR THEN 'S' ELSE 'N' END AS FORNECEDORPADRAO,
    
    FORNECEDORESITEM.IDITEM,
    ITEMESTOQUE.DESCRICAO,

    FORNECEDORESITEM.CUSTO,
    FORNECEDORESITEM.PRECO,
    FORNECEDORESITEM.IPI,
    FORNECEDORESITEM.ST,    
    

    FORNECEDORESITEM.DATAATUALIZACAO,
    FORNECEDORESITEM.APROVACAO,
    FORNECEDORESITEM.USUARIOAPROVACAO,
    FORNECEDORESITEM.IDUSUARIO,
    case cadestab.uf when cadfor.uf 
        then TRIBUTACAOICMSUF.ALIQUOTA
        else estado.PICMSINTERESTADUALCOMPRA
    end as picms
    

FROM 
    FORNECEDORESITEM
INNER JOIN 
    ITEMESTOQUE ON FORNECEDORESITEM.IDITEM = ITEMESTOQUE.CODIGO
inner join
    cadastroparceiros cadfor on
        cadfor.cadastro=fornecedoresitem.fornecedor
inner join
    estado on
        estado.ESTADO=cadfor.UF
INNER join
    CADASTROPARCEIROS CADESTAB ON
        CADESTAB.CADASTRO=110
inner join
    tributacaoicmsuf on
        tributacaoicmsuf.ID=itemestoque.TRIBUTACAOICMS and
        tributacaoicmsuf.uf=cadestab.UF
where
    FORNECEDORESITEM.FORNECEDOR = 86