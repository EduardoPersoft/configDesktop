UPDATE
    MERCADORIASNOTA
set
    PRECOLISTA = (select (VLRTOTAL - coalesce(ALIQICMSST,0)) / qtde from C_I_MOVESTX where C_I_MOVESTX.idnota=mercadoriasnota.idnota and C_I_MOVESTX.CODPECA=mercadoriasnota.codigo), 
    PRECOUNITARIO = (select (VLRTOTAL - coalesce(ALIQICMSST,0)) / qtde from C_I_MOVESTX where C_I_MOVESTX.idnota=mercadoriasnota.idnota and C_I_MOVESTX.CODPECA=mercadoriasnota.codigo),  
    VLRTOTALMERCAD = (select VLRTOTAL from C_I_MOVESTX where C_I_MOVESTX.idnota=mercadoriasnota.idnota and C_I_MOVESTX.CODPECA=mercadoriasnota.codigo),  
    ALIQUOTAICMS = (select ALIQICMS from C_I_MOVESTX where C_I_MOVESTX.idnota=mercadoriasnota.idnota and C_I_MOVESTX.CODPECA=mercadoriasnota.codigo),  
    VALORICMS = (select valoricms from C_I_MOVESTX where C_I_MOVESTX.idnota=mercadoriasnota.idnota and C_I_MOVESTX.CODPECA=mercadoriasnota.codigo) 
WHERE
    mercadoriasnota.filial=5 AND
    mercadoriasnota.idnota between 110280 and 178832
        