    mercadoriasnota.basecofins=0,
    mercadoriasnota.VLRCOFINS=0,
    
    mercadoriasnota.cstpis=98,
    mercadoriasnota.ppis=0,
    mercadoriasnota.basepis=0,
    mercadoriasnota.VLRPISPASEP=0
where
    mercadoriasnota.filial=1 and
    mercadoriasnota.idnota>=306406 and
    mercadoriasnota.cstpis=2 and
    substring(mercadoriasnota.cfop from 1 for 1) in ('1', '2');
    
    
