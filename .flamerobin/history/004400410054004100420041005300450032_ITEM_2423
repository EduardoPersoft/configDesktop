
  UPDATE MERCADORIASPEDCOMPRA SET QTDEENTREGUE= coalesce((select sum(mercadoriasnotacompra.quantidade) FROM mercadoriasnotacompra
                                                 where mercadoriasnotacompra.filial=mercadoriaspedcompra.filial and 
                                                 mercadoriasnotacompra.IDPEDIDO=mercadoriaspedcompra.idnota AND
                                                 mercadoriasnotacompra.IDMERCADORIA=mercadoriaspedcompra.IDMERCADORIA
                                                 plan join ) ,0)

--select * from mercadoriaspedcompra
where filial=5 and baixa = 'N'
plan join (MERCADORIASNOTACOMPRA INDEX (I_MERCITEMSAIDA),
            PLAN (MERCADORIASPEDCOMPRA INDEX (BAIXA_MERCADORIASPEDCOMPRA)))
--order by filial, idnota                                         

UPDATE
    MERCADORIASPEDCOMPRA
SET
    mercadoriaspedcompra.MINIMOBAIXA=0 ,
    mercadoriaspedcompra.qtdeentregue=quantidade,
    baixa='S'
WHERE
    filial=5 and exists (
    select * from notacompra 
    where notacompra.filial=mercadoriaspedcompra.filial AND
    notacompra.idnota=mercadoriaspedcompra.idnota AND
    notacompra.DATAEMISSAO<='01.01.2021')
    
    
create index c_i_mercpedcompra index mercadoriaspedcompra(filial,idpedido,idmercpedido)