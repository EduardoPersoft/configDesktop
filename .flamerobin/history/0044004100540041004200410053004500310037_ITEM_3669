select
    orcamento.vendedor,
    count(orcamento.idnota) qtdorc,
    sum((select 
            count(mercadoriasorc.idnota)
         from
            MERCADORIASORC
         where
            mercadoriasorc.filial=orcamento.filial and
            mercadoriasorc.idnota=orcamento.idnota)) qtdorc,
    sum(orcamento.VLRTOTALnota) valorOrcado
from
    orcamento
where 
    orcamento.DATAREFERENCIA between '24.09.2024' and '24.09.2024'
group by 
    orcamento.vendedor