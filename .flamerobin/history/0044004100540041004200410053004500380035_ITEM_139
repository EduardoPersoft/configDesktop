/*
select
    MERCADORIASPED.FILIAL,
    MERCADORIASPED.IDNOTA,
    MERCADORIASPED.IDMERCADORIA,
    MERCADORIASPED.CODIGO,
    MERCADORIASPED.DESREDUZIDA,
    'P'||SUBSTRING(MERCADORIASPED.CODIGO FROM 3 FOR 3)
FROM 
    MERCADORIASPED
WHERE 
    MERCADORIASPED.CODIGO<>SUBSTRING(MERCADORIASPED.CODIGO FROM 1 FOR 4)
  */  
update
    MERCADORIASPED
set
    CODIGO = 'P'||SUBSTRING(MERCADORIASPED.CODIGO FROM 3 FOR 3)
WHERE 
    MERCADORIASPED.CODIGO<>SUBSTRING(MERCADORIASPED.CODIGO FROM 1 FOR 4)
