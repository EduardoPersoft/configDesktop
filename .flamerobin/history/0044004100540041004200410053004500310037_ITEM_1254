select 
    inventarioestoquedata.filial,
    inventarioestoquedata.codigo,
    itemestoque.descricao,
    inventarioestoquedata.lote,
    inventarioestoquedata.local,
    local.descricao,
    locallote.quantidade saldoatual,
    inventarioestoquedata.quantidade contado,
    inventarioestoquedata.quantidadeEstoque esperado,
    inventarioestoquedata.idmovimento            
from 
    inventarioestoquedata
inner join
    itemestoque on
        itemestoque.codigo=inventarioestoquedata.CODIGO
left join
    local on
        local.id=inventarioestoquedata."LOCAL"
        

