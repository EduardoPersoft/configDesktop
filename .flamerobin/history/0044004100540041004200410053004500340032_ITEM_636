select
    CADASTROPARCEIROS.CADASTRO,
    CADASTROPARCEIROS.NOME,
    MAX(PEDIDO.DATACADASTRO) DATA
from
    NOTAFISCAL PEDIDO
INNER join
    CADASTROPARCEIROS ON
        CADASTROPARCEIROS.CADASTRO=PEDIDO.DESTINATARIO
where 
    pedido.filial=110 and
    NOTAFISCAL.DATACANCELAMENTO IS NULL
GROUP BY
CADASTROPARCEIROS.CADASTRO,
    CADASTROPARCEIROS.NOME