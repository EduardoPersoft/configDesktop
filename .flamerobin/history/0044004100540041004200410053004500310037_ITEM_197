select 
    INVENTARIOESTOQUEDATA.* ,
    materiallocal.SALDOTOTAL,
    (select sum(materialmovimentoetoque.quantidade*MATERIALMOVIMENTOESTOQUE.sinal)
     from MATERIALMOVIMENTOESTOQUE
     inner join movimentoestoque on
        movimentoestoque.filial=materialmovimentoestoque.filial AND
        movimentoestoque.idmoviento=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
     where MATERIALMOVIMENTOESTOQUE.fillial=INVENTARIOESTOQUEDATA.filial AND
     materialmovimentoestoque.IDITEM=inventarioestoquedata.codigo AND
     materialmovimentoestoque.lote=inventarioestoquedata.lote AND
     materialmovimentoestoque.LOCALARMAZENAMENTO=inventarioestoquedata.local AND
     movimentoestoque.EMISSAO>=inventarioestoquedata.data)
from 
    INVENTARIOESTOQUEDATA 
inner JOIN
    materiallocal on
        materiallocal.filial=INVENTARIOESTOQUEDATA.filial AND
        materiallocal.iditem=inventarioestoquedata.codigo AND
        materiallocal.IDLOCAL=INVENTARIOESTOQUEDATA.local