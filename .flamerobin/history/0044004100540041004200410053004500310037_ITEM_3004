SELECT
    MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO,
    MOVIMENTOESTOQUE.FILIAL,
    MAX(MOVIMENTOESTOQUE.EMISSAO) AS MAX_EMISSAO, 
    LOCAL.DESCRICAO,
    max(inventarioestoquedata.data)
FROM
    MATERIALMOVIMENTOESTOQUE
INNER JOIN
    MOVIMENTOESTOQUE ON
    MATERIALMOVIMENTOESTOQUE.FILIAL = MOVIMENTOESTOQUE.FILIAL AND
    MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO = MOVIMENTOESTOQUE.IDMOVIMENTO
inner join 
    local on 
    MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO=LOCAL.ID
left join     
    inventarioestoquedata.codigo=MATERIALMOVIMENTOESTOQUE.iditem and
    inventarioestoquedata.local=materialmovimentoestoque.LOCALARMAZENAMENTO and
    inventarioestoquedata.lote=MATERIALMOVIMENTOESTOQUE.lote and
    inventarioestoquedata.filial=materialmovimentoestoque.filial
WHERE
    MATERIALMOVIMENTOESTOQUE.IDITEM = '2100708'
GROUP BY
    MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO,
    MOVIMENTOESTOQUE.FILIAL,
    LOCAL.DESCRICAO
order by 
    3 desc


