update
    materialmovimentoestoque
set
    valor = 0
where
   materialmovimentoestoque.FILIAL=110 and
   materialmovimentoestoque.iditem like 'MPP%' and
   exists (
    select  
        *
    from
        MOVIMENTOESTOQUE
    where
        movimentoestoque.filial=MATERIALMOVIMENTOESTOQUE.filial and
        movimentoestoque.idmovimento=materialmovimentoestoque.idmovimento and
        movimentoestoque.tipomovimento  in ('10', '11') and
        movimentoestoque.emissao >= '01.02.2024')