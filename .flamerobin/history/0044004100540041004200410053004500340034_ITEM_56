select 
    cadcli.cadastro,
    cadcli.nome,
    cadven.nome vendedor,
    count(mercadoriasorc.idnota) qtdOrcamento,
    sum(case when mercPedConvertido.idnota is null then 0 else 1 end) qtdConversao
from 
    orcamento
inner join
    mercadoriasorc on
        orcamento.filial=mercadoriasorc.filial and
        orcamento.idnota=mercadoriasorc.idnota 
inner join
    CADASTROPARCEIROS cadcli on
        cadcli.cadastro=orcamento.destinatario
inner join
    clientes on 
        cadcli.cadastro=clientes.CADASTRO
inner join
    CADASTROPARCEIROS cadven on
        cadven.cadastro=clientes.vendedor
inner join
    itemestoque on
        itemestoque.codigo=mercadoriasorc.CODIGO
inner join
    C_FORNECEDORPECA on
        C_FORNECEDORPECA.id=itemestoque.C_FORNECEDOR
left join
    pedido pedConvertido on
        pedConvertido.filial=orcamento.filial and
        pedConvertido.idorcamento=orcamento.idnota and
        pedConvertido.CANCELAMENTO='N'
left join
    mercadoriasped mercPedConvertido on
        pedconvertido.filial=mercPedConvertido.filial and
        pedConvertido.idnota=mercPedconvertido.idnota and
        mercadoriasOrc.codigo=mercPedconvertido.codigo
where 
    orcamento.DATACADASTRO between '01.01.2023' and '31.12.2023' and
    orcamento.CANCELAMENTO='N'
group by    
    CADASTROPARCEIROS.cadastro,
    cadastroparceiros.nome
order by 4 desc,3 desc