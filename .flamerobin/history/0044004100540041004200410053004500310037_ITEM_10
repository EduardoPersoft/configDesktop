SELECT
      ITEMESTOQUE.CODIGO,
      ITEMESTOQUE.CODIGO as IDITEM,
      ll1.QUANTIDADE,
      ITEMESTOQUE.DESCRICAO,
      LOCALATUAL.DESCRICAO AS DESCLOCAL,
      itemestoque.C_MRFORNECEDOR as codfornec,
      LOCALSALDO.DESCRICAO AS DESCLOCALSALDO,      
      'N' as p_marca
FROM
    LOCALLOTE ll1 
INNER JOIN
      LOCAL LOCALATUAL ON (ll1.LOCAL=LOCALATUAL.ID)
INNER JOIN
      ITEMESTOQUE ON (ll1.IDITEM=ITEMESTOQUE.CODIGO)

inner join 
    locallote ll2 on
        ll1.FILIAL=ll2.filial AND
        ll1.IDITEM=ll2.iditem AND
        ll2.QUANTIDADE>0
INNER JOIN
      LOCAL LOCALSALDO ON (ll2.LOCAL=LOCALSALDO.ID)
        
        
WHERE
     ll1.FILIAL=12826  AND
     ll1.QUANTIDADE < 0 AND
     ll2.QUANTIDADE>0