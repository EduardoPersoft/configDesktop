SELECT 
    * 
FROM 
    NOTAFISCAL
inner join 
    naturezaoperacao on 
        naturezaoperacao.id=notafiscal.OPERACAO
where
    NATUREZAOPERACAO.estoque='S'
and notafiscal.filial=1
and notafiscal.cancelamento='N'    
and notafiscal.dataemissao>='01.01.2020'
and notafiscal.operacao<>158
and notafiscal.operacao<>144
and notafiscal.entradasaida='S'
and notafiscal.tiponota<>2
and not exists
    (select 
        * 
     from 
        movimentoestoque 
     where 
        movimentoestoque.filial=NOTAFISCAL.FILIAL and
        movimentoestoque.idnota=notafiscal.idnota)
order by datacadastro     