select
    case movimentoestoque.TIPOMOVIMENTO when '06' then 'NF' else 'PED' end TipoDoc,
    movimentoestoque.emissao,
    movimentoestoque.documento,
    MATERIALMOVIMENTOESTOQUE.iditem,
    itemestoque.descricao,
    MATERIALMOVIMENTOESTOQUE.sinal,
    MATERIALMOVIMENTOESTOQUE.QUANTIDADE,
    cast(materialmovimentoestoque.valor/
    MATERIALMOVIMENTOESTOQUE.quantidade
    as decimal(12,3)) as unitario,
    MATERIALMOVIMENTOESTOQUE.quantidade,
    materialmovimentoestoque.VALOR,
    materialmovimentoestoque.valor*MATERIALMOVIMENTOESTOQUE.sinal
from
    MATERIALMOVIMENTOESTOQUE
inner join
    movimentoestoque on
        movimentoestoque.filial=materialmovimentoestoque.filial and
        movimentoestoque.idmovimento=MATERIALMOVIMENTOESTOQUE.idmovimento
inner join 
    itemestoque on
        itemestoque.codigo=MATERIALMOVIMENTOESTOQUE.iditem
where
    MATERIALMOVIMENTOESTOQUE.filial=1 and
    materialmovimentoestoque.LOCALARMAZENAMENTO=7 and
    MOVIMENTOESTOQUE.emissao between '01.11.2025' and '30.11.2025' 