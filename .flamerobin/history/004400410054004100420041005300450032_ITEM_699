SELECT
    cadfor.razaosocial,
    /*
    notacompra.NRNOTAFORNECEDOR,    
    notacompra.serie,
    */
    notacompra.dataentrada,
    mercadoriasnotacompra.codigo,
    mercadoriasnotacompra.DESreduzida,
    case movimentoestoque.tipomovimento when '05' then 0 else mercadoriasnotacompra.quantidade end,
    sum(mercadoriasnotacompra.vlrfinalmercad)/sum(mercadoriasnotacompra.quantidade) as preco,
    cast(
        materialmovimentoestoque.valor/
        case when coalesce(MATERIALMOVIMENTOESTOQUE.QUANTIDADE,1) = 0 then 1
        else materialmovimentoestoque.quantidade end
        as
        decimal(12,3)) custoentrada,
    precopromocao.preco as promocao,
    preconormal.preco as preconormal
FROM
    NOTACOMPRA
inner JOIN
    mercadoriasnotacompra on
        notacompra.filial=mercadoriasnotacompra.filial AND
        notacompra.idnota=mercadoriasnotacompra.IDNOTA
inner JOIN
    LISTAPRECOPRODUTO precoNormal on (
        precoNormal.lista=1 AND
        precoNormal.produto=mercadoriasnotacompra.codigo)
inner JOIN
    LISTAPRECOPRODUTO precoPromocao on (
        precoPromocao.lista=2 AND
        precoPromocao.PRODUTO=mercadoriasnotacompra.codigo)
inner JOIN
    movimentoestoque on
        movimentoestoque.filial=notacompra.filial AND
        movimentoestoque.IDNOTACOMPRA=notacompra.IDNOTA
inner JOIN
    materialmovimentoestoque on
        materialmovimentoestoque.filial=movimentoestoque.filial AND
        materialmovimentoestoque.idmovimento=movimentoestoque.IDmovimento AND
        materialmovimentoestoque.IDMOVIMENTOMATERIAL=mercadoriasnotacompra.idmercadoria
inner JOIN
    CADASTROPARCEIROS cadfor on
        cadfor.cadastro=notacompra.DESTINATARIO
WHERE
    notacompra.filial=5
    and notacompra.DATAENTRADA between '22.02.2021' and '31.12.2021'
order by
    dataentrada,codigo