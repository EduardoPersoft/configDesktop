SELECT
    itemestoque.codigo,
    itemestoque.descricao,
    itemestoque.referencia,
    coalesce((select
        sum(m1.saldototal)
     from 
        MATERIALLOCAL m1
     inner join 
        local l1 on
            l1.id = m1.IDLOCAL
     where
        m1.filial=materialfilial.filial and
        m1.iditem=materialfilial.iditem and
        substring(l1.descricao from 1 for 2) = 'Z2'),0) as saldo,
    itemestoque.unidade,    
    materialfilial.SALDOMINIMO,
    materialfilial.saldomaximo - 
    coalesce((select
        sum(m1.saldototal)
     from 
        MATERIALLOCAL m1
     inner join 
        local l1 on
            l1.id = m1.IDLOCAL
     where
        m1.filial=materialfilial.filial and
        m1.iditem=materialfilial.iditem and
        substring(l1.descricao from 1 for 2) = 'Z2'),0) as qtd,
    l2.descricao local
    
FROM
    materialfilial
inner JOIN
    itemestoque on
        itemestoque.codigo = materialfilial.IDITEM
inner join
    materiallocal m2 on
        m1.filial=materialfilial.filial and
        m1.iditem=materialfilial.iditem         
inner join
    local l2 on
        l2.id=m1.IDLOCAL and
        substring(l1.descricao from 1 for 2) = 'Z2'       
WHERE
    materialfilial.filial=:filial AND
    materialfilial.saldominimo > 0 and
    coalesce((select
        sum(m1.saldototal)
     from 
        MATERIALLOCAL m1
     inner join 
        local l1 on
            l1.id = m1.IDLOCAL
     where
        m1.filial=materialfilial.filial and
        m1.iditem=materialfilial.iditem and
        substring(l1.descricao from 1 for 2) = 'Z2'),0)<materialfilial.SALDOMINIMO 
order by
    itemestoque.codigo