SET TERM ^ ;
CREATE TRIGGER C_FATURASPED_FECHAMENTO FOR C_FATURASPED ACTIVE
BEFORE insert OR update POSITION 0

AS

DECLARE VARIABLE INICIO DATE;
DECLARE VARIABLE FIM DATE;

BEGIN
    /* enter trigger code here */ 
    IF((coalesce(NEW.IDTITULO,-1)<>-1) and 
       (coalesce(OLD.IDTITULO,-1)=-1)) then begin
        select 
            estabelecimento.VENDASINICIO,
            estabelecimento.VENDASFIM
        from
            ESTABELECIMENTO
        where 
            estabelecimento.cadastro=new.FILIAL
        into :inicio, :fim;
        
        if(new.DATA<:inicio or new.data>:fim) then
            exception C_DATAFECHAMENTOVENDAS;
        
    END
       
END
^
SET TERM ; ^
