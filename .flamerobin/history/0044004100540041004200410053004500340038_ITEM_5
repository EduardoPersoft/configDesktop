update
    LANTOCONTPAG
set
    LANTOCONTPAG.CONTACONTABIL=(SELECT first 1
                                    T_CONVERTE.CONTACONTABIL
                                from
                                    T_CONVERTE
                                where
                                    T_CONVERTE.ID=LANTOCONTPAG.IDMOVTOBANC)
WHERE 
    EXISTS 
    (SELECT 
                                    T_CONVERTE.CONTACONTABIL
                                from
                                    T_CONVERTE
                                where
                                    T_CONVERTE.ID=LANTOCONTPAG.IDMOVTOBANC)
    
    