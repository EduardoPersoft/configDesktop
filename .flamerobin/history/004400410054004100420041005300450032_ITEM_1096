select 
    mercadoriasorc.codigo,
    CLASSIFICACAOFISCAL.DESCRICAO,
    mercadoriasorc.quantidade,
    mercadoriasorc.precolista,
    mercadoriasorc.VLRICMSRECOLHIDO 
from 
    MERCADORIASORC
left JOIN
    CLASSIFICACAOFISCAL on 
        CLASSIFICACAOFISCAL.CFISCAL=mercadoriasorc.CLASSIFISCAL
where 
    filial=5 and 
    idnota=198695