select 
    prazomercpedcompra.filial,
    prazomercpedcompra.idnota,
    prazomercpedcompra.IDITEM,
    count(prazomercpedcompra.dias)
from 
    prazomercpedcompra
inner JOIN
    mercadoriaspedcompra on
        mercadoriaspedcompra.filial=PRAZOMERCPEDCOMPRA.filial AND
        mercadoriaspedcompra.idnota=prazomercpedcompra.IDNOTA
WHERE
    mercadoriaspedcompra.filial=5 AND
    mercadoriaspedcompra.baixa='N'
group by
    prazomercpedcompra.filial,
    prazomercpedcompra.idnota,
    prazomercpedcompra.iditem