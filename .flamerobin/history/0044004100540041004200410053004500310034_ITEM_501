select 
    RECURSOSXCENTROCUSTOS.*,
    recursos.descricao,
    CENTROCUSTOS.DESCRICAO
from 
    RECURSOSXCENTROCUSTOS
inner join 
    recursos on
        recursos.id=RECURSOSXCENTROCUSTOS.ID
INNER join
    CENTROCUSTOS ON
        CENTROCUSTOS.IDPLANO=2 and
        CENTROCUSTOS.CENTROCUSTO=RECURSOSXCENTROCUSTOS.CENTROCUSTO
    