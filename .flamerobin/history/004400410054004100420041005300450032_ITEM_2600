SET TERM ^ ;
ALTER TRIGGER ATITEMPEDCOMPRA_DELETE ACTIVE
BEFORE DELETE POSITION 0
AS
declare cont integer;
BEGIN  
  UPDATE MERCADORIASPEDCOMPRA SET QTDEENTREGUE= case when mercadoriaspedcompra.unidade in ('PC', 'UN') and old.unidade = 'MIL' then QTDEENTREGUE-(old.QUANTIDADE*1000)
                                                     when mercadoriaspedcompra.unidade in ('PC', 'UN') and old.unidade IN ('CT','CEN') then QTDEENTREGUE-(old.QUANTIDADE*100) 
                                                     ELSE (QTDEENTREGUE-old.QUANTIDADE) end
  WHERE MERCADORIASPEDCOMPRA.FILIAL=old.FILIAL
  AND MERCADORIASPEDCOMPRA.IDNOTA=old.IDPEDIDO
  AND MERCADORIASPEDCOMPRA.IDMERCADORIA=old.IDMERCPEDIDO;
   

  UPDATE MERCADORIASPED SET QTDEENVIADA=QTDEENVIADA+old.QUANTIDADE
  WHERE MERCADORIASPED.FILIAL=OLD.FILIAL
  AND MERCADORIASPED.IDNOTA=OLD.IDPEDVENDEV
  AND MERCADORIASPED.IDMERCADORIA=OLD.IDPEDVENMERCDEV;

  
  
END^
SET TERM ; ^
