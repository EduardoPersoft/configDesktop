select  
    cast(movimentoestoque.EMISSAO as date),
    movimentoestoque.idmovimento,
    movimentoestoque.COLETADATA,
    c_coletas.VALORMEDIO,
    c_coletas.*
from 
    c_coletas
inner join
    MOVIMENTOESTOQUE on
        movimentoestoque.COLETA=c_coletas.COLETA
where
    c_coletas.DATACOLETA between '14.11.2025' and '27.11.2025'
    and movimentoestoque.TIPOMOVIMENTO='13'
union    
select  
    cast(c_destinoavulso.DATASOLICITACAO as date),
    0,
    c_destinoavulso.DATACOLETA,
    c_coletas.VALORMEDIO,
    c_coletas.*
from 
    c_coletas
inner join
    c_destinoavulso on
        c_destinoavulso.COLETA=c_coletas.COLETA
where
    c_coletas.DATACOLETA between '14.11.2025' and '27.11.2025'
order by 5