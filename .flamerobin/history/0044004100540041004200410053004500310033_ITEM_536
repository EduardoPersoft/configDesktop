select
    mercadoriasnota.codigo,
    sum(mercadoriasnota.quantidade) as qtd,
    materiallocal.SALDOTOTAL
from
    MERCADORIASNOTA
inner join
    materiallocal on
    materiallocal.filial=mercadoriasnota.filial and
    materiallocal.iditem=mercadoriasnota.codigo
where
    mercadoriasnota.filial=1 and
    mercadoriasnota.idnota=23017
group by
    mercadoriasnota.codigo,
    materiallocal.saldototal
having
    sum(mercadoriasnota.quantidade)>
    materiallocal.SALDOTOTAL