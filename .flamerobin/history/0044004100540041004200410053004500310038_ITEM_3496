select 
    orcRelacionado.filial,
    orcRelacionado.idNota,
    orcRelacionado.uuid
from 
    orcamento orcLeitura
inner join
    orcamento orcRelacionado on
        orcRelacionado.filial=orcLeitura.filial and
        orcRelacionado.idrelacao=coalesce(orcleitura.idrelacao,orcLeitura.idnota)
where 
    orcleitura.filial=1 and
    orcleitura.idnota=201650
