SELECT
    TITULOREC.FILIAL,
     filial.nome,
    TITULOREC.IDTITULO id,
    TITULOREC.TITULO,
    TITULOREC.FATURA,

    TITULOREC.PARCEIRO idparceiro,
   
    CADASTROPARCEIROS.NOME,
    CADASTROPARCEIROS.RAZAOSOCIAL,

    titulorec.VLRDESCONTOELETRON,
    TITULOREC.VALORTITULO,
    TITULOREC.TOTALPAGO,
    TITULOREC.TOTALABATIDO,
    TITULOREC.VALOREMABERTO,
    TITULOREC.TOTALDESCONTO,
    TITULOREC.TOTALJUROS,
    TITULOREC.totalpago+TITULOREC.totaljuros-TITULOREC.totaldesconto totalPagamento,

    TITULOREC.EMISSAO,
    TITULOREC.VENCIMENTO,
    TITULOREC.PROVAVEL,
    TITULOREC.baixa,

    TITULOREC.TIPOTRANSACAO,
    TIPOCOBRANCA.DESCRICAO DESCRICAOCOBRANCA,    
    TIPOCOBRANCA.tPag,
    TITULOREC.CONTACORRENTE,
    CONTACORRENTE.DESCRICAOCONTA,
    banco.CODCAMARACOMP,

    TITULOREC.NUMBOLBANCO,

    titulorec.codretorno,
    TITULOREC.BANDEIRACARTAO,
    NOTAFISCAL.VLRTOTALNOTA,
    'N' AS P_MARCA,
    
    CASE WHEN TITULOREC.BAIXA IS NOT NULL THEN 8421504
    WHEN TITULOREC.VENCIMENTO<CAST('NOW' AS DATE) THEN 255
    ELSE 0 END AS P_STATUSCOR
  
FROM TITULOREC

inner join 
     CADASTROPARCEIROS filial on
     filial.cadastro=titulorec.filial
INNER JOIN CADASTROPARCEIROS ON (TITULOREC.PARCEIRO = CADASTROPARCEIROS.CADASTRO)
left JOIN CONTACORRENTE ON(TITULOREC.FILIAL=CONTACORRENTE.FILIAL AND
                                                          TITULOREC.CONTACORRENTE=CONTACORRENTE.CODIGO)
left JOIN TIPOCOBRANCA ON (TITULOREC.TIPOTRANSACAO=TIPOCOBRANCA.TIPOCOBRANCA)

left join 
    FATURAS on 
    faturas.filial=titulorec.filial and faturas.idtitulo=titulorec.idtitulo
left join 
    NOTAFISCAL on 
    FATURAS.FILIAL=NOTAFISCAL.FILIAL and 
    FATURAS.IDNOTA=NOTAFISCAL.IDNOTA
left join
    banco on
        banco.banco=contacorrente.banco
where
    TITULOREC.FILIAL=12826 and 
    TITULOREC.EMISSAO between '01.01.2025'  and '31.12.2025' and 
    tipocobranca.TPAG in (3,4) and 
    TITULOREC.BAIXA is null