SELECT c_listastatus.VENDEDOR,
       C_LISTASTATUS.NOMEVENDEDOR,
       SUM(CASE WHEN C_LISTASTATUS.limite > CAST('NOW' AS TIMESTAMP)
           THEN 1 ELSE 0 END) AS NOPRAZO ,
       SUM(CASE WHEN C_LISTASTATUS.limite <= CAST('NOW' AS TIMESTAMP)
            THEN 1 ELSE 0 END) AS EMATRASO
    FROM C_LISTASTATUS(1,null,null)
    GROUP BY c_listastatus.VENDEDOR,c_listastatus.NOMEVENDEDOR