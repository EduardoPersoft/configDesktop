select * from MATERIALMOVIMENTOESTOQUE
where filial=110
and iditem='MPP01METAL'
and exists (
    select 
        *
    from 
        movimentoestoque
    where
        movimentoestoque.filial=materialmovimentoestoque.FILIAL and
        movimentoestoque.idmovimento=materialmovimentoestoque.idmovimento and
        movimentoestoque.emissao<='01.04.2023')
        