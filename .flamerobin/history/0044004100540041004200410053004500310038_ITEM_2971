select 
    principal.dataemissao,
    principal.filial,
    principal.idnota,
    principal.c_status,
    alternativo.filial,
    alternativo.idnota,
    alternativo.c_status

from
    orcamento principal
inner join
    orcamento alternativo on
        alternativo.filial=principal.FILIAL and
        alternativo.IDRELACAO=principal.IDNOTA
where
    principal.c_status<4 and
    (select
        *
     from 
        PEDIDO
     where
        pedido.filial=alternativo.filial and
        pedido.IDORCAMENTO=alternativo.idnota and
        pedido.CANCELAMENTO='N')
        
    
    order by principal.idnota
