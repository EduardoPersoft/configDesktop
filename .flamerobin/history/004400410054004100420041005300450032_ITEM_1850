SELECT

       I1.CODIGO,
       I1.DESCRICAO,
       I1.unidade,

       COALESCE((SELECT SUM(MATERIALLOCAL.saldototal) FROM MATERIALLOCAL
        WHERE MATERIALLOCAL.FILIAL=5
        AND MATERIALLOCAL.iditem=I1.CODIGO),0) AS QUANTIDADE,

       COALESCE((SELECT SUM(MATERIALLOCAL.saldototal) FROM MATERIALLOCAL
        WHERE MATERIALLOCAL.FILIAL=5
        AND MATERIALLOCAL.iditem=I1.CODIGO),0)  -
       COALESCE((SELECT SUM(MERCADORIASPED.quantidade-COALESCE(MERCADORIASPED.qtdeenviada,0))
        FROM MERCADORIASPED
        INNER JOIN PEDIDO ON (PEDIDO.FILIAL=MERCADORIASPED.filial
                AND PEDIDO.IDNOTA=MERCADORIASPED.IDNOTA)
        WHERE MERCADORIASPED.FILIAL=5
        AND MERCADORIASPED.CODIGO=I1.codigo
        AND MERCADORIASPED.BAIXA='N'
        AND PEDIDO.datacancelamento IS NULL),0) AS SALDOLIQUIDO,

       (SELECT FIRST 1 LISTAPRECOPRODUTO.preco *
        (CASE COALESCE(QUANTIDADE,0) WHEN 0 THEN 1 ELSE QUANTIDADE END)
         FROM LISTAPRECOPRODUTO
        WHERE LISTAPRECOPRODUTO.LISTA=(select listapreco.lista from listapreco where listapreco.listapadrao='S')
        AND LISTAPRECOPRODUTO.PRODUTO=I1.CODIGO
        order by quantidade) AS PRECO,
        ARQ1.NOMEARQUIVO,
        I1.REFERENCIA,
        (SELECT COUNT(I2.CODIGO)
         FROM ITEMESTOQUE I2
         WHERE I1.REFERENCIA=I2.REFERENCIA
         AND I1.FAMILIA=I2.FAMILIA
         AND I1.CODIGO<>I2.CODIGO) AS ALTERNATIVAS
FROM ITEMESTOQUE I1
LEFT JOIN CLASSIFICACAOFISCAL ON (CLASSIFICACAOFISCAL.CFISCAL=I1.CLASSIFISCAL)
LEFT JOIN ITEMESTOQUEXARQUIVO ARQ1 ON (ARQ1.CODIGO=I1.CODIGO AND ARQ1.ORDEM=0)
LEFT JOIN ITEMESTOQUEXARQUIVO ARQ2 ON (ARQ2.CODIGO=I1.CODIGO AND ARQ2.ORDEM=1)
LEFT JOIN FAMILIA ON (FAMILIA.ID=I1.FAMILIA)
LEFT JOIN UNIDADE ON (UNIDADE.UNIDADE=CASE COALESCE(I1.UNIDADE2, '') WHEN ''
                                      THEN I1.UNIDADE
                                      ELSE I1.UNIDADE2 END)
WHERE I1.TIPOPRODUTO IN (3,4)
i1.codigo = '05869'

