SELECT 
       NOTAFISCAL.FILIAL, 
       MODELODOCTO.MODELO,
       'E',
       cast(NOTAFISCAL.DATAEMISSAO as date) AS DATA,
       NOTAfiscal.NRNOTAFORNECEDOR AS NUMERONOTA,
       NOTAfiscal.NRNOTAFORNECEDOR AS ORDEMNOTA,
       mercadoriasnota.cfop,
       mercadoriasnota.idpedvendev,
       mercadoriasnota.codigo,
       itemestoque.descricao,
       CLIENTES.CADASTRO,
       CLIENTES.NOME,
       'N',
       NOTAFISCAL.DEVOLUCAO,
       case opsaida.entradasaida when 'S' 
            then opsaida.FATURA 
            else opsaida.DEVOLUCAOFATURAMENTO 
            end fatura,
       opsaida.receita,
       
       case when exists (select 
                            * 
                         from 
                            ESTABELECIMENTO
                         where estabelecimento.CADASTRO=clientes.cadastro) 
        then 'S' else 'N' end entreFiliais,

        mercadoriasnota.quantidade,
        mercadoriasnota.unidade,
        
        CASE WHEN ITEMESTOQUE.CODIGO= 'APARAS' or substring(itemestoque.codigo from 1 for 3)='CIC' THEN 0 ELSE     
        case mercadoriasnota.unidade when 'MIL' then mercadoriasnota.QUANTIDADE*itemestoque.C_PESOPOREMBALAGEM
        else mercadoriasnota.quantidade end END qtdPorUnidade,

 --      GRUPOMERCADORIA.DESCRICAO,
       COALESCE(mercadoriasnota.VLRTOTALMERCAD,0)+
           COALESCE(mercadoriasnota.VALORIPI,0)+
           COALESCE(MERCADORIASNOTA.VLRICMSRECOLHIDO,0)+
           COALESCE(mercadoriasnota.ICMSSTFCPVALOR,0)+
           mercadoriasnota.frete+
           mercadoriasnota.seguro+
           mercadoriasnota.OUTDESPACESSOR-
           (coalesce(mercadoriasnota.DESCONTONOTA,0)+
            coalesce(mercadoriasnota.VLRDESCPRODUTO,0)+
            case notafiscal.ZONAFRANCA when 'S' then mercadoriasnota.valoricms else 0 end)   as VLRTOTALNOTA,
       COALESCE(mercadoriasnota.VALORIPI,0) AS VALORIPI,
       COALESCE(mercadoriasnota.VLRTOTALMERCAD,0) AS VLRSEMIPI,
       NOTAFISCAL.FILIAL,
       ESTAB.RAZAOSOCIAL,
       MERCADORIASNOTA.VLRICMSRECOLHIDO AS VLRICMSRECOLHIDO,

       mercadoriasnota.frete + mercadoriasnota.seguro +
          mercadoriasnota.OUTDESPACESSOR AS DESPACESSORIAS,
       

        mercadoriasnota.VLRTOTALMERCAD-
            (coalesce(mercadoriasnota.DESCONTONOTA,0)+
             coalesce(mercadoriasnota.VLRDESCPRODUTO,0)+
             case notafiscal.ZONAFRANCA when 'S' then mercadoriasnota.valoricms else 0 end)  AS VLRFINALMERCADORIAS,
         
        CASE NOTAFISCAL.ZONAFRANCA 
            WHEN 'S' THEN 0
            ELSE MERCADORIASNOTA.valoricms end AS TOTVALORICMS,
        CASE NOTAFISCAL.ZONAFRANCA 
            WHEN 'S' THEN 0
            ELSE mercadoriasnota.valoricms end AS ICMSORIGEMVALOR,
        0 ICMSDESTINOVALOR,  

        mercadoriasnota.VLRPISPASEP as pis,            
        mercadoriasnota.VLRCOFINS as cofins,        
            
       
        COALESCE(mercadoriasnota.VLRFINALMERCAD,0) - COALESCE(mercadoriasnota.VALORICMS,0) AS VALORLIQUIDO,
       CAST ('0' AS NUMERIC (12,2))AS VLRFINALSERVICOS,
       CAST ('0' AS NUMERIC (12,2)) AS ISS,
       0 AS simples,
       MODELODOCTO.ID,     
       coalesce(cadven.cadastro, -1),
       coalesce(cadven.nome, 'SEM VENDEDOR'),     
       'ENTRADA' as emissaoentrada
FROM 
    NOTACOMPRA NOTAFISCAL
inner join
    naturezaoperacao opDevolucao on
        opDevolucao.id=notafiscal.OPERACAO 
INNER JOIN 
    CADASTROPARCEIROS ESTAB ON 
        (NOTAFISCAL.FILIAL = ESTAB.CADASTRO)
INNER JOIN 
    CADASTROPARCEIROS CLIENTES 
        ON (NOTAFISCAL.DESTINATARIO=CLIENTES.CADASTRO)
INNER JOIN MODELODOCTO ON 
    (NOTAFISCAL.MODELO = MODELODOCTO.ID)
INNER join 
        mercadoriasnotaCompra mercadoriasnota  on
           ( mercadoriasnota.filial=notafiscal.filial and 
             mercadoriasnota.idnota=notafiscal.idnota)
INNER join 
        itemestoque on 
            (itemestoque.codigo=mercadoriasnota.codigo)
INNER join
        MERCADORIASNOTA MERCSAIDA ON 
            MERCSAIDA.FILIAL=MERCADORIASNOTA.FILIAL and
            MERCSAIDA.IDNOTA=MERCADORIASNOTA.IDNOTASAIDA and
            MERCSAIDA.IDMERCADORIA=MERCADORIASNOTA.IDMERCADORIASAIDA
INNER join
        notafiscal notasaida ON 
            MERCSAIDA.FILIAL=notasaida.FILIAL and
            MERCSAIDA.IDNOTA=notasaida.IDNOTA
inner join
        NATUREZAOPERACAO opsaida on
            opsaida.id=notasaida.operacao
            
INNER JOIN 
        PEDIDO ON
            PEDIDO.FILIAL=MERCSAIDA.FILIALPED and
            PEDIDO.IDNOTA=MERCSAIDA.IDPEDIDO 
left join
    CADASTROPARCEIROS cadven on
        cadven.cadastro = PEDIDO.VENDEDOR
WHERE 
    notafiscal.dataentrada between ? and ?

order by
       NOTAFISCAL.DATAEMISSAO,
       NOTAFISCAL.NRNOTAFORNECEDOR,
       mercadoriasnota.CFOP,
       mercadoriasnota.idpedvendev
