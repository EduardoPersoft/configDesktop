  FROM MOVIMENTOESTOQUE MOV
  INNER JOIN MATERIALMOVIMENTOESTOQUE MAT ON
        (     MAT.FILIAL=MOV.FILIAL 
         AND  MAT.IDMOVIMENTO=MOV.IDMOVIMENTO     )
  WHERE  MOV.FILIAL=:P_FILIAL 
  AND    MAT.IDITEM=:P_IDITEM
  AND    MOV.EMISSAO > :VAREMISS
  INTO   :VARCOUNT;
  IF (:VARCOUNT > 0) THEN
  BEGIN
    UPDATE ESTABELECIMENTO SET ESTABELECIMENTO.RECALCULARESTOQUE='S'
    WHERE  ESTABELECIMENTO.CADASTRO=:P_FILIAL;
  END*/
END
