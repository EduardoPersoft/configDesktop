SET TERM ^ ;
CREATE or alter PROCEDURE PROC_ATUALIZAESTOQUE (
    P_FILIAL integer,
    P_IDMOVTO integer,
    P_IDITEM varchar(15),
    P_QTDE double precision,
    P_VALOR double precision,
    P_LOCAL smallint,
    P_LOTE char(12),
    P_VERTICALGRADE char(15),
    P_HORIZONTALGRADE char(15) )

AS
declare variable varemiss timestamp;
declare variable varcount integer;
declare variable varcustomedio double precision;
BEGIN
  IF (:P_VALOR IS NULL) THEN
     P_VALOR = 0;
  SELECT MOVIMENTOESTOQUE.EMISSAO 
  FROM   MOVIMENTOESTOQUE 
  WHERE MOVIMENTOESTOQUE.FILIAL=:P_FILIAL
  AND MOVIMENTOESTOQUE.IDMOVIMENTO=:P_IDMOVTO
  INTO :VAREMISS;

  SELECT COUNT(MATERIALLOTE.IDITEM)
  FROM MATERIALLOTE
  WHERE MATERIALLOTE.FILIAL=:P_FILIAL
  AND   MATERIALLOTE.IDITEM=:P_IDITEM
  AND   MATERIALLOTE.LOTE=:P_LOTE
  INTO  :VARCOUNT;
  IF (:VARCOUNT > 0) THEN
  BEGIN
    UPDATE MATERIALLOTE SET QUANTIDADE=QUANTIDADE+:P_QTDE,
    VALOR=VALOR+:P_VALOR,
    DATA=CASE WHEN DATA <=  :VAREMISS THEN DATA ELSE :VAREMISS END
    WHERE MATERIALLOTE.FILIAL=:P_FILIAL
    AND MATERIALLOTE.IDITEM=:P_IDITEM
    AND MATERIALLOTE.LOTE=:P_LOTE;
  END ELSE
  BEGIN
    INSERT INTO MATERIALLOTE (FILIAL,IDITEM,LOTE,QUANTIDADE,VALOR,QUANTIDADEANTERIOR,VALORANTERIOR,data,GRADEVERTICAL,GRADEHORIZONTAL)
           VALUES (:P_FILIAL,:P_IDITEM,:P_LOTE,:P_QTDE,:P_VALOR,0,0,:varemiss,:p_verticalgrade,:p_horizontalgrade);
  END

  UPDATE MATERIALLOTE SET CUSTOMEDIO=VALOR/QUANTIDADE
  WHERE MATERIALLOTE.FILIAL=:p_filial
  AND MATERIALLOTE.IDITEM=:P_IDITEM
  AND MATERIALLOTE.LOTE=:P_LOTE
  AND MATERIALLOTE.QUANTIDADE>0.0009;


  if (COALESCE(P_VERTICALGRADE,'')<>'' or
      COALESCE(P_HORIZONTALGRADE,'')<>'' ) then BEGIN

     SELECT COUNT(itemestoquexgrade.CODIGO)
     FROM itemestoquexgrade
     WHERE itemestoquexgrade.codigo=:p_iditem
     AND   itemestoquexgrade.gradevertical=:p_verticalgrade
     AND   itemestoquexgrade.gradehorizontal=:p_horizontalgrade
     INTO  :VARCOUNT;
     IF (:VARCOUNT = 0) THEN
     BEGIN
       INSERT INTO itemestoquexgrade (
           CODIGO           ,
           GRADEVERTICAL    ,
           GRADEHORIZONTAL  ,
           CODIGOBARRAS     )
       VALUES (:P_IDITEM,:p_verticalgrade,:p_horizontalgrade,'');
     END

     SELECT COUNT(itemestoquexgradeQ.CODIGO)
     FROM itemestoquexgradeQ
     WHERE itemestoquexgradeQ.FILIAL=:p_FILIAL
     AND   itemestoquexgradeQ.codigo=:p_iditem
     AND   itemestoquexgradeQ.gradevertical=:p_verticalgrade
     AND   itemestoquexgradeQ.gradehorizontal=:p_horizontalgrade
     AND   itemestoquexgradeQ.LOTE=:P_LOTE
     INTO  :VARCOUNT;
     IF (:VARCOUNT > 0) THEN
     BEGIN
       UPDATE itemestoquexgradeQ SET QUANTIDADE=QUANTIDADE+:P_QTDE
       WHERE itemestoquexgradeQ.FILIAL=:p_FILIAL
       AND   itemestoquexgradeQ.codigo=:p_iditem
       AND   itemestoquexgradeQ.gradevertical=:p_verticalgrade
       AND   itemestoquexgradeQ.gradehorizontal=:p_horizontalgrade
       AND   itemestoquexgradeQ.LOTE=:p_LOTE ;
     END ELSE
     BEGIN
       INSERT INTO itemestoquexgradeQ (
           FILIAL           ,
           CODIGO           ,
           GRADEVERTICAL    ,
           GRADEHORIZONTAL  ,
           LOTE  ,
           QUANTIDADE)
       VALUES (:P_FILIAL,:P_IDITEM,:p_verticalgrade,:p_horizontalgrade,:P_LOTE,:p_qtde);
     END

  END


  SELECT COUNT(MATERIALLOCAL.IDITEM)
  FROM MATERIALLOCAL
  WHERE MATERIALLOCAL.FILIAL=:P_FILIAL
  AND   MATERIALLOCAL.IDITEM=:P_IDITEM
  AND   MATERIALLOCAL.IDLOCAL=:P_LOCAL
  INTO  :VARCOUNT;
  IF (:VARCOUNT > 0) THEN
  BEGIN
    UPDATE MATERIALLOCAL SET SALDOTOTAL=SALDOTOTAL+:P_QTDE
    WHERE MATERIALLOCAL.FILIAL=:P_FILIAL
    AND MATERIALLOCAL.IDITEM=:P_IDITEM
    AND MATERIALLOCAL.IDLOCAL=:P_LOCAL;
  END ELSE
  BEGIN
    INSERT INTO MATERIALLOCAL (FILIAL,IDITEM,IDLOCAL,SALDOTOTAL,SALDOINICIAL) 
           VALUES (:P_FILIAL,:P_IDITEM,:P_LOCAL,:P_QTDE,0);
  END


  SELECT COUNT(LOCALLOTE.IDITEM)
  FROM LOCALLOTE
  WHERE LOCALLOTE.FILIAL=:P_FILIAL
  AND   LOCALLOTE.IDITEM=:P_IDITEM
  AND   LOCALLOTE.LOTE=:p_lote
  AND   LOCALLOTE.LOCAL=:P_LOCAL
  INTO  :VARCOUNT;
  IF (:VARCOUNT > 0) THEN
  BEGIN
    UPDATE LOCALLOTE SET QUANTIDADE=QUANTIDADE+:P_QTDE
    WHERE LOCALLOTE.FILIAL=:P_FILIAL
    AND   LOCALLOTE.IDITEM=:P_IDITEM
    AND   LOCALLOTE.LOTE=:p_lote
    AND   LOCALLOTE.LOCAL=:P_LOCAL ;
  END ELSE
  BEGIN
    INSERT INTO LOCALLOTE (FILIAL,IDITEM,LOTE,LOCAL,QUANTIDADE)
           VALUES (:P_FILIAL,:P_IDITEM,:P_LOTE,:P_LOCAL,:P_QTDE);
  END
 
 
  SELECT COUNT(MATERIALFILIAL.IDITEM)
  FROM MATERIALFILIAL
  WHERE MATERIALFILIAL.FILIAL=:P_FILIAL
  AND   MATERIALFILIAL.IDITEM=:P_IDITEM
  INTO :VARCOUNT;

  IF (:VARCOUNT > 0) THEN
  BEGIN
    UPDATE MATERIALFILIAL SET VALORTOTALESTOCADO=VALORTOTALESTOCADO+:P_VALOR
    WHERE MATERIALFILIAL.FILIAL=:P_FILIAL
    AND MATERIALFILIAL.IDITEM=:P_IDITEM;        
  END ELSE
  BEGIN
    INSERT INTO MATERIALFILIAL (FILIAL,IDITEM,VALORTOTALESTOCADO,VALORINICIAL,CUSTOMEDIO)
           VALUES (:P_FILIAL,:P_IDITEM,:P_VALOR,0,0);
  END
/*
  SELECT * FROM PROC_CUSTOMEDIO (:P_FILIAL,:P_IDITEM,null)
  INTO :VARCUSTOMEDIO;
  IF (:VARCUSTOMEDIO IS NULL) THEN
     VARCUSTOMEDIO = 0;  
 VARCUSTOMEDIO = CAST(VARCUSTOMEDIO AS DECIMAL(12,4));
     
 -- IF (:VARCUSTOMEDIO > 0.0009) THEN BEGIN
     UPDATE MATERIALFILIAL SET CUSTOMEDIO=cast(:VARCUSTOMEDIO as decimal(12,3))
     WHERE MATERIALFILIAL.FILIAL=:P_FILIAL
     AND MATERIALFILIAL.IDITEM=:P_IDITEM;    
 -- END
*/
