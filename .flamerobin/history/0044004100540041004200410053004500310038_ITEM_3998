select 
    mercadoriasped.filial,
    mercadoriasped.idnota,
    mercadoriasped.idmercadoria,
    mercadoriasped.cfop,
    mercadoriasped.pipi,
    mercadoriasped.valoripi,
    mercadoriasped.IPIBASE,
    mercadoriasped.ipioutros,
    mercadoriasped.IPIISENTO
from
    MERCADORIASPED
where
    mercadoriasped.baixa='N'
order by
    mercadoriasped.idnota desc