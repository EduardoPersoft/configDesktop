select 
    MOVIMENTOESTOQUE.COLETADATA,
    movimentoestoque.emissao,
    movimentoestoque.idmovimento,
    movimentoestoque.idpedido,
    c_coletas.* 
from 
    c_coletas
inner join
    movimentoestoque on
        movimentoestoque.COLETA=c_coletas.COLETA
where
    (movimentoestoque.coletadata < '30.04.2026' or movimentoestoque.coletadata > '14.05.2026 23:59') and
    c_coletas.DATACOLETA between '30.04.2026' and '14.05.2026' and
    movimentoestoque.tipomovimento='13'