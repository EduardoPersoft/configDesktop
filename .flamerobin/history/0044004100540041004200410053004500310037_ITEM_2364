SELECT
    DISTINCT
    PEDIDO.uuid,
    PEDIDO.FILIAL,
    PEDIDO.IDNOTA,
    PEDIDO.DATAREFERENCIA,
    PEDIDO.ENTREGA,
    CADCLI.NOME,
    PEDIDO.VLRTOTALNOTA,
    PEDIDO.NUMPEDIDOCLIENTE,
    CADCLI.UF, 
    CADCLI.CIDADE,

    (SELECT FIRST 1
        CADVEN.NOME
     FROM
        VENDEDORESPED
     INNER JOIN
        CADASTROPARCEIROS CADVEN ON
            CADVEN.CADASTRO=VENDEDORESPED.VENDEDOR
     WHERE
        VENDEDORESPED.FILIAL=PEDIDO.FILIAL AND
        VENDEDORESPED.IDNOTA=PEDIDO.IDNOTA) AS NOMEVENDEDOR,
    CASE WHEN PEDIDO.cancelamento ='S' THEN 'Cancelado'
     WHEN PEDIDO.BLOQUEADOFATURAMENTO = 'S' THEN 'Bloqueado'
       WHEN NOT EXISTS
       (SELECT * FROM MERCADORIASPED
        WHERE MERCADORIASPED.FILIAL=PEDIDO.FILIAL
        AND MERCADORIASPED.IDNOTA=PEDIDO.IDNOTA
        AND MERCADORIASPED.BAIXA='N'
        plan JOIN (MERCADORIASPED INDEX (RDB$PRIMARY37))) THEN 'Baixado'
       WHEN EXISTS
       (SELECT * FROM MERCADORIASPED
        WHERE MERCADORIASPED.FILIAL=PEDIDO.FILIAL
        AND MERCADORIASPED.IDNOTA=PEDIDO.IDNOTA
        AND MERCADORIASPED.BAIXA='S'
        plan JOIN (MERCADORIASPED INDEX (RDB$PRIMARY37))) THEN 'Parcial'
       WHEN EXISTS (
            SELECT 
                *
            from
                MATERIALMOVIMENTOESTOQUE
            INNER join
                MOVIMENTOESTOQUE ON
                    MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL and
                    MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
            WHERE
                MATERIALMOVIMENTOESTOQUE.FILIAL=PEDIDO.FILIAL and
                MATERIALMOVIMENTOESTOQUE.IDPEDIDO=PEDIDO.IDNOTA and
                COALESCE(MOVIMENTOESTOQUE.PERMITIREDITARPEDIDO, 'N')='N' and 
                MOVIMENTOESTOQUE.TIPOMOVIMENTO='13') THEN 'Pack'
             WHEN EXISTS (
            SELECT 
                *
            from
                MATERIALMOVIMENTOESTOQUE
            INNER join
                MOVIMENTOESTOQUE ON
                    MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL and
                    MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
            WHERE
                MATERIALMOVIMENTOESTOQUE.FILIAL=PEDIDO.FILIAL and
                MATERIALMOVIMENTOESTOQUE.IDPEDIDO=PEDIDO.IDNOTA and
                MOVIMENTOESTOQUE.TIPOMOVIMENTO='13') THEN 'Pack Parado'
                
       WHEN PEDIDO.dataemissao IS NOT NULL THEN 'Aprovado'
       ELSE 'Rascunho' END AS STATUS,
    CASE WHEN PEDIDO.cancelamento ='S' THEN 'red'
       WHEN NOT EXISTS
       (SELECT * FROM MERCADORIASPED
        WHERE MERCADORIASPED.FILIAL=PEDIDO.FILIAL
        AND MERCADORIASPED.IDNOTA=PEDIDO.IDNOTA
        AND MERCADORIASPED.BAIXA='N'
        plan JOIN (MERCADORIASPED INDEX (RDB$PRIMARY37))) THEN 'grey'
       WHEN EXISTS
       (SELECT * FROM MERCADORIASPED
        WHERE MERCADORIASPED.FILIAL=PEDIDO.FILIAL
        AND MERCADORIASPED.IDNOTA=PEDIDO.IDNOTA
        AND MERCADORIASPED.BAIXA='S'
        plan JOIN (MERCADORIASPED INDEX (RDB$PRIMARY37))) THEN 'yellow'
       WHEN EXISTS (
            SELECT 
                *
            from
                MATERIALMOVIMENTOESTOQUE
            INNER join
                MOVIMENTOESTOQUE ON
                    MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL and
                    MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
            WHERE
                MATERIALMOVIMENTOESTOQUE.FILIAL=PEDIDO.FILIAL and
                MATERIALMOVIMENTOESTOQUE.IDPEDIDO=PEDIDO.IDNOTA and
                MOVIMENTOESTOQUE.TIPOMOVIMENTO='13') THEN 'grey'       
       WHEN PEDIDO.dataemissao IS NOT NULL THEN 'blak'       
       ELSE 'blue' END AS  p_cor
FROM 
    PEDIDO 
INNER JOIN 
    CADASTROPARCEIROS CADCLI ON
        CADCLI.CADASTRO = PEDIDO.DESTINATARIO
INNER JOIN 
    MERCADORIASPED ON 
        MERCADORIASPED.FILIAL = PEDIDO.FILIAL AND 
        MERCADORIASPED.IDNOTA = PEDIDO.IDNOTA        
LEFT JOIN 
    CADASTROPARCEIROS CADTRANS ON   
        CADTRANS.CADASTRO = PEDIDO.CODIGOTRANSP
WHERE
    PEDIDO.FILIAL=1 AND PEDIDO.DATAREFERENCIA >= CAST('NOW' AS DATE)-30
order by
    PEDIDO.IDNOTA DESC