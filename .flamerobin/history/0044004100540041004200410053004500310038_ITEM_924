
SELECT
    MATERIALLOTE.FILIAL,
    MATERIALLOTE.IDITEM,
    MATERIALLOTE.LOTE,
    COALESCE((SELECT SUM(MATERIALMOVIMENTOESTOQUE.QUANTIDADE*MATERIALMOVIMENTOESTOQUE.SINAL)
     FROM MATERIALMOVIMENTOESTOQUE
     WHERE MATERIALMOVIMENTOESTOQUE.FILIAL=MATERIALLOTE.FILIAL
     AND MATERIALMOVIMENTOESTOQUE.iditem=MATERIALLOTE.iditem
     and MATERIALMOVIMENTOESTOQUE.lote=MATERIALLOTE.lote),0),
     
    COALESCE((SELECT SUM(MATERIALMOVIMENTOESTOQUE.VALOR*MATERIALMOVIMENTOESTOQUE.SINAL)
     FROM MATERIALMOVIMENTOESTOQUE
     WHERE MATERIALMOVIMENTOESTOQUE.FILIAL=MATERIALLOTE.FILIAL
     AND MATERIALMOVIMENTOESTOQUE.iditem=MATERIALLOTE.iditem
     and MATERIALMOVIMENTOESTOQUE.lote=MATERIALLOTE.lote),0) 
FROM      
    MATERIALLOTE

     WHERE FILIAL=1
     AND IDITEM BETWEEN '01.' AND '09.99.9999'

