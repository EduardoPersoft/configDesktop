update
    ITEMCUSTODATA
set
    ITEMCUSTODATA.CUSTOUNITARIO=(SELECT
                                    C_CUSTOMEDIO.CUSTO
                                 from  
                                    C_CUSTOMEDIO
                                 WHERE 
                                    C_CUSTOMEDIO.IDITEM=ITEMCUSTODATA.CODIGO)
where
    ITEMCUSTODATA.FILIAL=110 and
    ITEMCUSTODATA.DATAINVENTARIO = '31.12.2023' and
    ITEMCUSTODATA.CODIGO IN ('MPP01METHBG14', 'MPP01METHBG14', 'MPP03MET1G27')
    
    