    SELECT
        C_COMISSAOPEDIDOPAGA.VENDEDOR,
        CADVEN.NOME,
        SUM(C_COMISSAOPEDIDOPAGA.BASECOMISSAO) BASECOMISSAO,
        SUM(C_COMISSAOPEDIDOPAGA.VALORCOMISSAO) VALORCOMISSAO,
        CASE CADVEN.C_TABELACOMISSAO WHEN 3 THEN
		(SELECT CADLOJA.NOME FROM CADASTROPARCEIROS CADLOJA,PEDIDO
         WHERE PEDIDO.FILIAL=MIN(C_COMISSAOPEDIDOPAGA.FILIAL )
         AND PEDIDO.IDNOTA=MIN(C_COMISSAOPEDIDOPAGA.IDNOTA)
         AND CADLOJA.CADASTRO=PEDIDO.C_LOJA)
		ELSE
		(SELECT CADLOJA.NOME FROM CADASTROPARCEIROS CADLOJA
         WHERE CADLOJA.CADASTRO=VENDEDOR.CANALRELACIONADO) 
		 END AS LOJA,
        MIN(COALESCE(C_COMISSAOPEDIDOPAGA.IMPRESSA ,'N')) AS IMPRESSA
    FROM
        C_COMISSAOPEDIDOPAGA
    INNER join
        CADASTROPARCEIROS CADVEN ON  CADVEN.CADASTRO = C_COMISSAOPEDIDOPAGA.VENDEDOR
	LEFT JOIN
		VENDEDOR ON 
		   VENDEDOR.CADASTRO=CADVEN.CADASTRO
    LEFT join
        TITPAGCOMISSOES on
            titpagcomissao.filial=c_comissaopedidopaga.filial and
            tippagcomissao.idComissao=c_comissaopedidopaga.id and
            titpagcomissao.vendedor=c_comissaopedidopaga.vendedor 
    WHERE
        C_COMISSAOPEDIDOPAGA.ID = ?
    GROUP BY
        C_COMISSAOPEDIDOPAGA.VENDEDOR,
        CADVEN.C_TABELACOMISSAO,
        VENDEDOR.CANALRELACIONADO,
        CADVEN.NOME
   ORDER BY 5,
        CADVEN.NOME
