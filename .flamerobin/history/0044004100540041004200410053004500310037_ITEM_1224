select   
    materiallocal.filial,
    materiallocal.idlocal,
    local.DESCRICAO,    
    itemestoque.codigo,
    itemestoque.referencia,
    itemestoque.descricao,
    materiallocal.SALDOTOTAL,
    (select
        max(INVENTARIOESTOQUEDATA.DATA)
     from 
        INVENTARIOESTOQUEDATA
     where
        inventarioestoquedata.filial=materiallocal.filial and
        inventarioestoquedata.idlocal=materiallocal.IDLOCAL and
        inventarioestoquedata.codigo=materiallocal.iditem)
from
    MATERIALLOCAL
inner join
    local on 
        materiallocal.IDLOCAL=local.ID
inner join
    itemestoque on
        itemestoque.codigo=materiallocal.IDITEM
left join
    INVENTARIOESTOQUEDATA i1 on
        i1.filial=materiallocal.filial and
        i1.CODIGO=materiallocal.iditem and
        i1."LOCAL"=materiallocal.IDLOCAL and
        i1.data = (select 
                        max(i2.data)
                   from
                        INVENTARIOESTOQUEDATA i2
                   where 
                    i1.filial=materiallocal.filial and
        i1.CODIGO=materiallocal.iditem and
        i1."LOCAL"=materiallocal.IDLOCAL and

                        i1
                    
                    
where
    materiallocal.filial=1 and
    materiallocal.SALDOtotal <> 0