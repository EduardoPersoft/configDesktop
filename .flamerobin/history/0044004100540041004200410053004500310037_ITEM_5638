select
    MOVIMENTOESTOQUE.documento,
    c_coletas.datacoleta,
    movimentoestoque.COLETADATA
from
    c_Coletas
inner join
    MOVIMENTOESTOQUE on
        MOVIMENTOESTOQUE.coleta=c_coletas.coleta and
        movimentoestoque.TIPOMOVIMENTO='13' and
        cast(movimentoestoque.COLETADATA as date)<>c_coletas.datacoleta
where
    movimentoestoque.coletadata between '29.09.2025' and '30.09.2025'
