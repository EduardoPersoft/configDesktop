SELECT 
    DISTINCT
    NOTAFISCAL.C_TRANSP_DOCUMENTO,
    NOTAFISCAL.C_TRANSP_NOME,
    NOTAFISCAL.C_TRANSP_IE,
    SUBSTRING(NOTAFISCAL.C_TRANSP_LOGRADOURO FROM 1 FOR 60),
    NOTAFISCAL.C_TRANSP_CIDADE,
    NOTAFISCAL.C_TRANSP_UF
FROM    
    NOTAFISCAL
WHERE
    NOTAFISCAL.C_TRANSP_DOCUMENTO IS NOT NULL