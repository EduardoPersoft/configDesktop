SELECT
    item.codigo,
    item.descricao,
    CADASTROPARCEIROS.nome,    
    estrutura.codigo,
    estrutura.descricao
FROM
    itemestoque item 
left JOIN
    cadastroparceiros on
        CADASTROPARCEIROS.cadastro=item.C_CLIENTE
left JOIN   
    itemestoque estrutura on
        estrutura.codigo=item.base
WHERE
    item.tipoproduto=4
        
        