update
    MATERIALMOVIMENTOESTOQUE
set
    materialmovimentoestoque.setup = 
            coalesce((
                select 
                    itemestoque.C_SETUPPOUCHE
                from
                    ITEMESTOQUE
                where
                    itemestoque.CODIGO=MATERIALMOVIMENTOESTOQUE.produto),1)/60, 
    MATERIALMOVIMENTOESTOQUE.tempo= materialmovimentoestoque.quantidade*1000/
        coalesce((
            select 
                itemestoque.C_VELOCIDADEPOUCHE
            from
                ITEMESTOQUE
            where
                itemestoque.CODIGO=MATERIALMOVIMENTOESTOQUE.produto),1)/75
where 
    MATERIALMOVIMENTOESTOQUE.filial=110 and
    MATERIALMOVIMENTOESTOQUE.idmovimento=66886
    
