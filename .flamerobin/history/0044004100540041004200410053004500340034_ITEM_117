SET TERM ^ ;
ALTER PROCEDURE GENERATORESTABELECIMENTO (
    FILIAL integer,
    NOME varchar(20),
    SALTO integer )
RETURNS (
    VALOR integer,
    "DATA" date,
    DATAHORA timestamp )

AS
BEGIN

  data = cast('now' as date);
  dataHora = cast('now' as date); 

  if (NOME='MOVIMENTO') then
  BEGIN
    SELECT ESTABELECIMENTO.Idmovtoestoque FROM ESTABELECIMENTO
    WHERE ESTABELECIMENTO.CADASTRO=:FILIAL WITH LOCK
    INTO :VALOR;

    UPDATE ESTABELECIMENTO SET ESTABELECIMENTO.Idmovtoestoque=:VALOR + :Salto
    WHERE ESTABELECIMENTO.CADASTRO=:FILIAL;

  END
  if (NOME='RECEBER') then
  BEGIN
    SELECT ESTABELECIMENTO.Idtituloreceber FROM ESTABELECIMENTO
    WHERE ESTABELECIMENTO.CADASTRO=:FILIAL WITH LOCK
    INTO :VALOR;

    UPDATE ESTABELECIMENTO SET ESTABELECIMENTO.Idtituloreceber=:VALOR + :Salto
    WHERE ESTABELECIMENTO.CADASTRO=:FILIAL;

  END
  if (NOME='PAGAR') then
  BEGIN
    SELECT ESTABELECIMENTO.Idtitulopagar FROM ESTABELECIMENTO
    WHERE ESTABELECIMENTO.CADASTRO=:FILIAL WITH LOCK
    INTO :VALOR;

    UPDATE ESTABELECIMENTO SET ESTABELECIMENTO.IdtituloPAGAR=:VALOR + :Salto
    WHERE ESTABELECIMENTO.CADASTRO=:FILIAL;

  END


  if (NOME='PEDIDO') then
  BEGIN
    SELECT ESTABELECIMENTO.idpedido FROM ESTABELECIMENTO
    WHERE ESTABELECIMENTO.CADASTRO=:FILIAL WITH LOCK
    INTO :VALOR;

    UPDATE ESTABELECIMENTO SET ESTABELECIMENTO.IDPEDIDO=:VALOR + :Salto
    WHERE ESTABELECIMENTO.CADASTRO=:FILIAL;

  END
  if (NOME='ORCAMENTO') then
  BEGIN
    SELECT ESTABELECIMENTO.IDORCAMENTO FROM ESTABELECIMENTO
    WHERE ESTABELECIMENTO.CADASTRO=:FILIAL WITH LOCK
    INTO :VALOR;

    UPDATE ESTABELECIMENTO SET ESTABELECIMENTO.IDORCAMENTO=:VALOR + :Salto
    WHERE ESTABELECIMENTO.CADASTRO=:FILIAL;

  END

  if (NOME='PEDIDOCOMPRA') then
  BEGIN
    SELECT ESTABELECIMENTO.IDPEDIDOCOMPRA FROM ESTABELECIMENTO
    WHERE ESTABELECIMENTO.CADASTRO=:FILIAL WITH LOCK
    INTO :VALOR;

    UPDATE ESTABELECIMENTO SET ESTABELECIMENTO.IDPEDIDOCOMPRA=:VALOR + :Salto
    WHERE ESTABELECIMENTO.CADASTRO=:FILIAL;

  END

  if (NOME='NOTACOMPRA') then
  BEGIN
    SELECT ESTABELECIMENTO.IDNOTACOMPRA FROM ESTABELECIMENTO
    WHERE ESTABELECIMENTO.CADASTRO=:FILIAL WITH LOCK
    INTO :VALOR;

    UPDATE ESTABELECIMENTO SET ESTABELECIMENTO.IDNOTACOMPRA=:VALOR + :Salto
    WHERE ESTABELECIMENTO.CADASTRO=:FILIAL;

  END

  if (NOME='NOTAFISCAL') then
  BEGIN
    SELECT ESTABELECIMENTO.IDNOTAFISCAL FROM ESTABELECIMENTO
    WHERE ESTABELECIMENTO.CADASTRO=:FILIAL WITH LOCK
    INTO :VALOR;

    UPDATE ESTABELECIMENTO SET ESTABELECIMENTO.IDNOTAFISCAL=:VALOR + :Salto
    WHERE ESTABELECIMENTO.CADASTRO=:FILIAL;

  END

  if (NOME='CADASTROPARCEIROS') then
  BEGIN
    SELECT COALESCE(MAX(CADASTRO),0) FROM CADASTROPARCEIROS
    INTO :VALOR;
  END
  if (NOME='LOTERELATORIOS') then
  BEGIN
    SELECT COALESCE(MAX(ID),0) FROM LOTERELATORIOS
    INTO :VALOR;
  END
  
  if (NOME='COMENTARIOS') then 
  BEGIN
    valor=GEN_ID("G_COMENTARIO",salto);
  end

  if (NOME='TICKET') then 
  BEGIN
    valor=GEN_ID("G_TICKET",salto);
  end

  if (NOME='EANLOTE') then 
  BEGIN
    valor=GEN_ID("CODIGOBARRALOTES",salto);
  end

  VALOR = VALOR +1;
  SUSPEND;
END
^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE GENERATORESTABELECIMENTO TO  SYSDBA;

