SELECT 
    M1.FILIAL,
    M1.IDNOTA,
    M1.CODIGO,
    M1.IDMERCADORIA,
    M1.DESREDUZIDA,
    PEDIDOCOMPRA.DESTINATARIO,
    PEDIDOCOMPRA.DATACADASTRO,
    M1.QUANTIDADE,
    M1.QUANTIDADE,
    M1.QTDEENTREGUE,
    M1.MINIMOBAIXA,
    M1.BAIXA
FROM 
    MERCADORIASPEDCOMPRA M1
INNER JOIN
    PEDIDOCOMPRA ON 
        PEDIDOCOMPRA.FILIAL=M1.FILIAL AND
       PEDIDOCOMPRA.IDNOTA=M1.IDNOTA
WHERE
    M1.FILIAL=5 AND
    M1.BAIXA = 'N' AND
    M1.QTDEENTREGUE>0 AND
    EXISTS (
    SELECT * FROM MERCADORIASPEDCOMPRA M2
    WHERE
    M2.FILIAL=M1.FILIAL AND
    M2.CODIGO=M1.CODIGO AND
    M2.IDNOTA<>M1.IDNOTA AND
    M2.BAIXA='N')
ORDER BY
CODIGO