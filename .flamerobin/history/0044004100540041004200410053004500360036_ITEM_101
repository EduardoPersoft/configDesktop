SET TERM ^ ;
ALTER PROCEDURE SPEDFISCALTOTALIZA

AS
declare variable v_totalregistros integer;
declare variable sequencia9 integer;
declare variable segmento char(4);
declare variable qtd_lin integer;


BEGIN
  /* write your code here */ 

    insert into SPEDFISCAL_G (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, IND_MOV)
    values (1, 'G001', 0, 1, 1);

    insert into SPEDFISCAL_G (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, QTD_LIN)
    values (2, 'G990', 0, 1, 2);

    insert into SPEDFISCAL_1 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, IND_MOV)
    values (1, '1001', 0, 1, 0);

    insert into SPEDFISCAL_1 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, QTD_LIN)
    values (2, '1010', 0, 2, 2);

    insert into SPEDFISCAL_1 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, QTD_LIN)
    values (3, '1990', 0, 1, 3);

    V_TOTALREGISTROS = 0;
    SEQUENCIA9 = 1;
    insert into SPEDFISCAL_9 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, IND_MOV)
    values (:SEQUENCIA9, '9001', 0, 1, 0);

    for select SPEDFISCAL_0.SEGMENTO, count(SPEDFISCAL_0.SEQUENCIA)
        from SPEDFISCAL_0
        group by SPEDFISCAL_0.SEGMENTO
        into :SEGMENTO, :QTD_LIN
    do
    begin
      V_TOTALREGISTROS = V_TOTALREGISTROS + QTD_LIN;
      SEQUENCIA9 = SEQUENCIA9 + 1;
      insert into SPEDFISCAL_9 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, REG_BLC, QTD_LIN)
      values (:SEQUENCIA9, '9900', 0, 2, :SEGMENTO, :QTD_LIN);
    end

    for select SPEDFISCAL_0.SEGMENTO, count(SPEDFISCAL_0.SEQUENCIA)
        from SPEDFISCAL_A SPEDFISCAL_0
        group by SPEDFISCAL_0.SEGMENTO
        into :SEGMENTO, :QTD_LIN
    do
    begin
      V_TOTALREGISTROS = V_TOTALREGISTROS + QTD_LIN;
      SEQUENCIA9 = SEQUENCIA9 + 1;
      insert into SPEDFISCAL_9 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, REG_BLC, QTD_LIN)
      values (:SEQUENCIA9, '9900', 0, 2, :SEGMENTO, :QTD_LIN);
    end
    
    ---
    for select SPEDFISCAL_0.SEGMENTO, count(SPEDFISCAL_0.SEQUENCIA)
        from SPEDFISCAL_B SPEDFISCAL_0
        group by SPEDFISCAL_0.SEGMENTO
        into :SEGMENTO, :QTD_LIN
    do
    begin
      V_TOTALREGISTROS = V_TOTALREGISTROS + QTD_LIN;
      SEQUENCIA9 = SEQUENCIA9 + 1;
      insert into SPEDFISCAL_9 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, REG_BLC, QTD_LIN)
      values (:SEQUENCIA9, '9900', 0, 2, :SEGMENTO, :QTD_LIN);
    end
    ---
    for select SPEDFISCAL_0.SEGMENTO, count(SPEDFISCAL_0.SEQUENCIA)
        from SPEDFISCAL_C SPEDFISCAL_0
        where segmento <> '_101'
        group by SPEDFISCAL_0.SEGMENTO
        into :SEGMENTO, :QTD_LIN
    do
    begin
      V_TOTALREGISTROS = V_TOTALREGISTROS + QTD_LIN;
      SEQUENCIA9 = SEQUENCIA9 + 1;
      insert into SPEDFISCAL_9 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, REG_BLC, QTD_LIN)
      values (:SEQUENCIA9, '9900', 0, 2, :SEGMENTO, :QTD_LIN);
    end

    for select SPEDFISCAL_0.SEGMENTO, count(SPEDFISCAL_0.SEQUENCIA)
        from SPEDFISCAL_D SPEDFISCAL_0
        group by SPEDFISCAL_0.SEGMENTO
        into :SEGMENTO, :QTD_LIN
    do
    begin
      V_TOTALREGISTROS = V_TOTALREGISTROS + QTD_LIN;
      SEQUENCIA9 = SEQUENCIA9 + 1;
      insert into SPEDFISCAL_9 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, REG_BLC, QTD_LIN)
      values (:SEQUENCIA9, '9900', 0, 2, :SEGMENTO, :QTD_LIN);
    end

    for select SPEDFISCAL_0.SEGMENTO, count(SPEDFISCAL_0.SEQUENCIA)
        from SPEDFISCAL_E SPEDFISCAL_0
        group by SPEDFISCAL_0.SEGMENTO
        into :SEGMENTO, :QTD_LIN
    do
    begin
      V_TOTALREGISTROS = V_TOTALREGISTROS + QTD_LIN;
      SEQUENCIA9 = SEQUENCIA9 + 1;
      insert into SPEDFISCAL_9 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, REG_BLC, QTD_LIN)
      values (:SEQUENCIA9, '9900', 0, 2, :SEGMENTO, :QTD_LIN);
    end

    for select SPEDFISCAL_0.SEGMENTO, count(SPEDFISCAL_0.SEQUENCIA)
        from SPEDFISCAL_G SPEDFISCAL_0
        group by SPEDFISCAL_0.SEGMENTO
        into :SEGMENTO, :QTD_LIN
    do
    begin
      V_TOTALREGISTROS = V_TOTALREGISTROS + QTD_LIN;
      SEQUENCIA9 = SEQUENCIA9 + 1;
      insert into SPEDFISCAL_9 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, REG_BLC, QTD_LIN)
      values (:SEQUENCIA9, '9900', 0, 2, :SEGMENTO, :QTD_LIN);
    end
    for select SPEDFISCAL_0.SEGMENTO, count(SPEDFISCAL_0.SEQUENCIA)
        from SPEDFISCAL_H SPEDFISCAL_0
        group by SPEDFISCAL_0.SEGMENTO
        into :SEGMENTO, :QTD_LIN
    do
    begin
      V_TOTALREGISTROS = V_TOTALREGISTROS + QTD_LIN;
      SEQUENCIA9 = SEQUENCIA9 + 1;
      insert into SPEDFISCAL_9 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, REG_BLC, QTD_LIN)
      values (:SEQUENCIA9, '9900', 0, 2, :SEGMENTO, :QTD_LIN);
    end

    for select SPEDFISCAL_0.SEGMENTO, count(SPEDFISCAL_0.SEQUENCIA)
        from SPEDFISCAL_K SPEDFISCAL_0
        group by SPEDFISCAL_0.SEGMENTO
        into :SEGMENTO, :QTD_LIN
    do
    begin
      V_TOTALREGISTROS = V_TOTALREGISTROS + QTD_LIN;
      SEQUENCIA9 = SEQUENCIA9 + 1;
      insert into SPEDFISCAL_9 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, REG_BLC, QTD_LIN)
      values (:SEQUENCIA9, '9900', 0, 2, :SEGMENTO, :QTD_LIN);
    end

    for select SPEDFISCAL_0.SEGMENTO, count(SPEDFISCAL_0.SEQUENCIA)
        from SPEDFISCAL_1 SPEDFISCAL_0
        group by SPEDFISCAL_0.SEGMENTO
        into :SEGMENTO, :QTD_LIN
    do
    begin
      V_TOTALREGISTROS = V_TOTALREGISTROS + QTD_LIN;
      SEQUENCIA9 = SEQUENCIA9 + 1;
      insert into SPEDFISCAL_9 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, REG_BLC, QTD_LIN)
      values (:SEQUENCIA9, '9900', 0, 2, :SEGMENTO, :QTD_LIN);
    end

    for select SPEDFISCAL_0.SEGMENTO, count(SPEDFISCAL_0.SEQUENCIA)
        from SPEDFISCAL_9 SPEDFISCAL_0
        where SEGMENTO <> '9900'
        group by SPEDFISCAL_0.SEGMENTO
        into :SEGMENTO, :QTD_LIN
    do
    begin
      V_TOTALREGISTROS = V_TOTALREGISTROS + QTD_LIN;
      SEQUENCIA9 = SEQUENCIA9 + 1;
      insert into SPEDFISCAL_9 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, REG_BLC, QTD_LIN)
      values (:SEQUENCIA9, '9900', 0, 2, :SEGMENTO, :QTD_LIN);
    end

    select SPEDFISCAL_0.SEGMENTO, count(SPEDFISCAL_0.SEQUENCIA)
    from SPEDFISCAL_9 SPEDFISCAL_0
    where SEGMENTO = '9900'
    group by SPEDFISCAL_0.SEGMENTO
    into :SEGMENTO, :QTD_LIN;
    V_TOTALREGISTROS = V_TOTALREGISTROS + QTD_LIN + 1;
    QTD_LIN = QTD_LIN + 3;
    SEQUENCIA9 = SEQUENCIA9 + 1;
    insert into SPEDFISCAL_9 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, REG_BLC, QTD_LIN)
    values (:SEQUENCIA9, '9900', 0, 2, :SEGMENTO, :QTD_LIN);

    QTD_LIN = 1;
    V_TOTALREGISTROS = V_TOTALREGISTROS + QTD_LIN;
    SEQUENCIA9 = SEQUENCIA9 + 1;
    insert into SPEDFISCAL_9 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, REG_BLC, QTD_LIN)
    values (:SEQUENCIA9, '9900', 0, 2, '9990', :QTD_LIN);

    QTD_LIN = 1;
    V_TOTALREGISTROS = V_TOTALREGISTROS + QTD_LIN;
    SEQUENCIA9 = SEQUENCIA9 + 1;
    insert into SPEDFISCAL_9 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, REG_BLC, QTD_LIN)
    values (:SEQUENCIA9, '9900', 0, 2, '9999', :QTD_LIN);

    V_TOTALREGISTROS = V_TOTALREGISTROS + 1;
    SEQUENCIA9 = SEQUENCIA9 + 1;
    insert into SPEDFISCAL_9 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, REG_BLC, QTD_LIN)
    values (:SEQUENCIA9, '9990', 0, 1, :SEGMENTO, :SEQUENCIA9 + 1);

    V_TOTALREGISTROS = V_TOTALREGISTROS + 1;
    SEQUENCIA9 = SEQUENCIA9 + 1;
    insert into SPEDFISCAL_9 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, REG_BLC, QTD_LIN)
    values (:SEQUENCIA9, '9999', 0, 0, :SEGMENTO, :V_TOTALREGISTROS);
 
END
^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE SPEDFISCALTOTALIZA TO  SYSDBA;

