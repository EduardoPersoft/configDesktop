select 
    MERCADORIASNOTA.*
FROM
    MERCADORIASNOTA
INNER JOIN
    NOTAFISCAL ON 
        NOTAFISCAL.FILIAL=MERCADORIASNOTA.FILIAL
        AND NOTAFISCAL.IDNOTA=MERCADORIASNOTA.IDNOTA
WHERE
    notafiscal.filial=5 AND
    notafiscal.DATAEMISSAO between '01.03.2021' and '31.03.2021' 
ORDER BY
    idnota desc
    