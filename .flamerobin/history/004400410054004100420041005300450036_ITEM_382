SELECT 
    c_itemlocalimp.CODIGO,
    ITEMESTOQUE.C_MRFORNECEDOR,
    ITEMESTOQUE.DESCRICAO,
    C_ITEMLOCALIMP.LOCAL,
    MATERIALLOCAL.SALDOTOTAL
FROM 
    C_ITEMLOCALIMP
INNER JOIN 
    MATERIALLOCAL ON
        MATERIALLOCAL.FILIAL=1 AND
        MATERIALLOCAL.IDLOCAL=1 AND
        MATERIALLOCAL.IDITEM=C_ITEMLOCALIMP.CODIGO
INNER JOIN
    ITEMESTOQUE ON
        ITEMESTOQUE.CODIGO=C_ITEMLOCALIMP.CODIGO
where 
    materiallocal.saldototal>0
ORDER BY
    C_ITEMLOCALIMP.LOCAL,
    ITEMESTOQUE.CODIGO
    
        
