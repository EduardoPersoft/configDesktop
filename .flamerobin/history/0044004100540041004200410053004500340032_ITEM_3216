select
    materialmovimentoestoque.*,
    (coalesce(materialmovimentoestoque.C_METROS,0)*
      coalesce((select 
         itemestoque.C_VELOCIDADEIMPRESSAO
       from
         ITEMESTOQUE
       where
         itemestoque.codigo=MATERIALMOVIMENTOESTOQUE.iditem),0))+
       coalesce((select 
         itemestoque.C_setupIMPRESSAO
       from
         ITEMESTOQUE
       where
         itemestoque.codigo=MATERIALMOVIMENTOESTOQUE.iditem),0)         
from
    MATERIALMOVIMENTOESTOQUE
where 
    MATERIALMOVIMENTOESTOQUE.filial=110 and
    MATERIALMOVIMENTOESTOQUE.concluido='N' and
    MATERIALMOVIMENTOESTOQUE.idcentrocusto='101'
    