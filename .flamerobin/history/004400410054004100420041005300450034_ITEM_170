SELECT DISTINCT PEDIDO.FILIAL,
       PEDIDO.IDNOTA,
       PEDIDO.DATACADASTRO,
       PEDIDO.VLRTOTALNOTA,
       CADLOJA.NOME,
       CADCLI.CADASTRO,
       CADCLI.RAZAOSOCIAL,
       CADCLI.NOME,
       CADCLI.DOCUMENTO,
       LIBERACAO AS DATALIBERACAOFINANCEIRO,
       case when  c_faturasped.Idtitulo is  null then 0
       else 8421504
       end as P_STATUSCOR,

       C_MALOTEFIN.DATA DATAFIN,
       C_MALOTEPAPEL.DATA DATAPED

FROM C_MALOTE C_MALOTEFIN
INNER JOIN C_FATURASPED ON (C_FATURASPED.C_Malote=C_MALOTEFIN.Malote)
INNER JOIN PEDIDO On (C_FATURASPED.FILIAL=PEDIDO.FILIAL
    AND C_FATURASPED.IDNOTA=PEDIDO.IDNOTA)
INNER JOIN Cadastroparceiros CADLOJA ON (CADLOJA.CADASTRO=PEDIDO.C_Loja)
INNER JOIN CADASTROPARCEIROS CADCLI ON
           (CADCLI.CADASTRO=PEDIDO.DESTINATARIO)
LEFT JOIN C_MALOTE C_MALOTEPAPEL ON (
    C_MALOTEPAPEL.Malote=PEDIDO.C_Malote)
WHERE  C_FATURASPED.FILIAL=1
AND C_MALOTEFIN.Data BETWEEN '01.01.2020' AND '31.12.2021'
AND PEDIDO.DATACANCELAMENTO IS NULL
and pedido.idnota='61894'   