select
    MOVBANCARIOS.filial,
    MOVBANCARIOS.idcontacorrente as contacorrente,
    ccMovto.DESCRICAOCONTA,
    movbancarios.DATAEXTRATO,
    movbancarios.HISTORICOEXTRATO,
    movbancarios.VALORMOVIMENTO*case movbancarios.TIPOMOVIMENTO when 'C' then 1 else -1 end as valor,
    movbancarios.tipomovimento cd,
    case movbancarios.TRANSFERENCIA when 'S' then 'Transferencia' else '' end as tipo,
    ccTransf.DESCRICAOCONTA as contaTransferencia
    
from
    MOVBANCARIOS
inner join
    contacorrente ccMovto on 
        ccMovto.filial=movbancarios.filial and
        ccMovto.codigo=movbancarios.idcontacorrente
inner join
    contacorrente ccTransf on 
        ccTransf.filial=movbancarios.filial and
        ccTransf.codigo=movbancarios.CONTACORRENTEDEST
       
where 
    MOVBANCARIOS.filial=1 and
    MOVBANCARIOS.IDCONTACORRENTE = 341 and
    MOVBANCARIOS.DATAEXTRATO between '01.01.2022' and '31.01.2022'