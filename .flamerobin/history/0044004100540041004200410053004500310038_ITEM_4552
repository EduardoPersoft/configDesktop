select 
    contadre.contacontabil,
    lantocontpag.*
from
    TITULOPAG

inner join 
    ESTABELECIMENTO on 
    TITULOPAG.FILIAL=ESTABELECIMENTO.CADASTRO 
inner join
    LANTOCONTPAG on 
        lantocontpag.filial=titulopag.Filial and 
        lantocontpag.IDMOVTOBANC=titulopag.idtitulo
inner join 
    CONTASCONTABEIS contaDre on
    ESTABELECIMENTO.PLANOCONTAS=contaDre.IDPLANO and 
    lantocontpag.contacontabil = contaDre.CONTACONTABIL
where
    TITULOPAG.DATAREFERENCIA between '01.01.2026'  and '31.01.2026'
order by
    lantocontpag.contacontabil,
    lantocontpag.IDMOVTOBANC

