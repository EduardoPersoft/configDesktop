select 
    mercadoriasnota.*
FROM
    notacompra NOTAFISCAL 
inner JOIN
    mercadoriasnotacompra mercadoriasnota on 
        mercadoriasnota.filial=notafiscal.filial AND
        mercadoriasnota.idnota=notafiscal.IDNOTA
WHERE
    mercadoriasnota.filial=1 AND
    notafiscal.DATAENTRADA >='01.09.2021' and 
    substring(mercadoriasnota.cfop from 1 for 1) in (1, 2) AND
    mercadoriasnota.cstpis<50 
order by
    idnota