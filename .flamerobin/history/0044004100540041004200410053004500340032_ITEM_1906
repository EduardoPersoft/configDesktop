select 
    materialmovimentoestoque.iditem,
    sum(materialmovimentoestoque.quantidade*
        materialmovimentoestoque.SINAl)
from 
    MATERIALMOVIMENTOESTOQUE
inner join 
    MOVIMENTOESTOQUE on
        movimentoestoque.filial=materialmovimentoestoque.filial and
        movimentoestoque.idmovimento=materialmovimentoestoque.CENTROCUSTO
where
    movimentoestoque.TIPOMOVIMENTO in ('17', '10', '11') and
    movimentoestoque.LOCALARMAZENAMENTO <> 2 and
    movimentoestoque.LOCALTRANSFERENCIA <> 2 
group by    
    materialmovimentoestoque.iditem