select 
    materialmovimentoestoque.*
from
    MATERIALMOVIMENTOESTOQUE
where
    materialmovimentoestoque.filial=7 and
    materialmovimentoestoque.iditem like 'INT%' and
    exists (
        select
            *
        from
            MOVIMENTOESTOQUE
        where 
            movimentoestoque.filial=MATERIALMOVIMENTOESTOQUE.filial and
            movimentoestoque.idmovimento=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO and
            movimentoestoque.TIPOMOVIMENTO in ('09', '04'))