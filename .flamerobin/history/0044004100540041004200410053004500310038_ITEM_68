SELECT
    mercadoriasnota.*
FROM
    NOTAfiscal
inner JOIN
    mercadoriasnota on
        mercadoriasnota.filial=notafiscal.filial AND
        mercadoriasnota.idnota=notafiscal.idnota
WHERE
    notafiscal.filial=1 AND
    notafiscal.dataemissao between '01.09.2021' and '30.09.2021' AND
    mercadoriasnota.cfop= '5924'