SELECT CAST('MERCADORIAS' AS VARCHAR(30)) TIPO, 0 AS CODIGO,
SUM(CASE WHEN (MERCADORIASPED.QTDEENVIADA-MERCADORIASPED.MINIMO)>1 THEN 0
    WHEN MERCADORIASPED.QTDEENVIADA = 0 THEN
        (COALESCE(MERCADORIASPED.VLRFINALMERCAD,0) +
        COALESCE(MERCADORIASPED.VALORIPI,0) +
        COALESCE(MERCADORIASPED.FRETE,0)+
        COALESCE(MERCADORIASPED.SEGURO,0)+
        COALESCE(MERCADORIASPED.OUTDESPACESSOR,0) +
        COALESCE(MERCADORIASPED.ACRESCIMONOTA,0) +
        COALESCE(MERCADORIASPED.VLRICMSRECOLHIDO,0)) -
        (COALESCE(MERCADORIASPED.VLRDESCPRODUTO,0)+
        COALESCE(MERCADORIASPED.DESCONTONOTA,0) +
        COALESCE(CASE PEDIDO.ZONAFRANCA WHEN 'S' THEN MERCADORIASPED.VALORICMS
                              ELSE 0 END,0) )
    ELSE
        (COALESCE(MERCADORIASPED.VLRFINALMERCAD,0) +
        COALESCE(MERCADORIASPED.VALORIPI,0) +
        COALESCE(MERCADORIASPED.FRETE,0)+
        COALESCE(MERCADORIASPED.SEGURO,0)+
        COALESCE(MERCADORIASPED.OUTDESPACESSOR,0) +
        COALESCE(MERCADORIASPED.ACRESCIMONOTA,0) +
        COALESCE(MERCADORIASPED.VLRICMSRECOLHIDO,0)) -
        (COALESCE(MERCADORIASPED.VLRDESCPRODUTO,0)+
        COALESCE(MERCADORIASPED.DESCONTONOTA,0) +
        COALESCE(CASE PEDIDO.ZONAFRANCA WHEN 'S' THEN MERCADORIASPED.VALORICMS
        ELSE 0 END,0) )*(MERCADORIASPED.QUANTIDADE-MERCADORIASPED.QTDEENVIADA)
    END) TOTAL
FROM PEDIDO
INNER JOIN MERCADORIASPED ON (MERCADORIASPED.FILIAL = PEDIDO.FILIAL
    AND MERCADORIASPED.IDNOTA = PEDIDO.IDNOTA)
WHERE PEDIDO.FILIAL=110
AND     PEDIDO.DESTINATARIO=3164
AND     MERCADORIASPED.BAIXA='N'
AND     PEDIDO.CANCELAMENTO ='N'
GROUP BY PEDIDO.DESTINATARIO
