SELECT 
    MATERIALLOCAL.FILIAL,
    
    LOCALORIGEM.ID,
    LOCALORIGEM.DESCRICAO,

    LOCALDESTINO.ID,
    LOCALDESTINO.DESCRICAO,
    
    MATERIALLOCAL.IDITEM,
    ITEMESTOQUE.CODIGOBARRA,
    ITEMESTOQUE.DESCRICAO, 
    
    MATERIALLOCAL.SALDOTOTAL
    
FROM 
    MATERIALLOCAL
INNER join
    LOCAL LOCALORIGEM ON
        LOCALORIGEM.ID=MATERIALLOCAL.IDLOCAL
INNER join
    T_LOCAIS ON
        T_LOCAIS.ID=MATERIALLOCAL.IDLOCAL
INNER join
    LOCAL LOCALDESTINO ON
        LOCALDESTINO.ID=T_LOCAIS.LOCALDESTINO
where
    MATERIALLOCAL.SALDOTOTAL>0