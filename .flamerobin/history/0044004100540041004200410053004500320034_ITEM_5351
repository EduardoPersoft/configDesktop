SELECT
    CADCLI.CADASTRO,
    count(titulorec.idtitulo)
FROM
        TITULOREC
inner JOIN
    cadastroparceiros cadcli on
        cadcli.cadastro = titulorec.PARCEIRO
inner JOIN
    clientes on
        clientes.cadastro = cadcli.CADASTRO
left JOIN
    vendedor on
        vendedor.cadastro = clientes.VENDEDOR AND
        vendedor.NOTIFICARVENDEDOR = 'S'
left JOIN
    CADASTROPARCEIROS cadven on
        cadven.cadastro=vendedor.CADASTRO
WHERE
    titulorec.DATAENVIO is null
    and titulorec.baixa is null 
	and titulorec.linhadigitavel is not null 
	and coalesce(titulorec.codretorno,'03') <> '03'
	and coalesce(COALESCE(CLIENTES.EMAILCOBRANCA,COALESCE(CADCLI.EMAILNFE, CADCLI.EMAIL)),'') <> ''
group by
    cadcli.cadastro