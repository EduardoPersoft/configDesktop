SET TERM ^ ;
ALTER PROCEDURE C_ESTOQUEINATIVO (
    FILIAL integer )
RETURNS (
    CODIGO varchar(8),
    DESCRICAO varchar(240),
    C_MRFORNECEDOR varchar(20),
    C_ORIGINAL varchar(80),
    MARCA varchar(20),
    C_APLICACAO varchar(100),
    FORNECEDOR varchar(30),
    PRECOA double precision,
    PRECOB double precision,
    MLOCAL double precision,
    CLOCAL double precision,
    RESERVADO double precision,
    COR varchar(30),
    TIPOPRODUTO char(1),
    METATAG varchar(400) )

AS
Begin
  For Select itemestoque.codigo,itemestoque.descricao, itemestoque.c_mrfornecedor,
             itemestoque.c_original, c_marca.descricao as marca, itemestoque.c_aplicacao,
             c_fornecedorpeca.descricao as fornecedor, itemestoque.TIPOPRODUTO, itemestoque.METATAG, GRUPOMERCADORIA.C_COR
             
      from itemestoque
      Left join c_marca on (itemestoque.c_marca=c_marca.idmarca)
      Inner join c_fornecedorpeca on (c_fornecedorpeca.id=itemestoque.c_fornecedor)
      left join GRUPOMERCADORIA on itemestoque.GRUPO=GRUPOMERCADORIA.GRUPO
      Into :Codigo, :Descricao, :C_MrFornecedor, :C_Original, :Marca, :C_Aplicacao,
           :Fornecedor, :tipoproduto, :metatag, :cor
      Do Begin
           PrecoA=0;
           PrecoB=0;
           MLocal=0;
           CLocal=0;
           Reservado=0;

           if (filial=1) then begin

               select listaA.preco from listaprecoproduto listaa
               where listaA.produto=:codigo and listaA.lista=2
               into :precoA;
               if (:precoa is null) then
                  precoa=0;

               select listaB.preco from listaprecoproduto listab
               where listaB.produto=:codigo and listaB.lista=3
               into :precob;
               if (:precob is null) then
                  precob=0;
           end


           if (filial=12826) then begin

               select listaA.preco from listaprecoproduto listaa
               where listaA.produto=:codigo and listaA.lista=7
               into :precoA;
               if (:precoa is null) then
                  precoa=0;

               select listaB.preco from listaprecoproduto listab
               where listaB.produto=:codigo and listaB.lista=8
               into :precob;
               if (:precob is null) then
                  precob=0;
           end

           select sum(MLocal.Saldototal) From MaterialLocal MLocal
           where Mlocal.filial=:Filial and
                 Mlocal.iditem=:codigo 
           into :Mlocal;
           If (:Mlocal Is Null) then
              MLocal=0;

           select clocal.saldototal from materiallocal clocal
           where clocal.filial=:Filial and
                 clocal.iditem=:codigo and
                 clocal.idlocal = 2
           into :CLocal;
           If (:CLocal Is Null) then
              CLocal=0;

           select sum(MercadoriasPed.Quantidade) from MercadoriasPed
           Inner Join Pedido On (Mercadoriasped.Filial=Pedido.Filial And
                                 Mercadoriasped.Idnota=Pedido.Idnota)
           Inner Join Naturezaoperacao On (Pedido.Operacao=Naturezaoperacao.Id And
                                           Naturezaoperacao.Estoque='S' And
                                           Naturezaoperacao.Entradasaida='S')
           Where mercadoriasped.filial=:Filial and
                 mercadoriasped.Codigo=:Codigo and
                 MercadoriasPed.Baixa='N'  And
                 Pedido.Datacancelamento Is Null And
                 Pedido.Entradasaida='S'
           Having Not (sum(MercadoriasPed.Quantidade) is null)
           Plan  (MERCADORIASPED INDEX (MERCADORIASPED_IDX1),
                  PEDIDO INDEX (rdb$primary50),
                  NATUREZAOPERACAO INDEX (rdb$primary25))
           Into :Reservado;
           If (:Reservado Is Null) then
              Reservado=0;
      suspend;
   end
End
^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE C_ESTOQUEINATIVO TO  SYSDBA;

