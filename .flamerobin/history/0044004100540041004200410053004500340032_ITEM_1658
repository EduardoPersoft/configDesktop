select 
    composicaoop.*,
    MATERIALMOVIMENTOESTOQUE.*
from
    MOVIMENTOESTOQUE
inner join
    MATERIALMOVIMENTOESTOQUE on
        movimentoestoque.filial=MATERIALMOVIMENTOESTOQUE.filial and
        movimentoestoque.idmovimento=MATERIALMOVIMENTOESTOQUE.idmovimento
inner join
    composicaoop on
        composicaoop.filial=MATERIALMOVIMENTOESTOQUE.filial and
        composicaoop.IDMOVIMENTO=materialmovimentoestoque.idmovimento and
        composicaoop.IDMOVIMENTOMATERIAL=MATERIALMOVIMENTOESTOQUE.idmo 
where
    movimentoestoque.filial=110 and
    movimentoestoque.TIPOMOVIMENTO='12' and
    movimentoestoque.emissao between '01.01.2024' and '31.12.2024'
    