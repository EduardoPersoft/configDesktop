select
    MATERIALMOVIMENTOESTOQUE.QUANTIDADE,
    MERCADORIASNOTA.*
from
    MATERIALMOVIMENTOESTOQUE
INNER join
    MOVIMENTOESTOQUE ON
        MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL and
        MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
inner join
    MERCADORIASNOTA ON
        MOVIMENTOESTOQUE.FILIAL=MERCADORIASNOTA.FILIAL and
        MOVIMENTOESTOQUE.IDNOTAEXPEDICAO=MERCADORIASNOTA.IDNOTA and
        MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL=MERCADORIASNOTA.IDMERCADORIA
where
    MOVIMENTOESTOQUE.FILIAL=5 and
    MOVIMENTOESTOQUE.TIPOMOVIMENTO='13' and
    MATERIALMOVIMENTOESTOQUE.QUANTIDADE<>MERCADORIASNOTA.QUANTIDADE
    