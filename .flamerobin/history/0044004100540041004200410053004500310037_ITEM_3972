select 
    c_fatores.idlocal,
    c_fatores.CFISCAL, 
    CLASSIFICACAOFISCAL.descricao,
    count(c_fatores.IDFATOR)    
from
    c_fatores
inner join 
    classificacaofiscal on 
        (c_fatores.cfiscal=classificacaofiscal.cfiscal)
inner join
    c_localimportacao on
        c_localimportacao.id=c_fatores.id

group by
    c_fatores.idlocal,
    c_fatores.CFISCAL,
    CLASSIFICACAOFISCAL.descricao
having
    count(c_fatores.IDFATOR)>1    