select 
    TITULOREC.PARCEIRO,
    TITULOREC.FILIAL,
    TITULOREC.IDTITULO,
   TITULOREC.VALORTITULO valorTitulo,
   TITULOREC.TOTALPAGO totalPago,
   TITULOREC.TOTALABATIDO abatido,
   TITULOREC.VALOREMABERTO emAberto
from 
    TITULOREC
INNER JOIN 
    ESTABELECIMENTO ON 
    TITULOREC.FILIAL=ESTABELECIMENTO.CADASTRO
INNER JOIN 
    TIPOCOBRANCA ON  
    TITULOREC.TIPOTRANSACAO=TIPOCOBRANCA.TIPOCOBRANCA
WHERE 
    TITULOREC.PARCEIRO= 14186 and
    coalesce(tipoBaixa,'')<>'E' 
