SELECT 
    PEDIDO.uuid,
    PEDIDO.FILIAL,
    PEDIDO.IDNOTA,
    PEDIDO.DATAREFERENCIA,
    PEDIDO.ENTREGA,
    CADCLI.NOME,
    PEDIDO.VLRTOTALNOTA,
    PEDIDO.NUMPEDIDOCLIENTE,
    CADCLI.UF, 
    CADCLI.CIDADE,
     CADCLI.DOCUMENTO,
    pedido.cancelamento, 
    pedido.dataEmissao, 
    pedido.bloqueadoFaturamento,
    (SELECT FIRST 1
        CADVEN.NOME
     FROM
        VENDEDORESPED
     INNER JOIN
        CADASTROPARCEIROS CADVEN ON
            CADVEN.CADASTRO=VENDEDORESPED.VENDEDOR
     WHERE
        VENDEDORESPED.FILIAL=PEDIDO.FILIAL AND
        VENDEDORESPED.IDNOTA=PEDIDO.IDNOTA) AS NOMEVENDEDOR 
FROM
    PEDIDO 
INNER JOIN 
    CADASTROPARCEIROS CADCLI ON
        CADCLI.CADASTRO = PEDIDO.DESTINATARIO
WHERE
    pedido.cancelamento='N' and
    pedido.dataemissao is not null and
    pedido.tipoNota=3 and
    cadcli.contribuinte='N' and
    exists (select * from MERCADORIASPED
           where mercadoriasped.filial=pedido.filial and
           mercadoriasped.idnota=pedido.idnota and
           MERCADORIASPED.BAIXA='N') 
order by
    12 desc,
    pedido.idnota
