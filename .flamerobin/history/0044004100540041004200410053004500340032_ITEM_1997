select 
    movimentoestoque.filial,
    movimentoestoque.documento,
    materialmovimentoestoque.iditem codSaida,
    saida.descricao as descricaoSaida
from
    MOVIMENTOESTOQUE
inner join
    materialmovimentoestoque on
        materialmovimentoestoque.filial=movimentoestoque.filial and
        materialmovimentoestoque.idmovimento=movimentoestoque.idmovimento
inner join
    itemestoque saida on
        saida.codigo=MATERIALMOVIMENTOESTOQUE.iditem
where 
    movimentoestoque.filial=110 and
    movimentoestoque.tipomovimento='12' and 
    materialmovimentoestoque.concluido='N'