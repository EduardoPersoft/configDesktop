update 
    mercadoriasnotacompra 
set
    mercadoriasnotacompra.CSTPIS=case mercadoriasnotacompra.CSTPIS when 2 then 70 when 1 then 50 else mercadoriasnotaconta.cstpis end,
    mercadoriasnotacompra.cstcofins=case mercadoriasnotacompra.cstcofins when 2 then 70 when 1 then 50 else mercadoriasnotaconta.cstcofins end 
where 
    MERCADORIASNOTACOMPRA.filial=1 and 
    mercadoriasnotacompra.idnota>=5219