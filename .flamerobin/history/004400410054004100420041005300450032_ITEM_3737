SELECT 
    C_I_POSICAOESTOQUE.codigo,
    C_I_POSICAOESTOQUE.estoque,
    C_I_REGISTROINVENTARIO.QUANTIDADE
FROM 
    C_I_POSICAOESTOQUE
inner JOIN
    C_I_REGISTROINVENTARIO on
        C_I_REGISTROINVENTARIO.codigo=C_I_POSICAOESTOQUE.CODIGO
WHERE
    c_i_posicaoestoque.estoque<>C_I_REGISTROINVENTARIO.quantidade
