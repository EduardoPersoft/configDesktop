SELECT
      /*ESTAB.CADASTRO*/ notafiscal.filial, NOTAFISCAL.IDNOTA,
      notafiscal.numeronota,
      notafiscal.datareferencia,
      CAST(NATUREZAOPERACAO.cfop AS VARCHAR(4)),
      MERCADORIASNOTA.IDMERCADORIA AS IDMERCSERV,
      EXTRACT(YEAR FROM NOTAFISCAL.DATACADASTRO) ANO,
      EXTRACT(MONTH FROM NOTAFISCAL.DATACADASTRO) MES,
      NOTAFISCAL.DESTINATARIO, ((MERCADORIASNOTA.VLRFINALMERCAD+MERCADORIASNOTA.ACRESCIMONOTA)-MERCADORIASNOTA.DESCONTONOTA) 
VLRFINALMERCAD,
      MERCADORIASNOTA.CODIGO, ITEM.GRUPO,
      item.familia,
      item.itembase,
       (select item2.descricao from itemestoque item2 where item2.codigo=item.itembase) as itembasedesc, 
      CAST(ITEM.DESCRICAO AS VARCHAR(240)) AS DESCRICAO,
      CLIENTE.NOME, 'PRODUTO' AS TIPO,
      MERCADORIASNOTA.QUANTIDADE, MERCADORIASNOTA.QUANTIDADE*coalesce(ITEM.QUANTIDADEUNIDADE,1), ESTSIN.DATAINICIAL,ESTSIN.DATAFINAL,
      ESTSIN.MATERIALINICIAL, ESTSIN.MATERIALFINAL,ESTSIN.CONSOLIDADO, ESTSIN.DESCRICAO, ESTAB.NOME,CAST(ESTSIN.SERVICOINICIAL AS 
VARCHAR(8)),CAST(ESTSIN.SERVICOFINAL AS VARCHAR(8)),
    estsin.consumo,
    mercadoriasnota.frete,
    mercadoriasnota.seguro,
    mercadoriasnota.outdespacessor,
      /*GRUPOMERCADORIA.DESCRICAO, */NOTAFISCAL.VALORIPI,MERCADORIASNOTA.VALORIPI,MERCADORIASNOTA.VALORICMS,
      NOTAFISCAL.ZONAFRANCA, MERCADORIASNOTA.VLRICMSSUBST,ESTSIN.INC, /*NOTAFISCAL.DATACADASTRO*/
      notafiscal.datareferencia,ESTSIN.OPCAO,
      NATUREZAOPERACAO.estatisticaestoque,notafiscal.substributaria,
      MERCADORIASNOTA.VLRICMSRECOLHIDO,
      NATUREZAOPERACAO.FATURA,ESTSIN.aoscuidados,ESTSIN.vertical,
      notafiscal.uf
FROM  PEDIDO NOTAFISCAL, ESTSIN
INNER JOIN MERCADORIASPED MERCADORIASNOTA ON (NOTAFISCAL.FILIAL = MERCADORIASNOTA.FILIAL
                           AND   NOTAFISCAL.IDNOTA = MERCADORIASNOTA.IDNOTA)
INNER JOIN ITEMESTOQUE ITEM ON (MERCADORIASNOTA.CODIGO = ITEM.CODIGO)
INNER JOIN CADASTROPARCEIROS CLIENTE ON (NOTAFISCAL.DESTINATARIO = CLIENTE.CADASTRO)
INNER JOIN NATUREZAOPERACAO ON (NOTAFISCAL.OPERACAO = NATUREZAOPERACAO.ID)
INNER JOIN CADASTROPARCEIROS ESTAB ON (ESTAB.CADASTRO = ESTSIN.ESTABELECIMENTO)
/*LEFT JOIN GRUPOMERCADORIA ON (ITEMESTOQUE.GRUPO = GRUPOMERCADORIA.GRUPO)*/
WHERE ESTSIN.RELATORIO ='ESTATSIN'
AND   NOTAFISCAL.DATAREFERENCIA BETWEEN ESTSIN.DATAINICIAL AND ESTSIN.DATAFINAL
AND   NOT NOTAFISCAL.DATAEMISSAO IS NULL
AND   ((ESTSIN.CONSOLIDADO = 2) OR (NOTAFISCAL.FILIAL = ESTSIN.ESTABELECIMENTO))
AND   (NATUREZAOPERACAO.FATURA = 'S' or naturezaoperacao.estatisticaestoque='S')
AND   MERCADORIASNOTA.CODIGO BETWEEN ESTSIN.MATERIALINICIAL AND ESTSIN.MATERIALFINAL
AND  ((NOTAFISCAL.CANCELAMENTO = 'N') OR (NOTAFISCAL.CANCELAMENTO IS NULL))
AND  MERCADORIASNOTA.CFOP NOT IN ('5949','6949','5922','6922','5902','6902','5903','6903' )