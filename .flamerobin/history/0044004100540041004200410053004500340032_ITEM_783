select
    titulopag.filial,
    cadfor.razaosocial,
    CONTASCONTABEIS.CONTACONTABIL,
    contascontabeis.DESCRICAO,
    titulopag.idtitulo,
    titulopag.TITULO,
    titulopag.fatura,
    titulopag.emissao,
    titulopag.VENCIMENTO,
    lantocontpag.valor
from 
    TITULOPAG
inner join
    CADASTROPARCEIROS cadfor on
        cadfor.CADASTRO = titulopag.PARCEIRO
inner join
    LANTOCONTPAG on
        lantocontpag.filial=titulopag.filial and
        lantocontpag.IDMOVTOBANc=titulopag.IDTITULO
inner join
    CONTASCONTABEIS on
        contascontabeis.IDPLANO=4 and
        contascontabeis.CONTACONTABIL=lantocontpag.CONTACONTABIL
where    
    titulopag.vencimento between '21.11.2023' and '31.12.2023'
order by
    cadfor.razaosocial,
    CONTASCONTABEIS.CONTACONTABIL,
    titulopag.titulo,
    titulopag.fatura