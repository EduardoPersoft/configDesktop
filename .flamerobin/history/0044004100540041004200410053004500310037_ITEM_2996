SELECT
    MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO,
    MOVIMENTOESTOQUE.FILIAL,
    MAX(MOVIMENTOESTOQUE.EMISSAO) AS MAX_EMISSAO, 
    LOCAL.DESCRICAO
FROM
    MATERIALMOVIMENTOESTOQUE
INNER JOIN
    MOVIMENTOESTOQUE ON
    MATERIALMOVIMENTOESTOQUE.FILIAL = MOVIMENTOESTOQUE.FILIAL AND
    MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO = MOVIMENTOESTOQUE.IDMOVIMENTO
inner join 
    local on 
    MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO=LOCAL.ID
WHERE
    MATERIALMOVIMENTOESTOQUE.IDITEM = '1145105'
GROUP BY
    MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO,
    MOVIMENTOESTOQUE.FILIAL,
    LOCAL.DESCRICAO
order by 
    3 desc
