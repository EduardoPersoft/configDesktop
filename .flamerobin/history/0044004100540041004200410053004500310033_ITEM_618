select 
    distinct MERCADORIASPED.idnota
from 
    MERCADORIASPED
inner join
    COMPOSICAOMERCPED ON
        COMPOSICAOMERCPED.FILIAL=MERCADORIASPED.FILIAL and
        COMPOSICAOMERCPED.IDNOTA=MERCADORIASPED.IDNOTA and
        COMPOSICAOMERCPED.IDMERCADORIA=MERCADORIASPED.IDMERCADORIA
where
    mercadoriasped.baixa='N' and
    COMPOSICAOMERCPED.IDITEM<>MERCADORIASPED.CODIGO
    

