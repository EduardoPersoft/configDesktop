select
    FILIAL,
    IDNOTA,
    CODIGO,
    CFOP,
    VLRTOTALMERCAD,
    VALORICMS
from
    MERCADORIASNOTACOMPRA
where
    MERCADORIASNOTACOMPRA.FILIAL=110
    AND MERCADORIASNOTACOMPRA.CFOP IN ('1102', '2102', '3101')
    AND SUBSTRING(MERCADORIASNOTACOMPRA.CODIGO FROM 1 FOR 3) IN ('MPP', 'MPS')