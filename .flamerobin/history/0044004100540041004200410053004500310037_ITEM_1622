select
    (select first 1
        materiallocal.filial
     from
        materiallocal
     where
        materiallocal.iditem=itemestoque.codigo
     group by
        materiallocal.filial
     order by
        sum(materiallocal.saldototal) desc),
    itemestoque.codigo,
    itemestoque.codigoBarra,
    itemestoque.referencia,
    itemestoque.descricao
from
    itemestoque
order by
    itemestoque.codigo
