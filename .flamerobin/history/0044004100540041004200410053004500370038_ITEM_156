update
    itemcustodata
set
    custounitario = coalesce((select max(decimal(MATERIALMOVIMENTOESTOQUE.valor/materialmovimentoestoque.quantidade,2))
                              from MATERIALMOVIMENTOESTOQUE
                              where MATERIALMOVIMENTOESTOQUE.iditem=itemcustodata.codigo),0)
where 
    datainventario = '30.09.2025'