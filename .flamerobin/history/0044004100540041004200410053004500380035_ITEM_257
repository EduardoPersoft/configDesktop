select
    MATERIALMOVIMENTOESTOQUE.IDITEM,
    ITEMESTOQUE.DESCRICAO
from
    MATERIALMOVIMENTOESTOQUE
inner join
    movimentoestoque on
        movimentoestoque.filial=MATERIALMOVIMENTOESTOQUE.filial and
        movimentoestoque.idmovimento=MATERIALMOVIMENTOESTOQUE.idmovimento and
        movimentoestoque.TIPOMOVIMENTO='02'
INNER join
    ITEMESTOQUE ON
        ITEMESTOQUE.CODIGO = MATERIALMOVIMENTOESTOQUE.IDITEM
where 
    SUBSTRING(MATERIALMOVIMENTOESTOQUE.IDITEM FROM 1 FOR 2) IN ('EM', 'MP') and
    MATERIALMOVIMENTOESTOQUE.VALOR IS NULL and
    MATERIALMOVIMENTOESTOQUE.FILIAL=7
ORDER BY
    MATERIALMOVIMENTOESTOQUE.IDITEM
