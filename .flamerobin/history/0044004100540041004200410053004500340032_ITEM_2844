select 
    composicaoop.CODIGO,
    apontamentocomp.lote,
    sum(apontamentocomp.quantidade)
from 
    materialmovimentoestoque
inner join 
    composicaoop on 
    composicaoop.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL and 
    composicaoop.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO and
    composicaoop.IDMOVIMENTOMATERIAL=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL
inner join 
    APONTAMENTOCOMP on 
     composicaoop.FILIAL=APONTAMENTOCOMP.FILIAL and 
    composicaoop.IDMOVIMENTO=APONTAMENTOCOMP.IDMOVIMENTO and
    composicaoop.IDMOVIMENTOMATERIAL=APONTAMENTOCOMP.IDMATERIAL and
    composicaoop.IDCOMPOSICAO=APONTAMENTOCOMP.IDCOMPOSICAO 
where 
    materialmovimentoestoque.filial=110 and
    --composicaoop.codigo=? and 
    coalesce(materialmovimentoestoque.concluido, 'N') ='N'
group by 
    composicaoop.codigo,
    apontamentocomp.lote
order by
    composicaoop.codigo,
    apontamentocomp.lote
        
    
