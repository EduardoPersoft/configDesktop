
update
    VENDEDORESNOTA VENDEDORESPED
set
    comissaorecebimento = (select vendedor.COMISSAORECEBIMENTO 
                           from VENDEDOR
                           where vendedor.CADASTRO=vendedoresped.VENDEDOR),
    comissaovenda = (select vendedor.COMISSAOvenda
                           from VENDEDOR
                           where vendedor.cadastro=vendedoresped.vendedor)
where
    exists (
        select
            *
        from
            NOTAFISCAL pedido
        where 
            pedido.filial=vendedoresped.filial and
            pedido.idnota=vendedoresped.idnota and
            pedido.datacadastro>='01.01.2023')
                           
