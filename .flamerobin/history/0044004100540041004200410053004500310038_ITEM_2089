SELECT MATERIALMOVIMENTOESTOQUE.iditem,
               sum(MATERIALMOVIMENTOESTOQUE.quantidade*materialmovimentoestoque.sinal),
               sum(MATERIALMOVIMENTOESTOQUE.valor*materialmovimentoestoque.sinal)
     FROM MOVIMENTOESTOQUE
     INNER JOIN MATERIALMOVIMENTOESTOQUE ON (MATERIALMOVIMENTOESTOQUE.filial = MOVIMENTOESTOQUE.FILIAL
            AND MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO = MOVIMENTOESTOQUE.IDMOVIMENTO)
     INNER JOIN ITEMESTOQUE ON (ITEMESTOQUE.CODIGO=MATERIALMOVIMENTOESTOQUE.IDITEM)
     WHERE MOVIMENTOESTOQUE.filial = 1
     AND MOVIMENTOESTOQUE.emissao < '01.12.2023'
     AND MATERIALMOVIMENTOESTOQUE.iditem ='01.12.1487'
     AND ITEMESTOQUE.estocado = 'S'
     group by MATERIALMOVIMENTOESTOQUE.iditem
     HAVING sum(MATERIALMOVIMENTOESTOQUE.quantidade*materialmovimentoestoque.sinal)<>0
     or sum(MATERIALMOVIMENTOESTOQUE.VALOR*materialmovimentoestoque.sinal)<>0