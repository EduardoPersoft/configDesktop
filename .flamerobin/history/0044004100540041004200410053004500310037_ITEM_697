UPDATE
    MERCADORIASNOTACOMPRA 
set 
    MERCADORIASNOTACOMPRA.cstpis = 50,
    MERCADORIASNOTACOMPRA.cstcofins = 50
WHERE
    MERCADORIASNOTACOMPRA.filial=1 AND
    MERCADORIASNOTACOMPRA.idnota>=5306 and
    MERCADORIASNOTACOMPRA.cfop in ('2020', '1202','1411')  and
    MERCADORIASNOTACOMPRA.cstpis=1
