select 
    itemestoque.codigo,
    itemestoque.descricao,
    itemestoque.REFERENCIA,
    for1.CODIGOFORNEC
from 
    fornecedoresitem  for1
inner JOIN
    cadastroparceiros on
        cadastroparceiros.cadastro=for1.FORNECEDOR
where 
    for1.fornecedor = 1247 AND
    not exists(
        select 
            * 
        from 
            fornecedoresitem for2
        WHERE
            for2.fornecedor <> 1247)            