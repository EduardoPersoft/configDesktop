select 
    MERCADORIASREQ.CODIGO,
    REQUISICAO.FILIAL,
    REQUISICAO.IDNOTA,
    REQUISICAO.UUID,
    REQUISICAO.DATACADASTRO,
    MERCADORIASREQ.QUANTIDADE
from
    REQUISICAO
INNER JOIN
    MERCADORIASREQ ON
        MERCADORIASREQ.FILIAL=REQUISICAO.FILIAL and
        MERCADORIASREQ.IDNOTA=REQUISICAO.IDNOTA
INNER JOIN
    ITEMESTOQUE ON
        ITEMESTOQUE.CODIGO=MERCADORIASREQ.CODIGO
where 
    REQUISICAO.STATUS='R' AND
    ITEMESTOQUE.FAMILIA=10001
group by 
     ITEMESTOQUE.CODIGO, 
     ITEMESTOQUE.DESCRICAO,
     ITEMESTOQUE.UNIDADE
order by 
     ITEMESTOQUE.CODIGO,
    REQUISICAO.DATACADASTRO
