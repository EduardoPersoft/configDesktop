SET TERM ^ ;
ALTER PROCEDURE C_PEDIDOSEMABERTOPRODUCAO (
    PFILIAL integer )
RETURNS (
    FILIAL integer,
    IDPEDIDO integer,
    IDMERCADORIAPED integer,
    DATAREFERENCIA timestamp,
    PREVISAOVENDAS timestamp,
    PREVISAOPRODUCAO timestamp,
    CLIENTENOME varchar(60),
    CODIGO varchar(15),
    DESCRICAOPRODUTO varchar(100),
    NOVOREPETICAOALTERACAO varchar(20),
    QUANTIDADEPRODUZIR numeric(12,2),
    UNIDADE varchar(3),
    ARTEOK varchar(1),
    DATAPREVISTAARTE timestamp,
    CLICHEOK varchar(1),
    DATAPREVISTACLICHE timestamp,
    MATERIAPRIMAOK varchar(1),
    DATAPREVISTAMATERIAPRIMA timestamp,
    OP integer,
    IMPRESSAOTEM varchar(1),
    IMPRESSAOID integer,
    IMPRESSAOQTDESTIMADA numeric(12,2),
    IMPRESSAOTEMPOESTIMADO numeric(12,2),
    IMPRESSAODATAPROGRAMADA timestamp,
    IMPRESSAOCONCLUIDO varchar(1),
    IMPRESSAOMPEMPENHADA char(1),
    LAMINACAO1TEM varchar(1),
    LAMINACAO1ID integer,
    LAMINACAO1QTDESTIMADA numeric(12,2),
    LAMINACAO1TEMPOESTIMADO numeric(12,2),
    LAMINACAO1DATAPROGRAMADA timestamp,
    LAMINACAO1CONCLUIDO varchar(1),
    LAMINACAO2TEM varchar(1),
    LAMINACAO2ID integer,
    LAMINACAO2QTDESTIMADA numeric(12,2),
    LAMINACAO2TEMPOESTIMADO numeric(12,2),
    LAMINACAO2DATAPROGRAMADA timestamp,
    LAMINACAO2CONCLUIDO varchar(1),
    LAMINACAO3TEM varchar(1),
    LAMINACAO3ID integer,
    LAMINACAO3QTDESTIMADA numeric(12,2),
    LAMINACAO3TEMPOESTIMADO numeric(12,2),
    LAMINACAO3DATAPROGRAMADA timestamp,
    LAMINACAO3CONCLUIDO varchar(1),
    FORMATACAOTEM varchar(1),
    FORMATACAOID integer,
    FORMATACAOQTDESTIMADA numeric(12,2),
    FORMATACAOTEMPOESTIMADO numeric(12,2),
    FORMATACAODATAPROGRAMADA timestamp,
    FORMATACAOCONCLUIDO varchar(1),
    ITEMIMPRESSO varchar(1),
    EMPENHOIMPRESSAO varchar(1),
    EMPENHOLAMINACAO1 varchar(1),
    EMPENHOLAMINACAO2 varchar(1),
    DTMPIMPRESSAO date,
    DTMPLAMINACAO1 date,
    DTMPLAMINACAO2 date,
    C_STATUSARTE smallint,
    QTDAPONTAMENTO decimal(12,2) )

AS
declare variable movimentoTEMPOESTIMADO integer;
declare variable movimentoDATAPROGRAMADA timestamp;
declare variable idMovtoLaminacao integer;
declare variable idContadorLaminacao integer;
declare variable idcentrocusto integer;
declare variable quantidade decimal(12,2);
declare variable opconcluida char(1);
declare variable empenhados integer;
declare variable naoempenhados integer;
declare variable idMovtoMaterial integer;
begin

   FOR SELECT DISTINCT C_PEDIDOSEMABERTO.filial,
                    C_PEDIDOSEMABERTO.idnota,
                    C_PEDIDOSEMABERTO.idmercadoria,
                    C_PEDIDOSEMABERTO.datareferencia,
                    C_PEDIDOSEMABERTO.dataentrega ,
                    c_pedidosemaberto.DATAPREVISTA as previsaoproducao,
                    C_PEDIDOSEMABERTO.clientenome ,
                    C_PEDIDOSEMABERTO.produto,
                    C_PEDIDOSEMABERTO.descricaoproduto,
                    c_pedidosemaberto.C_NOVOREPETICAOALTERADO,
                    c_pedidosemaberto.QUANTIDADEPRODUZIR,
                    c_pedidosemaberto.unidade,
                    c_pedidosemaberto.c_statusArte
                    
    FROM 
        C_PEDIDOSEMABERTO(:pFILIAL)
    LEFT JOIN 
        VENDEDORESPED ON (VENDEDORESPED.filial = C_PEDIDOSEMABERTO.filial
                            AND VENDEDORESPED.idnota = C_PEDIDOSEMABERTO.idnota)
    LEFT JOIN 
        CADASTROPARCEIROS VENDEDOR ON 
            (VENDEDOR.cadastro = VENDEDORESPED.vendedor)
    where
        C_PEDIDOSEMABERTO.DATAEMISSAO is not null
    ORDER BY 
            c_pedidosemaberto.DATAPREVISTA,
            C_PEDIDOSEMABERTO.IDNOTA,
            C_PEDIDOSEMABERTO.IDCOMPOSICAO
    INTO
        :filial,:idpedido,:idmercadoriaped,:datareferencia,:previsaovendas ,                    
        :previsaoproducao,:clientenome,:codigo,:descricaoproduto,:novorepeticaoalteracao,
        :quantidadeproduzir, :unidade, :c_statusArte
        

    DO BEGIN 
    
        select 
            itemestoque.c_impressao
        from 
            itemestoque 
        where 
            itemestoque.codigo=:codigo 
        into
            :itemImpresso;
    
        :ARTEok = 'S'; 
		:DATAPREVISTAARTE = NULL; 
        
        
        :DATAPREVISTACLICHE = NULL; 
		:DATAPREVISTAMATERIAPRIMA = NULL; 
		:OP = NULL; 
		
        :IMPRESSAOTEM = 'N'; 
        :IMPRESSAOID = NULL;
		:IMPRESSAOQTDESTIMADA = NULL; 
		:IMPRESSAOTEMPOESTIMADO = NULL; 
		:IMPRESSAODATAPROGRAMADA = NULL; 
        :IMPRESSAOCONCLUIDO = NULL; 
        DTMPIMPRESSAO = null;
        empenhoImpressao = 'N';                    
        
        
		:LAMINACAO1TEM = 'N'; 
        :LAMINACAO1ID = NULL;		
		:LAMINACAO1QTDESTIMADA = NULL; 
		:LAMINACAO1TEMPOESTIMADO = NULL; 
        :LAMINACAO1DATAPROGRAMADA = NULL; 
        :LAMINACAO1CONCLUIDO = NULL;
        empenholaminacao1 = 'N';                    
        DTMPLAMINACAO1 = null;

        
		:LAMINACAO2TEM = 'N'; 
        :LAMINACAO2ID = NULL;				
		:LAMINACAO2QTDESTIMADA = NULL; 
		:LAMINACAO2TEMPOESTIMADO = NULL; 
        :LAMINACAO2DATAPROGRAMADA = NULL; 
        :LAMINACAO2CONCLUIDO = NULL;        
        empenholaminacao2 = 'N';
        DTMPLAMINACAO2 = null;


		:LAMINACAO3TEM = 'N'; 
        :LAMINACAO3ID = NULL;				
		:LAMINACAO3QTDESTIMADA = NULL; 
		:LAMINACAO3TEMPOESTIMADO = NULL; 
        :LAMINACAO3DATAPROGRAMADA = NULL; 
        :LAMINACAO3CONCLUIDO = NULL;        

        
		:FORMATACAOTEM = 'N'; 
        :FORMATACAOID = NULL;				
		:FORMATACAOQtdESTIMADA = NULL; 
		:FORMATACAOTEMPOESTIMADO = NULL; 
        :FORMATACAODATAPROGRAMADA  = NULL;
        :FORMATACAOCONCLUIDO = NULL;
        
        :idMovtoLaminacao = 0;

       
        if(substring(novorepeticaoalteracao from 1 for 1) in ('N', 'A')) then
            select 
                coalesce(MERCADORIASPED.C_ARTE, 'N'),
                MERCADORIASPED.C_DATAARTE
            from 
                MERCADORIASPED
            where 
                MERCADORIASPED.filial=:filial and
                MERCADORIASPED.idnota=:idpedido and
                mercadoriasped.idmercadoria=:idmercadoriaped
            into 
                :arteok,
                :dataprevistaarte;                
       
        for select 
            materialmovimentoestoque.idmovimento,
            materialmovimentoestoque.IDMOVIMENTOmaterial,
            materialmovimentoestoque.idcentrocusto,
            materialmovimentoestoque.quantidade,
            coalesce(materialmovimentoestoque.concluido, 'N'),
            materialmovimentoestoque.tempo+materialmovimentoestoque.setup tempoestimado,
            MAPAPRODUCAO.fim dataprogramada,
            movimentoestoque.C_MATERIAPRIMA
        from 
            materialmovimentoestoque
        inner join
            movimentoestoque on
                movimentoestoque.filial=MATERIALMOVIMENTOESTOQUE.filial and
                movimentoestoque.idmovimento=materialmovimentoestoque.idmovimento
        left join
            MAPAPRODUCAO on
                MAPAPRODUCAO.FILIAL=MATERIALMOVIMENTOESTOQUE.filial and
                mapaproducao.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO and
                mapaproducao.IDMOVIMENTOMATERIAL=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL
        where
            movimentoestoque.TIPOMOVIMENTO='12' and  
            materialmovimentoestoque.filial=:filial and 
            materialmovimentoestoque.idpedido=:idpedido and 
            materialmovimentoestoque.idmercadoria=:idmercadoriaped
        order by
            movimentoestoque.emissao,
            MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL
        into        
            :op,
            :idMovtoMaterial,
            :idcentrocusto,
            :quantidade,
            :opconcluida,
            :movimentoTEMPOESTIMADO,
            :movimentoDATAPROGRAMADA,
            :materiaPrimaok                    
        do begin     
        
            select 
                case itemestoque.c_cliche when 'S' then 'S' when '0' then 'S' else 'N' end,
                itemestoque.C_DATACLICHE
            from
                ITEMESTOQUE
            where
                itemestoque.codigo=:codigo
            into 
                :clicheok, DATAPREVISTACLICHE;

            if (idmovtoLaminacao<>op) then begin
                idContadorLaminacao = 1;
                idmovtoLaminacao=op;
            end

            
            if (idcentrocusto= 101) THEN 
                BEGIN
                    :IMPRESSAOTEM = 'S'; 
                    impressaoid = idmovtomaterial;
                    :IMPRESSAOQTDESTIMADA = :quantidade; 
                    :IMPRESSAOTEMPOESTIMADO = :movimentoTEMPOESTIMADO; 
                    :IMPRESSAODATAPROGRAMADA = :movimentoDATAPROGRAMADA; 
                    :IMPRESSAOCONCLUIDO = :opconcluida; 
                    
                    if(opconcluida='N') then begin
                    
                        select                           
                            case when   
                                (sum(coalesce(APONTAMENTOcomp.QUANTIDADE,0))< max( composicaoop.QUANTIDADE))
                                then 'N'
                                ELSE 'S' END  
                        from
                            composicaoop
                        inner join 
                                itemestoque on 
                                    (itemestoque.codigo=composicaoop.CODIGO)
                        left join
                            APONTAMENTOCOMP on
                                composicaoop.filial=APONTAMENTOCOMP.filial and
                                composicaoop.IDMOVIMENTO=apontamentocomp.idmovimento and
                                composicaoop.IDMOVIMENTOMATERIAL=apontamentocomp.IDMATERIAL and 
                                composicaoop.IDCOMPOSICAO=apontamentocomp.IDCOMPOSICAO 
                        where 
                            composicaoop.filial=:filial and
                            composicaoop.IDMOVIMENTO=:OP and                         
                            composicaoop.IDMOVIMENTOMATERIAL=:idMovtoMaterial and 
                            itemestoque.tipoproduto=1 and
                            itemestoque.GRUPO=2
                            
                        into 
                            :empenhoImpressao;    
                        
                        select 
                            max(PEDIDOCOMPRA.datacadastro+PRAZOMERCPEDCOMPRA.dias)
                        from
                            MERCADORIASPEDCOMPRA            
                        inner join
                            pedidocompra on
                                mercadoriaspedcompra.filial=pedidocompra.filial and
                                mercadoriaspedcompra.idnota=pedidocompra.idnota 
                        inner join
                            PRAZOMERCPEDCOMPRA on
                                PRAZOMERCPEDCOMPRA.filial=mercadoriaspedcompra.filial and
                                prazomercpedcompra.idnota=mercadoriaspedcompra.idnota and
                                prazomercpedcompra.IDITEM=mercadoriaspedcompra.IDMERCADORIA
                        where 
                            mercadoriaspedcompra.filial=:filial and
                            mercadoriaspedcompra.IDPEDVEN=:idpedido and
                            mercadoriaspedcompra.IDMERCPEDVEN=:idmercadoriaped and
                            mercadoriaspedcompra.baixa='N' and
                            mercadoriaspedcompra.codigo in (
                                select 
                                    composicaoop.CODIGO
                                from
                                    COMPOSICAOOP
                                where
                                    composicaoop.filial=:filial and
                                    composicaoop.idmovimento = :op and
                                    composicaoop.idmovimentomaterial = :idmovtomaterial
                            )
                        into 
                            DTMPIMPRESSAO;                        
                    end else begin
                        DTMPIMPRESSAO = null;
                        empenhoImpressao = 'S';                                        
                    end
                            
                END 
                
            if (idcentrocusto= 106) THEN 
                BEGIN
                    :FORMATACAOTEM = 'S'; 
                    formatacaoid = idmovtomaterial;                     
                    :FORMATACAOQTDESTIMADA = :quantidade; 
                    :FORMATACAOTEMPOESTIMADO = :movimentoTEMPOESTIMADO; 
                    :FORMATACAODATAPROGRAMADA = :movimentoDATAPROGRAMADA; 
                    :FORMATACAOCONCLUIDO = :opconcluida; 
                END 
                           
            if (:idcentrocusto= 103) THEN BEGIN
                if(idContadorLaminacao=1) then begin
                    :LAMINACAO1TEM = 'S'; 
                    laminacao1id = idmovtomaterial;                     
                    :LAMINACAO1QTDESTIMADA = :quantidade; 
                    :LAMINACAO1TEMPOESTIMADO = :movimentoTEMPOESTIMADO; 
                    :LAMINACAO1DATAPROGRAMADA = :movimentoDATAPROGRAMADA; 
                    :LAMINACAO1CONCLUIDO = :opconcluida;      
                    
                    if(opconcluida='N') then begin                    
                        select                           
                            case when   
                                (sum(coalesce(APONTAMENTOcomp.QUANTIDADE,0)+1)< max( composicaoop.QUANTIDADE))
                                then 'N'
                                ELSE 'S' END  
                        from
                            composicaoop
                        inner join 
                                itemestoque on 
                                    (itemestoque.codigo=composicaoop.CODIGO)
                        left join
                            APONTAMENTOCOMP on
                                composicaoop.filial=APONTAMENTOCOMP.filial and
                                composicaoop.IDMOVIMENTO=apontamentocomp.idmovimento and
                                composicaoop.IDMOVIMENTOMATERIAL=apontamentocomp.IDMATERIAL and 
                                composicaoop.IDCOMPOSICAO=apontamentocomp.IDCOMPOSICAO 
                        where 
                            composicaoop.filial=:filial and
                            composicaoop.IDMOVIMENTO=:OP and                         
                            composicaoop.IDMOVIMENTOMATERIAL=:idMovtoMaterial and 
                            itemestoque.tipoproduto=1 and
                            itemestoque.GRUPO=2
                        into :empenholaminacao1;                         

                        select 
                            max(PEDIDOCOMPRA.datacadastro+PRAZOMERCPEDCOMPRA.dias)
                        from
                            MERCADORIASPEDCOMPRA            
                        inner join
                            pedidocompra on
                                mercadoriaspedcompra.filial=pedidocompra.filial and
                                mercadoriaspedcompra.idnota=pedidocompra.idnota 
                        inner join
                            PRAZOMERCPEDCOMPRA on
                                PRAZOMERCPEDCOMPRA.filial=mercadoriaspedcompra.filial and
                                prazomercpedcompra.idnota=mercadoriaspedcompra.idnota and
                                prazomercpedcompra.IDITEM=mercadoriaspedcompra.IDMERCADORIA
                        where 
                            mercadoriaspedcompra.filial=:filial and
                            mercadoriaspedcompra.IDPEDVEN=:idpedido and
                            mercadoriaspedcompra.IDMERCPEDVEN=:idmercadoriaped and
                            mercadoriaspedcompra.baixa='N' and
                            mercadoriaspedcompra.codigo in (
                                select 
                                    composicaoop.CODIGO
                                from
                                    COMPOSICAOOP
                                where
                                    composicaoop.filial=:filial and
                                    composicaoop.idmovimento = :op and
                                    composicaoop.idmovimentomaterial = :idmovtomaterial
                            )
                        into 
                            DTMPLAMINACAO1;                        
                    end else begin
                        DTMPLAMINACAO1 = null;
                        empenholaminacao1 = null;
                    end
                    
                end
                if(idContadorLaminacao=2) then begin
                    :LAMINACAO2TEM = 'S'; 
                    laminacao2id = idmovtomaterial;                     
                    :LAMINACAO2QTDESTIMADA = :quantidade; 
                    :LAMINACAO2TEMPOESTIMADO = :movimentoTEMPOESTIMADO; 
                    :LAMINACAO2DATAPROGRAMADA = :movimentoDATAPROGRAMADA; 
                    :LAMINACAO2CONCLUIDO = :opconcluida; 
                    
                    if(opconcluida='N') then begin                    
                        select                           
                            case when   
                                (sum(coalesce(APONTAMENTOcomp.QUANTIDADE,0)+1)< max( composicaoop.QUANTIDADE))
                                then 'N'
                                ELSE 'S' END  
                        from
                            composicaoop
                        inner join 
                                itemestoque on 
                                    (itemestoque.codigo=composicaoop.CODIGO)
                        left join
                            APONTAMENTOCOMP on
                                composicaoop.filial=APONTAMENTOCOMP.filial and
                                composicaoop.IDMOVIMENTO=apontamentocomp.idmovimento and
                                composicaoop.IDMOVIMENTOMATERIAL=apontamentocomp.IDMATERIAL and 
                                composicaoop.IDCOMPOSICAO=apontamentocomp.IDCOMPOSICAO 
                        where
                            composicaoop.filial=:filial and
                            composicaoop.IDMOVIMENTO=:OP and                         
                            composicaoop.IDMOVIMENTOMATERIAL=:idMovtoMaterial and 
                            itemestoque.TIPOPRODUTO=1 and
                            itemestoque.GRUPO=2
                        into :empenholaminacao2;        
                    
                        select 
                            max(PEDIDOCOMPRA.datacadastro+PRAZOMERCPEDCOMPRA.dias)
                        from
                            MERCADORIASPEDCOMPRA            
                        inner join
                            pedidocompra on
                                mercadoriaspedcompra.filial=pedidocompra.filial and
                                mercadoriaspedcompra.idnota=pedidocompra.idnota 
                        inner join
                            PRAZOMERCPEDCOMPRA on
                                PRAZOMERCPEDCOMPRA.filial=mercadoriaspedcompra.filial and
                                prazomercpedcompra.idnota=mercadoriaspedcompra.idnota and
                                prazomercpedcompra.IDITEM=mercadoriaspedcompra.IDMERCADORIA
                        where 
                            mercadoriaspedcompra.filial=:filial and
                            mercadoriaspedcompra.IDPEDVEN=:idpedido and
                            mercadoriaspedcompra.IDMERCPEDVEN=:idmercadoriaped and
                            mercadoriaspedcompra.baixa='N' and
                            mercadoriaspedcompra.codigo in (
                                select 
                                    composicaoop.CODIGO
                                from
                                    COMPOSICAOOP
                                where
                                    composicaoop.filial=:filial and
                                    composicaoop.idmovimento = :op and
                                    composicaoop.idmovimentomaterial = :idmovtomaterial
                            )
                        into 
                            DTMPLAMINACAO2;                                                                
                    end else begin
                        DTMPLAMINACAO2 = null;
                        empenholaminacao2 = null;
                    end
                            
                    
                end
                if(idContadorLaminacao>2) then begin                
                    :LAMINACAO3TEM = 'S'; 
                    laminacao3id = idmovtomaterial; 
                    :LAMINACAO3QTDESTIMADA = :quantidade; 
                    :LAMINACAO3TEMPOESTIMADO = :movimentoTEMPOESTIMADO; 
                    :LAMINACAO3DATAPROGRAMADA = :movimentoDATAPROGRAMADA; 
                    :LAMINACAO3CONCLUIDO = :opconcluida; 
                end
                
                idContadorLaminacao  = idContadorLaminacao  +1;
            END                                
                           
            
                                          
        end
                
       
        if(itemimpresso='N') then begin
            arteok = null;
            clicheok=null;
        end
            
                
        SUSPEND;

    END        
end
^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE C_PEDIDOSEMABERTOPRODUCAO TO  SYSDBA WITH GRANT OPTION;

