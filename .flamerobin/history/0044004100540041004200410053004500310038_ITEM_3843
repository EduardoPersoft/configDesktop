
update 
    orcamento pedido
set 
    pedido.VBRUTOFATURA=coalesce((select sum(fatped.VALORFATURA) from fatORC FATPED
                                 where fatped.filial=pedido.FILIAL
                                 and fatped.idnota=pedido.idnota),0),
    pedido.VliquidoFATURA=coalesce((select sum(fatped.VALORFATURA) from fatORC FATPED
                                 where fatped.filial=pedido.FILIAL
                                 and fatped.idnota=pedido.idnota),0);
                                 
