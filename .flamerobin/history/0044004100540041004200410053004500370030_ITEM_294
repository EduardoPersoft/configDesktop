IDSEPARADOR, C_NOVOREPETICAOALTERADO, C_CLICHE, C_MATERIAPRIMA, IDCONFERENTE, C_MP, DETALHEVOLUME, 
IDCQ, EAN, UUID, MOTORISTA, IMPRESSO, C_DATAANTERIOR, MSGLIBERACAO, VALORFRETE) 
select 
233, IDMOVIMENTO, TIPOMOVIMENTO, DOCUMENTO, EMISSAO, PROCESSAMENTO, ESPECIE,ERIE, LOCALARMAZENAMENTO, 
CFOP, FORNECEDOR, IDITEMESTOQUE, QUANTIDADE, LOCALTRANSFERENCIA, IDNOTA, PRIORIDADE, IDAPLICACAO, IDCENTROCUSTO, 
