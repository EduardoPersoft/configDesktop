SAIDAPRODUCAO, PREVISAO, IDPEDIDO, C_IDNOTA, IDOP, IDOPITEM, LOTE, C_2VIA, C_CANCELADO, CADTRANS, CANCELADO, 
TRANSPORTADORA, QUANTIDADEVOLUMES, PESOLIQUIDO, PESOBRUTO, MARCAVOLUME, CALCULAVOLUME, COLETA, COLETADATA, 
IDNOTAEXPEDICAO, C_FORCASELAGEM, C_FORCALAMINACAO, DATAENTREGA, C_IDNOTACOMPRA, OBSERVACAOEXPEDICAO, 
OBSERVACAONOTAFISCAL, DATAINTINERARIO, PLACAINTINERARIO, ORDEM, C_APAARAS, CHAVERASTREAMENTO, 
C_ADESIVOAPLICADONOMINAL, EMAILENVIADO, ERROEMAIL, EMAILPEDIDOENTREGUE, OBSERVACAO, CODSERVICOENTREGA, 
DESCRICAOSERVICOENTREGA, MERCADORIASERVICO, ITINERARIO, PREVISAOFIMPRODUCAO, PERMITIREDITARPEDIDO, 
IDSEPARADOR, C_NOVOREPETICAOALTERADO, C_CLICHE, C_MATERIAPRIMA, IDCONFERENTE, C_MP, DETALHEVOLUME, 
IDCQ, EAN, UUID, MOTORISTA, IMPRESSO, C_DATAANTERIOR, MSGLIBERACAO, VALORFRETE
from 
    movimentoestoque 
where 
    movimentoestoque.filial=110 and 
    tipomovimento in (12,13) and exists
        (select pedido.idnota from pedido 
            where pedido.idnota=movimentoestoque.IDPEDIDO and 
                  pedido.filial=233);
				  
