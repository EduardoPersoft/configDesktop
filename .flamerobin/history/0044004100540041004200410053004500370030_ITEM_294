INSERT INTO COMPOSICAOOP (FILIAL, IDMOVIMENTO, IDMOVIMENTOMATERIAL, IDCOMPOSICAO, CODIGO, LOTE, GRADEVERTICAL, 
GRADEHORIZONTAL, QUANTIDADE, ESPECIFICACAO, LOCALARMAZENAMENTO, GRAMATURA, 
PERDAESTIMADAP, PERDAESTIMADAQ, COMPRIMENTO, LARGURA, METRAGEM, C_BOBINADOR) 
select
233, IDMOVIMENTO, IDMOVIMENTOMATERIAL, IDCOMPOSICAO, CODIGO, LOTE, GRADEVERTICAL, 
GRADEHORIZONTAL, QUANTIDADE, ESPECIFICACAO, LOCALARMAZENAMENTO, GRAMATURA, 
PERDAESTIMADAP, PERDAESTIMADAQ, COMPRIMENTO, LARGURA, METRAGEM, C_BOBINADOR
from 
    COMPOSICAOOP 
where 
    COMPOSICAOOP.filial=110 and
     exists
        (select   MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL 
                     from MATERIALMOVIMENTOESTOQUE 
            where MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO=COMPOSICAOOP.IDMOVIMENTO and 
                  MATERIALMOVIMENTOESTOQUE.IDMERCADORIA=COMPOSICAOOP.IDMOVIMENTOMATERIAL and 
                  MATERIALMOVIMENTOESTOQUE.filial=233);
           
                  
