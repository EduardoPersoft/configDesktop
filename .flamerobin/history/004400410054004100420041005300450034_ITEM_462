 select 
    c_ordemservico.IDORDEM as id,
    (case c_ordemservico.tipoOrdem 
     when 'A' then 'AT' 
     when 'S' then 'SAC' 
     else 'PED' end)||c_ordemServico.idpedido as title,
    cast(c_ordemservico.agendadaPara as date) as start
from
    c_ordemservico
where
    c_ordemServico.filial = 5  and
    c_ordemServico.agendadaPara between '01.01.2021' and '31.12.2021' and
    c_ordemservico.agendadaPara is not null
