select 
    cadastroparceiros.nome,
    count(distinct movimentoestoque.idmovimento),
    count(materialmovimentoestoque.idmovimentomaterial)
    
from 
    movimentoestoque 
inner JOIN
    cadastroparceiros on
       cadastroparceiros.cadastro=movimentoestoque.IDSEPARADOR
inner JOIN
    MATERIALMOVIMENTOESTOQUE on
        materialmovimentoestoque.filial=movimentoestoque.filial AND
        materialmovimentoestoque.idmovimento=movimentoestoque.idmovimento
WHERE
    movimentoestoque.filial = ? and 
    movimentoestoque.tipomovimento='13' AND
    movimentoestoque.EMISSAO between ? and ?
group by
    cadastroparceiros.nome