SELECT 
    MATERIALMOVIMENTOESTOQUE.FILIAL,
    MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO,
    MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL,
    MATERIALMOVIMENTOESTOQUE.IDITEM,
    ITEMESTOQUE.CODIGOBARRA EAN,
    ITEMESTOQUE.DESCRICAO,
    ITEMESTOQUE.PESOLIQUIDO,
    ITEMESTOQUE.REFERENCIA,
    ITEMESTOQUE.DEFINICAO,
    ITEMESTOQUE.LOCALIZACAO,
    ITEMESTOQUEXARQUIVO.NOMEARQUIVO ITEMESTOQUE_NOMEARQUIVO,	   	   
    GRUPOMERCADORIA.DESCRICAO AS GRUPO,
    FAMILIA.DESCRICAO AS FAMILIA, 
    MATERIALMOVIMENTOESTOQUE.LOTE,
    MATERIALMOVIMENTOESTOQUE.QUANTIDADE,
    ITEMESTOQUE.UNIDADE,
    MATERIALMOVIMENTOESTOQUE.VALOR,
    MATERIALMOVIMENTOESTOQUE.SINAL,
    MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO,
    LOCAL.DESCRICAO,
    MATERIALMOVIMENTOESTOQUE.FILIALLOCAL,
    MATERIALMOVIMENTOESTOQUE.IDPEDIDO,
    MATERIALMOVIMENTOESTOQUE.IDMERCADORIA,
    MATERIALMOVIMENTOESTOQUE.IDCOMPOSICAO,
    MATERIALMOVIMENTOESTOQUE.PRODUTO,
    MATERIALMOVIMENTOESTOQUE.TEMPO,
    MATERIALMOVIMENTOESTOQUE.SETUP,
    MATERIALMOVIMENTOESTOQUE.IDCENTROCUSTO,
    CENTROCUSTOS.DESCRICAO,
    MATERIALMOVIMENTOESTOQUE.CENTROCUSTO,
    MATERIALMOVIMENTOESTOQUE.RECURSO,
    cast(0 as decimal(12,3)) as quantidadeApontada,
    MATERIALMOVIMENTOESTOQUE.CONCLUIDO,
    MATERIALMOVIMENTOESTOQUE.RECALCULO,
    CAST('N' AS CHAR(1)) AS P_MARCA
FROM 
    MATERIALMOVIMENTOESTOQUE
INNER JOIN
    ITEMESTOQUE ON
        ITEMESTOQUE.CODIGO=MATERIALMOVIMENTOESTOQUE.IDITEM
INNER JOIN
    ESTABELECIMENTO ON
        ESTABELECIMENTO.CADASTRO=MATERIALMOVIMENTOESTOQUE.FILIAL
LEFT JOIN
    CENTROCUSTOS ON
        CENTROCUSTOS.IDPLANO=ESTABELECIMENTO.PLANOCONTAS AND
        CENTROCUSTOS.CENTROCUSTO=MATERIALMOVIMENTOESTOQUE.CENTROCUSTO
LEFT JOIN 
    GRUPOMERCADORIA ON 
        GRUPOMERCADORIA.GRUPO=ITEMESTOQUE.GRUPO
LEFT JOIN 
    FAMILIA ON 
        FAMILIA.ID=ITEMESTOQUE.FAMILIA
LEFT JOIN 
    ITEMESTOQUEXARQUIVO ON 
        ITEMESTOQUEXARQUIVO.CODIGO=ITEMESTOQUE.CODIGO AND
        ITEMESTOQUEXARQUIVO.ORDEM=0
left join 
    local on
        local.id=materialmovimentoestoque.LOCALARMAZENAMENTO
order by tempo