SET TERM ^ ;
ALTER PROCEDURE C_LOGECOMMERCEPEDIDO (
    FILIAL INTEGER,
    IDNOTA INTEGER )

AS
DECLARE VARIABLE QTD INTEGER; 
DECLARE VARIABLE QTDcarrinho INTEGER; 
BEGIN

    select count(carrinho.login) from CARRINHO
    where carrinho.filial=:filial and carrinho.id=:idnota
    into :qtdcarrinho;
    
    if (qtdcarrinho>0) then begin

        SELECT COUNT(*) 
        FROM C_LOGPEDIDOECOMMERCE 
        WHERE C_LOGPEDIDOECOMMERCE.FILIAL=:FILIAL 
        AND C_LOGPEDIDOECOMMERCE.IDNOTA=:IDNOTA
        INTO :QTD;
        IF (QTD=0) THEN BEGIN
            INSERT INTO C_LOGPEDIDOECOMMERCE(FILIAL, IDNOTA, INCLUSAO) VALUES (:FILIAL, :IDNOTA, 'N');
        END
        UPDATE C_LOGPEDIDOECOMMERCE 
        SET C_LOGPEDIDOECOMMERCE.STATUS_CODE = NULL
        WHERE C_LOGPEDIDOECOMMERCE.FILIAL=:FILIAL
        AND C_LOGPEDIDOECOMMERCE.IDNOTA=:IDNOTA;
    end
END
^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE C_LOGECOMMERCEPEDIDO TO  SYSDBA WITH GRANT OPTION;

