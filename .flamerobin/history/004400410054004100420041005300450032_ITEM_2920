SELECT  
    DISTINCT
    MERCADORIASNOTA.CLASSIFISCAL,
    MERCADORIASNOTA.SITUACAOTRIBUT,
    NOTAFISCAL.UF,


    MERCADORIASNOTA.CFOP    
FROM
    NOTAFISCAL
INNER JOIN
    MERCADORIASNOTA ON
        MERCADORIASNOTA.FILIAL=NOTAFISCAL.FILIAL AND
        MERCADORIASNOTA.IDNOTA=NOTAFISCAL.IDNOTA
WHERE
    NOTAFISCAL.FILIAL=5 AND
    NOTAFISCAL.DATAEMISSAO BETWEEN '01.01.2020' AND '31.12.2021' AND
    NOTAFISCAL.MODELO=1 AND
    NOTAFISCAL.UF IS NOT NULL
ORDER BY
     CLASSIFISCAL, UF, SITUACAOTRIBUT
    