update
    ITEMCUSTODATA
set
    QUANTIDADE = 
        (select
            SUM(MATERIALMOVIMENTOESTOQUE.QUANTIDADE*
            MATERIALMOVIMENTOESTOQUE.SINAL)
         FROM 
            MATERIALMOVIMENTOESTOQUE
         INNER join
            MOVIMENTOESTOQUE ON
                MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL and
                MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
         where
            MATERIALMOVIMENTOESTOQUE.FILIAL=ITEMCUSTODATA.FILIAL and
            MATERIALMOVIMENTOESTOQUE.IDITEM=ITEMCUSTODATA.CODIGO and
            MOVIMENTOESTOQUE.EMISSAO<ITEMCUSTODATA.DATA
            )
            
