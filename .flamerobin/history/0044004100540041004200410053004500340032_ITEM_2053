update
    materialmovimentoestoque
set
    valor = quantidade * (
        select 
            itemcustodata.CUSTOUNITARIO
        from 
            ITEMCUSTODATA
        where 
            itemcustodata.filial=
            MATERIALMOVIMENTOESTOQUE.filial and
            itemcustodata.codigo=MATERIALMOVIMENTOESTOQUE.iditem and
            itemcustodata.DATAINVENTARIO='31.03.2024')
where
   materialmovimentoestoque.FILIAL=110 and
   --materialmovimentoestoque.iditem like 'MPP%' and
   exists (
    select  
        *
    from
        MOVIMENTOESTOQUE
    where
        movimentoestoque.filial=MATERIALMOVIMENTOESTOQUE.filial and
        movimentoestoque.idmovimento=materialmovimentoestoque.idmovimento and
        movimentoestoque.tipomovimento not in ('01', '10', '11', '15') and
        movimentoestoque.emissao >= '01.03.2024')