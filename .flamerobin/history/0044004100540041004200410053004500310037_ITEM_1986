 SELECT    
    EXTRACT(YEAR FROM NOTAFISCAL.DATAEMISSAO) ANO,    
    SUM(NOTAFISCAL.VLRTOTALNOTA)
FROM
    NOTAFISCAL
WHERE
    NOTAFISCAL.DESTINATARIO = ? AND 
    NOTAFISCAL.DATACANCELAMENTO IS NULL and
    NOTAFISCAL.ENTRADASAIDA = 'S' and
    NOTAFISCAL.DATAEMISSAO IS NOT NULL
    AND EXISTS 
        (SELECT 
            * 
         FROM 
            FATURAS 
         WHERE 
            FATURAS.FILIAL=NOTAFISCAL.FILIAL 
            AND FATURAS.IDNOTA=NOTAFISCAL.IDNOTA)
GROUP BY
    EXTRACT(YEAR FROM NOTAFISCAL.DATAEMISSAO)    
ORDER BY
    NOTAFISCAL.DATAEMISSAO DESC
