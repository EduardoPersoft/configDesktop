SELECT
    itemestoque.codigo,
    itemestoque.descricao,
    max(movimentoestoque.emissao) ULTIMACOMPRA,
    materiallocal.SALDOTOTAL,
    listaprecoproduto.preco,
    listaprecoproduto.custoconsiderado
FROM
    ITEMESTOQUE
inner JOIN
    materialmovimentoestoque on
        materialmovimentoestoque.iditem=itemestoque.CODIGO
inner JOIN
    movimentoestoque on
        materialmovimentoestoque.filial=movimentoestoque.filial AND
        materialmovimentoestoque.idmovimento=movimentoestoque.idmovimento AND
        movimentoestoque.TIPOMOVIMENTO='01'
inner join 
    materiallocal on
        materiallocal.filial=5 AND
        materiallocal.iditem=itemestoque.codigo AND
        materiallocal.idlocal=1
inner JOIN
    listaprecoproduto on
        LISTAPRECOPRODUTO.produto=itemestoque.codigo AND
        listaprecoproduto.lista=1
group by
    1, 2
order by 
    3