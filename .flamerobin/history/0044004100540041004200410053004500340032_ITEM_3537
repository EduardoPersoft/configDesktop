update
    NOTAFISCAL
set
    vendedor = (select first 1 vendedoresnota.VENDEDOR
                from VENDEDORESNOTA
                where vendedoresnota.filial=notafiscal.filial and
                vendedoresnota.idnota=notafiscal.idnota)
where 
    notafiscal.filial=110 and
    notafiscal.DATAEMISSAO>='01.01.2024' and
    notafiscal.vendedor=474