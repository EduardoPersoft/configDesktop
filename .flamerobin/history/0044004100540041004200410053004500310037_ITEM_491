select 
    *
FROM
    MERCADORIASNOTACOMPRA
inner JOIN
    notacompra on 
        mercadoriasnotacompra.filial=NOTACOMPRA.filial and 
        mercadoriasnotacompra.idnota=notacompra.idnota
WHERE
    notacompra.filial=12826 AND
    notacompra.DATAENTRADA between '01.08.2021' and '31.08.2021'
    mercadoriasnotacompra.CSTIPI = 0 AND
    mercadoriasnotacompra.valoripi = 0