INSERT INTO C_SITUACAO
SELECT  
    MERCADORIASNOTA.CODIGO,
    MERCADORIASNOTA.CLASSIFISCAL,
    NOTAFISCAL.UF,
    MERCADORIASNOTA.SITUACAOTRIBUT,
    MERCADORIASNOTA.CFOP
FROM
    NOTAFISCAL
INNER JOIN
    MERCADORIASNOTA ON
        MERCADORIASNOTA.FILIAL=NOTAFISCAL.FILIAL AND
        MERCADORIASNOTA.IDNOTA=NOTAFISCAL.IDNOTA
INNER JOIN
    CADASTROPARCEIROS ON
        CADASTROPARCEIROS.CADASTRO=NOTAFISCAL.DESTINATARIO
WHERE
    NOTAFISCAL.FILIAL=5 AND
    NOTAFISCAL.DATAEMISSAO BETWEEN '01.01.2020' AND '31.12.2021' AND
    NOTAFISCAL.MODELO=1 AND
    NOTAFISCAL.UF IS NOT NULL AND
    MERCADORIASNOTA.CLASSIFISCAL IS NOT NULL AND
    MERCADORIASNOTA.SITUACAOTRIBUT IS NOT NULL AND
    CADASTROPARCEIROS.TIPOPESSOA = 'J'
ORDER BY
     MERCADORIASNOTA.CODIGO, CLASSIFISCAL, UF, SITUACAOTRIBUT
    