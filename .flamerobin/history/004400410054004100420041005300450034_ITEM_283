select MATERIALMOVIMENTOESTOQUE.* from MATERIALMOVIMENTOESTOQUE
where materialmovimentoestoque.concluido='N' 
and MATERIALMOVIMENTOESTOQUE.C_TUFTINGFUNDO is NULL
 and EXISTS
(select * from mercadoriasped 
where mercadoriasped.filial =materialmovimentoestoque.filial AND
mercadoriasped.idnota=MATERIALMOVIMENTOESTOQUE.idpedido AND
mercadoriasped.IDMERCADORIA=materialmovimentoestoque.IDMERCADORIA AND
mercadoriasped.baixa='S')
AND
exists ( 
select * from MOVIMENTOESTOQUE
where movimentoestoque.filial=materialmovimentoestoque.filial AND
movimentoestoque.idmovimento=materialmovimentoestoque.idmovimento AND
movimentoestoque.tipomovimento='12')
