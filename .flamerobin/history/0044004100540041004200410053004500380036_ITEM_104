select
    LANTOCONTPAG.Centrocusto,
    CENTROCUSTOs.descricao descricaocentro,
    lantocontPag.CONTACONTABIL,
    CONTASCONTABEIS.DESCRICAO descricaoconta,
    extract(month from titulopag.vencimento) ano,
    extract(month from titulopag.vencimento) mes,
    sum(lantocontpag.VALOR) valor
       
from 
    TITULOPAG
inner join
    lantocontpag on
        lantocontpag.filial=titulopag.filial and 
        lantocontpag.IDMOVTOBANC=titulopag.IDTITULO
inner join
    estabelecimento on
        estabelecimento.cadastro=TITULOPAG.FILIAL
inner join
    CONTASCONTABEIS on 
        CONTASCONTABEIS.IDPLANO=ESTABELECIMENTO.PLANOCONTAS and
        lantocontpag.CONTACONTABIL = contascontabeis.CONTACONTABIL  
left join
    CENTROCUSTOS on 
        CENTROCUSTOS.IDPLANO=ESTABELECIMENTO.PLANOCENTROCUSTOS and
        CENTROCUSTOS.CENTROCUSTO=lantocontpag.CENTROCUSTO
where 
    titulopag.filial=? and 
    titulopag.vencimento between ? and ?
group by        
    lantocontpag.CENTROCUSTO,
    CENTROCUSTOs.descricao,
    lantocontpag.CONTACONTABIL,
    CONTASCONTABEIS.DESCRICAO,
    extract(month from titulopag.vencimento),
    extract(month from titulopag.vencimento)    
order by
    lantocontpag.CENTROCUSTO,
    CENTROCUSTOs.descricao,
    lantocontpag.CONTACONTABIL,
    CONTASCONTABEIS.DESCRICAO,
    extract(month from titulopag.vencimento),
    extract(month from titulopag.vencimento)
