select
    materialfilial.C_LOCALIMPORTACAO,
    itemestoque.C_LOCALIMPORTACAO,
    itemestoque.*
from    
    ITEMESTOQUE
inner join 
    materialfilial on
        materialfilial.filial=12826 and
        itemestoque.codigo=materialfilial.iditem
where
    itemestoque.C_LOCALIMPORTACAO<>MATERIALFILIAL.C_LOCALIMPORTACAO