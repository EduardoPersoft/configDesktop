SELECT 
        DEST.CADASTRO,
        DEST.NOME,
        mercadoriasorc.FILIAL,
        mercadoriasorc.IDNOTA,
        mercadoriasorc.idmercadoria,       
        orcamento.NUMERONOTA,
        orcamento.DATAEMISSAO,
        mercadoriasorc.CODIGO,
        ITEMESTOQUE.DESCRICAO,       
        mercadoriasorc.QUANTIDADE,
        mercadoriasorc.precounitario,
        mercadoriasorc.VLRFINALMERCAD,
        (select sum(materiallocal.saldototal) 
         from MATERIALLOCAL
         inner join local on materiallocal.idlocal=local.id
         where materiallocal.filial=mercadoriasorc.filial AND
         materiallocal.iditem=mercadoriasorc.codigo AND
         local.disponivel = 'S') as saldo,
         listaProdutoPadrao.preco as precoNormal,
         listaProdutoDesconto.preco as precoDesconto
         
         
FROM oRCAMENTO
INNER JOIN mercadoriasorc ON (orcamento.FILIAL = mercadoriasorc.FILIAL AND
orcamento.IDNOTA = mercadoriasorc.IDNOTA)
INNER JOIN CADASTROPARCEIROS DEST ON (orcamento.DESTINATARIO = DEST.CADASTRO)
INNER JOIN CADASTROPARCEIROS FILIAL ON (orcamento.FILIAL = FILIAL.CADASTRO)
INNER JOIN ITEMESTOQUE ON (mercadoriasorc.CODIGO = ITEMESTOQUE.CODIGO)
left join listapreco listaPadrao on listapadrao.listapadrao='S'
left join listaprecoproduto listaProdutoPadrao on (
    listaProdutoPadrao.lista=listapadrao.LISTA and 
    listaProdutoPadrao.produto=mercadoriasorc.codigo)
left join listapreco listaDesconto on listaDesconto.listaReferencia = listaPadrao.lista 
left join listaprecoproduto listaProdutoDesconto on (
    listaProdutoDesconto.lista=listaDesconto.LISTA and 
    listaProdutoDesconto.produto=mercadoriasorc.codigo)
WHERE orcamento.FILIAL= 5
and orcamento.DESTINATARIO = 3778
AND orcamento.CANCELAMENTO = 'N'