select
    i1.codigo,
    i1.codigo as codchave
from
    itemestoque i1
union     
select
    i1.referencia,
    i1.codigo as codchave
from
    itemestoque i1
where    
    coalesce(i1.referencia, '')<>''
union    
select
    i1.C_ORIGINAL,
    i1.codigo as codchave
from
    itemestoque i1
where    
    coalesce(i1.c_original, '')<>''
union     
select
    i1.referencia,
    i2.codigo as codchave
from
    itemestoque i1
inner join
    itemestoque i2 on
        i2.c_original=i1.c_original
where    
    coalesce(i1.referencia, '')<>''
    
