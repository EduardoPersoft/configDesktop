select
    first 50
    itemestoque.codigo,
    itemestoque.descricao,    
    itemestoque.referencia,
    classificacaofiscal.DESCRICAO as ncm,
    listaprecoproduto.preco,
    'https://erp.persoft.com.br/falma/'||itemestoquexarquivo.NOMEARQUIVO as urlfoto,
    sum(mercadoriasnota.quantidade) quantidadeVendida
from
    NOTAFISCAL
inner join
    mercadoriasnota on
        mercadoriasnota.filial=notafiscal.filial and
        mercadoriasnota.idnota=notafiscal.IDNOTA
inner join
    itemestoque on
        itemestoque.codigo=mercadoriasnota.codigo
inner join
    CLASSIFICACAOFISCAL on
        classificacaofiscal.CFISCAL=itemestoque.CLASSIFISCAL
inner join
    listaprecoproduto on
        listaprecoproduto.lista=1 and
        listaprecoproduto.produto=itemestoque.codigo
inner join
    ITEMESTOQUEXARQUIVO on
        itemestoquexarquivo.codigo=itemestoque.codigo and
        itemestoquexarquivo.ordem=0
where
    notafiscal.filial=5 and
    notafiscal.cancelamento is null and
    notafiscal.DATAEMISSAO between '01.06.2021' and '31.05.2022'
group by    
    itemestoque.codigo,
    itemestoque.descricao,    
    itemestoque.referencia,
    classificacaofiscal.DESCRICAO,
    listaprecoproduto.preco,
    itemestoquexarquivo.NOMEARQUIVO
order by
    sum(mercadoriasnota.vlrfinalmercad) desc
        