ALTER PROCEDURE C_LISTAPEDCANAL (
    PFILIAL integer,
    PVENDEDOR integer )
RETURNS (
    FILIAL integer,
    IDNOTA integer,
    DATACADASTRO timestamp,
    DATAEMISSAO timestamp,
    NUMERONOTA integer,
    DESTINATARIO integer,
    EMAIL varchar(50),
    TELEFONE varchar(30),
    NOME varchar(50),
    DOCUMENTO varchar(14),
    NOME_LOJA varchar(50),
    VLRTOTALNOTA double precision,
    STATUS varchar(30),
    VENDEDOR varchar(60),
    TIPO varchar(30),
    AGENTENOME varchar(60),
    uuid varchar(36) )

AS
DECLARE V_TIPOAGENTE INTEGER;
DECLARE V_CANALRELACIONADO INTEGER;
DECLARE V_PRINCIPAL INTEGER;
DECLARE V_VENDEDORPESQUISA INTEGER;
BEGIN

  SELECT VENDEDOR.CANALRELACIONADO,VENDEDOR.TIPOVENDEDOR FROM VENDEDOR WHERE CADASTRO=:PVENDEDOR
  INTO V_CANALRELACIONADO,V_TIPOAGENTE;
  
  V_PRINCIPAL = PVENDEDOR;
  IF (V_TIPOAGENTE=6) then
    V_PRINCIPAL=V_cANALRELACIONADO;
    
  
  FOR SELECT VENDEDOR.CADASTRO,CADASTROPARCEIROS.NOME FROM VENDEDOR 
  INNER JOIN CADASTROPARCEIROS ON (CADASTROPARCEIROS.CADASTRO=VENDEDOR.CADASTRO)
  WHERE VENDEDOR.CANALRELACIONADO=:V_PRINCIPAL 
  UNION 
  SELECT VENDEDOR.CADASTRO,CADASTROPARCEIROS.NOME FROM VENDEDOR 
  INNER JOIN CADASTROPARCEIROS ON (CADASTROPARCEIROS.CADASTRO=VENDEDOR.CADASTRO)
  WHERE VENDEDOR.CADASTRO=:V_PRINCIPAL
  INTO  :V_VENDEDORPESQUISA,:AGENTENOME DO 
    FOR SELECT PED2.FILIAL,
       PED2.IDNOTA,
       PED2.DATACADASTRO,
       PED2.DATAEMISSAO,
       PED2.NUMERONOTA,
       PED2.DESTINATARIO,
       PED2.EMAIL,
       PED2.TELEFONE,
       PED2.VLRTOTALNOTA,
       CADCLI.NOME,
       CADCLI.DOCUMENTO,
       CADLOJA.NOME AS NOME_LOJA,
       CASE when PED2.dataemissao IS NULL THEN 'LOJA'
       when PED2.Cancelamento='S' Then 'CANCELADO'
       WHEN PED2.C_Pedidosubstituido  IS NOT NULL THEN 'SUBSTITUI'
       WHEN EXISTS
            ( SELECT * FROM Pedido PED3
              WHERE PED3.FILIAL=PED2.FILIAL
              AND PED3.C_Pedidosubstituido=PED2.IDNOTA) THEN 'SUBSTITUTÍDO'
       WHEN NOT EXISTS (SELECT * FROM MERCADORIASPED
                    WHERE PED2.FILIAL=MERCADORIASPED.FILIAL
                    AND PED2.IDNOTA=MERCADORIASPED.IDNOTA
                    AND MERCADORIASPED.baixa='S') THEN 'FABRICA'
       WHEN EXISTS (SELECT * FROM MERCADORIASPED
                    WHERE PED2.FILIAL=MERCADORIASPED.FILIAL
                    AND PED2.IDNOTA=MERCADORIASPED.IDNOTA
                    AND MERCADORIASPED.baixa='N') THEN 'PARCIAL'
       ELSE 'BAIXADO' END STATUS,
      (select FIRST 1 cadven.NOME FROM vendedoresPED
       INNER JOIN CADASTROPARCEIROS CADVEN ON (CADVEN.cadastro=VENDEDORESPED.vendedor)
       WHERE VENDEDORESPED.filial=PED2.FILIAL
       AND VENDEDORESPED.idnota=PED2.IDNOTA) VENDEDOR,
                  case when ped2.c_devolucao is not null then 'Devoluçăo'
           else
           case coalesce(ped2.cancelamento,'N') when 'S' THEN 'Cancelado'
           else
            CASE COALESCE(PED2.c_consignacao,'N') WHEN 'S' THEN
                CASE WHEN PED2.C_MALOTE IS NOT NULL THEN 'CONSIGNADO - DEVOLVIDO'
                ELSE 'CONSIGNADO'
                END
            ELSE
            CASE PED2.c_tipo WHEN 0 then
            case ped2.c_produtoencomendaacabado
              when 'E' THEN 'Encomenda'
              else 'Pronta Entrega'
              end
             WHEN 1 then 'Venda Interna'
             When 2 then 'Amostra'
             When 3 then 'Demonstraçăo'
             When 4 then 'Reposiçăo'
             When 5 then 'Estoque'
            end
           end
           end
           END as TIPO,
           ped2.uuid 

    FROM VENDEDORESPED
    INNER JOIN PEDIDO PED2 ON (PED2.FILIAL=VENDEDORESPED.FILIAL
                        AND PED2.IDNOTA=VENDEDORESPED.IDNOTA)
    INNER JOIN CADASTROPARCEIROS cadcli ON (CADCLI.CADASTRO = PED2.DESTINATARIO)
    LEFT JOIN CADASTROPARCEIROS CADLOJA ON (CADLOJA.CADASTRO = PED2.c_loja) 
    WHERE VENDEDORESPED.FILIAL=:pFILIAL
    AND VENDEDORESPED.VENDEDOR =:V_VENDEDORPESQUISA
    INTO FILIAL,IDNOTA,DATACADASTRO,DATAEMISSAO,NUMERONOTA,DESTINATARIO,EMAIL,
        TELEFONE,VLRTOTALNOTA,NOME,DOCUMENTO,NOME_LOJA,STATUS,VENDEDOR,TIPO,uuid 
         DO
        SUSPEND;
END
^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE C_LISTAPEDCANAL TO  SYSDBA;

