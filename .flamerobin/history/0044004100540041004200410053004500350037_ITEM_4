SELECT 
    C_MERCORCESPEC.FILIAL,
    C_MERCORCESPEC.IDNOTA,
    C_MERCORCESPEC.IDMERCADORIA,
    C_MERCORCESPEC.IDESPECIFICACAO,
    C_ESPECIFICACOES.DESCRICAO,
    C_MERCORCESPEC.OPCAO
FROM 
    C_MERCORCESPEC
INNER JOIN
	MERCADORIASORC ON 
        C_MERCORCESPEC.FILIAL=MERCADORIASORC.FILIAL and
        C_MERCORCESPEC.IDNOTA=MERCADORIASORC.idnota and
        C_MERCORCESPEC.IDMERCADORIA=MERCADORIASORC.idmercadoria
INNER JOIN
    C_ESPECIFICACOES on
        C_ESPECIFICACOES.IDITEM=MERCADORIASORC.CODIGO 
order by
    C_MERCORCESPEC.FILIAL,
    C_MERCORCESPEC.IDNOTA,
    C_MERCORCESPEC.IDMERCADORIA,
    C_MERCORCESPEC.IDESPECIFICACAO,
