insert into ITEMESTOQUECODIGOS(codigo,codigoalternativo)
select
  0,  i1.codigo,i1.codigo
from
    ITEMESTOQUE i1
UNION
select
   1, i1.codigo,itembase
from
    ITEMESTOQUE i1
UNION
select
    2,i1.codigo, referencia
from
    ITEMESTOQUE i1
UNION
select
    3,i1.itembase,i1.codigo
from
    itemestoque i1
union
select
    4,i1.codigo,i1.CODIGOALTERNATIVO
from
    ITEMESTOQUEoutroscodigos i1
UNION
SELECT
    5,i1.codigo,FORNECEDORESITEM.CODIGOFORNEC
FROM
    itemestoque i1
inner join 
    fornecedoresitem on
        fornecedoresitem.IDITEM=i1.codigo

