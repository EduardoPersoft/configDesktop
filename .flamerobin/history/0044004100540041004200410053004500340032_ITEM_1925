select 
    materialmovimentoestoque.iditem,
    movimentoestoque.tipomovimento,
    MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO,
    sum(materialmovimentoestoque.quantidade*
        case movimentoestoque.localtransferencia when 3 then -1 else 1 end)
from 
    MATERIALMOVIMENTOESTOQUE
inner join 
    MOVIMENTOESTOQUE on
        movimentoestoque.filial=materialmovimentoestoque.filial and
        movimentoestoque.idmovimento=materialmovimentoestoque.idmovimento
where
    movimentoestoque.TIPOMOVIMENTO = 10 and
    MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO <> 2 and
    MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO <> 6 and
    MATERIALMOVIMENTOESTOQUE.localtransferencia <> 6 and    
    MATERIALMOVIMENTOESTOQUE.localtransferencia <> 2 and        
    (movimentoestoque.LOCALARMAZENAMENTO = 3 or 
     movimentoestoque.LOCALTRANSFERENCIA = 3)

    
    movimentoestoque.emissao = '31.01.2024' and
    MATERIALMOVIMENTOESTOQUE.iditem like 'MP%'
group by    
    materialmovimentoestoque.iditem,
        movimentoestoque.tipomovimento,
    MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO