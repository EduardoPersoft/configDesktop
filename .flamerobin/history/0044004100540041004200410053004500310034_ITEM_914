select * from movimentoestoque
inner join
    movimentoestoque on
        movimentoestoque.filial=MATERIALMOVIMENTOESTOQUE.filial and
        movimentoestoque.idmovimento=materialmovimentoestoque.idmovimento
where MATERIALMOVIMENTOESTOQUE.filial=110 
and MATERIALMOVIMENTOESTOQUE.idpedido=10026 
and MATERIALMOVIMENTOESTOQUE.idmercadoria=1 
and movimentoestoque.tipomovimento='12'