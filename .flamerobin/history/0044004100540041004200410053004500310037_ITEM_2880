select 
    itemestoque.codigo,
    itemestoque.descricao,
    itemestoque.referencia,
    C_FORNECEDORPECA.decricao,
    count(mercadoriasorc.idnota)
from 
    orcamento
inner join
    mercadoriasorc on
        orcamento.filial=mercadoriasorc.filial and
        orcamento.idnota=mercadoriasorc.idnota 
inner join
    itemestoque on
        itemestoque.codigo=mercadoriasorc.CODIGO
inner join
    C_FORNECEDORPECA on
        C_FORNECEDORPECA.id=itemestoque.C_FORNECEDOR
where 
    orcamento.DATACADASTRO between '01.08.2023' and '31.08.2023' and
    orcamento.CANCELAMENTO='N'
group by    
    itemestoque.codigo,
    itemestoque.descricao,
    C_FORNECEDORPECA.decricao    
order by 4 
    desc
    