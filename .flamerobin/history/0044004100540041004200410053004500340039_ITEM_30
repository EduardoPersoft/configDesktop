SET TERM ^ ;
ALTER PROCEDURE C_INSERTPEDCOMP2OP (
    USUARIO integer )

AS
DECLARE VARIABLE FILIAL INTEGER; 
DECLARE VARIABLE IDMOVIMENTO INTEGER;
DECLARE VARIABLE IDMERCADORIA INTEGER;
DECLARE VARIABLE IDMOVIMENTOMATERIAL INTEGER;
DECLARE VARIABLE IDMOVIMENTOant INTEGER;
DECLARE VARIABLE IDREGIAO INTEGER;
DECLARE VARIABLE IDNOTA INTEGER;
DECLARE VARIABLE CONSUMO DECIMAL(12,3);
DECLARE VARIABLE FIOMANTA VARCHAR(15);
DECLARE VARIABLE MODELO VARCHAR(15);
DECLARE VARIABLE MANTAFIO VARCHAR(1);
DECLARE VARIABLE LOTE VARCHAR(12);
DECLARE VARIABLE LOTEFORNECEDOR VARCHAR(3);
DECLARE VARIABLE QUANTIDADE DECIMAL(12,3);
DECLARE VARIABLE QUANTIDADELOTE DECIMAL(12,3);
DECLARE VARIABLE QUANTIDADEAPLICADA DECIMAL(12,3);
DECLARE VARIABLE LARGURA DECIMAL(12,2);
DECLARE VARIABLE COMPRIMENTO DECIMAL(12,3);
DECLARE VARIABLE QTDLOTE DECIMAL(12,3);
BEGIN
  /* write your code here */ 
  
    IDMOVIMENTOant = 0;
    

    for SELECT C_Pedido2op.Filial,
       C_PEDIDO2OP.Idmovimento,
       MERCADORIASPED.Idmercadoria,
       COALESCE( C_Mercadoriaspedfios.Regiao,0)+1,
       COALESCE(C_Mercadoriaspedfios.Fio, ITEMESTOQUE.C_MODELO),
       CAST(COALESCE(ITEMESTOQUE.C_Pesoconsumo,0) *
       COALESCE(mercadoriasped.C_M2,0) *
       COALESCE(C_Itemregioes.Percentual,0) /100 AS DECIMAL(12,3)),
       CASE WHEN ITEMESTOQUE.C_MODELO IS NOT NULL THEN 'M' ELSE 'F' END,
       MERCADORIASPED.QUANTIDADE,
       ITEMESTOQUE.C_MODELO,
       MERCADORIASPED.IDNOTA
    from C_Pedido2op
    INNER JOIN MERCADORIASPED ON (
        MERCADORIASPED.FILIAL=C_PEDIDO2OP.FILIAL
        AND MERCADORIASPED.IDNOTA=C_PEDIDO2OP.IDPEDIDO)
    INNER JOIN ITEMESTOQUE ON (ITEMESTOQUE.CODIGO=MERCADORIASPED.CODIGO)
    LEFT JOIN C_Mercadoriaspedfios ON
        (C_Mercadoriaspedfios.Filial=MERCADORIASPED.FILIAL
        AND C_Mercadoriaspedfios.Idnota=MERCADORIASPED.Idnota
        AND C_Mercadoriaspedfios.Idmercadoria=MERCADORIASPED.Idmercadoria)
    LEFT JOIN C_Itemregioes ON (C_ITEMREGIOES.Codigo=ITEMESTOQUE.CODIGO
        AND C_ITEMREGIOES.Regiao=C_Mercadoriaspedfios.Regiao+1)            
    WHERE C_Pedido2op.USUARIO=:USUARIO
    AND Itemestoque.TIPOPRODUTO='4'  
    AND COALESCE(C_Mercadoriaspedfios.Fio, ITEMESTOQUE.C_MODELO) IS NOT NULL
    
    AND NOT EXISTS
            (SELECT materialmovimentoestoque.IDMERCADORIA FROM MOVIMENTOESTOQUE
             inner join materialmovimentoestoque on 
                    (materialmovimentoestoque.filial=movimentoestoque.filial and 
                     materialmovimentoestoque.idmovimento=movimentoestoque.idmovimento) 
             inner join composicaoop on 
                    (composicaoop.filial=movimentoestoque.filial and 
                     composicaoop.idmovimento=movimentoestoque.idmovimento and
                     composicaoop.IDMOVIMENTOMATERIAL=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL)              
             WHERE materialmovimentoestoque.FILIAL=MERCADORIASPED.FILIAL
             AND materialmovimentoestoque.IDPEDIDO=MERCADORIASPED.IDNOTA
             and materialmovimentoestoque.IDMERCADORIA=mercadoriasped.IDMERCADORIA
             AND MOVIMENTOESTOQUE.TIPOMOVIMENTO=12) 
    
    INTO :FILIAL,:IDMOVIMENTO,:IDMERCADORIA,:IDREGIAO,:FIOMANTA,CONSUMO,:MANTAFIO,QUANTIDADE,MODELO,:IDNOTA DO BEGIN 
    
        if (idmovimentoant<>idmovimento) then begin
            idmovimentoant=idmovimento;
            idmovimentomaterial=0;
        end
        idmovimentomaterial = idmovimentomaterial+1;
        IF (MANTAFIO='F')                
        THEN
            INSERT INTO COMPOSICAOOP (
                FILIAL               ,
                IDMOVIMENTO          ,
                IDMOVIMENTOMATERIAL  ,
                IDCOMPOSICAO         ,
                CODIGO               ,
                LOTE                 ,
                GRADEVERTICAL        ,
                GRADEHORIZONTAL      ,
                QUANTIDADE)
            VALUES (
                :FILIAL,
                :IDMOVIMENTO,
                :IDmovimentomaterial,
                :IDREGIAO,
                :FIOMANTA,
                '.',
                '',
                '',
                :CONSUMO);
        ELSE BEGIN
            IDREGIAO = 0;
            FOR SELECT 
                C_RESERVARMATERIALLOTE.IDITEM,
                C_RESERVARMATERIALLOTE.LOTE,
                C_rESERVARMATERIALLOTE.QUANTIDADE,
                materiallote.C_LARGURA
            FROM    
                C_RESERVARMATERIALLOTE
            inner JOIN
                materiallote on
                    materiallote.filial=C_RESERVARMATERIALLOTE.FILIAL
                    and materiallote.iditem=C_RESERVARMATERIALLOTE.IDITEM
                    and materiallote.lote=C_RESERVARMATERIALLOTE.lote
            WHERE 
                C_RESERVARMATERIALLOTE.FILIAL=:FILIAL
                AND C_RESERVARMATERIALLOTE.IDNOTA = :IDNOTA
                AND C_RESERVARMATERIALLOTE.IDMERCADORIA = :IDMERCADORIA
                AND C_RESERVARMATERIALLOTE.TIPO = 'P'
             
             
            INTO :FIOMANTA, :LOTE, :CONSUMO, :largura DO BEGIN
                IDREGIAO = IDREGIAO + 1;
                COMPRIMENTO =  CAST(consumo/LARGURA AS DECIMAL(12,3)) ;
                INSERT INTO COMPOSICAOOP (
                    FILIAL               ,
                    IDMOVIMENTO          ,
                    IDMOVIMENTOMATERIAL  ,
                    IDCOMPOSICAO         ,
                    CODIGO               ,
                    LOTE                 ,
                    GRADEVERTICAL        ,
                    GRADEHORIZONTAL      ,
                    QUANTIDADE,
                    c_largura,
                    c_comprimento)
                VALUES (
                    :FILIAL,
                    :IDMOVIMENTO,
                    :IDMERCADORIA,
                    :IDREGIAO,
                    :FIOMANTA,
                    :LOTE,
                    '',
                    '',
                    :CONSUMO,
                    :largura,
                    :comprimento);           
            END
            
            
         
            IF (IDREGIAO=0) THEN BEGIN

                LOTEFORNECEDOR='.';
                SELECT FIRST 1 materiallotedisponivel.iditem, substring(MATERIALLOTEDISPONIVEL.LOTE from 1 for 3)
                FROM ITEMESTOQUE
                INNER JOIN MATERIALLOTEDISPONIVEL ON (ITEMESTOQUE.CODIGO=MATERIALLOTEDISPONIVEL.IDITEM)
                INNER JOIN MATERIALLOTE ON (MATERIALLOTEDISPONIVEL.FILIAL=MATERIALLOTE.FILIAL
                AND MATERIALLOTEDISPONIVEL.IDITEM=MATERIALLOTE.IDITEM
                AND MATERIALLOTEDISPONIVEL.LOTE=MATERIALLOTE.LOTE)
                WHERE ITEMESTOQUE.C_MODELO=:MODELO
                GROUP BY MATERIALLOTEDISPONIVEL.FILIAL,
                         MATERIALLOTEDISPONIVEL.IDITEM,
                         substring(MATERIALLOTEDISPONIVEL.LOTE from 1 for 3)
                HAVING SUM(QUANTIDADE)
                    -COALESCE(
                            (SELECT SUM(composicaoop.QUANTIDADE) FROM COMPOSICAOOP
                             INNER JOIN MATERIALMOVIMENTOESTOQUE ON
                                        (COMPOSICAOOP.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL
                                         AND COMPOSICAOOP.idmovimento=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
                                         AND COMPOSICAOOP.idmovimentoMATERIAL=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL
                            AND COMPOSICAOOP.idmovimentomaterial=MATERIALMOVIMENTOESTOQUE.idmovimentomaterial)
                            WHERE COMPOSICAOOP.FILIAL=MATERIALLOTEDISPONIVEL.FILIAL
                            AND COMPOSICAOOP.codigo=MATERIALLOTEDISPONIVEL.IDITEM
                            AND COMPOSICAOOP.LOTE LIKE SUBSTRING(MATERIALLOTEDISPONIVEL.LOTE from 1 for 3)||'%'
                            AND MATERIALMOVIMENTOESTOQUE.CONCLUIDO='N'),0)>:QUANTIDADE
                ORDER BY SUM(QUANTIDADE)
                -COALESCE(
                            (SELECT SUM(composicaoop.QUANTIDADE) FROM COMPOSICAOOP
                             INNER JOIN MATERIALMOVIMENTOESTOQUE ON
                                        (COMPOSICAOOP.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL
                                         AND COMPOSICAOOP.idmovimento=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
                                         AND COMPOSICAOOP.idmovimentoMATERIAL=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL
                            AND COMPOSICAOOP.idmovimentomaterial=MATERIALMOVIMENTOESTOQUE.idmovimentomaterial)
                            WHERE COMPOSICAOOP.FILIAL=MATERIALLOTEDISPONIVEL.FILIAL
                            AND COMPOSICAOOP.codigo=MATERIALLOTEDISPONIVEL.IDITEM
                            AND COMPOSICAOOP.LOTE LIKE SUBSTRING(MATERIALLOTEDISPONIVEL.LOTE from 1 for 3)||'%'
                            AND MATERIALMOVIMENTOESTOQUE.CONCLUIDO='N'),0)
                INTO :fiomanta, :LOTEFORNECEDOR;
                
                FOR SELECT MATERIALLOTE.LOTE,
                       MATERIALLOTE.C_LARGURA,   
                       MATERIALLOTE.quantidade
                       -COALESCE(
                            (SELECT SUM(composicaoop.QUANTIDADE) FROM COMPOSICAOOP
                             INNER JOIN MATERIALMOVIMENTOESTOQUE ON
                                        (COMPOSICAOOP.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL
                                         AND COMPOSICAOOP.idmovimento=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
                                         AND COMPOSICAOOP.idmovimentoMATERIAL=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL
                            AND COMPOSICAOOP.idmovimentomaterial=MATERIALMOVIMENTOESTOQUE.idmovimentomaterial)
                            WHERE COMPOSICAOOP.FILIAL=MATERIALLOTE.FILIAL
                            AND COMPOSICAOOP.codigo=MATERIALLOTE.IDITEM
                            AND COMPOSICAOOP.LOTE=MATERIALLOTE.LOTE
                            AND MATERIALMOVIMENTOESTOQUE.CONCLUIDO='N'),0)
                FROM MATERIALLOTEDISPONIVEL 
                INNER JOIN MATERIALLOTE ON (MATERIALLOTE.FILIAL=MATERIALLOTEDISPONIVEL.FILIAL
                    AND MATERIALLOTE.IDITEM=MATERIALLOTEDISPONIVEL.IDITEM
                    AND MATERIALLOTE.LOTE=MATERIALLOTEDISPONIVEL.LOTE)
                WHERE MATERIALLOTEDISPONIVEL.IDITEM=:FIOMANTA
                AND MATERIALLOTEDISPONIVEL.LOTE LIKE :LOTEFORNECEDOR||'%'
                AND MATERIALLOTE.quantidade-COALESCE(
                            (SELECT SUM(composicaoop.QUANTIDADE) FROM COMPOSICAOOP
                             INNER JOIN MATERIALMOVIMENTOESTOQUE ON
                                        (COMPOSICAOOP.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL
                                         AND COMPOSICAOOP.idmovimento=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
                                         AND COMPOSICAOOP.idmovimentoMATERIAL=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL
                            AND COMPOSICAOOP.idmovimentomaterial=MATERIALMOVIMENTOESTOQUE.idmovimentomaterial)
                            WHERE COMPOSICAOOP.FILIAL=MATERIALLOTE.FILIAL
                            AND COMPOSICAOOP.codigo=MATERIALLOTE.IDITEM
                            AND COMPOSICAOOP.LOTE=MATERIALLOTE.LOTE
                            AND MATERIALMOVIMENTOESTOQUE.CONCLUIDO='N'),0)>0.01
                                    
                ORDER BY MATERIALLOTE.DATA,MATERIALLOTE.LOTE
                INTO :LOTE,LARGURA,QUANTIDADELOTE DO BEGIN
                    IF (QUANTIDADE<QUANTIDADELOTE) then
                        QUANTIDADEAPLICADA=QUANTIDADE;
                    else
                        QUANTIDADEAPLICADA=QUANTIDADELOTE;
                    COMPRIMENTO =  CAST(QUANTIDADEAPLICADA/LARGURA AS DECIMAL(12,3)) ;   
                    INSERT INTO COMPOSICAOOP (
                        FILIAL               ,
                        IDMOVIMENTO          ,
                        IDMOVIMENTOMATERIAL  ,
                        IDCOMPOSICAO         ,
                        CODIGO               ,
                        LOTE                 ,
                        GRADEVERTICAL        ,
                        GRADEHORIZONTAL      ,
                        QUANTIDADE,
                        C_LARGURA,
                        C_COMPRIMENTO)
                    VALUES (
                        :FILIAL,
                        :IDMOVIMENTO,
                        :IDMERCADORIA,
                        :IDREGIAO,
                        :FIOMANTA,
                        :LOTE,
                        '',
                        '',
                        :QUANTIDADEAPLICADA,
                        :LARGURA,
                        :COMPRIMENTO);
                    QUANTIDADE = QUANTIDADE - QUANTIDADEAPLICADA;
                    IDREGIAO=IDREGIAO+1;
                END
                IF (QUANTIDADE>0) then
                    INSERT INTO COMPOSICAOOP (
                        FILIAL               ,
                        IDMOVIMENTO          ,
                        IDMOVIMENTOMATERIAL  ,
                        IDCOMPOSICAO         ,
                        CODIGO               ,
                        LOTE                 ,
                        GRADEVERTICAL        ,
                        GRADEHORIZONTAL      ,
                        QUANTIDADE)
                    VALUES (
                        :FILIAL,
                        :IDMOVIMENTO,
                        :IDMERCADORIA,
                        :IDREGIAO,
                        :FIOMANTA,
                        '.',
                        '',
                        '',
                        :QUANTIDADE);
                        
                        
            END
        END

    END



END
^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE C_INSERTPEDCOMP2OP TO  SYSDBA;

