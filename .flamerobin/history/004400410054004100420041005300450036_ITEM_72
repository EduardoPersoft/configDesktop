SELECT 
    MATERIALLOCAL.FILIAL,
    MATERIALLOCAL.IDITEM,
    MATERIALLOCAL.IDLOCAL,
    MATERIALLOCAL.SALDOTOTAL*(-1)
FROM
    MOVIMENTOESTOQUE
INNER JOIN
    MATERIALMOVIMENTOESTOQUE ON
        MATERIALMOVIMENTOESTOQUE.FILIAL=MOVIMENTOESTOQUE.FILIAL
        MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO=MOVIMENTOESTOQUE.IDMOVIMENTO
INNER JOIN
    MATERIALLOCAL ON 
        MATERIALLOCAL.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL AND
        MATERIALLOCAL.IDITEM=MATERIALMOVIMENTOESTOQUE.IDITEM AND
        MATERIALLOCAL.IDLOCAL=MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO
WHERE 
    MOVIMENTOESTOQUE.FILIAL=12826
    MOVIMENTOESTOQUE.EMISSAO BETWEEN '08.03.2021' AND '08.03.2021'