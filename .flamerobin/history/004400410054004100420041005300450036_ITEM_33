UPDATE MERCADORIASNOTACOMPRA
SET MERCADORIASNOTACOMPRA.CSTIPI=49
WHERE EXISTS
(SELECT * FROM NOTACOMPRA
where NOTACOMPRA.FILIAL=12826 AND
NOTACOMPRA.DATAENTRADA>='01.02.2021'
AND MERCADORIASNOTACOMPRA.PIPI=0 AND MERCADORIASNOTACOMPRA.CSTIPI=0
AND mercadoriasnotaCOMPRA.filial=notaCOMPRA.filial 
AND MERCADORIASNOTACOMPRA.IDNOTA=NOTACOMPRA.IDNOTA
)