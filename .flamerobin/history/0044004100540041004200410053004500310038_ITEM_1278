update
    PEDIDO
set
    pedido.datareferencia=coalesce(pedido.c_datacomissao,
       cast((select
        min(fatped.DATA)
     from
        c_faturasped FATPED
     where
        fatped.filial=pedido.filial and
        fatped.idnota=pedido.idnota) as date))
where 
    pedido.filial=1 and
    pedido.dataemissao is not null and 
    pedido.datacadastro >= '01.01.202'  and
    pedido.C_PEDIDOSUBSTITUIDO is null and
    pedido.DATAREFERENCIA<>coalesce(pedido.c_datacomissao,
       cast((select
        min(fatped.DATA)
     from
        c_faturasped FATPED
     where
        fatped.filial=pedido.filial and
        fatped.idnota=pedido.idnota) as date))
