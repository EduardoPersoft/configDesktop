select 
    cast(0 as integer) qtd,
    cast(1 as integer) total,
    itemestoque.codigo,    
    materiallote.lote,
    SUBSTRING (itemestoque.DESCRICAO FROM 1 FOR 40) AS DESCRICAO1,
    SUBSTRING (itemestoque.DESCRICAO FROM 40 FOR 40) AS DESCRICAO2,
    materiallote.c_largura as largura,
    materiallote.QUANTIDADE,
    20000000000+materiallote.codigobarra
    materiallote.FILIAL,
    materiallote.uuid
from   
    itemestoque
inner join 
    materiallote on 
        (materiallote.IDITEM=itemestoque.codigo)      
left join
    consultas on
         (consultas.UUIDSELECIONADO=materiallote.uuid)
where 
    consultas.uuid='16ee8f06-da4a-4db8-b3b4-24f9b24a848e'

