update
    MERCADORIASPED
set
    baixa='S'
where
    baixa = 'N' and
    exists (
        select 
            *
        from
            PEDIDO
        where
            mercadoriasped.filial=pedido.filial and
            mercadoriasped.idnota = pedido.idnota and
            pedido.CANCELAMENTO='S')    