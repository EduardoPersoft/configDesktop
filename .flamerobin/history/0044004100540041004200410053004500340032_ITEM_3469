SELECT r.CODIGO, r.SEQUENCIA, r.FILME, r.GRAMATURAFILME, r.ADESIVO,
    r.GRAMATURAADESIVO, r.APLICARTRATADOR, r.LADOLAMINAR, r.SAIDAREBOBINADEIRA,
    r.LARGURAROLO, r.ITEMRIGOROSO, r.OBSERVACAO, r.C_VELOCIDADE, r.C_SETUP,
    r.C_TENSAREBOBINADOR, r.C_TENSAOPELICULA, r.C_TENSAODESBOBINADORA,
    r.C_TENSAODESBOBINADORB, r.C_PERDAPROCESSO, r.C_PERDAAJUSTEMAQUINA,
    r.FORCASELAGEM, r.FORCALAMINACAO, r.LADOLAMINAR2, r.APLICACAOADESIVOMINIMO,
    r.APLICACAOADESIVOMAXIMO, r.C_VELOCIDADEL10, r.C_SETUPL10,
    r.C_TENSAREBOBINADORL10, r.C_TENSAOPELICULAL10, r.C_TENSAODESBOBINADORAL10,
    r.C_TENSAODESBOBINADORBL10, r.C_PERDAPROCESSOL10, r.C_PERDAAJUSTEMAQUINAL10,
    r.FORCASELAGEML10, r.FORCALAMINACAOL10, r.TEMPERATURACONJUNTOL7,
    r.TEMPERATURANIPL10, r.TEMPERATURAAPLICADOSL10, r.FILME2, r.GRAMATURAFILME2,
    r.FILME1BOBINADOR, r.FILME2BOBINADOR, r.C_FILMESALVO, r.C_FILME2SALVO,
    r.C_GRAMATURAFILMES, r.C_GRAMATURA2FILMES, r.C_FILME1BOBINADORS,
    r.C_FILME2BOBINADORS
FROM
    ITEMESTOQUE
inner join
    C_LAMINACAO r on
        r.codigo=itemestoque.itembase
where
    substring(itemestoque.codigo from1 for 12)='PRO050245SUP"