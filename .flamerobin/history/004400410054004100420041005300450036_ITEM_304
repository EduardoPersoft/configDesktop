SELECT
    *
FROM
    PEDIDO
WHERE
    pedido.DATACADASTRO>='01.02.2021' and
    pedido.CANCELAMENTO = 'N' and 
    EXISTS
    (select * from mercadoriasped 
     where mercadoriasped.filial=pedido.filial AND
     mercadoriasped.idnota=pedido.idnota and
     mercadoriasped.baixa='N')  and
    EXISTS
    (select * from mercadoriasped 
     where mercadoriasped.filial=pedido.filial AND
     mercadoriasped.idnota=pedido.idnota and
     mercadoriasped.baixa='S')  