create table apontamentomat(
    filial integer not null,
    idmovimento integer not null,
    idmaterial integer not null,
    id integer not null,
    lote varchar(15),
    quantidade decimal(12,3),
    constraint pk_apontamento
    primary key apontamentomat(filial,
                               idmovimento,
                               idmaterial, 
                               id))