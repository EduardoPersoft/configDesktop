SELECT
      ITEMESTOQUE.CODIGO,
      itemestoque.C_MRFORNECEDOR as codfornec,
      C_FORNECEDORPECA.DESCRICAO,
      ITEMESTOQUE.DESCRICAO,
      LOCAL.DESCRICAO AS DESCLOCAL,
      itemestoque.localizacao,
      LOCALLOTE.QUANTIDADE
FROM
    LOCALLOTE
INNER JOIN
      LOCAL ON (LOCALLOTE.LOCAL=LOCAL.ID)
INNER JOIN
      ITEMESTOQUE ON (LOCALLOTE.IDITEM=ITEMESTOQUE.CODIGO)
LEFT JOIN
    C_FORNECEDORPECA ON (C_FORNECEDORPECA.ID=ITEMESTOQUE.C_FORNECEDOR)
WHERE
     LOCALLOTE.FILIAL=:FILIAL   AND
     LOCALLOTE.QUANTIDADE <> 0 