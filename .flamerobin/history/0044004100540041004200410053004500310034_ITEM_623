select 
    DISTINCT
    CLASSIFICACAOFISCAL.DESCRICAO,
    TRIBUTACAOICMs.ID,
    cast(TRIBUTACAOICMS.DESCRICAO as blob sub_type 0 character set iso8859_1)
from 
    ITEMESTOQUE 
INNER JOIN 
    CLASSIFICACAOFISCAL 
        ON (CLASSIFICACAOFISCAL.CFISCAL=ITEMESTOQUE.CLASSIFISCAL)
INNER JOIN 
    TRIBUTACAOICMS 
        ON (ITEMESTOQUE.TRIBUTACAOICMS=TRIBUTACAOICMS.ID)
where 

    CLASSIFICACAOFISCAL.DESCRICAO IN (
    '39219090',
    '76072000',
    '76129090',
    '39232990'  )