select
C_LOJA,
VENDEDOR,
NOMELOJA,
NOMEVENDEDOR,
IDNOTA,
MAX(DATACADASTRO) DATACADASTRO,
NOME,
sum(VALORPEDIDO) VALORPEDIDO,
sum(VALORIPI) VALORIPI,
SUM(COMISSAOAGENTE) COMISSAOAGENTE,
SUM(VALOR) VALOR,
PERCENTUALPARTICIPACAO,
SUM(VALORPARTICIPACAO) VALORPARTICIPACAO,
MAX(C_META) C_META,
DATAINICIAL,
DATAFINAL,
MAX(PERCENTUALDESCONTO) PERCENTUALDESCONTO,
SUM(SERVICOS) SERVICOS,
SUM(CREDITO) CREDITO
from C_Relatoriovendasvendedor('C_LOJVEN')
GROUP BY C_LOJA,
VENDEDOR,
NOMELOJA,
NOMEVENDEDOR,
IDNOTA,
NOME,
PERCENTUALPARTICIPACAO,
DATAINICIAL,
DATAFINAL
HAVING CAST(SUM(VALORPARTICIPACAO) AS DECIMAL(12,2))<>0