SELECT
    tipoitemestoque.DESCRICAO,
    ITEMCUSTODATA.datainventario,
    sum(itemcustodata.custo)
   
FROM
    ITEMCUSTODATA
INNER JOIN
    ITEMESTOQUE ON
        ITEMESTOQUE.CODIGO=materialmovimentoestoque.iditem
INNER JOIN
    TIPOiTEMeSTOQUE ON
        tipoitemestoque.ID=ITEMESTOQUE.tipoproduto
WHERE
    ITEMCUSTODATA.datainventario between '01.01.2026' and '31.12.2026'
GROUP BY 
    tipoitemestoque.DESCRICAO
    itemcustodata.datainventario
