select
    itemestoque.codigo,
    itemestoque.descricao,
    local.descricao,
    locallote.LOTE,
    locallote.quantidade,
    itemestoque.unidade,
    materiallote.C_LOCAL,
    materiallote.C_ROLO,
    materiallote.c_largura,
    materiallote.C_MEDIDAREAL,
    locallote.quantidade/materiallote.c_largura metrolinear
from
    LOCALLOTE
inner join
    itemestoque on
        locallote.IDITEM=itemestoque.codigo
inner join
    local on
        local.id=locallote."LOCAL"
inner join
    materiallote on
        materiallote.filial=locallote.filial and
        materiallote.iditem=locallote.iditem and
        materiallote.lote=locallote.lote
where
    cast(locallote.QUANTIDADE as decimal(12,2))<>0 and
    substring(locallote.IDITEM from 1 for 2)='M-'
order by
    materiallote.c_local,
    locallote.iditem,
    locallote.lote
        
        