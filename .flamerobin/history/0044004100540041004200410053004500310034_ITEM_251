select 
    MOVBANCARIOS.MOVIMENTACAO,
    LANTOCONTBANC.CONTACONTABIL,
    CONTASCONTABEIS.descricao,
    contascontabeis.NIVEL,
    contascontabeis.TIPOCONTA,
    sum(LANTOCONTBANC.VALOR*case movbancarios.tipomovimento when 'D' then -1 else 1 end)
from 
    MOVBANCARIOS
    
INNER JOIN 
    LANTOCONTBANC on 
    MOVBANCARIOS.FILIAL =LANTOCONTBANC.FILIAL and
    MOVBANCARIOS.IDCONTACORRENTE=LANTOCONTBANC.IDCONTACORRENTE and
    MOVBANCARIOS.IDMOVTOBANCARIO=LANTOCONTBANC.IDMOVTOBANC 
INNER JOIN 
      ESTABELECIMENTO ON
      LANTOCONTBANC.FILIAL= ESTABELECIMENTO.CADASTRO 
INNER JOIN 
    CONTASCONTABEIS ON
    estabelecimento.PLANOCONTAS=CONTASCONTABEIS.IDPLANO and
    LANTOCONTBANC.contacontabil like contascontabeis.CONTACONTABIL||'%'        
where
    MOVBANCARIOS.FILIAL=? and
    MOVBANCARIOS.MOVIMENTACAO between ? and ?
group by 
    MOVBANCARIOS.MOVIMENTACAO,
    LANTOCONTBANC.CONTACONTABIL,
    CONTASCONTABEIS.descricao,
    contascontabeis.NIVEL,
    contascontabeis.TIPOCONTA
