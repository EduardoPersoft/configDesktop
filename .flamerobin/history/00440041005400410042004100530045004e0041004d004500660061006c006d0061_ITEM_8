SELECT
    ITEMESTOQUE.CODIGO,
    ITEMESTOQUE.DESCRICAO,
    MATERIALFILIAL.CONSUMOMEDIOESTIMADO
FROM
    C_ITENSAZERO
INNER JOIN
    ITEMESTOQUE ON
        ITEMESTOQUE.CODIGO=C_ITENSAZERO.CODIGO
INNER JOIN
    MATERIALFILIAL ON
        MATERIALFILIAL.FILIAL=5 AND
        MATERIALFILIAL.IDITEM=C_ITENSAZERO.CODIGO
LEFT JOIN
    MATERIALLOCAL ON
        MATERIALLOCAL.FILIAL=MATERIALFILIAL.FILIAL AND
        MATERIALLOCAL.IDITEM=MATERIALFILIAL.IDITEM AND
        MATERIALLOCAL.IDLOCAL=1
WHERE
    MATERIALLOCAL.SALDOTOTAL=0 AND
    NOT EXISTS
    (SELECT * FROM MERCADORIASPEDCOMPRA 
     WHERE MERCADORIASPEDCOMPRA.FILIAL=MATERIALLOCAL.FILIAL
     AND MERCADORIASPEDCOMPRA.CODIGO=MATERIALLOCAL.IDITEM
     AND MERCADORIASPEDCOMPRA.BAIXA='N')