SELECT
    materialmovimentoestoque.*
FROM
    MATERIALMOVIMENTOESTOQUE
inner JOIN
    movimentoestoque on
        movimentoestoque.filial=materialmovimentoque.filial AND
        movimentoestoque.idmovimento=materialmovimentoestoque.IDMOVIMENTO
where 
    materialmovimentoestoque.filial=12826 AND
    materialmovimentoestoque.iditem <='6' AND
    movimentoestoque.documento=movimentoestoque.idmovimento
    