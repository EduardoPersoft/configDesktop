FROM 
    CLIENTES 
left join
    condicaoPagamento on
        condicaoPagamento.id = clientes.condicaoPagamento
left join
    tipoCobranca on
        tipoCobranca.tipoCobranca = clientes.tipoCobranca
left join
    BANCO on
        BANCO.BANCO = clientes.banco
left join
    listaPreco on
        listaPreco.lista = clientes.listaPrecoDefault
left join
    cadastroparceiros cadven on
        cadven.cadastro=clientes.vendedor
left JOIN
    CANALDISTRIBUICAO on
        canaldistribuicao.canaldist=clientes.canaldistribuicao
where
    clientes.cadastro = 2742
