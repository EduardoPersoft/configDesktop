select
    notacompra.dataemissao,
    cadfor.razaosocial,
    notacompra.numeronota,
    mercadoriasnotacompra.cfop,
    itemestoque.codigo,
    itemestoque.descricao,
    mercadoriasnotacompra.quantidade,
    mercadoriasnotacompra.unidade,
    mercadoriasnotacompra.vlrfinalmercad+
    mercadoriasnotacompra.frete+
    mercadoriasnotacompra.seguro+
    mercadoriasnotacompra.OUTDESPACESSOR,
    mercadoriasnotacompra.icmsbase,
    mercadoriasnotacompra.icmsoutros,
    mercadoriasnotacompra.VALORICMS,
    mercadoriasnotacompra.vlrfinalmercad-mercadoriasnotacompra.VALORICMS
from
    notafiscal notacompra
inner join
    mercadoriasnota mercadoriasnotacompra on
        mercadoriasnotacompra.filial=notacompra.filial and
        mercadoriasnotacompra.idnota=notacompra.IDNOTA
inner join
    cadastroparceiros cadfor on
        cadfor.cadastro=notacompra.DESTINATARIO
inner join
    itemestoque on
        itemestoque.codigo=mercadoriasnotacompra.CODIGO
where
    notacompra.filial=110 and
    notacompra.dataemissao between '01.07.2023' and '31.07.2023' and
    mercadoriasnotacompra.cfop in ('1201', '2201')