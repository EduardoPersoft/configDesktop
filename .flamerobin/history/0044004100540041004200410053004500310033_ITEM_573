select
    mercadoriasnota.codigo,
    materiallocal.saldototal,
    sum(mercadoriasnota.quantidade)
from 
    MERCADORIASNOTA
left join
    materiallocal on
        materiallocal.filial=mercadoriasnota.filial and
        materiallocal.iditem=mercadoriasnota.codigo and
        materiallocal.idlocal=1
where 
    mercadoriasnota.filial=1 and
    mercadoriasnota.idnota=24112
group by
    mercadoriasnota.codigo,
    materiallocal.saldototal