SELECT CODIGO,
       DESCRICAO,
      COMPRIMENTO,
      LARGURA,
      M2,
	  QUANTIDADE,
	  UNIDADE,
	   cast(0 as double precision) TRANSFERENCIA 
FROM C_INVENTARIOITENS
WHERE IDLOCAL=1
/*
and not exists
(SELECT * FROM C_TRANSFERENCIAITEM
INNER JOIN C_TRANSFERENCIA ON (
    C_TRANSFERENCIA.FILIAL=C_TRANSFERENCIAITEM.FILIAL AND
    C_TRANSFERENCIA.idtransferencia=C_TRANSFERENCIAITEM.idtransferencia)
WHERE C_TRANSFERENCIAITEM.codigo=C_INVENTARIOITENS.CODIGO
AND C_TRANSFERENCIA.idmovimento = -1)
*/
ORDER BY LOCAL,CODIGO