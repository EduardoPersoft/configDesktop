UPDATE
    MERCADORIASPEDCOMPRA
set
    baixa='S'
WHERE
    mercadoriaspedcompra.filial=5 AND
    mercadoriaspedcompra.baixa='N' AND
    exists
(SELECT
    *
 FROM
    PEDIDOCOMPRA
 WHERE
    pedidocompra.filial=mercadoriaspedcompra.filial AND
    pedidocompra.idnota=mercadoriaspedcompra.idnota AND
    pedidocompra.datacadastro<='31.12.2020')