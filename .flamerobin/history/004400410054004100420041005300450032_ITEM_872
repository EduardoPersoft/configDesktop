SELECT
    distinct
    cadven.cadastro cod,
    cadven.nome as nomevendedor,
    cadcli.cidade,
    cadcli.uf
from
    clientes
inner JOIN
    cadastroparceiros cadcli on
        cadcli.CADASTRO = clientes.CADASTRO
inner JOIN
    cadastroparceiros cadven on
        cadven.CADASTRO = clientes.vendedor
order by
    nomevendedor,cod,uf

    

