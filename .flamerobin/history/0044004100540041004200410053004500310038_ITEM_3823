select * from PEDIDO
where pedido.DESTINATARIO in (
select cadastro from ENDERECOENTREGA
where UPPER(logradouro) liKe '%FREDERICO%' and numero = 215) 
and exists (
select * from vendedoresped 
where vendedoresped.filial=pedido.filial and
vendedoresped.idnota=pedido.idnota and
vendedoresped.cadastro in (10568,14917))
