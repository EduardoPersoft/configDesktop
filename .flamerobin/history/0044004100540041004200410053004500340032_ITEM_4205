select
    MOVBANCARIOS.filial,
    MOVBANCARIOS.IDCONTACORRENTE,
    MOVBANCARIOS.IDMOVTOBANCARIO,
    MOVBANCARIOS.MOVIMENTACAO,
    MOVBANCARIOS.HISTORICOEXTRATO,
    MOVBANCARIOS.NRDOCUMENTO,
    MOVBANCARIOS.VALORMOVIMENTO*(
        CASE MOVBANCARIOS.TIPOMOVIMENTO WHEN 'C' 
        THEN 1 ELSE -1 END) VALORMOVIMENTO,
    CAST(0 AS DECIMAL(12,2)) SALDO,
    cast('N' as char(1)) p_check
from
    MOVBANCARIOS
WHERE 
    MOVBANCARIOS.FILIAL=3941 and
    MOVBANCARIOS.IDCONTACORRENTE = 237  AND
    MOVBANCARIOS.MOVIMENTACAO BETWEEN '01.12.2025' AND '31.12.2025'
union
select
    MOVBANCARIOS.filial,
    MOVBANCARIOS.IDCONTACORRENTE,
    MOVBANCARIOS.IDMOVTOBANCARIO,
    MOVBANCARIOS.MOVIMENTACAO,
    MOVBANCARIOS.HISTORICOEXTRATO,
    MOVBANCARIOS.NRDOCUMENTO,
    MOVBANCARIOS.VALORMOVIMENTO*(
        CASE MOVBANCARIOS.TIPOMOVIMENTO WHEN 'C' 
        THEN 1 ELSE -1 END) VALORMOVIMENTO,
    CAST(0 AS DECIMAL(12,2)) SALDO,
    cast('N' as char(1)) p_check
from
    CONTACORRENTE
inner join
    MOVBANCARIOS on
        MOVBANCARIOS.filial=contacorrente.filial and
        movbancarios.IDCONTACORRENTE=CONTACORRENTE.codigo
WHERE 
    contacorrente.FILIALCONSOLIDAR=3941 and
    contacorrente.IDCONSOLIDAR = 237  AND
    MOVBANCARIOS.MOVIMENTACAO BETWEEN '01.12.2025' AND '31.12.2025'
order by
    movimentacao,
    filial,
    idContaCorrente,
    TIPOMOVIMENTO,
    nrdocumento
