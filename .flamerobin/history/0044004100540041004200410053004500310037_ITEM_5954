select 
    c_destinoavulso.ID,
    c_destinoavulso.DATASOLICITACAO,
    c_destinoavulso.MOTORISTA,
    c_destinoavulso.COLETA,
    c_destinoavulso.DATACOLETA,
    c_destinoavulso.OBSERVACAO,
    c_destinoavulso.LOCALIZACAO,
    cast('N' as char(1)) as P_MARCA
from
    c_destinoavulso
where 
    c_destinoavulso.COLETA='0877'
