select
    coalesce(itemestoque.itembase,itemestoque.codigo),
    itemestoque.descricao,
    itemestoque.LOCALIZACAO,
    count(mercadoriasnota.idmercadoria)/12 as qtd_vendas,
    sum(mercadoriasnota.quantidade)/12 as qtd_pecas,    
    sum(coalesce(mercadoriasnota.VLRTOTALMERCAd,0))/12 as valor
FROM
    itemestoque
inner join
    MERCADORIASNOTA on
        mercadoriasnota.codigo=itemestoque.codigo
inner JOIN
    notafiscal on
        mercadoriasnota.filial=notafiscal.filial and 
        mercadoriasnota.idnota=notafiscal.IDNOTA
WHERE
    notafiscal.filial=5 AND
    notafiscal.DATAEMISSAO between '01.10.2020' and '30.04.2021'
group by
    itemestoque.codigo,
    itemestoque.descricao,
    itemestoque.LOCALIZACAO
order by
    4 desc