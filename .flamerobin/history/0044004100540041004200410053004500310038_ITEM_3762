select 
    CADASTROPARCEIROS.CADASTRO,
    CADASTROPARCEIROS.NOME,
    LISTAPRECO.NOMELISTA,
    C_LISTAXCADASTRO.PRIORIDADE,
    C_LISTAXCADASTRO.DATAINICIAL,
    C_LISTAXCADASTRO.DATAFINAL
from 
    C_LISTAXCADASTRO
INNER join
    CADASTROPARCEIROS ON
        CADASTROPARCEIROS.CADASTRO=C_LISTAXCADASTRO.CADASTRO
INNER join
    LISTAPRECO ON
        LISTAPRECO.LISTA=C_LISTAXCADASTRO.LISTA
ORDER BY
    C_LISTAXCADASTRO.CADASTRO,
    C_LISTAXCADASTRO.PRIORIDADE,
    C_LISTAXCADASTRO.LISTA