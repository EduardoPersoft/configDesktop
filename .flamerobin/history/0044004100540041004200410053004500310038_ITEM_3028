select pedido.filial,
       cast(pedido.datacadastro as date) dtpedido,
       pedido.idnota,
       cast(orcamento.datacadastro as date) dtorc,
       pedido.IDORCAMENTO 
from 
    PEDIDO
inner join
    orcamento on 
        orcamento.filial=pedido.filial and
        orcamento.idnota=pedido.idorcamento
where 
    pedido.DATAREFERENCIa>='2024-11-30'
order by idorcamento

