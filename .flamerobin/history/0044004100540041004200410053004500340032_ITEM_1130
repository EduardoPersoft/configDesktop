update
    MATERIALMOVIMENTOESTOQUE
set
    materialmovimentoestoque.valor = MATERIALMOVIMENTOESTOQUE.quantidade*17.054
where filial=110
and iditem='MPP01METAL'
and exists (
    select 
        *
    from 
        movimentoestoque
    where
        movimentoestoque.filial=materialmovimentoestoque.FILIAL and
        movimentoestoque.idmovimento=materialmovimentoestoque.idmovimento and
        movimentoestoque.tipomovimento<>'01')
        