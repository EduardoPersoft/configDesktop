select
    notafiscal.FILIAL,    
    notafiscal.idnota,
    notafiscal.numeronota,    
    notafiscal.DATAEMISSAO,
    cadcli.nome,
    cadcli.tranportadora,
    NOTAFISCAL.VALORFRETE,
    notafiscal.VALORSEGURO,
    notafiscal.VLROUTDESPACESSORIA,
    notafiscal.VLRTOTALNOTA

from
    NOTAFISCAL
inner join
    cadastroparceiros cadcli on
        cadcli.cadasttro=notafiscal.DESTINATARIO
inner join
    cadastroparceiros cadtrans on
        cadtrans.cadastro=notafiscal.CODIGOTRANSP
where
    notafiscal.DATAEMISSAO>='01.08.2023' and valorfrete>0