select
    *
from
    MATERIALMOVIMENTOESTOQUE
where
    concluido='S' and
    exists (select * from MOVIMENTOESTOQUE
            where movimentoestoque.filial=MATERIALMOVIMENTOESTOQUE.filial and
            movimentoestoque.idmovimento=MATERIALMOVIMENTOESTOQUE.idmovimento and
            movimentoestoque.tipomovimento='12') and
    not exists (select * from MOVIMENTOESTOQUE
                where movimentoestoque.filial=MATERIALMOVIMENTOESTOQUE.filial and
                movimentoestoque.idop=MATERIALMOVIMENTOESTOQUE.idmovimento and
                movimentoestoque.IDOPITEM=materialmovimentoestoque.IDMOVIMENTOMATERIAL)
            