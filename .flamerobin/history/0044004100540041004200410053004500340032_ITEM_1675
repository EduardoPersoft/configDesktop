update lantocontpag 
set 
    valor=5596.31
where 
    exists (
        select 
            *
        from    
            TITULOPAG
        where
            titulopag.filial=lantocontpag.FILIAL and
            titulopag.IDTITULO=lantocontpag.IDMOVTOBANC and
            titulopag.titulo='8872850' and
            titulopag.fatura<>'1')