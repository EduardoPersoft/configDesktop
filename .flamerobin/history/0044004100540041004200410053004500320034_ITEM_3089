select 
    FORNECEDORESITEM.FORNECEDOR,
    MATERIALFILIAL.SALDOMINIMO,
    MATERIALFILIAL.CUSTOMEDIO,
    SUM(MATERIALLOCAL.SALDOTOTAL) SALDO
FROM
    MATERIALFILIAL
INNER join
    FORNECEDORESITEM ON
        FORNECEDORESITEM.IDITEM=MATERIALFILIAL.IDITEM
INNER join
    MATERIALLOCAL ON
        MATERIALLOCAL.FILIAL=MATERIALFILIAL.FILIAL and
        MATERIALLOCAL.IDTEM=MATERIALFILIAL.IDITEM
WHERE
    MATERALFILIAL.FILIAL=5
GROUP BY
    FORNECEDORESITEM.FORNECEDOR,
    MATERIALFILIAL.SALDOMINIMO,
    MATERIALFILIAL.CUSTOMEDIO
    