update 
    PEDIDO
set 
    vendedor=(select vendedoresped.vendedor from vendedoresped
              where vendedoresped.filial=pedido.filial 
              and vendedoresped.idnota=pedido.idnota)
where exists (
    select  
        *
    from 
        MERCADORIASPED
    where
        mercadoriasped.filial=pedido.filial and
        mercadoriasped.idnota=pedido.idnota ) and
    pedido.vendedor is null and
    pedido.filial=110 and
    pedido.DATACADASTRO>='01.01.2023'