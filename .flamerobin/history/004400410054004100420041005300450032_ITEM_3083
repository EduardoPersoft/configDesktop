update 
    MATERIALLOCAL
set 
    materiallocal.saldototal = coalesce(materiallocal.saldototal,0)+
    (select sum(mercadoriasnotacompra.quantidade) from notacompra
         inner join MERCADORIASNOTACOMPRA on
            notacompra.filial=mercadoriasnotacompra.filial AND
            notacompra.idnota=mercadoriasnotacompra.IDNOTA
         where
            notacompra.filial=materiallocal.filial AND
            mercadoriasnotacompra.codigo=materiallocal.iditem AND
            notacompra.dataentrada='14.07.2021')


from 
    MATERIALLOCAL
WHERE
    materiallocal.filial=5 and
    EXISTS
        (select * from notacompra
         inner join MERCADORIASNOTACOMPRA on
            notacompra.filial=mercadoriasnotacompra.filial AND
            notacompra.idnota=mercadoriasnotacompra.IDNOTA
         where
            notacompra.filial=materiallocal.filial AND
            mercadoriasnotacompra.codigo=materiallocal.iditem AND
            notacompra.dataentrada='14.07.2021')

