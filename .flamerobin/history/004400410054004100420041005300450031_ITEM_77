select   
    mapaProducao.recurso,
    mapaProducao.filial,
    mapaProducao.idMovimento,
    mapaProducao.idMovimentoMaterial,
    materialMovimentoEstoque.tempo,
    materialMovimentoEstoque.setup,
    mapaProducao.inicio,
    mapaProducao.fim,    

    movimentoestoque.documento,
    movimentoestoque.emissao,
    movimentoestoque.previsaofimproducao,
    produto.codigo,
    produto.descricao,
    materialmovimentoestoque.quantidade,
    
    CADASTROPARCEIROS.CADASTRO,
    CADASTROPARCEIROS.NOME,

    materialmovimentoestoque.idcentrocusto,
    produto.C_CILINDRO,
    produto.c_ladoImpressao,
    (select  first 1
        c_laminacao.LARGURAROLO 
     from 
        c_laminacao 
     where 
        c_laminacao.codigo=produto.codigo
     order by 
        c_laminacao.SEQUENCIA)

from
    materialMovimentoEstoque
inner JOIN
    movimentoestoque on 
        movimentoestoque.filial=materialmovimentoestoque.filial AND
        movimentoestoque.idmovimento=materialmovimentoestoque.idmovimento
inner join
    mapaProducao on
        materialMovimentoEstoque.filial = mapaProducao.filial and
        materialMovimentoEstoque.idMovimento = mapaProducao.idMovimento and
        materialMovimentoEstoque.idMovimentoMaterial = mapaProducao.idMovimentoMaterial
left JOIN
    ITEMEsTOQUE PRODUTO ON
        produto.codigo = materialmovimentoestoque.PRODUTO
LEFT JOIN
    PEDIDO ON
        PEDIDO.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL AND
        PEDIDO.IDNOTA=MATERIALMOVIMENTOESTOQUE.IDPEDIDO 
LEFT JOIN
    CADASTROPARCEIROS ON
        CADASTROPARCEIROS.CADASTRO = PEDIDO.DESTINATARIO
where
    materialMovimentoEstoque.filial = 1 and
    materialMovimentoEstoque.concluido = 'N' and
    mapaProducao.recurso = 1
order by 
    mapaProducao.inicio nulls last

