select * from MATERIALMOVIMENTOESTOQUE
where idpedido is not null and concluido='N' and 
exists (select * from mercadoriasped
        where MERCADORIASPED.filial=materialmovimentoestoque.filial
        and MERCADORIASPED.idnota=mterialmovimentoestoque.idpedido
        and mercadoriasped.IDMERCADORIA=materialmovimentoestoque.IDMERCADORIA
        and mercadoriasped.baixa='S')