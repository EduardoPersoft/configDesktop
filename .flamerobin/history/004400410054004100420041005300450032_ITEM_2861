SELECT
    ITEMESTOQUE.CODIGO,
    ITEMESTOQUE.DESCRICAO,
    CLASSIFICACAOFISCAL.DESCRICAO NCM
FROM
    ITEMESTOQUE
INNER JOIN
    CLASSIFICACAOFISCAL ON
        CLASSIFICACAOFISCAL.CFISCAL=ITEMESTOQUE.CLASSIFISCAL
WHERE
    CLASSIFICACAOFISCAL.DESCRICAO<>'99999999' AND
    ITEMESTOQUE.TIPOPRODUTO = 3
ORDER BY
    3
    
