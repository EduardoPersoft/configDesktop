select
    notafiscal.filial,
    MODELODOCTO.MODELO,
    notafiscal.entradaSaida,  
    NOTAFISCAL.DATAEMISSAO AS DATA,
    CAST(NOTAFISCAL.NUMERONOTA AS VARCHAR(10)) AS NUMERONOTA,
    NOTAFISCAL.NUMERONOTA AS ORDEMNOTA,  
    mercadoriasnota.cfop,
    mercadoriasnota.idpedido,

    CLIENTES.CADASTRO,
    CLIENTES.NOME,
    NOTAFISCAL.CANCELAMENTO,
    NOTAFISCAL.DEVOLUCAO,
    case notafiscal.entradasaida when 'S' 
         then NATUREZAOPERACAO.FATURA 
         else NATUREZAOPERACAO.DEVOLUCAOFATURAMENTO 
         end fatura
    
            
from
    NOTAFISCAL
INNER JOIN MODELODOCTO ON 
    (NOTAFISCAL.MODELO = MODELODOCTO.ID)
INNER JOIN 
    CADASTROPARCEIROS CLIENTES 
        ON (NOTAFISCAL.DESTINATARIO=CLIENTES.CADASTRO)
INNER join 
    mercadoriasnota  on
     ( mercadoriasnota.filial=notafiscal.filial and 
       mercadoriasnota.idnota=notafiscal.idnota)
INNER JOIN 
    NATUREZAOPERACAO ON 
        (NOTAFISCAL.OPERACAO=NATUREZAOPERACAO.ID)

where
    notafiscal.dataemissao between '01.01.2024' and '31.05.2024' 
    AND NOTAFISCAL.CANCELAMENTO = 'N'
order by
       MODELODOCTO.MODELO,
       NOTAFISCAL.DATAEMISSAO,
       NOTAFISCAL.NUMERONOTA, 
       mercadoriasnota.CFOP,
       mercadoriasnota.idpedido
    