SELECT
    ITEMESTOQUE.CODIGO,
    ITEMESTOQUE.DESCRICAO,
    CLASSIFICACAOFISCAL.DESCRICAO,
    CLASSIFICACAOFISCAL.C_TRIBUTACAOICMS
FROM
    ITEMESTOQUE
INNER JOIN
    CLASSIFICACAOFISCAL ON
        CLASSIFICACAOFISCAL.CFISCAL=ITEMESTOQUE.CLASSIFISCAL
        
WHERE
    exists (
        SELECT
            *
        from 
            CLASSIFICACAOFISCAL
        WHERE
            classificacaofiscal.CFISCAL = itemestoque.CLASSIFISCAL
            and COALESCE(CLASSIFICACAOFISCAL.C_TRIBUTACAOICMS,0)=2)