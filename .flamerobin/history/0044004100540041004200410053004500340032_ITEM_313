UPDATE 
    LANTOCONTPAG
set
    LANTOCONTPAG.CONTACONTABIL='11206'
where
    LANTOCONTPAG.FILIAL=110 and
    EXISTS (SELECT * FROM TITULOPAG
     WHERE TITULOPAG.FILIAL=LANTOCONTPAG.FILIAL 
     and TITULOPAG.IDTITULO=LANTOCONTPAG.IDMOVTOBANC 
     AND TITULOPAG.PARCEIRO IN (4010, 4040, 4043,
     4048, 4058, 4238, 4459, 500))