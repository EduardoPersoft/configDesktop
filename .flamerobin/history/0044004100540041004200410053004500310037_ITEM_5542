select 
    coalesce((select count(movimentoestoque.IDMOVIMENTO) 
                from movimentoestoque 
                where movimentoestoque.coleta=c_coletas.COLETA
                and movimentoestoque.tipomovimento='13'),0),
    coalesce((select count(C_DESTINOAVULSO.ID) 
                          from c_destinoavulso
                            where c_destinoavulso.coleta=c_coletas.COLETA),0),
    coalesce((select count(movimentoestoque.IDMOVIMENTO) 
                from movimentoestoque 
                where movimentoestoque.coleta=c_coletas.COLETA
                and movimentoestoque.tipomovimento='13'),0)+
    coalesce((select count(C_DESTINOAVULSO.ID) 
                from c_destinoavulso
                where c_destinoavulso.coleta=c_coletas.COLETA),0),
                
     (
    coalesce((select count(C_DESTINOAVULSO.ID) 
                from c_destinoavulso
                where c_destinoavulso.coleta=c_coletas.COLETA),0))*C_coletas.VALORMEDIO as valormedio,               
   ((coalesce((select count(movimentoestoque.IDMOVIMENTO) 
                from movimentoestoque 
                where movimentoestoque.coleta=c_coletas.COLETA
                and movimentoestoque.tipomovimento='13'),0)+
    coalesce((select count(C_DESTINOAVULSO.ID) 
                from c_destinoavulso
                where c_destinoavulso.coleta=c_coletas.COLETA),0))*C_coletas.VALORMEDIO)-C_COLETAS.VALOR as dife,               
                
    C_COLETAS.QTDEXPEDICOES*C_COLETAS.VALORMEDIO,
    (C_COLETAS.QTDEXPEDICOES*C_COLETAS.VALORMEDIO)-C_COLETAS.VALOR,
    c_coletas.* 
from c_coletas
where c_coletas.DATACOLETA between '15.09.2025' and '29.09.2025'
order by 1
