select
    listapreco.lista,
    listapreco.NOMELISTA,
    itemestoque.codigo,
    itemestoque.descricao,
    LISTAPRECOPRODUTO.preco,
    CLASSIFICACAOFISCAL.ALIQUOTA pipi,
    listaprecoproduto.preco*CLASSIFICACAOFISCAL.ALIQUOTA/100 as valoripi,
    TRIBUTACAOICMSUF.ALIQUOTA icms,
    TRIBUTACAOICMSUF.REDUCAO,   
    LISTAPRECOPRODUTO.preco*(1-tributacaoicmsuf.reducao/100) baseicms,
    (LISTAPRECOPRODUTO.preco*(1-tributacaoicmsuf.reducao/100))*tributacaoicmsuf.ALIQUOTA/100 icmsproprio,
    TRIBUTACAOICMSUF.LUCROSUBSTITUICAO,
    ((LISTAPRECOPRODUTO.preco*(1-tributacaoicmsuf.reducao/100))+
     listaprecoproduto.preco*CLASSIFICACAOFISCAL.ALIQUOTA/100)*(1+TRIBUTACAOICMSUF.LUCROSUBSTITUICAO/100) baseicmsst
    
from
    LISTAPRECOPRODUTO
inner join
    LISTAPRECO on
        listapreco.lista=LISTAPRECOPRODUTO.LISTA
inner join
    itemestoque on
        itemestoque.codigo=listaprecoproduto.PRODUTO
inner join
    CLASSIFICACAOFISCAL on
        CLASSIFICACAOFISCAL.CFISCAL=itemestoque.CLASSIFISCAL
inner join
    TRIBUTACAOICMSUF on
        TRIBUTACAOICMSUF.id=itemestoque.TRIBUTACAOICMS and
        TRIBUTACAOICMSUF.UF='SP'