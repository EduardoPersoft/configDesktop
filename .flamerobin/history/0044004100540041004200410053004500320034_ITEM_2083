SELECT
    CLASSIFICACAOFISCAL.CFISCAL,
    classificacaofiscal.descricao,
    classificacaofiscal.CEST
FROM
    CLASSIFICACAOFISCAL
    
    
UPDATE
    CLASSSIFICACAOFISCAL
SET
    CLASSSIFICACAOFISCAL.CEST='0'|| CLASSIFICACAOFISCAL.CEST
    
where 
    CLASSIFICACAOFISCAL.CEST = SUBSTRING(CLASSIFICACAOFISCAL.CEST FROM 1 FOR 6)