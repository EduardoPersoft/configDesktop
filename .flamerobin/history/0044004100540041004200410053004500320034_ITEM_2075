SELECT
   CLASSIFICACAOFISCAL.CFISCAL,
   CLASSIFICACAOFISCAL.DESCRICAO,
   CLASSIFICACAOFISCAL.CEST,
   T_CEST2022.NCM,
   T_CEST2022.CEST
FROM 
    CLASSIFICACAOFISCAL
WHERE
    EXISTS (
        SELECT 
            *
        FROM
            T_CEST2022
        WHERE
            CLASSIFICACAOFISCAL.DESCRICAO LIKE T_CEST2022.NCM||'%' )   
        