SELECT
      TITULOPAG.FILIAL,
      ESTAB.RAZAOSOCIAL,
      PARCEIRO.CADASTRO AS PARCEIRO,
      PARCEIRO.RAZAOSOCIAL,
      TITULOPAG.IDTITULO,
      TITULOPAG.TITULO,
      TITULOPAG.FATURA,
      TITULOPAG.EMISSAO,
      TITULOPAG.VENCIMENTO,
      TITULOPAG.BAIXA,
      LANTOCONTPAG.VALOR AS VALOR,
      CONTASCONTABEIS.CONTACONTABIL,
      CONTASCONTABEIS.DESCRICAO
FROM TITULOPAG
INNER JOIN CADASTROPARCEIROS ESTAB ON (ESTAB.CADASTRO = TITULOPAG.FILIAL)
INNER JOIN CADASTROPARCEIROS PARCEIRO ON (PARCEIRO.CADASTRO = TITULOPAG.PARCEIRO)
INNER JOIN ESTSIN ON (ESTSIN.ESTABELECIMENTO = TITULOPAG.FILIAL AND
                      TITULOPAG.EMISSAO BETWEEN ESTSIN.DATAINICIAL AND ESTSIN.DATAFINAL AND
                      ESTSIN.RELATORIO = 'PTITULOSEMITIDOS')
INNER JOIN RCONTACORRENTE ON (RCONTACORRENTE.CONTACORRENTE = TITULOPAG.CONTACORRENTE AND
                              RCONTACORRENTE.RELATORIO = 'PTITULOSEMITIDOS')
INNER JOIN RTIPOPAGAMENTO ON (RTIPOPAGAMENTO.TIPOPAGAMENTO = TITULOPAG.TIPOTRANSACAO AND
                              RTIPOPAGAMENTO.RELATORIO = 'PTITULOSEMITIDOS')
LEFT JOIN MOEDA ON (MOEDA.MOEDA = TITULOPAG.MOEDA)
INNER JOIN LANTOCONTPAG ON (LANTOCONTPAG.FILIAL = TITULOPAG.FILIAL
                        AND LANTOCONTPAG.IDMOVTOBANC = TITULOPAG.IDTITULO)
INNER JOIN ESTABELECIMENTO ON (TITULOPAG.FILIAL = ESTABELECIMENTO.CADASTRO)
LEFT JOIN CONTASCONTABEIS ON (CONTASCONTABEIS.IDPLANO = ESTABELECIMENTO.PLANOCONTAS
                          AND LANTOCONTPAG.CONTACONTABIL=CONTASCONTABEIS.CONTACONTABIL)
WHERE (TITULOPAG.TIPOBAIXA<>'E' OR TITULOPAG.TIPOBAIXA IS NULL)
  AND LANTOCONTPAG.CONTACONTABIL BETWEEN ESTSIN.CONTACONTABILI AND ESTSIN.CONTACONTABILF
  AND LANTOCONTPAG.CENTROCUSTO   BETWEEN ESTSIN.CENTROCUSTOI   AND ESTSIN.CENTROCUSTOF