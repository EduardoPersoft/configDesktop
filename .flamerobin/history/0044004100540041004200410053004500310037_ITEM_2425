declare variable descr_compl_aj varchar(256);
declare variable vl_aj_apur decimal(12,2);
declare variable vl_sld_dev_ant_fcp decimal(12,2);
declare variable v_devolucao char(1);
declare variable ITEMCODREFNFE char(1);
declare variable v_ipiOut decimal(12,2);
declare variable v_icmsStOut decimal(12,2);
declare variable FILIAL integer;
declare variable idnotareferenciada varchar (10);
declare variable sub char (3);
declare variable idnota varchar (10);
declare variable VL_FCP_OP numeric(12,2);
declare variable VL_FCP_ST numeric(12,2);
declare variable vl_fcp_ret numeric(12,2);



begin

vl_tot_debitos = 0;
vl_tot_creditos = 0;
vl_aj_debitos = 0;
vl_aj_CREDITOS = 0;

filial=pfilial;
DT_INI = pDT_INI;
DT_FIM = pDT_FIM;

SEQUENCIAC = 1;

select
      CONFIGURACOESGERAIS.ITEMCODREFNFE
from
    CONFIGURACOESGERAIS
into
    :ITEMCODREFNFE;
     

select  CADASTROPARCEIROS.UF
  from SPEDFISCAL
  inner join CADASTROPARCEIROS on (CADASTROPARCEIROS.CADASTRO = SPEDFISCAL.ESTABELECIMENTO)
  left join MUNICIPIO on (CADASTROPARCEIROS.UF = MUNICIPIO.UF_SIGLA and
        upper(CADASTROPARCEIROS.CIDADE) = upper(MUNICIPIO.MUNICIPIO_NOME))
  left join CLIENTES on (CADASTROPARCEIROS.CADASTRO = CLIENTES.CADASTRO)
  where SPEDFISCAL.ESTABELECIMENTO = :FILIAL
  into V_UFESTABELECIMENTO;

  for select cast('NS' as char(2)) as ORIGEM, NOTAFISCAL.DATAEMISSAO, NOTAFISCAL.IDNOTA,
             case NOTAFISCAL.ENTRADASAIDA
               when 'S' then 1
               else 0
             end,
             0 as EMISSOR, NOTAFISCAL.DESTINATARIO, MODELODOCTO.CODMODELOFISCAL,
             case
               when NOTAFISCAL.CANCELAMENTO = 'S' then '02'
               when NOTAFISCAL.TIPONOTA = '2' then '06'
               else '00'
             end,
             MODELODOCTO.SERIE, cast(NOTAFISCAL.NUMERONOTA as varchar(10)), NOTAFISCAL.CHAVE,
             case
               when NOTAFISCAL.DATAENTRADASAIDA is null then NOTAFISCAL.DATAEMISSAO
               else NOTAFISCAL.DATAENTRADASAIDA
             end,
             NOTAFISCAL.VLRTOTALNOTA,
             case
               when notafiscal.devolucao='S' then '2'
               when exists(select *
                           from FATURAS
                           where FATURAS.FILIAL = NOTAFISCAL.FILIAL and
                                 FATURAS.IDNOTA = NOTAFISCAL.IDNOTA and
                                 FATURAS.DATAVENCIMENTO <> NOTAFISCAL.DATAEMISSAO) then '0'
               when exists(select *
                           from FATURAS
                           where FATURAS.FILIAL = NOTAFISCAL.FILIAL and
                                 FATURAS.IDNOTA = NOTAFISCAL.IDNOTA and
                                 FATURAS.DATAVENCIMENTO = NOTAFISCAL.DATAEMISSAO) then '1'
               else '2'
             end,
             coalesce(NOTAFISCAL.VLRDESCMERCADORIAS, 0) + coalesce(NOTAFISCAL.VLRDESCSERVICOS, 0) + coalesce(NOTAFISCAL.VLRDESCINDPRODUTO, 0) + coalesce(NOTAFISCAL.VLRDESCINDSERVICOS, 0),
             case NOTAFISCAL.ZONAFRANCA
               when 'S' then NOTAFISCAL.TOTVALORICMS
               else 0
             end,
             case
               when NOTAFISCAL.VALORFRETE = 0 then '9'
               when NOTAFISCAL.FRETE = 'R' then '1'
               else '2'
             end,
             NOTAFISCAL.VLRFINALMERCADORIAS, NOTAFISCAL.VALORFRETE, NOTAFISCAL.VALORSEGURO,
             NOTAFISCAL.VLROUTDESPACESSORIA, NOTAFISCAL.VLRBASESUBSTITUTO, NOTAFISCAL.VLRICMSRECOLHIDO+coalesce(notafiscal.VFCPST,0),
             NOTAFISCAL.VLRPISPASEPMERC, NOTAFISCAL.VLRCOFINSMERC, 0, 0, NOTAFISCAL.DI,
             case NATUREZAOPERACAO.ESTOQUE
               when 'S' then '0'
               else '1'
             end,
             NOTAFISCAL.OPERACAO, NOTAFISCAL.UF, NOTAFISCAL.ICMSDESTINOFCP, NOTAFISCAL.ICMSDESTINOVALOR, NOTAFISCAL.ICMSORIGEMVALORINTERESTADUAL,
             cast(0 as decimal(12,2)),
             naturezaoperacao.CONTACONTABIL
      from NOTAFISCAL
      inner join MODELODOCTO on (NOTAFISCAL.MODELO = MODELODOCTO.ID)
      left join NATUREZAOPERACAO on (NATUREZAOPERACAO.ID = NOTAFISCAL.OPERACAO)
      where NOTAFISCAL.FILIAL = :FILIAL and
            NOTAFISCAL.DATAEMISSAO between :DT_INI and :DT_FIM and
            MODELODOCTO.BLOCOSPED = 'C' and
            cast(MODELODOCTO.CODMODELOFISCAL as char(2)) in ('55', '1', '1B', '4', '5')
      union
      select DISTINCT cast('NC' as char(2)) as ORIGEM, notafiscal.DATAEMISSAO, NOTAFISCAL.IDNOTA, 0 as IND_OPER, 1 as EMISSOR,
             NOTAFISCAL.DESTINATARIO, MODELODOCTO.CODMODELOFISCAL, '00' as COD_SIT, coalesce(notafiscal.serie, modelodocto.serie),
             notafiscal.NRNOTAFORNECEDOR, NOTAFISCAL.CHAVE,
             case
               when notafiscal.DATAENTRADA is null then notafiscal.DATAEMISSAO
               else NOTAFISCAL.DATAENTRADA
             end,
             NOTAFISCAL.VLRTOTALNOTA,
             case
               when notafiscal.devolucao='S' then '2'
               when exists(select *
                           from FATURASNOTACOMPRA
                           where FATURASNOTACOMPRA.FILIAL = NOTAFISCAL.FILIAL and
                                 FATURASNOTACOMPRA.IDNOTA = NOTAFISCAL.IDNOTA and
                                 FATURASNOTACOMPRA.DATAVENCIMENTO <> NOTAFISCAL.DATAEMISSAO) then '0'
               when exists(select *
                           from FATURASNOTACOMPRA
                           where FATURASNOTACOMPRA.FILIAL = NOTAFISCAL.FILIAL and
                                 FATURASNOTACOMPRA.IDNOTA = NOTAFISCAL.IDNOTA and
                                 FATURASNOTACOMPRA.DATAVENCIMENTO = NOTAFISCAL.DATAEMISSAO) then '1'
               else '2'
             end,
             coalesce(NOTAFISCAL.VLRDESCMERCADORIAS, 0) + coalesce(NOTAFISCAL.VLRDESCSERVICOS, 0) + coalesce(NOTAFISCAL.VLRDESCINDPRODUTO, 0) + coalesce(NOTAFISCAL.VLRDESCINDSERVICOS, 0),
             case NOTAFISCAL.ZONAFRANCA
               when 'S' then NOTAFISCAL.TOTVALORICMS
               else 0
             end,
             case
               when NOTAFISCAL.VALORFRETE = 0 then '9'
               else '1'
             end,
             NOTAFISCAL.VLRFINALMERCADORIAS, NOTAFISCAL.VALORFRETE, NOTAFISCAL.VALORSEGURO,
             NOTAFISCAL.VLROUTDESPACESSORIA,
             case 
                when substring(MERCADORIASNOTACOMPRA.SITUACAOTRIBUT from 1 for 3) in ('060','160','260') then 0
                when  NOTAFISCAL.DEVOLUCAO ='S'  OR MERCADORIASNOTACOMPRA.CFOP IN ('1949', '2949') then NOTAFISCAL.VLRBASESUBSTITUTO
                else 0
             end,
             case 
                when substring(MERCADORIASNOTACOMPRA.SITUACAOTRIBUT from 1 for 3) in ('060','160','260') then 0
                when NOTAFISCAL.DEVOLUCAO ='S' OR MERCADORIASNOTACOMPRA.CFOP IN ('1949', '2949') then NOTAFISCAL.VLRICMSRECOLHIDO+coalesce(notafiscal.VFCPST,0)
                else 0
             end,
             NOTAFISCAL.VALORPIS, NOTAFISCAL.VALORCOFINS, 0, 0, cast(null as varchar(12)) as NUM_DOC_IMP,
             0,
             NOTAFISCAL.OPERACAO as COD_NAT,
             NOTAFISCAL.UF,
             cast(0.00 as decimal(12,2)) as ICMSDESTINOFCP,
             notafiscal.ICMSDESTINOVALOR,
             cast(0.00 as decimal(12,2)) as ICMSORIGEMVALOR,
             case 
                when substring(MERCADORIASNOTACOMPRA.SITUACAOTRIBUT from 1 for 3) in ('060','160','260') then coalesce(NOTAFISCAL.VLRICMSRECOLHIDO,0)+coalesce(notafiscal.vfcpst,0)
                when  NOTAFISCAL.DEVOLUCAO ='S' OR MERCADORIASNOTACOMPRA.CFOP IN ('1949', '2949') then 0
                else coalesce(NOTAFISCAL.VLRICMSRECOLHIDO,0)+coalesce(notafiscal.VFCPST,0)
             end,
             naturezaoperacao.CONTACONTABIL
      from NOTACOMPRA NOTAFISCAL
      inner join MODELODOCTO on (NOTAFISCAL.MODELO = MODELODOCTO.ID)
      left join NATUREZAOPERACAO on (NATUREZAOPERACAO.ID = NOTAFISCAL.OPERACAO)
      INNER JOIN MERCADORIASNOTACOMPRA ON 
        (MERCADORIASNOTACOMPRA.FILIAL=NOTAFISCAL.FILIAL AND MERCADORIASNOTACOMPRA.IDNOTA=NOTAFISCAL.IDNOTA)
      where NOTAFISCAL.FILIAL = :FILIAL and
            NOTAFISCAL.DATAENTRADA between :DT_INI and :DT_FIM and
            MODELODOCTO.BLOCOSPED = 'C' and
            cast(MODELODOCTO.CODMODELOFISCAL as char(2)) in ('55', '1', '1B', '4', '5')
      into ORIGEM, DT_DOC, V_IDNOTA, IND_OPER, IND_EMIT, COD_PART, COD_MOD, COD_SIT, SER, NUM_DOC, CHV_NFE,
           DT_E_S, VL_DOC, IND_PGTO, VL_DESC, VL_ABAT_NT, IND_FRT, VL_MERC, VL_FRT, VL_SEG, VL_OUT_DA, VL_BC_ICMS_ST,
           VL_ICMS_ST, VL_PIS, VL_COFINS, VL_PIS_ST, VL_COFINS_ST, NUM_DOC_IMP, IND_MOV_EST, COD_NAT, UF,
           VL_FCP_UF_DEST, VL_ICMS_UF_DEST, VL_ICMS_UF_REM, v_icmsstOut, cod_cta
  do
  begin

    if (:cod_mod='1') then cod_mod='01';
    
    if (:ORIGEM = 'NS') then
    begin
      select sum(
             case MERCADORIASNOTA.ICMSORIGEMBASE
               when 0 then MERCADORIASNOTA.ICMSBASE
               else MERCADORIASNOTA.ICMSORIGEMBASE
             end),
             sum(
             case MERCADORIASNOTA.ICMSORIGEMBASE
               when 0 then MERCADORIASNOTA.VALORICMS
               else MERCADORIASNOTA.ICMSORIGEMVALOR
             end)
      from ITEMESTOQUE
      inner join MERCADORIASNOTA on (ITEMESTOQUE.CODIGO = MERCADORIASNOTA.CODIGO)
      inner join NOTAFISCAL on (MERCADORIASNOTA.FILIAL = NOTAFISCAL.FILIAL and
            MERCADORIASNOTA.IDNOTA = NOTAFISCAL.IDNOTA)
      where MERCADORIASNOTA.FILIAL = :FILIAL and
            MERCADORIASNOTA.IDNOTA = :V_IDNOTA
      into :VL_BC_ICMS, :VL_ICMS;
    end
    else
    if (:ORIGEM = 'NC') then
    begin
      select sum(
             case
               when ITEMESTOQUE.TIPOPRODUTO not in ('1', '3', '4') then 0
               when substring(MERCADORIASNOTA.SITUACAOTRIBUT from 1 for 3) in ('060','160','260') then 0
               else case
                      when (mercadoriasnota.vlricmsrecolhido>0 and NOTAFISCAL.DEVOLUCAO = 'N' and mercadoriasnota.cfop not in ('1949', '2949'))   then 0
                      else MERCADORIASNOTA.ICMSBASE
                    end
             end),
             sum(
             case
               when ITEMESTOQUE.TIPOPRODUTO not in ('1', '3', '4') then 0
               when substring(MERCADORIASNOTA.SITUACAOTRIBUT from 1 for 3) in ('060','160','260') then 0
               else case
                      when (mercadoriasnota.vlricmsrecolhido>0 and NOTAFISCAL.DEVOLUCAO = 'N' and mercadoriasnota.cfop not in ('1949', '2949') ) then 0
                      else MERCADORIASNOTA.VALORICMS
                    end
             end)
      from ITEMESTOQUE
      inner join MERCADORIASNOTACOMPRA MERCADORIASNOTA on (ITEMESTOQUE.CODIGO = MERCADORIASNOTA.CODIGO)
      inner join NOTACOMPRA NOTAFISCAL on (MERCADORIASNOTA.FILIAL = NOTAFISCAL.FILIAL and
            MERCADORIASNOTA.IDNOTA = NOTAFISCAL.IDNOTA)
      where MERCADORIASNOTA.FILIAL = :FILIAL and
            MERCADORIASNOTA.IDNOTA = :V_IDNOTA
      into :VL_BC_ICMS, :VL_ICMS;
    end


    vl_ipi = 0;
    v_ipiout = 0;

    if (:ORIGEM = 'NS') then
    begin
      select sum(
             case
               when MERCADORIASNOTA.CSTIPI in (0,  50, 99) then MERCADORIASNOTA.VALORIPI
               else 0
             end),
             sum(
             case
               when MERCADORIASNOTA.CSTIPI in (0, 50, 99) then 0
               else MERCADORIASNOTA.VALORIPI
             end),
           min(mercadoriasnota.IDNOTASAIDA)
      from MERCADORIASNOTA
      where MERCADORIASNOTA.FILIAL = :FILIAL and
            MERCADORIASNOTA.IDNOTA = :V_IDNOTA
      --group by mercadoriasnota.IDNOTASAIDA      
      into :VL_IPI,v_ipiout, :idnotareferenciada;
    end
    else
    if (:ORIGEM = 'NC') then
    begin
      select sum(
             case
               when MERCADORIASNOTACOMPRA.CSTIPI = 0 then MERCADORIASNOTACOMPRA.VALORIPI
               else 0
             end),
             sum(
             case
               when MERCADORIASNOTACOMPRA.CSTIPI = 0 then 0
               else MERCADORIASNOTACOMPRA.VALORIPI
             end),
             min(mercadoriasnotacompra.IDNOTASAIDA)
      from  MERCADORIASNOTACOMPRA
      where MERCADORIASNOTACOMPRA.FILIAL = :FILIAL and
            MERCADORIASNOTACOMPRA.IDNOTA = :V_IDNOTA
      --group by mercadoriasnotacompra.IDNOTASAIDA      
      into :VL_IPI, v_ipiout, :idnotareferenciada;
    end
    
    
    VL_merc = vl_merc + coalesce(v_ipiout, 0) + coalesce(v_icmsstOut, 0);
    VL_OUT_DA = VL_OUT_DA + coalesce(v_icmsstOut, 0);

     if (:COD_SIT = '02') then
    begin
      COD_PART = null;
      DT_DOC = null;
      DT_E_S = null;
      VL_DOC = null;
      IND_PGTO = null;
      VL_DESC = null;
      VL_ABAT_NT = null;
      VL_MERC = null;
      IND_FRT = null;
      VL_FRT = null;
      VL_SEG = null;
      VL_OUT_DA = null;
      VL_BC_ICMS = null;
      VL_ICMS = null;
      VL_BC_ICMS_ST = null;
      VL_ICMS_ST = null;
      VL_IPI = null;
      VL_PIS = null;
      VL_COFINS = null;
      VL_PIS_ST = null;
      VL_COFINS_ST = null;
    end

    SEQUENCIAC = SEQUENCIAC + 1;
    ORDEM = 0;
    NIVEL = 3;
    if (VL_BC_ICMS < 0.00 or VL_ICMS < 0.00) then
    begin
      VL_BC_ICMS = 0.00;
      VL_ICMS = 0.00;
      aliq_icms = 0.00;
    end
    

    insert into SPEDFISCAL_C (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, IND_OPER, IND_EMIT, COD_PART, COD_MOD, COD_SIT, SER,
                              NUM_DOC, CHV_NFE, DT_DOC, DT_E_S, VL_DOC, IND_PGTO, VL_DESC, VL_MERC, VL_ABAT_NT, IND_FRT,
                              VL_FRT, VL_SEG, VL_OUT_DA, VL_BC_ICMS, VL_ICMS, VL_BC_ICMS_ST, VL_ICMS_ST, VL_IPI, VL_PIS,
                              VL_COFINS, VL_PIS_ST, VL_COFINS_ST, COD_NAT)
    values (:SEQUENCIAC, 'C100', :ORDEM, 2, :IND_OPER, :IND_EMIT, :COD_PART, :COD_MOD, :COD_SIT, :SER, :NUM_DOC,
            :CHV_NFE, :DT_DOC, :DT_E_S, :VL_DOC, :IND_PGTO, :VL_DESC, :VL_MERC, :VL_ABAT_NT, :IND_FRT, :VL_FRT, :VL_SEG,
            :VL_OUT_DA, :VL_BC_ICMS, :VL_ICMS, :VL_BC_ICMS_ST, :VL_ICMS_ST, :VL_IPI, :VL_PIS, :VL_COFINS, :VL_PIS_ST,
            :VL_COFINS_ST, :COD_NAT);

 

    if (:UF <> :V_UFESTABELECIMENTO and
        :COD_SIT <> '02') then
    begin
      if (coalesce(VL_ICMS_UF_DEST,0)+coalesce(VL_FCP_UF_DEST,0) > 0.00) then
      begin
        SEQUENCIAC = SEQUENCIAC + 1;
        IF (IND_OPER=1) THEN

            insert into SPEDFISCAL_C (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, IND_OPER, UF, VL_FCP_UF_DEST, VL_ICMS_UF_DEST,VL_ICMS_UF_REM)
            values (:SEQUENCIAC, 'C101', 0, 3, :IND_OPER,  :UF, :VL_FCP_UF_DEST, :VL_ICMS_UF_DEST, :VL_ICMS_UF_REM);
        ELSE
            insert into SPEDFISCAL_C (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, IND_OPER, UF, VL_FCP_UF_DEST, VL_ICMS_UF_DEST,VL_ICMS_UF_REM)
            values (:SEQUENCIAC, 'C101', 0, 3, :IND_OPER, :UF, :VL_FCP_UF_DEST, :VL_ICMS_UF_REM, :VL_ICMS_UF_DEST );
      end
    end
    
    if (coalesce (idnotareferenciada,0)<>0 and :cod_sit<>'02') then
   
   
    begin 
     SEQUENCIAC = SEQUENCIAC + 1; 
     
     insert into SPEDFISCAL_C (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, CODIGOC110, descricaoC110  )
     values (:SEQUENCIAC, 'C110', 0, 3, :cod_nat, 'DEVOLUCAO DE NOTA DE VENDA' );

     SEQUENCIAC = SEQUENCIAC + 1; 
      
     if (:ORIGEM = 'NS') then
        begin
              
              SELECT distinct
                 notafiscal.numeronota as NUM_DOC,                
                 notafiscal.chave as chv_nfe,                     
                 notafiscal.dataemissao as DT_DOC,
                 modelodocto.serie as SER,
                '1' as SUB
            from
                notafiscal 
            inner join modelodocto on         
                    (modelodocto.ID=notafiscal.MODELO)
            where 

                notafiscal.FILIAL = :FILIAL and
                notafiscal.IDNOTA = :idnotareferenciada
                into :NUM_DOC, :CHV_NFE, :DT_DOC, :SER, :SUB;       
           end
             
        else
        
        if (:ORIGEM = 'NC') then
        begin
         SELECT distinct
                NOTACOMPRA.NRNOTAFORNECEDOR,
                NOTACOMPRA.dataemissao,
                NOTACOMPRA.chave,
                NOTACOMPRA.serie,
                coalesce (NOTACOMPRA.subserie,0) 
            from
                NOTACOMPRA 
            where 

                NOTACOMPRA.FILIAL = :FILIAL and
                NOTACOMPRA.IDNOTA = :idnota
           into :NUM_DOC, :DT_DOC, :CHV_NFE, :SER, :SUB;  
        END 
         

        insert into SPEDFISCAL_C (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, IND_OPER, IND_EMIT, COD_PART, COD_MOD, 
                                  NUM_DOC, CHV_NFE, DT_DOC, SER, SUB, codigoC110, descricaoC110  )
        values (:SEQUENCIAC, 'C113', 0, 4, :IND_OPER, :IND_EMIT, :COD_PART, :COD_MOD, 
                :NUM_DOC, :CHV_NFE, :DT_DOC, :SER, :SUB, '1', 'NOTA DEVOLVIDA' );
         
    end    

    if (NUM_DOC_IMP <> '' and ind_oper = 0) then
    begin
      SEQUENCIAC = SEQUENCIAC + 1;
      insert into SPEDFISCAL_C (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, COD_DOC_IMP, NUM_DOC_IMP, VL_PIS_IMP, VL_COFINS_IMP)
      values (:SEQUENCIAC, 'C120', 0, 3, '0', :NUM_DOC_IMP, :VL_PIS, :VL_COFINS);
    end

    NUM_ITEM = 0;

     if (:ORIGEM = 'NS' and
        :COD_SIT <> '02') then
    begin
      for select sum(coalesce(mercadoriasnota.vlrfinalmercad,0)+
                    COALESCE(mercadoriasnota.acrescimonota,0)+coalesce(mercadoriasnota.frete, 0)+coalesce(mercadoriasnota.seguro,0)+
                    coalesce(mercadoriasnota.outdespacessor,0)+coalesce(mercadoriasnota.vlricmsrecolhido,0)+
                    coalesce(mercadoriasnota.valoripi,0)+coalesce(mercadoriasnota.icmsstfcpvalor,0)+
                     case substring(mercadoriasnota.cfop from 1 for 1) when 3 then
                     coalesce(mercadoriasnota.vlrtaxasiscomex,0)+coalesce(mercadoriasnota.vlrmarinhamerc,0)+
                     coalesce(mercadoriasnota.vlrdespaduaneiras,0)+coalesce(mercadoriasnota.vlrpispasep,0)+
                     coalesce(mercadoriasnota.vlrcofins,0)+(
                        case MERCADORIASNOTA.ICMSORIGEMBASE
                          when 0 then MERCADORIASNOTA.VALORICMS
                          else MERCADORIASNOTA.ICMSORIGEMVALOR
                        end) else 0 end)- sum(coalesce(MERCADORIASNOTA.DESCONTONOTA, 0)),
                 sum(coalesce(MERCADORIASNOTA.VLRDESCPRODUTO, 0) + coalesce(MERCADORIASNOTA.DESCONTONOTA, 0)) as DESCONTOS,
                 case substring(MERCADORIASNOTA.SITUACAOTRIBUT from 4 for 1)
                   when '' then MERCADORIASNOTA.SITUACAOTRIBUT
                   else substring(MERCADORIASNOTA.SITUACAOTRIBUT from 2 for 3)
                 end,
                 MERCADORIASNOTA.CFOP,
                 sum(
                 case MERCADORIASNOTA.ICMSORIGEMBASE
                   when 0 then MERCADORIASNOTA.ICMSBASE
                   else MERCADORIASNOTA.ICMSORIGEMBASE
                 end),
                 case MERCADORIASNOTA.ICMSORIGEMBASE
                   when 0 then MERCADORIASNOTA.ALIQUOTAICMS
                   else MERCADORIASNOTA.ICMSORIGEMALIQUOTA
                 end,
                 sum(
                 case MERCADORIASNOTA.ICMSORIGEMBASE
                   when 0 then MERCADORIASNOTA.VALORICMS
                   else MERCADORIASNOTA.ICMSORIGEMVALOR
                 end),
                 sum(MERCADORIASNOTA.VLRBASESUBST) as VLRBASESUBST, 
                 sum(MERCADORIASNOTA.VLRICMSRECOLHIDO+coalesce(mercadoriasnota.icmsstfcpvalor,0)), 
                 sum(case when MERCADORIASNOTA.CSTIPI in (0, 50, 99) then MERCADORIASNOTA.VALORIPI else 0 end),
                 sum(case when MERCADORIASNOTA.CSTIPI in (0, 50, 99) then 0 else MERCADORIASNOTA.VALORIPI end),
                 SUM(MERCADORIASNOTA.ICMSORIGEMFCPVALOR),
                 SUM(MERCADORIASNOTA.ICMSSTFCPVALOR),
                 0
          from MERCADORIASNOTA
          inner join ITEMESTOQUE on (MERCADORIASNOTA.CODIGO = ITEMESTOQUE.CODIGO)
          where MERCADORIASNOTA.FILIAL = :FILIAL and
                MERCADORIASNOTA.IDNOTA = :V_IDNOTA
          group by 3, 4, 6
          into VL_ITEM, VL_DESC, CST_ICMS, CFOP, VL_BC_ICMS, ALIQ_ICMS,
               VL_ICMS, VL_BC_ICMS_ST, VL_ICMS_ST, VL_IPI,v_ipiout, VL_FCP_OP,VL_FCP_ST, vl_fcp_ret

      do
      begin
        NUM_ITEM = NUM_ITEM + 1;

        SEQUENCIAC = SEQUENCIAC + 1;
            
  --      VL_ITEM=VL_ITEM+v_ipiout;
        

/*
        IF(:CST_IPI not in (0, 50, 99)) THEN BEGIN
            VL_ITEM=VL_ITEM+vl_ipi;
            VL_IPI=0;
            ALIQ_IPI=0;
            VL_BC_IPI=0;
        END  
*/

        if (VL_BC_ICMS < 0.00 or VL_ICMS < 0.00) then
        begin
          VL_BC_ICMS = 0.00;
          VL_ICMS = 0.00;
          aliq_icms = 0.00;
        end

        if (substring(CFOP from 1 for 1) in ('1', '2', '3')) then
          VL_TOT_CREDITOS = VL_TOT_CREDITOS + VL_ICMS;
        if (substring(CFOP from 1 for 1) in ('5', '6', '7')) then
          VL_TOT_DEBITOS = VL_TOT_DEBITOS + VL_ICMS;

        VL_RED_BASE = VL_ITEM - (VL_DESC + VL_IPI);
        VL_RED_BASE = VL_RED_BASE - VL_BC_ICMS;
        if (VL_RED_BASE < 0) then
          VL_RED_BASE = 0;
        --              cod_enq='999';
        if(VL_ICMS=0) THEN
          aliq_icms = 0;
        if(VL_ICMS_ST=0) THEN
          aliq_st = 0;
        
        

        insert into SPEDFISCAL_C (SEQUENCIA, SEGMENTO, ORDEM, NIVEL,VL_ITEM, VL_DESC, IND_MOV, CST_ICMS, CFOP, VL_OPR,
                                 VL_BC_ICMS, ALIQ_ICMS, VL_ICMS, VL_BC_ICMS_ST, VL_ICMS_ST, VL_IPI)
        values (:SEQUENCIAC, 'C190', 0, 3, :VL_ITEM, :VL_DESC, :IND_MOV, :CST_ICMS, :CFOP, :VL_ITEM,
               :VL_BC_ICMS, :ALIQ_ICMS, :VL_ICMS, :VL_BC_ICMS_ST, :VL_ICMS_ST,:VL_IPI);

        NUM_ITEM = NUM_ITEM + 1;
        
        if(coalesce(vl_fcp_op,0)>0 or coalesce(vl_fcp_ret,0)>0 or coalesce(vl_fcp_st,0)>0) then BEGIN
        
            SEQUENCIAC = SEQUENCIAC + 1;
        
            insert into SPEDFISCAL_C (SEQUENCIA, SEGMENTO, ORDEM, NIVEL,VL_fcp_op, vl_fcp_st, vl_fcp_ret)
            values (:SEQUENCIAC, 'C191', 0, 4, :vl_fcp_op, :vl_fcp_st, :vl_fcp_ret);

            NUM_ITEM = NUM_ITEM + 1;
        
        
        end
        
        
        
        
      end
      NUM_ITEM = 0;
    end

    else
    if (:ORIGEM = 'NC') then
    begin
      if (:IND_EMIT = 1) then
      begin
        for select MERCADORIASNOTA.CODIGO,
                   --MERCADORIASNOTA.DESREDUZIDA,
                   case    (:ITEMCODREFNFE)
                           WHEN 'S' then
                           SUBSTRING ( substring(coalesce(ITEMESTOQUE.REFERENCIA, '') || ' ' || coalesce
                           (substring(MERCADORIASNOTA.DESCRICAO from 1 for 120), '') from 1 for 120) from 1 for 50)
                           else coalesce(substring(MERCADORIASNOTA.DESCRICAO from 1 for 50), '') end,
                   MERCADORIASNOTA.QUANTIDADE,
                   MERCADORIASNOTA.UNIDADE,
                   MERCADORIASNOTA.VLRFINALMERCAD - (coalesce(MERCADORIASNOTA.VLRDESCPRODUTO, 0) + coalesce(MERCADORIASNOTA.DESCONTONOTA, 0)),
                   coalesce(MERCADORIASNOTA.VLRDESCPRODUTO, 0) + coalesce(MERCADORIASNOTA.DESCONTONOTA, 0),
                   case substring(MERCADORIASNOTA.SITUACAOTRIBUT from 4 for 1)
                     when '' then MERCADORIASNOTA.SITUACAOTRIBUT
                     else substring(MERCADORIASNOTA.SITUACAOTRIBUT from 2 for 3)
                   end,
                   MERCADORIASNOTA.CFOP,
                   case
                     when ITEMESTOQUE.TIPOPRODUTO not in ('1', '3', '4') then 0
                     else case
                            when (mercadoriasnota.vlricmsrecolhido>0 and NOTACOMPRA.DEVOLUCAO = 'N' AND MERCADORIASNOTA.CFOP NOT IN ('1949','2949')) then 0
                            else MERCADORIASNOTA.ICMSBASE
                          end
                   end,
                   MERCADORIASNOTA.ALIQUOTAICMS,
                   case
                     when ITEMESTOQUE.TIPOPRODUTO not in ('1', '3', '4') then 0
                     else case
                            when (mercadoriasnota.vlricmsrecolhido>0 and NOTACOMPRA.DEVOLUCAO = 'N' AND MERCADORIASNOTA.CFOP NOT IN ('1949','2949')) then 0
                            else MERCADORIASNOTA.VALORICMS
                          end
                   end,
                   case WHEN NOTACOMPRA.DEVOLUCAO = 'S' OR  MERCADORIASNOTA.CFOP IN ('1949','2949') then MERCADORIASNOTA.VLRBASESUBST
                     else 0
                   end,
                   MERCADORIASNOTA.ALIQUOTASUBSTITUTO,
                   MERCADORIASNOTA.VLRICMSRECOLHIDO+coalesce(mercadoriasnota.icmsstfcpvalor,0),
                   substring ( MERCADORIASNOTA.CSTIPI from 1 for 2),
                   MERCADORIASNOTA.IPIBASE, MERCADORIASNOTA.PIPI,
                   MERCADORIASNOTA.VALORIPI,
                   MERCADORIASNOTA.CSTPIS, MERCADORIASNOTA.BASEPIS, MERCADORIASNOTA.PPIS, MERCADORIASNOTA.VLRPISPASEP,
                   MERCADORIASNOTA.CSTCOFINS, MERCADORIASNOTA.BASECOFINS, MERCADORIASNOTA.PCOFINS,
                   MERCADORIASNOTA.VLRCOFINS,
                   0,
                   notacompra.devolucao
            from MERCADORIASNOTACOMPRA MERCADORIASNOTA
            inner join ITEMESTOQUE on (MERCADORIASNOTA.CODIGO = ITEMESTOQUE.CODIGO)
            inner join NOTACOMPRA on (MERCADORIASNOTA.FILIAL = NOTACOMPRA.FILIAL and
                  MERCADORIASNOTA.IDNOTA = NOTACOMPRA.IDNOTA)
            inner join NATUREZAOPERACAO on (NOTACOMPRA.OPERACAO = NATUREZAOPERACAO.ID)
            where MERCADORIASNOTA.FILIAL = :FILIAL and
                  MERCADORIASNOTA.IDNOTA = :V_IDNOTA
            order by MERCADORIASNOTA.IDMERCADORIA
            into COD_ITEM, DESCR_COMPL, QTD, UNID, VL_ITEM, VL_DESC, CST_ICMS, CFOP, VL_BC_ICMS, ALIQ_ICMS, VL_ICMS,
                 VL_BC_ICMS_ST, ALIQ_ST, VL_ICMS_ST, CST_IPI, VL_BC_IPI, ALIQ_IPI, VL_IPI, CST_PIS, VL_BC_PIS,
                 ALIQ_PIS, VL_PIS, CST_COFINS, VL_BC_COFINS, ALIQ_COFINS, VL_COFINS, IND_MOV, :v_devolucao
        do
        begin
          NUM_ITEM = NUM_ITEM + 1;
          SEQUENCIAC = SEQUENCIAC + 1;
          COD_ENQ = '';

          IF(:CST_IPI<>0) THEN BEGIN
            --VL_ITEM=VL_ITEM+vl_ipi;
            VL_IPI=0;
            ALIQ_IPI=0;
            VL_BC_IPI=0;
          END  

          IF((CST_PIS BETWEEN 4 AND 9) OR (CST_PIS BETWEEN 70 AND 99)) THEN BEGIN
            VL_PIS=0;
            ALIQ_PIS=0;
            VL_BC_PIS=0;
          END  

          IF((CST_COFINS BETWEEN 4 AND 9) OR (CST_COFINS BETWEEN 70 AND 99)) THEN BEGIN
            VL_COFINS=0;
            ALIQ_COFINS=0;
            VL_BC_COFINS=0;
          END  

          if((:ORIGEM = 'NC') and :cst_icms in ('060','160','260')) then
              
          begin
                 vl_item = vl_item + vl_icms_st;
                 VL_BC_ICMS=0.00;
                 ALIQ_ICMS=0.00;
                 VL_ICMS=0.00;
                 VL_BC_ICMS_ST=0.00;
                 ALIQ_ST=0.00;
                 VL_ICMS_ST=0.00;
          end
          
          if(VL_ICMS=0) THEN
            aliq_icms = 0;
          if(VL_ICMS_ST=0) THEN
            aliq_st = 0;

          insert into SPEDFISCAL_C (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, NUM_ITEM, COD_ITEM, DESCR_COMPL, QTD, UNID,
                                   VL_ITEM, VL_DESC, IND_MOV, CST_ICMS, CFOP, COD_NAT, VL_BC_ICMS, ALIQ_ICMS, VL_ICMS,
                                    VL_BC_ICMS_ST, ALIQ_ST, VL_ICMS_ST, IND_APUR, CST_IPI, COD_ENQ, VL_BC_IPI, ALIQ_IPI,
                                    VL_IPI, CST_PIS, VL_BC_PIS, ALIQ_PIS, VL_PIS, CST_COFINS, VL_BC_COFINS, ALIQ_COFINS, VL_COFINS, cod_cta)
          values (:SEQUENCIAC, 'C170', 0, 3, :NUM_ITEM, :COD_ITEM, :DESCR_COMPL, :QTD, :UNID, :VL_ITEM, :VL_DESC,
                  :IND_MOV, :CST_ICMS, :CFOP, :COD_NAT, :VL_BC_ICMS, :ALIQ_ICMS, :VL_ICMS,:VL_BC_ICMS_ST, :ALIQ_ST,
                  :VL_ICMS_ST, :IND_APUR, :CST_IPI, :COD_ENQ, :VL_BC_IPI, :ALIQ_IPI, :VL_IPI,:CST_PIS, :VL_BC_PIS,
                  :ALIQ_PIS, :VL_PIS, :CST_COFINS, :VL_BC_COFINS, :ALIQ_COFINS, :VL_COFINS, :cod_cta);
        end
      end
      
      
      for select sum(coalesce(mercadoriasnota.vlrfinalmercad,0)+COALESCE(mercadoriasnota.acrescimonota,0)+coalesce(mercadoriasnota.frete, 0)+coalesce(mercadoriasnota.seguro,0)+coalesce(mercadoriasnota.outdespacessor,0)+
        (CASE COALESCE(NOTACOMPRA.ST_JA_RECOLHIDO,'N') WHEN 'S' THEN 0 ELSE coalesce(mercadoriasnota.vlricmsrecolhido,0) END)+coalesce(mercadoriasnota.valoripi,0)+coalesce(mercadoriasnota.icmsstfcpvalor,0))- sum(coalesce(MERCADORIASNOTA.DESCONTONOTA, 0)),
                 sum(coalesce(MERCADORIASNOTA.VLRDESCPRODUTO, 0) + coalesce(MERCADORIASNOTA.DESCONTONOTA, 0)) as DESCONTOS,
                 case substring(MERCADORIASNOTA.SITUACAOTRIBUT from 4 for 1)
                   when '' then MERCADORIASNOTA.SITUACAOTRIBUT
                   else substring(MERCADORIASNOTA.SITUACAOTRIBUT from 2 for 3)
                 end,
                 MERCADORIASNOTA.CFOP,
                 sum(
                 case
                   when ITEMESTOQUE.TIPOPRODUTO not in ('1', '3', '4') then 0
                   else case
                          when (mercadoriasnota.vlricmsrecolhido>0 and NOTACOMPRA.DEVOLUCAO = 'N'  AND MERCADORIASNOTA.CFOP NOT IN ('1949','2949')) then 0
                          else MERCADORIASNOTA.ICMSBASE
                        end
                 end),
                 case substring(MERCADORIASNOTA.SITUACAOTRIBUT from 2 for 3) when '60' then 0 else MERCADORIASNOTA.ALIQUOTAICMS end,
                 sum(
                 case
                   when ITEMESTOQUE.TIPOPRODUTO not in ('1', '3', '4') then 0
                   else case
                          when (mercadoriasnota.vlricmsrecolhido>0 and NOTACOMPRA.DEVOLUCAO = 'N'  AND MERCADORIASNOTA.CFOP NOT IN ('1949','2949')) then 0
                          else MERCADORIASNOTA.VALORICMS
                        end
                 end),
                 sum(
                 case WHEN NOTACOMPRA.DEVOLUCAO='S'  OR MERCADORIASNOTA.CFOP IN ('1949','2949') then MERCADORIASNOTA.VLRBASESUBST
                   else 0
                 end) as VLRBASESUBST,
                 sum(
                 case WHEN NOTACOMPRA.DEVOLUCAO = 'S'  OR MERCADORIASNOTA.CFOP IN ('1949','2949') then MERCADORIASNOTA.VLRICMSRECOLHIDO+coalesce(mercadoriasnota.icmsstfcpvalor,0)
                   else 0
                 end),
                  sum(
                 case
                   when MERCADORIASNOTA.CSTIPI in (0) then MERCADORIASNOTA.VALORIPI
                   else 0
                 end), notacompra.devolucao,
                 0,
                 SUM(mercadoriasnota.ICMSSTFCPVALOR),
                 0
                 
                 
          from MERCADORIASNOTACOMPRA MERCADORIASNOTA
          inner join ITEMESTOQUE on (MERCADORIASNOTA.CODIGO = ITEMESTOQUE.CODIGO)
          inner join NOTACOMPRA on (MERCADORIASNOTA.FILIAL = NOTACOMPRA.FILIAL and
                MERCADORIASNOTA.IDNOTA = NOTACOMPRA.IDNOTA)
          inner join NATUREZAOPERACAO on (NOTACOMPRA.OPERACAO = NATUREZAOPERACAO.ID)
          where MERCADORIASNOTA.FILIAL = :FILIAL and
                MERCADORIASNOTA.IDNOTA = :V_IDNOTA
          group by 3, 4, 6, 11
          into VL_ITEM, VL_DESC, CST_ICMS, CFOP, VL_BC_ICMS, ALIQ_ICMS, VL_ICMS, VL_BC_ICMS_ST, VL_ICMS_ST, VL_IPI, :v_devolucao,
                 vl_fcp_op, vl_fcp_st, vl_fcp_ret
      do
      begin
        NUM_ITEM = NUM_ITEM + 1;

        SEQUENCIAC = SEQUENCIAC + 1;
        if( :cst_icms in ('060','160','260')) then
        begin
                 VL_BC_ICMS=0.00;
                 ALIQ_ICMS=0.00;
                 VL_ICMS=0.00;
                 VL_BC_ICMS_ST=0.00;
                 ALIQ_ST=0.00;
                 VL_ICMS_ST=0.00;
                 VL_BC_IPI=0.00;
                 ALIQ_IPI=0.00;
                 VL_IPI=0.00;
        end
        
        if(VL_ICMS=0) THEN
            aliq_icms = 0;
        if(VL_ICMS_ST=0) THEN
            aliq_st = 0;
        
        
        VL_TOT_CREDITOS = VL_TOT_CREDITOS + VL_ICMS;
        VL_RED_BASE = VL_ITEM - (VL_DESC + VL_IPI);
        VL_RED_BASE = VL_RED_BASE - VL_BC_ICMS;
        if (VL_RED_BASE < 0) then
          VL_RED_BASE = 0;


        insert into SPEDFISCAL_C (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, VL_ITEM, VL_DESC, IND_MOV,CST_ICMS, CFOP, VL_OPR,
                                 VL_BC_ICMS, ALIQ_ICMS, VL_ICMS,VL_BC_ICMS_ST, VL_ICMS_ST,VL_IPI)
        values (:SEQUENCIAC, 'C190', 0, 3, :VL_ITEM, :VL_DESC, :IND_MOV,:CST_ICMS, :cfop, :VL_ITEM,
                :VL_BC_ICMS, :ALIQ_ICMS, :VL_ICMS, :VL_BC_ICMS_ST, :VL_ICMS_ST,:VL_IPI);

        NUM_ITEM = NUM_ITEM + 1;
        
        
        if(coalesce(vl_fcp_op,0)>0 or coalesce(vl_fcp_ret,0)>0 or coalesce(vl_fcp_st,0)>0) then BEGIN
        
            SEQUENCIAC = SEQUENCIAC + 1;
        
            insert into SPEDFISCAL_C (SEQUENCIA, SEGMENTO, ORDEM, NIVEL,VL_fcp_op, vl_fcp_st, vl_fcp_ret)
            values (:SEQUENCIAC, 'C191', 0, 4, :vl_fcp_op, :vl_fcp_st, :vl_fcp_ret);

            NUM_ITEM = NUM_ITEM + 1;
        
        
        end
      end
      
      for select  
        sum(COALESCE(MERCADORIASNOTACOMPRA.ICMSBASE ,0)), 
        TRIBUTACAOICMSUF.ALIQUOTA - MERCADORIASNOTACOMPRA.ALIQUOTAICMS
      from 
        MERCADORIASNOTAcompra
      inner join  
        itemestoque on
            mercadoriasnotacompra.codigo=itemestoque.CODIGO
      inner join 
            cadaStroparceiros on
                cadastroparceiros.cadastro=mercadoriasnotacompra.filial
      inner JOIN
        TRIBUTACAOICMSUF on
            TRIBUTACAOICMSUF.id=mercadoriasnotacompra.CLASSIFICACAOTRIBUTARIA AND
            tributacaoicmsuf.uf=CADASTROPARCEIROS.UF            
      WHERE
        mercadoriasnotacompra.filial=:filial
        and mercadoriasnotacompra.idnota=:v_idnota
        and itemestoque.tipoproduto = '2'
      GROUP BY 2      
