select 
    titulopag.idtitulo,
    titulopag.titulo,
    titulopag.fatura,
    cadastroparceiros.cadastro,
    cadastroparceiros.nome,
    titulopag.EMISSAO,
    titulopag.vencimento
from 
    titulopag 
inner join
    CADASTROPARCEIROS on
        CADASTROPARCEIROS.cadastro=TITULOPAG.parceiro
where 
    titulopag.vencimento <> cast(vencimento as date) and
    titulopag.baixa is not null 