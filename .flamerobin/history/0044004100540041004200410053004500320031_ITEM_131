select
    materiallocal.saldototal,
    locallote.*,
    composicaomercnota.*
    
from 
    COMPOSICAOMERCNOTA
left join
    locallote on
        locallote.filial=COMPOSICAOMERCNOTA.filial and
        locallote."LOCAL"=composicaomercnota.IDLOCAL and
        locallote.lote=COMPOSICAOMERCNOTA.LOTE and
        locallote.iditem=composicaomercnota.iditem
left join
    materiallocal on
        locallote.filial=materiallocal.filial and
        locallote."LOCAL"=materiallocal.IDLOCAL and
        locallote.iditem=materiallocal.iditem


where 
    composicaomercnota.filial=1 and composicaomercnota.idnota=82389