select 
    c_fatores.idlocal, 
    c_fatores.idfator, 
    c_fatores.CFISCAL, 
    classificacaofiscal.descricao as classificacaofiscal,
    CLASSIFICACAOFISCAL.PII as impimportacao,    
    CLASSIFICACAOFISCAL.aliquota as ipi,
    c_fatores.fatora, 
    c_fatores.fatorb, 
    c_fatores.fatorc,
    c_fatores.fatord, 
    c_fatores.fatore
    
from
    c_fatores
inner join 
    classificacaofiscal on 
        (c_fatores.cfiscal=classificacaofiscal.cfiscal)
WHERE 
  c_fatores.idlocal=13
order by 
    idfator
