    INSERT INTO CADASTROPARCEIROS(
        CADASTRO,
        C_CODCLIENTEANTIGO,
        RAZAOSOCIAL,
        NOME,
        DOCUMENTO,
        INSCESTADUAL,
        INSCMUNICIPAL,
        PRINCIPALCONTATO,
        EMAIL,
        LOGRADOURO,
        NUMERO,
        COMPLEMENTO,
        BAIRRO,
        CIDADE,
        UF,
        CEP)   

    SELECT 
        t_cadastro.cadastro,
        T_CADASTRO.CODIGO,
        RAZAO,
        FANTASIA,
        DOCUMENTO2,
        INSCEST,
        INSCMUN,
        CONTATO1,
        SUBSTRING(:EMAIL FROM 1 FOR  50),
        ENDERECO,
        NULL,
        NULL,
        BAIRRO,
        CIDADE,
        UF,
        SUBSTRING(CEP FROM 1 FOR 5)||SUBSTRING(CEP FROM 7 FOR 3)   
    FROM T_CADASTRO
    WHERE NOT EXISTS
    (SELECT * FROM CADASTROPARCEIROS WHERE CADASTROPARCEIROS.C_CODCLIENTEANTIGO=T_CADASTRO.CODIGO);
