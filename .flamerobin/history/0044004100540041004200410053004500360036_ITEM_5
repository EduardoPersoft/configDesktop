update pedido set vendedor = 
(select first 1 
vendedoresped.vendedor 
from vendedor 
where vendedoresped.filial=pdido.filial
and vendedoresped.idnota=pedido.idnota),
atendente = 
(select first 1 
vendedoresped.vendedor 
from vendedor 
where vendedoresped.filial=pdido.filial
and vendedoresped.idnota=pedido.idnota)