select 
    CADASTROPARCEIROS.CADASTRO,
    CADASTROPARCEIROS.NOME,
    CADASTROPARCEIROS.PARCEIROFORNECEDOR,
    cadastroparceiros.RAMOATIVIDADE
  
from 
    CADASTROPARCEIROS
inner join 
    FORNECEDORES MERCADO ON 
    CADASTROPARCEIROS.CADASTRO=MERCADO.CADASTRO
where   
    --CADASTROPARCEIROS.PARCEIROFORNECEDOR='S' and
    CADASTROPARCEIROS.RAMOATIVIDADE=2
