select 
    itemestoque.CODIGO,
    itemestoque.C_MATERIAPRIMABASE,
    itemestoque.c_tinta,
    (select    
                                        C_CONVERSAOMP.CODIGONOVO
                                      from  
                                        C_CONVERSAOMP
                                      where
                                        C_CONVERSAOMP.CODIGO=ITEMESTOQUE.CODIGO)
from
    itemestoque