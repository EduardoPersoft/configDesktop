 select 
    itemestoque.codigo,
    itemestoque.descricao produto,
    'Nr.Original: '||itemestoque.REFERENCIA||'. Aplicação: '||itemestoque.DEFINICAO descricao,
    itemestoque.itembase,
    cast('' as varchar(2)) as lado,
    itemestoquexarquivo.NOMEARQUIVO,
    materialfilial.customedio,
    materiallocal.SALDOTOTAL,
    tributacaoicmsuf.IVAAJUSTADO,
    CLASSIFICACAOFISCAL.descricao,
    'Troca', 
    1,
    'ano'    
from 
    estabelecimento
inner join 
    materiallocal on
        materiallocal.filial=estabelecimento.cadastro and
        materiallocal.IDLOCAL in (0, 1)
inner join
    itemestoque on
        itemestoque.codigo=materiallocal.IDITEM
inner join
    materialfilial on
        materialfilial.filial=materiallocal.filial and
        materialfilial.iditem=materiallocal.IDITEM       
left join
    CADASTROPARCEIROS cadest on
        cadest.cadastro=ESTABELECIMENTO.CADASTRO
left join
    itemestoquexarquivo on
        itemestoquexarquivo.CODIGO=itemestoque.codigo and
        itemestoquexarquivo.ordem =0
left join
    TRIBUTACAOICMSUF on
        tributacaoicmsuf.ID=itemestoque.TRIBUTACAOICMS and
        tributacaoicmsuf.uf=cadest.uf
        
left join
    CLASSIFICACAOFISCAL on
        CLASSIFICACAOFISCAL.CFISCAL=itemestoque.CLASSIFISCAL   
where
    estabelecimento.cadastro = 5 and
    itemestoque.codigo in ('102317', '104877',  '105963', '17412', '105525', '104569')
    
