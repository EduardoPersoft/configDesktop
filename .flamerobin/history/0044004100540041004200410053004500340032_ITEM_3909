select filial,idmovimento,pesoliquido,pesobruto,
(select sum(VOLUMESMOVIMENTOESTOQUE.PESOLIQUIDO)
 FROM VOLUMESMOVIMENTOESTOQUE
 WHERE VOLUMESMOVIMENTOESTOQUE.filial=MOVIMENTOESTOQUE.filial
 and VOLUMESMOVIMENTOESTOQUE.IDMOVIMENTO=MOVIMENTOESTOQUE.idmovimento),
(select sum(VOLUMESMOVIMENTOESTOQUE.PESOBRUTO)
 FROM VOLUMESMOVIMENTOESTOQUE
 WHERE VOLUMESMOVIMENTOESTOQUE.filial=MOVIMENTOESTOQUE.filial
 and VOLUMESMOVIMENTOESTOQUE.IDMOVIMENTO=MOVIMENTOESTOQUE.idmovimento)
FROM MOVIMENTOESTOQUE
where filial=110 and idmovimento=74834