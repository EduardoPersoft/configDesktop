SELECT  
    MATERIALMOVIMENTOESTOQUE.FILIAL,
    MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO,
    MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL,
    MOVIMENTOESTOQUE.DOCUMENTO,
    MOVIMENTOESTOQUE.EMISSAO,
    MATERIALMOVIMENTOESTOQUE.IDITEM,
    MATERIALMOVIMENTOESTOQUE.LOTE,
    ITEMESTOQUE.DESCRICAO,
    MATERIALMOVIMENTOESTOQUE.QUANTIDADE-
            coalesce((select sum(m2.quantidade) from movimentoestoque m2
                     where materialmovimentoestoque.filial=m2.filial
                     and materialmovimentoestoque.idmovimento=m2.idop
                     and materialmovimentoestoque.idmovimentomaterial=m2.idopitem
                     and movimentoestoque.tipomovimento='09'),0) as quantidade,
    COALESCE(ESTABELECIMENTO.LOCALDEFAULT,MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO) LOCALARMAZENAMENTO,
    MATERIALMOVIMENTOESTOQUE.quantidadE AS TOTAL,
    centrocustos.descricao as centrocusto
FROM 
    MATERIALMOVIMENTOESTOQUE
INNER JOIN 
    MOVIMENTOESTOQUE ON 
        (MATERIALMOVIMENTOESTOQUE.FILIAL=MOVIMENTOESTOQUE.FILIAL
         AND MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO=MOVIMENTOESTOQUE.IDMOVIMENTO)
INNER JOIN 
    ITEMESTOQUE ON 
        (ITEMESTOQUE.CODIGO=MATERIALMOVIMENTOESTOQUE.IDITEM)
INNER JOIN 
    ESTABELECIMENTO ON 
        (ESTABELECIMENTO.CADASTRO=MOVIMENTOESTOQUE.FILIAL)
LEFT JOIN   
    CENTROCUSTOS ON
        CENTROCUSTOS.IDPLANO = ESTABELECIMENTO.PLANOCENTROCUSTOS AND
        CENTROCUSTOS.CENTROCUSTO = MATERIALMOVIMENTOESTOQUE.CENTROCUSTO
WHERE 
    MOVIMENTOESTOQUE.FILIAL=1
    AND MOVIMENTOESTOQUE.EMISSAO BETWEEN '01.01.2021' AND '31.12.2021'
    AND MOVIMENTOESTOQUE.TIPOMOVIMENTO=12
    and materialmovimentoestoque.concluido='N'