declare variable VVALORMERCAPLICADA double precision;
declare variable PNOTAFISCALMAODEOBRA char(1);
declare variable pTIPONOTA char(1);
DECLARE variable tipocalculoipi char (1);


begin
  VIPIDEVOLITEM=0;
  VIPIDEVOLTOT=0;
  icmspart=0;
  pFCP=0;
  pFCPST=0;
  pFCPSTRET=0;
  VFCP=0;
  VFCPST=0;
  VFCPSTRET=0;
  vBCFCP=0;
  vBCFCPST=0;
  vBCFCPSTRet=0;
  MSGADICIONAL = '';
  MSGCORPONOTA = '';
  VTOTTRIBNF = 0;
  VTOTTRIBFEDNF = 0;
  VTOTTRIBESTNF = 0;
  VICMSDESONERADO = null;
  MOTDESICMS = null;
  TPEMIS = 1;
  PROCEMI = 0;
  VERPROC = '0902';
  PDATAHOJE = cast('now' as timestamp);
  DIAHOJE = extract(day from PDATAHOJE);
  ANOHOJE = extract(year from PDATAHOJE);
  VDESC = 0.001;

  --NT2018.005
  vBCSTRet = 100;
  vICMSSubstituto = 18;
  vICMSSTRet = 18;

  MESHOJEEXTENSO = case extract(month from PDATAHOJE)
                     when 1 then 'Janeiro'
                     when 2 then 'Fevereiro'
                     when 3 then 'Mar?o'
                     when 4 then 'Abril'
                     when 5 then 'Maio'
                     when 6 then 'Junho'
                     when 7 then 'Julho'
                     when 8 then 'Agosto'
                     when 9 then 'Setembro'
                     when 10 then 'Outubro'
                     when 11 then 'Novembro'
                     when 12 then 'Dezembro'
                   end;
  select PEDIDONFE, PEDIDOCLINFE, VENDEDORDANFE, PEDIDONFEREGNUM, ITEMCODREFNFE, EANNFE, IBPTFONTE || ' ' || IBPTCHAVE
  from CONFIGURACOESGERAIS
  into :PEDIDONFE, :PEDIDOCLINFE, :VENDEDORDANFE, :PEDIDONFEREGNUM, :ITEMCODREFNFE, :VEANNFE, :IBPTFONTECHAVE;

  select CADASTROPARCEIROS.CADASTRO, CADASTROPARCEIROS.RAZAOSOCIAL, CADASTROPARCEIROS.NOME,
         case
           when (CADASTROPARCEIROS.DOCUMENTO <> '') and (not CADASTROPARCEIROS.DOCUMENTO is null) then case CADASTROPARCEIROS.TIPOPESSOA
                                                                                                         when 'F' then cast(substring(CADASTROPARCEIROS.DOCUMENTO from 1 for 3) || '.' || substring(CADASTROPARCEIROS.DOCUMENTO from 4 for 3) || '.' || substring(CADASTROPARCEIROS.DOCUMENTO from 7 for 3) || '-' || substring(CADASTROPARCEIROS.DOCUMENTO from 10 for 2) as varchar(18))
                                                                                                         when 'J' then cast(substring(CADASTROPARCEIROS.DOCUMENTO from 1 for 2) || '.' || substring(CADASTROPARCEIROS.DOCUMENTO from 3 for 3) || '.' || substring(CADASTROPARCEIROS.DOCUMENTO from 6 for 3) || '/' || substring(CADASTROPARCEIROS.DOCUMENTO from 9 for 4) || '-' || substring(CADASTROPARCEIROS.DOCUMENTO from 13 for 2) as varchar(18))
                                                                                                         else null
                                                                                                       end
           else null end as DOCUMENTO,
         case CADASTROPARCEIROS.INSCESTADUAL
           when 'ISENTO' then ''
           else CADASTROPARCEIROS.INSCESTADUAL end as INSCESTADUAL,
         CADASTROPARCEIROS.INSCMUNICIPAL, CADASTROPARCEIROS.LOGRADOURO,
         case coalesce(CADASTROPARCEIROS.NUMERO, 0)
           when 0 then 'SN'
           else CADASTROPARCEIROS.NUMERO end,
         CADASTROPARCEIROS.COMPLEMENTO, CADASTROPARCEIROS.BAIRRO, CADASTROPARCEIROS.CIDADE, CADASTROPARCEIROS.UF,
         substring(CADASTROPARCEIROS.CEP from 1 for 5) || '-' || substring(CADASTROPARCEIROS.CEP from 6 for 3),
         CADASTROPARCEIROS.CEP, CADASTROPARCEIROS.TELEFONE, CADASTROPARCEIROS.TELEFONECOMERCIAL, CADASTROPARCEIROS.FAX,
         CADASTROPARCEIROS.PRINCIPALCONTATO, CADASTROPARCEIROS.EMAIL, CADASTROPARCEIROS.WEB, ESTSIN.IDNOTAINICIAL,
         ESTSIN.IDNOTAFINAL, USUARIO.NOMECOMPLETO, USUARIO.TELEFONE, USUARIO.FAX, USUARIO.EMAIL, USUARIO.DEPARTAMENTO,
         USUARIO.CARGO, ESTADO.CODIGOIBGE,
         case coalesce(PAISES.CODIGOPAIS, '1058')
           when '1058' then 
               case coalesce (cadastroparceiros.MUNICIPIO,'') 
                    when '' then MUNICIPIO.UF || MUNICIPIO.MUNICIPIO
                    else MUNICIPIO.UF || cadastroparceiros.MUNICIPIO end
           else '9999999'
         end,
         ESTADO.INSCRICAOSUBSTITUTO, ESTABELECIMENTO.CNAE,
         case CADASTROPARCEIROS.TIPOPESSOA
           when 'J' then CADASTROPARCEIROS.DOCUMENTO
           else ''
         end,
         case CADASTROPARCEIROS.TIPOPESSOA
           when 'F' then CADASTROPARCEIROS.DOCUMENTO
           else ''
         end,
         coalesce(PAISES.CODIGOPAIS, '1058'),
         PAISES.DESCRICAOPAIS,
         ESTABELECIMENTO.UTC,
         ESTABELECIMENTO.TIPOCALCULOIPI,
         estabelecimento.cnpjcontador,
         estabelecimento.cpfcontador

  from ESTSIN
  inner join
        CADASTROPARCEIROS
                         on (CADASTROPARCEIROS.CADASTRO = ESTSIN.ESTABELECIMENTO)
  inner join
        ESTABELECIMENTO
                       on (ESTABELECIMENTO.CADASTRO = ESTSIN.ESTABELECIMENTO)
  left join
       ESTADO
             on (ESTADO.ESTADO = CADASTROPARCEIROS.UF)
  left join
       MUNICIPIO
                on (MUNICIPIO.UF_SIGLA = CADASTROPARCEIROS.UF and
        upper(MUNICIPIO.MUNICIPIO_NOME) = upper(CADASTROPARCEIROS.CIDADE))
  left join
       USUARIO
              on (USUARIO.USUARIO = ESTSIN.USUARIO)
  left join
       PAISES
             on (CADASTROPARCEIROS.CODIGOPAIS = PAISES.CODIGOPAIS)
  where
       ESTSIN.RELATORIO = :RELATORIO
  into FILIAL, RAZAOFILIAL, NOMEFILIAL, DOCUMENTOFILIAL, INSCESTADUALFILIAL, INSCMUNICIPALFILIAL,
       LOGRADOUROFILIAL, NUMEROFILIAL, COMPLEMENTOFILIAL, BAIRROFILIAL, CIDADEFILIAL, UFFILIAL, CEPFILIAL, NCEP,
       TELEFONEFILIAL, TELEFONECOMERCIALFILIAL, FAXFILIAL, PRINCIPALCONTATOFILIAL, EMAILFILIAL, WEBFILIAL,
       PIDINICIAL, PIDFINAL, NOMEUSUARIO, TELEFONEUSUARIO, FAXUSUARIO, EMAILUSUARIO, DEPARTAMENTOUSUARIO,
       CARGOUSUARIO, CUFFILIAL, CMUNICIPIOFILIAL, INSCSUBSTITUTAFILIAL, CNAEFILIAL, CNPJFILIAL, CPFFILIAL,
       CODIGOPAISFILIAL, PAISFILIAL, S_UTC, :tipocalculoipi, :cnpjcontador, :cpfcontador;

  for select
             NOTAFISCAL.IDNOTA,
             NOTAFISCAL.NUMERONOTA,
             NOTAFISCAL.DATAHORAEMISSAO,
             NOTAFISCAL.DATACADASTRO,
             NOTAFISCAL.DESTINATARIO,
             NOTAFISCAL.DEVOLUCAO,
             CADASTROPARCEIROS.RAZAOSOCIAL,
             CADASTROPARCEIROS.NOME,
             CADASTROPARCEIROS.LOGRADOURO,
             case coalesce(CADASTROPARCEIROS.NUMERO, 0)
               when 0 then 'SN'
               else CADASTROPARCEIROS.NUMERO
             end,
             CADASTROPARCEIROS.COMPLEMENTO, CADASTROPARCEIROS.BAIRRO, CADASTROPARCEIROS.CIDADE, CADASTROPARCEIROS.UF,
             substring(CADASTROPARCEIROS.CEP from 1 for 5) || '-' || substring(CADASTROPARCEIROS.CEP from 6 for 3),
             CADASTROPARCEIROS.CEP,
             case
               when (CADASTROPARCEIROS.DOCUMENTO <> '') and (not CADASTROPARCEIROS.DOCUMENTO is null) then case CADASTROPARCEIROS.TIPOPESSOA
                                                                                                             when 'F' then cast(substring(CADASTROPARCEIROS.DOCUMENTO from 1 for 3) || '.' || substring(CADASTROPARCEIROS.DOCUMENTO from 4 for 3) || '.' || substring(CADASTROPARCEIROS.DOCUMENTO from 7 for 3) || '-' || substring(CADASTROPARCEIROS.DOCUMENTO from 10 for 2) as varchar(18))
                                                                                                             when 'J' then cast(substring(CADASTROPARCEIROS.DOCUMENTO from 1 for 2) || '.' || substring(CADASTROPARCEIROS.DOCUMENTO from 3 for 3) || '.' || substring(CADASTROPARCEIROS.DOCUMENTO from 6 for 3) || '/' || substring(CADASTROPARCEIROS.DOCUMENTO from 9 for 4) || '-' || substring(CADASTROPARCEIROS.DOCUMENTO from 13 for 2) as varchar(18))
                                                                                                             else null
                                                                                                           end
               else null
             end as DOCUMENTO,
             case CADASTROPARCEIROS.TIPOPESSOA
               when 'J' then CADASTROPARCEIROS.INSCESTADUAL
               else case CADASTROPARCEIROS.CONTRIBUINTE
                      when 'S' then CADASTROPARCEIROS.INSCESTADUAL
                      else ''
                    end
             end,
             CADASTROPARCEIROS.INSCMUNICIPAL,
             case
               when coalesce(NOTAFISCAL.EMAIL, '') <> '' then NOTAFISCAL.EMAIL
               else CADASTROPARCEIROS.EMAIL
             end,
             case coalesce(PAISES.CODIGOPAIS, '1058')
               when '1058' then CADASTROPARCEIROS.TELEFONE
               else ''
             end,
             case coalesce(PAISES.CODIGOPAIS, '1058')
               when '1058' then CADASTROPARCEIROS.TELEFONECOMERCIAL
               else ''
             end,
             case coalesce(PAISES.CODIGOPAIS, '1058')
               when '1058' then CADASTROPARCEIROS.CELULAR
               else ''
             end,
             case coalesce(PAISES.CODIGOPAIS, '1058')
               when '1058' then CADASTROPARCEIROS.FAX
               else ''
             end,
             case
               when coalesce(NOTAFISCAL.CONTATO, '') <> '' then NOTAFISCAL.CONTATO
               else CADASTROPARCEIROS.PRINCIPALCONTATO
             end,
             NOTAFISCAL.LOGRADOUROENTREGA,
             case coalesce(NOTAFISCAL.NUMEROENTREGA, 0)
               when 0 then 'SN'
               else NOTAFISCAL.NUMEROENTREGA
             end,
             NOTAFISCAL.COMPLEMENTOENTREGA,
             NOTAFISCAL.BAIRROENTREGA,
             NOTAFISCAL.CIDADEENTREGA,
             NOTAFISCAL.UFENTREGA,
             substring(NOTAFISCAL.CEPENTREGA from 1 for 5) || '-' || substring(NOTAFISCAL.CEPENTREGA from 6 for 3),
             NOTAFISCAL.CEPENTREGA,
             USUARIO.NOMECOMPLETO,
             USUARIO.TELEFONE,
             USUARIO.FAX,
             USUARIO.EMAIL,
             USUARIO.DEPARTAMENTO,
             USUARIO.CARGO,
             NOTAFISCAL.CFOP,
             NOTAFISCAL.NATUREZAOPERACAO,
             TIPOCOBRANCA.DESCRICAO,
             CONDICAOPAGAMENTO.DESCRICAO,
             NOTAFISCAL.VLRDESCMERCADORIAS,
             substring(NOTAFISCAL.MSGDESCMERCADORIAS from 1 for 120),
             NOTAFISCAL.VLRDESCINDPRODUTO,
             substring(NOTAFISCAL.MSGDESCPRODUTOS from 1 for 120),
             NOTAFISCAL.VLRACRESCMERCAD,
             substring(NOTAFISCAL.MSGACRESCMERCADORIA from 1 for 120),
             NOTAFISCAL.VLRTOTNOTAEXTENSO,
             NOTAFISCAL.VLRTOTALMERCADORIAS,
             case
               when substring(NOTAFISCAL.CFOP from 1 for 1) in ('6', '2') and coalesce(CADASTROPARCEIROS.CONTRIBUINTE, 'N') = 'N' and NOTAFISCAL.SIMPLES = 'N' then NOTAFISCAL.ICMSORIGEMVALOR
               else case NOTAFISCAL.ZONAFRANCA
                      when 'S' then 0
                      else NOTAFISCAL.icmsorigemvalor
                    end
             end,
             case NOTAFISCAL.ZONAFRANCA
               when 'N' then 0
               else NOTAFISCAL.icmsorigemvalor
             end,
             NOTAFISCAL.VALORIPI,
             NOTAFISCAL.VLRICMSRECOLHIDO,
             NOTAFISCAL.VALORFRETE,
             NOTAFISCAL.VALORSEGURO,
             NOTAFISCAL.VLROUTDESPACESSORIA +
             coalesce(NOTAFISCAL.JUROSMULTAIMPOSTOS, 0) +
             coalesce(NOTAFISCAL.VLRTAXASISCOMEX, 0) +
             coalesce(NOTAFISCAL.VLRACRESCMERCAD, 0) +
             coalesce(NOTAFISCAL.VLRACRESCSERVICOS, 0) +
             coalesce(NOTAFISCAL.VLRDESPADUANEIRAS, 0),
             NOTAFISCAL.VLRFINALSERVICOS,
             NOTAFISCAL.VLRTOTALNOTA,
             NOTAFISCAL.CODIGOTRANSP,
             NOTAFISCAL.QUANTIDADEVOLUME,
             NOTAFISCAL.PESOLIQUIDO,
             NOTAFISCAL.PESOBRUTO,
             case NOTAFISCAL.ENTRADASAIDA
               when 'E' then '0'
               else '1'
             end,
             cast(NOTAFISCAL.FRETE as varchar(1)),
             case NOTAFISCAL.FRETE
               when '0' then 'REMETENTE'
               when '1' then 'DESTINAT?RIO'
               when '2' then 'TERCEIROS'
               when '3' then 'REMETENTE'
               when '4' then 'DESTINAT?RIO'
               else 'SEM FRETE'
             end as REM_DEST_DESC,
             NOTAFISCAL.PLACAVEICULO,
             case
               when substring(NOTAFISCAL.CFOP from 1 for 1) = '6' and coalesce(CADASTROPARCEIROS.CONTRIBUINTE, 'N') = 'N' and NOTAFISCAL.SIMPLES = 'N' then NOTAFISCAL.ICMSORIGEMBASE
               else case NOTAFISCAL.ZONAFRANCA
                      when 'S' then 0
                      else NOTAFISCAL.TOTBASEICMS
                    end
             end,
             NOTAFISCAL.VLRBASESUBSTITUTO,
             NOTAFISCAL.DATAENTRADASAIDA,
             NOTAFISCAL.INSCRICAOSUBSTITUTO,
             NOTAFISCAL.NUMEROVOLUME,
             NOTAFISCAL.MARCAVOLUME,
             NOTAFISCAL.ESPECIEVOLUME,
             NOTAFISCAL.VLRTOTALSERVICOS,
             NOTAFISCAL.ISS,
             MODELODOCTO.SERIE,
             NOTAFISCAL.CHAVE,
             NOTAFISCAL.ALEATORIO,
             MODELODOCTO.CODMODELOFISCAL,
             CADASTROPARCEIROS.DOCUMENTOENTREGA,
             case coalesce(PAISES.CODIGOPAIS, '1058')
           when '1058' then 
               case coalesce (cadastroparceiros.MUNICIPIO,'') 
                    when '' then MUNICIPIO.UF || MUNICIPIO.MUNICIPIO
                    else MUNICIPIO.UF || cadastroparceiros.MUNICIPIO end
           else '9999999'
         end,
             case
               when CADASTROPARCEIROS.TIPOEMPRESA = 'N' and CADASTROPARCEIROS.TIPOPESSOA = 'J' then CADASTROPARCEIROS.DOCUMENTO
               else ''
             end,
             case
               when CADASTROPARCEIROS.TIPOEMPRESA = 'N' and CADASTROPARCEIROS.TIPOPESSOA = 'F' then CADASTROPARCEIROS.DOCUMENTO
               else ''
             end,
             case CADASTROPARCEIROS.TIPOEMPRESA
               when 'E' then CADASTROPARCEIROS.IDESTRANGEIRO
               else ''
             end,
             coalesce(NOTAFISCAL.VLRDESCMERCADORIAS, 0) + coalesce(NOTAFISCAL.VLRDESCINDPRODUTO, 0),
             NOTAFISCAL.UFPLACAVEICULO, coalesce(PAISES.CODIGOPAIS, '1058'), PAISES.DESCRICAOPAIS, substring(extract(year from NOTAFISCAL.DATAEMISSAO) from 3 for 2) ||
             case extract(month from NOTAFISCAL.DATAEMISSAO)
               when 1 then '01'
               when 2 then '02'
               when 3 then '03'
               when 4 then '04'
               when 5 then '05'
               when 6 then '06'
               when 7 then '07'
               when 8 then '08'
               when 9 then '09'
               when 10 then '10'
               when 11 then '11'
               when 12 then '12'
             end,
             substring(NOTAFISCAL.CHAVE from 44 for 1), MODELODOCTO.AMBIENTE,
             case
               when NOTAFISCAL.DEVOLUCAO = 'S' then 4
               when NOTAFISCAL.TIPONOTA = 2 then 2
               else 1
             end,
             NOTAFISCAL.VLRIMPOSTOIMPORT, MODELODOCTO.TIPOIMPDANFE, NOTAFISCAL.VLRPISPASEPMERC,
             NOTAFISCAL.VLRCOFINSMERC, NOTAFISCAL.BASEPISPASEPMERC,
             substring(NOTAFISCAL.MSGDESCRMERCADORIAS from 1 for 1000), NOTAFISCAL.MCODIGO, NOTAFISCAL.MDESCRICAO,
             NOTAFISCAL.MCF, NOTAFISCAL.MCST, NOTAFISCAL.MCFOP, NOTAFISCAL.MUN, NOTAFISCAL.MQTD, NOTAFISCAL.MVLRUNI,
             NOTAFISCAL.MVLRTOT, NOTAFISCAL.MBASEICMS, NOTAFISCAL.MVLRICMS, NOTAFISCAL.MVLRIPI, NOTAFISCAL.MALIQICMS,
             NOTAFISCAL.MALIQIPI, NOTAFISCAL.MAODEOBRA as PNOTAFISCALMAODEOBRA, MODELODOCTO.REMONTARDESCRICAO,
             NOTAFISCAL.SIMPLES, NOTAFISCAL.ALIQUOTASIMPLES, NOTAFISCAL.CRT, MODELODOCTO.FORMAEMISSAONFE,
             MODELODOCTO.LOCALENTREGANOTA, NFECTRL.AMBIENTE,
             case coalesce(NFECTRL.PROTOCOLO, ' ')
               when ' ' then null
               else NFECTRL.ENVIO
             end,
             case coalesce(NOTAFISCAL.CANCELAMENTO, ' ')
               when ' ' then null
               else NOTAFISCAL.CANCELAMENTO
             end,
             case
               when NOTAFISCAL.ENTRADASAIDA = 'S' and NOTAFISCAL.DEVOLUCAO = 'N' then 'S'
               else 'N'
             end,
             NOTAFISCAL.VTOTTRIB,
             case NOTAFISCAL.TIPONOTA
               when 3 then 1
               when 2 then case CADASTROPARCEIROS.CONTRIBUINTE
                             when 'N' then 1
                             else 0
                           end
               else 0
             end,
             NOTAFISCAL.INDPRES,
             case CADASTROPARCEIROS.CONTRIBUINTE
               when 'N' then '9'
               when 'S' then case CADASTROPARCEIROS.INSCESTADUAL
                               when 'ISENTO' then 2
                               else 1
                             end
             end,
             NOTAFISCAL.XLOCDESEMB, NOTAFISCAL.XLOCDESPACHO,
             case substring(NOTAFISCAL.CFOP from 1 for 1)
               when '7' then NOTAFISCAL.UFDI
               else ''
             end,
             case
               when substring(NOTAFISCAL.CFOP from 1 for 1) in ('6', '2') and coalesce(CADASTROPARCEIROS.CONTRIBUINTE, 'N') = 'N' then 'S'
               else 'N'
             end as NCONTRIBUINTEINTER,
             coalesce(NOTAFISCAL.ICMSDESTINOFCP, 0), coalesce(NOTAFISCAL.ICMSDESTINOVALOR, 0),
             coalesce(NOTAFISCAL.ICMSORIGEMVALORINTERESTADUAL, 0), coalesce(NOTAFISCAL.ICMSDESTINOPARTILHA, 0),
             coalesce(NOTAFISCAL.VALORRETIDOPIS, 0), coalesce(NOTAFISCAL.VALORRETIDOCOFINS, 0),
             coalesce(NOTAFISCAL.VALORRETIDOCSLL, 0), coalesce(NOTAFISCAL.BASERETENCAOIRRF, 0),
             coalesce(NOTAFISCAL.VALORRETENCAOIRRF, 0), coalesce(NOTAFISCAL.BASERETENCAOPREVSOCIAL, 0),
             coalesce(NOTAFISCAL.VALORRETENCAOPREVSOCIAL, 0), NOTAFISCAL.NDRAW, NOTAFISCAL.CHNFEEXPORTACAO,
             NOTAFISCAL.VTOTTRIBFED, NOTAFISCAL.VTOTTRIBEST, NOTAFISCAL.TIPOCOBRANCA, NOTAFISCAL.VFCP,
             NOTAFISCAL.VFCPST, NOTAFISCAL.VFCPSTRET, notafiscal.tiponota,
             notafiscal.INFADFISCO
      from NOTAFISCAL
      inner join ESTABELECIMENTO on (NOTAFISCAL.FILIAL = ESTABELECIMENTO.CADASTRO)
      inner join CADASTROPARCEIROS on (NOTAFISCAL.DESTINATARIO = CADASTROPARCEIROS.CADASTRO)
      inner join MODELODOCTO on (MODELODOCTO.ID = NOTAFISCAL.MODELO)      
      inner join NATUREZAOPERACAO on (NATUREZAOPERACAO.ID = NOTAFISCAL.OPERACAO)
      left join NFECTRL on (NFECTRL.IDNOTA = NOTAFISCAL.IDNOTA and
            NFECTRL.FILIAL = NOTAFISCAL.FILIAL)
      left join TIPOCOBRANCA on (TIPOCOBRANCA.TIPOCOBRANCA = NOTAFISCAL.TIPOCOBRANCA)
      left join CONDICAOPAGAMENTO on (CONDICAOPAGAMENTO.ID = NOTAFISCAL.CONDICAOPAGAMENTO)
      left join USUARIO on (NOTAFISCAL.USUARIOEMISSAO = USUARIO.USUARIO)
      left join MUNICIPIO on (MUNICIPIO.UF_SIGLA = CADASTROPARCEIROS.UF and
            upper(MUNICIPIO.MUNICIPIO_NOME) = upper(CADASTROPARCEIROS.CIDADE))
      left join PAISES on (PAISES.CODIGOPAIS = CADASTROPARCEIROS.CODIGOPAIS)
      where NOTAFISCAL.FILIAL = :FILIAL and
            NOTAFISCAL.IDNOTA between :PIDINICIAL and :PIDFINAL
      into IDNOTA, NUMERONOTA, DATAEMISSAO, DATACADASTRO, DESTINATARIO, DEVOLUCAO, RAZAO, NOME, LOGRADOURO,
           NUMERO, COMPLEMENTO, BAIRRO, CIDADE, UF, CEP, NCEP, DOCUMENTO, INSCESTADUAL, INSCMUNICIPAL, EMAIL,
           TELEFONE, TELEFONECOMERCIAL, CELULAR, FAX, PRINCIPALCONTATO, LOGRADOUROENTREGA, NUMEROENTREGA,
           COMPLEMENTOENTREGA, BAIRROENTREGA, CIDADEENTREGA, UFENTREGA, CEPENTREGA, NCEPENTREGA,
           NOMEUSUARIOAPROVACAO, TELEFONEUSUARIOAPROVACAO, FAXUSUARIOAPROVACAO, EMAILUSUARIOAPROVACAO,
           DEPARTAMENTOUSUARIOAPROVACAO, CARGOUSUARIOAPROVACAO, CFOP, NATUREZAOPERACAO, TIPOPAGTO, CONDICAOPAGTO,
           VLRDESCONTO, MSGDESCMERCADORIAS, VLRDESCINDPRODUTO, MSGDESCPRODUTOS, VLRACRESCIMO, MSGACRESCMERCADORIA,
           VLRTOTNOTAEXTENSO, VLRMERCADORIAS, VLRICMS, VLRZONAFRANCA, VLRIPITOTAL, VLRSUBSTRIB, VLRFRETE,
           VLRSEGURO, VLRDESPESAS, VLRSERVICO, VLRTOTANOTA, CODTRANSP, QTDEVOLUME, PESOLIQUIDO, PESOBRUTO,
           ENTRADA_SAIDA, REM_DEST, REM_DEST_DESC, PLACAVEICULO, TOTBASEICMS, VLRBASESUBSTITUTO,
           DATAENTRADASAIDA, INSCRICAOSUBSTITUTO, NUMEROVOLUME, MARCAVOLUME, ESPECIEVOLUME, VLRTOTALSERVICOS,
           ISS, SERIE, CHAVE, ALEATORIO, MODELO, CNPJENTREGA, CCIDADE, CNPJ, CPF, IDESTRANGEIRO,
           DESCONTOTOTAL, UFPLACAVEICULO, CODIGOPAIS, PAIS, AAMM, CDV, TPAMB, FINNFE, VII, TPIMP, PISNOTA,
           COFINSNOTA, BASEPISCOFINSNOTA, MSGDESCRMERCADORIAS, MCODIGO, MDESCRICAO, MCF, MCST, MCFOP, MUN,
           MQTD, MVLRUNI, MVLRTOT, MBASEICMS, MVLRICMS, MVLRIPI, MALIQICMS, MALIQIPI, PNOTAFISCALMAODEOBRA,
           VREMONTADESCRICAO, SIMPLES, ALIQUOTASIMPLES, CRT, TPEMIS, LOCALENTREGANOTA, AMBIENTE, DATAENVIO,
           CANCELAMENTO, APRESENTARTRIBUTOCONSUMIDOR, VTOTTRIBNF, INDFINAL, INDPRES, INDIEDEST, XLOCDESEMB,
           XLOCDESPACHO, UFSAIDAPAIS, NCONTRIBUINTEINTER, VLRFCPUFDEST, VLRICMSUFDEST, VLRICMSUFREMET,
           PICMSINTERPART, VRETPIS, VRETCOFINS, VRETCSLL, VBCIRRF, VIRRF, VBCRETPREV, VRETPREV, NDRAW,
           CHNFEEXP, VTOTTRIBFEDNF, VTOTTRIBESTNF, TIPOCOBRANCA, VFCP, VFCPST, VFCPSTRET, PTIPONOTA,
           INFADFISCO
  do
  begin
    select MSGADICIONAL
    from IMP_NFE_MENSAGEMDADOSADICIONAIS(:FILIAL, :IDNOTA)
    into :MSGADICIONAL;
    if (substring(:CFOP from 1 for 1) = '7') then
      VTOTTRIBFEDNF = 0;
    VTOTTRIBESTNF = 0;

    if (VLRTOTANOTA > 0) then
      PTOTTRIBUTO = cast(VTOTTRIBNF / VLRTOTANOTA * 100 as decimal(12,2));

    if (TPEMIS <> 1) then
    begin
      DHCONT = cast('now' as timestamp);
      XJUST = 'NOTA FISCAL EM CONTING?NCIA';
    end

    select PROTOCOLO
    from NFECTRL
    where FILIAL = :FILIAL and
          IDNOTA = :IDNOTA
    into PROTOCOLO;

    if (substring(cast(CFOP as varchar(4)) from 1 for 1) = '7') then
      EXPORTACAO = 'S';
    else
      EXPORTACAO = 'N';

    if (substring(cast(CFOP as varchar(4)) from 1 for 1) in ('3', '7')) then
      IDDEST = 3;
    if (substring(cast(CFOP as varchar(4)) from 1 for 1) in ('2', '6')) then
      IDDEST = 2;
    if (substring(cast(CFOP as varchar(4)) from 1 for 1) in ('1', '5')) then
      IDDEST = 1;

    if (IDDEST = 2 and
        INDIEDEST = 9 and
        FINNFE = 2) then
      INDFINAL = 1;

    if (VLRZONAFRANCA > 0) then
    begin
      DESCONTOTOTAL = DESCONTOTOTAL + VLRZONAFRANCA;
      MOTDESICMS = '7';
    end

    MENSAGEMAUXILIAR = '';

    if (PEDIDONFE = 'S') then
    begin

      if (PEDIDONFEREGNUM = 'S') then
      begin
        for select distinct IDPEDIDO
            from MERCADORIASNOTA
            where FILIAL = :FILIAL and
                  IDNOTA = :IDNOTA
            into :IDPEDIDO
        do
        begin
          MENSAGEMAUXILIAR = MENSAGEMAUXILIAR || ' ' || coalesce(IDPEDIDO, '');
        end
        if (MENSAGEMAUXILIAR <> '') then
        begin
          MSGADICIONAL = MSGADICIONAL || '
';
          MSGADICIONAL = MSGADICIONAL || 'PEDIDO N? ' || coalesce(MENSAGEMAUXILIAR, '' || ' ');
        end
      end
      else
      begin
        for select distinct PEDIDO.NUMERONOTA
            from MERCADORIASNOTA
            inner join PEDIDO on (PEDIDO.FILIAL = MERCADORIASNOTA.FILIAL and
                  PEDIDO.IDNOTA = MERCADORIASNOTA.IDPEDIDO)
            where MERCADORIASNOTA.FILIAL = :FILIAL and
                  MERCADORIASNOTA.IDNOTA = :IDNOTA
            into :NUMEROPEDIDO
        do
        begin
          MENSAGEMAUXILIAR = MENSAGEMAUXILIAR || ' ' || coalesce(NUMEROPEDIDO, '');
        end
        if (MENSAGEMAUXILIAR <> '') then
        begin
          MENSAGEMAUXILIAR = MENSAGEMAUXILIAR || '
';
          MSGADICIONAL = MSGADICIONAL || ' PEDIDO N? ' || coalesce(MENSAGEMAUXILIAR, '' || ' ');
        end
      end
    end

    MENSAGEMAUXILIAR = '';

    if (PEDIDOCLINFE = 'S') then
    begin
      for select distinct cast(NUMPEDIDOCLIENTE as varchar(15))
          from MERCADORIASNOTA
          inner join PEDIDO on (PEDIDO.FILIAL = MERCADORIASNOTA.FILIAL and
                PEDIDO.IDNOTA = MERCADORIASNOTA.IDPEDIDO)
          where MERCADORIASNOTA.FILIAL = :FILIAL and
                MERCADORIASNOTA.IDNOTA = :IDNOTA
          into :NUMEROPEDIDOCLIENTE
      do
      begin
        MENSAGEMAUXILIAR = MENSAGEMAUXILIAR || ' ' || coalesce(NUMEROPEDIDOCLIENTE, '');
      end
      if (MENSAGEMAUXILIAR <> '') then
        MSGADICIONAL = MSGADICIONAL || ' PEDIDO DO CLIENTE N? ' || coalesce(MENSAGEMAUXILIAR, 0);
    end

    if (:SIMPLES = 'S' and
        DEVOLUCAO = 'N') then
    begin

      if (coalesce(MSGADICIONAL, '') = '') then
        MSGADICIONAL = '';
      else
        MSGADICIONAL = MSGADICIONAL || '
';
      MSGADICIONAL = MSGADICIONAL || '"Documento emitido por ME ou EPP optante pelo simples nacional, conforme LC 123/2006"."N?o gera direito a cr?dito fiscal de IPI".
';


      select sum(
             case
               when (coalesce(MERCADORIASNOTA.VLRICMSRECOLHIDO, 0) = 0 and NOTAFISCAL.TIPONOTA <> '3') or (substring(MERCADORIASNOTA.CFOP from 1 for 1) <> 3 and NOTAFISCAL.TIPONOTA <> '3') then MERCADORIASNOTA.VALORICMS
               else 0
             end),
             sum(
             case
               when (coalesce(MERCADORIASNOTA.VLRICMSRECOLHIDO, 0) > 0) or (substring(MERCADORIASNOTA.CFOP from 1 for 1) = 3) then MERCADORIASNOTA.VALORICMS
               else 0
             end),
             sum(
             case
               when (coalesce(MERCADORIASNOTA.VLRICMSRECOLHIDO, 0) > 0) or (substring(MERCADORIASNOTA.CFOP from 1 for 1) = 3) then MERCADORIASNOTA.ICMSBASE
               else 0
             end)
      from MERCADORIASNOTA
      inner join NOTAFISCAL on (NOTAFISCAL.FILIAL = MERCADORIASNOTA.FILIAL and
            NOTAFISCAL.IDNOTA = MERCADORIASNOTA.IDNOTA)
      where MERCADORIASNOTA.FILIAL = :FILIAL and
            MERCADORIASNOTA.IDNOTA = :IDNOTA
      into :VLRICMSSIMPLES, :VLRICMS, :TOTBASEICMS;

      if (VLRICMSSIMPLES > 0 and
          (substring(CFOP from 1 for 1) <> 3)) then
      begin
        MSGADICIONAL = MSGADICIONAL || '"Permite o aproveitamento do cr?dito de ICMS no valor de R$ ' || cast(VLRICMSSIMPLES as decimal(8,2)) || ', correspondente ? al?quota de ' || cast(ALIQUOTASIMPLES as decimal(3,2)) || ' %, nos termos do art. 23 da LC 123/2006".
';
      end
    end

   if (:VLRZONAFRANCA > 0 ) then
      MSGADICIONAL=coalesce (MSGADICIONAL,'')||'Desconto concedido por zona franca no valor de: R$'|| cast (vlrzonafranca AS numeric (9,2));

    if (PNOTAFISCALMAODEOBRA = 'S') then
    begin
      select sum(coalesce(ICMSBASE, 0)), sum((coalesce(VLRTOTALMERCAD, 0))) - (sum(coalesce(ICMSBASE, 0)))
      from MERCADORIASNOTA
      where FILIAL = :FILIAL and
            IDNOTA = :IDNOTA and
            CFOP not in ('5902', '5925', '5903', '6902', '6925', '6903')
      into :VVALORMERCAPLICADA, :VVALORMAOOBRA;

      if (VVALORMAOOBRA > 0) then
      begin
        if (MSGADICIONAL is null) then
          MSGADICIONAL = '';
        else
          MSGADICIONAL = MSGADICIONAL || '
';
        MSGADICIONAL = MSGADICIONAL || '1) MATERIAL APLICADO R$ ' || cast(VVALORMERCAPLICADA as decimal(8,2)) || '
';
        MSGADICIONAL = MSGADICIONAL || '2) MAO DE OBRA R$ ' || cast(VVALORMAOOBRA as decimal(8,2));
      end
    end

    CHAVEXML = 'NFe' || CHAVE;
    CHAVEFORMATADA = substring(CHAVE from 1 for 2) || '.' || substring(CHAVE from 3 for 4) || '.' || substring(CHAVE from 7 for 2) || '.' || substring(CHAVE from 9 for 3) || '.' || substring(CHAVE from 12 for 3) || '/' || substring(CHAVE from 15 for 4) || '-' || substring(CHAVE from 19 for 2) || '-' || substring(CHAVE from 21 for 2) || '-' || substring(CHAVE from 23 for 3) || '-' || substring(CHAVE from 26 for 3) || '.' || substring(CHAVE from 29 for 3) || '.' || substring(CHAVE from 32 for 3) || '-' || substring(CHAVE from 35 for 3) || '.' || substring(CHAVE from 38 for 3) || '.' || substring(CHAVE from 41 for 3) || '-' || substring(CHAVE from 44 for 1);

    INDICADORPAGAMENTO = 2;
    VSEQFATURA = 1;
    IDFATURA1 = null; VENCIMENTO1 = null; VALORFATURA1 = null;
    IDFATURA2 = null; VENCIMENTO2 = null; VALORFATURA2 = null;
    IDFATURA3 = null; VENCIMENTO3 = null; VALORFATURA3 = null;
    IDFATURA4 = null; VENCIMENTO4 = null; VALORFATURA4 = null;
    IDFATURA5 = null; VENCIMENTO5 = null; VALORFATURA5 = null;
    IDFATURA6 = null; VENCIMENTO6 = null; VALORFATURA6 = null;
    IDFATURA7 = null; VENCIMENTO7 = null; VALORFATURA7 = null;
    IDFATURA8 = null; VENCIMENTO8 = null; VALORFATURA8 = null;
    DESCRICAODESDOBRAMENTO = null;

    select count(IDFATURA)
    from FATURAS
    where FILIAL = :FILIAL and
          IDNOTA = :IDNOTA
    into :VIDFATURA;
    if (VIDFATURA = 1) then
    begin
      select DATAVENCIMENTO, VALORFATURA
      from FATURAS
      where FILIAL = :FILIAL and
            IDNOTA = :IDNOTA
      into :VDATAVENCIMENTO, :VVALORFATURA1;
      if (VDATAVENCIMENTO <= :DATAEMISSAO) then
      begin
        INDICADORPAGAMENTO = 0;
        DESCRICAODESDOBRAMENTO = :CONDICAOPAGTO;
      end
      else
      begin
        INDICADORPAGAMENTO = 1;
        IDFATURA1 = VSEQFATURA;
        VENCIMENTO1 = VDATAVENCIMENTO;
        VALORFATURA1 = VVALORFATURA1;
      end
    end
    else
    begin
      if (VIDFATURA > 1) then begin
        INDICADORPAGAMENTO = 1;
        for select IDFATURA, DATAVENCIMENTO, VALORFATURA
            from FATURAS
            where FILIAL = :FILIAL and
                  IDNOTA = :IDNOTA
            order by DATAVENCIMENTO
            into :VIDFATURA, :VDATAVENCIMENTO, :VVALORFATURA
        do begin
          if (VSEQFATURA = 1) then
          begin
            IDFATURA1 = VSEQFATURA; VENCIMENTO1 = VDATAVENCIMENTO;VALORFATURA1 = VVALORFATURA;
          end
          if (VSEQFATURA = 2) then
          begin
            IDFATURA2 = VSEQFATURA;VENCIMENTO2 = VDATAVENCIMENTO;VALORFATURA2 = VVALORFATURA;
          end
          if (VSEQFATURA = 3) then
          begin
            IDFATURA3 = VSEQFATURA;VENCIMENTO3 = VDATAVENCIMENTO;VALORFATURA3 = VVALORFATURA;
          end
          if (VSEQFATURA = 4) then
          begin
            IDFATURA4 = VSEQFATURA;VENCIMENTO4 = VDATAVENCIMENTO;VALORFATURA4 = VVALORFATURA;
          end
          if (VSEQFATURA = 5) then
          begin
            IDFATURA5 = VSEQFATURA;VENCIMENTO5 = VDATAVENCIMENTO;VALORFATURA5 = VVALORFATURA;
          end
          if (VSEQFATURA = 6) then
          begin
            IDFATURA6 = VSEQFATURA;VENCIMENTO6 = VDATAVENCIMENTO;VALORFATURA6 = VVALORFATURA;
          end
          if (VSEQFATURA = 7) then
          begin
            IDFATURA7 = VSEQFATURA;VENCIMENTO7 = VDATAVENCIMENTO;VALORFATURA7 = VVALORFATURA;
          end
          if (VSEQFATURA = 8) then
          begin
            IDFATURA8 = VSEQFATURA;VENCIMENTO8 = VDATAVENCIMENTO;VALORFATURA8 = VVALORFATURA;
          end
          VSEQFATURA = VSEQFATURA + 1;
        end
      end
    end

    numerofatura = 0;
    VLRTOTALFATURA = 0;
    VLRLIQFATURA = 0;

    if (INDICADORPAGAMENTO <> 2) then
    begin
      NUMEROFATURA = NUMERONOTA;

      --VLRTOTALFATURA = VLRTOTANOTA;
      --VLRLIQFATURA = VLRTOTANOTA;

      select SUM (VALORFATURA)
      from FATURAS
      where FILIAL = :FILIAL and
            IDNOTA = :IDNOTA
      INTO :VLRTOTALFATURA;

      select SUM (VALORFATURA)
      from FATURAS
      where FILIAL = :FILIAL and
            IDNOTA = :IDNOTA
      INTO :VLRLIQFATURA;
    end
    if (coalesce(:LOGRADOUROENTREGA, '') <> '') then
    begin
      LOCALENTREGA = upper('LOCAL DE ENTREGA: ' || coalesce(LOGRADOUROENTREGA, '') || ', ' || coalesce(NUMEROENTREGA, '') || ' ' || coalesce(COMPLEMENTOENTREGA, '') || ' ' || coalesce(BAIRROENTREGA, '') || ' ' || coalesce(CIDADEENTREGA, '') || ' ' || coalesce(UFENTREGA, '') || ' ' || coalesce(CEPENTREGA, ''));

      if (LOCALENTREGANOTA = 'N') then
      begin
        MSGADICIONAL = MSGADICIONAL || '
';
        MSGADICIONAL = MSGADICIONAL || LOCALENTREGA;
        LOCALENTREGA = null;
      end
    end
    select LOGRADOUROCOBRANCA,
           case coalesce(NUMEROCOBRANCA, 0)
             when 0 then 'SN'
             else NUMEROCOBRANCA
           end,
           COMPLEMENTOCOBRANCA,
           BAIRROCOBRANCA,
           CIDADECOBRANCA,
           UFCOBRANCA,
           substring(CEPCOBRANCA from 1 for 5) || '-' || substring(CEPCOBRANCA from 6 for 3),
           CEPCOBRANCA, INSCSUFRAMA
    from CLIENTES
    where CADASTRO = :DESTINATARIO
    into :LOGRADOUROCOBRANCA, :NUMEROCOBRANCA, :COMPLEMENTOCOBRANCA, :BAIRROCOBRANCA, :CIDADECOBRANCA, :UFCOBRANCA,
         :CEPCOBRANCA, :NCEPCOBRANCA, :INSCSUFRAMA;
    if (coalesce(:LOGRADOUROCOBRANCA, '') = '') then
    begin
      LOCALCOBRANCA = 'O MESMO';
      LOGRADOUROCOBRANCA = LOGRADOURO;
      NUMEROCOBRANCA = NUMERO;
      COMPLEMENTOCOBRANCA = COMPLEMENTO;
      BAIRROCOBRANCA = BAIRRO;
      CIDADECOBRANCA = CIDADE;
      UFCOBRANCA = UF;
      CEPCOBRANCA = CEP;
    end
    else
      LOCALCOBRANCA = LOGRADOUROCOBRANCA || ', ' || NUMEROCOBRANCA || ' ' || coalesce(COMPLEMENTOCOBRANCA, '') || ' ' || BAIRROCOBRANCA || ' ' || CIDADECOBRANCA || ' ' || UFCOBRANCA || ' ' || CEPCOBRANCA;

    select first 1 VENDEDORESPED.VENDEDOR, CADASTROPARCEIROS.RAZAOSOCIAL, CADASTROPARCEIROS.NOME,
                   CADASTROPARCEIROS.TELEFONE, CADASTROPARCEIROS.CELULAR, CADASTROPARCEIROS.TELEFONECOMERCIAL,
                   CADASTROPARCEIROS.FAX, CADASTROPARCEIROS.EMAIL
    from VENDEDORESNOTA VENDEDORESPED
    inner join CADASTROPARCEIROS on (CADASTROPARCEIROS.CADASTRO = VENDEDORESPED.VENDEDOR)
    where VENDEDORESPED.FILIAL = :FILIAL and VENDEDORESPED.IDNOTA = :IDNOTA
    into :VENDEDOR, :RAZAOVENDEDOR, :NOMEVENDEDOR, :TELEFONEVENDEDOR, :CELULARVENDEDOR, :TELEFONECOMERCIALVENDEDOR,
         :FAXVENDEDOR, :EMAILVENDEDOR;

    if (VENDEDORDANFE = 'S') then
      if (coalesce(VENDEDOR, '') <> '') then
        if (coalesce(NOMEVENDEDOR, '') <> '') then
          MSGADICIONAL = 'Vendedor : (' || VENDEDOR || ') ' || NOMEVENDEDOR || '
' || MSGADICIONAL;

    select USUARIO.NOMECOMPLETO, USUARIO.TELEFONE, USUARIO.FAX, USUARIO.EMAIL, USUARIO.DEPARTAMENTO, USUARIO.CARGO
    from VENDEDOR
    inner join USUARIO on (VENDEDOR.USUARIORELACIONADO = USUARIO.ID)
    where VENDEDOR.CADASTRO = :VENDEDOR
    into :NOMEUSUARIOAPROVACAO, :TELEFONEUSUARIOAPROVACAO, :FAXUSUARIOAPROVACAO, :EMAILUSUARIOAPROVACAO,
         :DEPARTAMENTOUSUARIOAPROVACAO, :CARGOUSUARIOAPROVACAO;

    select CADASTROPARCEIROS.NOME, CADASTROPARCEIROS.RAZAOSOCIAL, CADASTROPARCEIROS.TELEFONE,
           CADASTROPARCEIROS.TELEFONECOMERCIAL, CADASTROPARCEIROS.CELULAR, CADASTROPARCEIROS.EMAIL,
           CADASTROPARCEIROS.PRINCIPALCONTATO, CADASTROPARCEIROS.LOGRADOURO,
           case coalesce(CADASTROPARCEIROS.NUMERO, 0)
             when 0 then 'SN'
             else CADASTROPARCEIROS.NUMERO
           end,
           CADASTROPARCEIROS.COMPLEMENTO, CADASTROPARCEIROS.BAIRRO, CADASTROPARCEIROS.CIDADE, CADASTROPARCEIROS.UF,
           case
             when (CADASTROPARCEIROS.DOCUMENTO <> '') and (not CADASTROPARCEIROS.DOCUMENTO is null) then case TIPOPESSOA
                                                                                                           when 'F' then cast(substring(DOCUMENTO from 1 for 3) || '.' || substring(DOCUMENTO from 4 for 3) || '.' || substring(DOCUMENTO from 7 for 3) || '-' || substring(DOCUMENTO from 10 for 2) as varchar(18))
                                                                                                           when 'J' then cast(substring(DOCUMENTO from 1 for 2) || '.' || substring(DOCUMENTO from 3 for 3) || '.' || substring(DOCUMENTO from 6 for 3) || '/' || substring(DOCUMENTO from 9 for 4) || '-' || substring(DOCUMENTO from 13 for 2) as varchar(18))
                                                                                                           else null
                                                                                                         end
             else null
           end as DOCUMENTO,
           INSCESTADUAL,
           case TIPOPESSOA
             when 'J' then DOCUMENTO
             else ''
           end,
           case TIPOPESSOA
             when 'F' then DOCUMENTO
             else ''
           end
    from CADASTROPARCEIROS
    where CADASTRO = :CODTRANSP
    into NOMETRANSP, RAZAOTRANSP, FONETRANSP, COMERCIALTRANSP, CELULARTRANSP, EMAILTRANSP, NOMECONTATOTRANSP,
         LOGRADOUROTRANSP, NUMEROTRANSP, COMPLEMENTOTRANSP, BAIRROTRANSP, CIDADETRANSP, UFTRANSP, DOCUMENTOTRANSP,
         INSCESTADUALTRANSP, CNPJTRANSP, CPFTRANSP;

    DETALHECF = '';
    for select distinct
    CLASSIFICACAOFISCAL.CFISCAL,
    CLASSIFICACAOFISCAL.DESCRICAO,
    cast(CLASSIFICACAOFISCAL.ALIQUOTA as decimal(2,2))

        from MERCADORIASPED MERCADORIASNOTA
        inner join CLASSIFICACAOFISCAL on (MERCADORIASNOTA.CLASSIFISCAL = CLASSIFICACAOFISCAL.CFISCAL)
        where MERCADORIASNOTA.FILIAL = :FILIAL and
              MERCADORIASNOTA.IDNOTA = :IDNOTA
        into :PCODCF, :PCF, :PPIPI
    do
    begin
      if (DETALHECF <> '') then
        DETALHECF = substring(DETALHECF || '
' from 1 for 400);
      DETALHECF = substring(DETALHECF || PCODCF || ' - ' || PCF from 1 for 400);
      if (PPIPI > 0) then
        DETALHECF = substring(DETALHECF || ' IPI ' || PPIPI || '%' from 1 for 400);
    end
    ORDEM=0;PVLRTOTAL=0;PQTDITEM=0;NADICAOANTES=0;INDTOT=1;
    for select
        IDITEM/*,        
        CODIGO,
        DESCRICAO,
        DESCRICAOREDUZIDA,
        QUANTIDADE,
        UNIDADE,
        PRUNITARIO,
        PRLISTA,
        PIPIMERC,
        VLRIPIMERC,
        VLRTOTITEM,
        PICMS,
        PCREDSN,
        VCREDICMSSN,
        CODCF,
        ICMSBASE,
        SITUACAOTRIBUT,
        VALORICMS_PROD,
        CFOP_PROD,
        EAN,
        NFCI,
        EANTRIBUTAVEL,
        UNIDADETRIBUTAVEL,
        QUANTIDADETRIBUTAVEL,
        VALORUNITARIOTRIBUTAVEL,
        FRETEPRODUTO,
        SEGUROPRODUTO,
        VOUTRO,
        DESCONTOPRODUTO,
        ORIGEM,
        CTICMS,
        MODBC,
        PREDBC,
        MODBCST,
        PMVAST,
        PREDBCST,
        VBCST,
        PICMSST,
        VICMSST,
        IPIBASE_PROD,
        PISALIQUOTA,
        IPICST,
        PISCST,
        PISBASE,
        PISVALOR,
        COFINSALIQUOTA,
        COFINSCST,
        COFINSBASECALCULO,
        COFINSVALOR,
        NDI,
        DDI,
        XLOCDESEMB,
        UFDI,
        DDESEMB,
        CEXPORTADOR,
        NADICAO,
        NSEQADIC,
        CFABRICANTE,
        VDESCDI,
        VBASEIMPORTAMERC,
        VDESPADUMERC,
        VIMPORTOIMPORTACAOMERC,
        VIOFMERC,
        PREDIPI,
        IDMERCADORIAPEDIDO,
        IDPEDIDO,
        INFADPROD,
        VTOTTRIB,
        VBCUFDEST,
        PFCUFDEST,
        PICMSUFDEST,
        PICMSINTER,
        VFCPUFDEST,
        VICMSUFDEST,
        VICMSUFREMET,
        VTOTTRIBFED,
        VTOTTRIBEST,
        CENQ,
        INDESCALA,
        ORIGEMPRODUTO,
        CNPJFAB,
        ICMSORIGEMFCP,
        ICMSORIGEMFCPVALOR,
        ICMSSTFCP,
        ICMSSTFCPVALOR,
        ICMSALIQUOTACF,
        ICMSALIQUOTASIMPLES,
        ICMSVALORSIMPLES,
        PRLISTA,
        VBCUFDEST,
        CODCF,
        VTOTTRIBFED,
        VIPIDEVOLITEM,
        VIPIDEVOLtot,
        PDEVOL,
        CBENEf,
        P_VALORRETIDO,
        CTICMSSIMPLES,
        NRE ,
        NSEQADIC,
        PICMSINTERESTADUAL,
        ORDEM,
        xPED ,
        CEST,
        CF,
        NVE,
        DETALHEITENS,
        NITEMPED,
        VICMSDESONERADO,
        ICMSPART,
        pst ,
        vBCFCPST,
        pFCPST,
        VBCSTRET,
        VICMSSUBSTITUTO,
        VICMSSTRET,
        cProdANP, descANP, pGLP, pGNn, pGNi, vPart

*/
    from IMP_NFE_MERCADORIAS (:FILIAL, :IDNOTA, :INDFINAL, :ITEMCODREFNFE, :NCONTRIBUINTEINTER,
              :SIMPLES, :DEVOLUCAO, :IDDEST,
              :pTIPONOTA, :uf, :VRETPIS, :VRETCOFINS,
              :VRETcsll, :CFOP, :VEANNFE, :VBCIRRF, :VBCRETPREV, :VIRRF, :VLRZONAFRANCA,
              :VREMONTADESCRICAO, :VRETPREV )
        order by IMP_NFE_MERCADORIAS.IDITEM
        into IDITEM/*, CODIGO, DESCRICAO, DESCRICAOREDUZIDA, QUANTIDADE, UNIDADE, PRUNITARIO, PRLISTA, PIPIMERC,
             VLRIPIMERC, VLRTOTITEM, PICMS, PCREDSN, VCREDICMSSN, CODCF, ICMSBASE, SITUACAOTRIBUT,
             VALORICMS_PROD, CFOP_PROD, EAN, NFCI, EANTRIBUTAVEL, UNIDADETRIBUTAVEL, QUANTIDADETRIBUTAVEL,
             VALORUNITARIOTRIBUTAVEL, FRETEPRODUTO, SEGUROPRODUTO, VOUTRO, DESCONTOPRODUTO, ORIGEM, CTICMS,
             MODBC, PREDBC, MODBCST, PMVAST, PREDBCST, VBCST, PICMSST,
              VICMSST,
             IPIBASE_PROD, PISALIQUOTA,
             IPICST, PISCST, PISBASE, PISVALOR, COFINSALIQUOTA, COFINSCST, COFINSBASECALCULO, COFINSVALOR, NDI,
             DDI, XLOCDESEMB, UFDI, DDESEMB, CEXPORTADOR, NADICAO, NSEQADIC, CFABRICANTE, VDESCDI,
             VBASEIMPORTAMERC, VDESPADUMERC, VIMPORTOIMPORTACAOMERC, VIOFMERC, PREDIPI, IDMERCADORIAPEDIDO,
             IDPEDIDO, INFADPROD, VTOTTRIB, VBCUFDEST, PFCUFDEST, PICMSUFDEST, PICMSINTER, VFCPUFDEST,
             VICMSUFDEST, VICMSUFREMET, VTOTTRIBFED, VTOTTRIBEST, CENQ, INDESCALA, ORIGEMPRODUTO, CNPJFAB,
             ICMSORIGEMFCP, ICMSORIGEMFCPVALOR, ICMSSTFCP, ICMSSTFCPVALOR, ICMSALIQUOTACF, ICMSALIQUOTASIMPLES,
             ICMSVALORSIMPLES, PRLISTA, VBCUFDEST, CODCF, VTOTTRIBFED, VIPIDEVOLITEM, VIPIDEVOLtot,
             PDEVOL , CBENEf, P_VALORRETIDO, CTICMSSIMPLES, NRE , NSEQADIC, PICMSINTERESTADUAL,
             ORDEM , xPED , CEST, CF, NVE , DETALHEITENS , NITEMPED , VICMSDESONERADO, ICMSPART,
             :pst, vBCFCPST, pFCPST, VBCSTRET, VICMSSUBSTITUTO, VICMSSTRET,
             :cProdANP, :descANP, :pGLP, :pGNn, :pGNi, :vPart
*/
    do
    begin

      --vFCPSTRet=coalesce (vFCPSTRet,0)+coalesce (ICMSSTFCPVALOR,0);
      vFCPSTRet=0;
      vBCFCPSTRet=coalesce (vBCFCPSTRet,0)+coalesce (vBCFCPST,0);
      vICMSSTtot= coalesce (VICMSSTtot,0)+   coalesce ( vICMSST,0);

      if (TIPOCALCULOIPI='N' AND DEVOLUCAO='S') then
      begin

           if (coalesce (IPIBASE_PROD,0)=0) then
              if (coalesce (ICMSBASE,0)=0) then PDEVOL=0;
              ELSE 
                PDEVOL=VIPIDEVOLITEM/ICMSBASE *100;
           else
              PDEVOL=VIPIDEVOLITEM/IPIBASE_PROD *100;
      end

      suspend;
    end

    IDITEM = null;
    CODIGO = null;
    DESCRICAO = null;
    DESCRICAOREDUZIDA = null;
    QUANTIDADE = null;
    UNIDADE = null;
    PRUNITARIO = null;
    PRLISTA = null;
    PIPIMERC = null;
    VLRIPIMERC = null;
    VLRTOTITEM = null;
    PICMS = null;
    CODCF = null;
    ICMSBASE = null;
    SITUACAOTRIBUT = null;
    CF = null;
    ORDEM = ORDEM + 1;
    CFOP = null;
    CFOP_PROD = null;
    VALORICMS_PROD = null;
    DETALHEITENS = 'N';
    REFERENCIADESCRICAO = null;
    INFADPROD=null;

    if (coalesce(:VLRDESCINDPRODUTO, 0) + coalesce(:VLRDESCONTO, 0) + coalesce(:VLRZONAFRANCA, 0) + coalesce(VLRACRESCIMO, 0) > 0) then
    begin

      DESCRICAOTOTAL = '';
      ORDEM = 101;
      if (VLRDESCINDPRODUTO > 0) then  begin
        DESCRICAODETALHE = MSGDESCPRODUTOS;
        VLRTOTITEM = VLRDESCINDPRODUTO * (-1);
       end
      if (VLRDESCONTO > 0) then
      begin
        DESCRICAODETALHE = MSGDESCMERCADORIAS;
        VLRTOTITEM = VLRDESCONTO * (-1);
      end
      if (VLRZONAFRANCA > 0) then
      begin
        DESCRICAODETALHE = 'Abatimento do ICMS';
        VLRTOTITEM = VLRZONAFRANCA * (-1);
      end
      if (VLRACRESCIMO > 0) then
      begin
        DESCRICAODETALHE = MSGACRESCMERCADORIA;
        VLRTOTITEM = VLRACRESCIMO;
      end
      DESCRICAODETALHE = null;
    end
    DESCRICAODETALHE = null; VLRTOTITEM = null;
    if (MSGDESCRMERCADORIAS is not null) then
    begin
      MSGCORPONOTA = MSGDESCRMERCADORIAS;
      suspend;
    end
    MSGCORPONOTA = null;
  end
end
