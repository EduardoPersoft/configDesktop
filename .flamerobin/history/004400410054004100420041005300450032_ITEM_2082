insert into ITEMESTOQUECODIGOS(codigo,codigoalternativo)
select
  i1.codigo,i1.codigo
from
    ITEMESTOQUE i1
UNION
select
   i1.codigo,I1.itembase
from
    ITEMESTOQUE i1
WHERE
    COALESCE(I1.ITEMBASE, '') <> ''
UNION
select
    i1.codigo, referencia
from
    ITEMESTOQUE i1
WHERE
    COALESCE(REFERENCIA, '') <> ''
UNION
select
    i1.itembase,i1.codigo
from
    itemestoque i1
WHERE
    COALESCE(I1.ITEMBASE, '')<> ''
union
select
    i1.codigo,i1.CODIGOALTERNATIVO
from
    ITEMESTOQUEoutroscodigos i1
UNION
SELECT
    i1.codigo,FORNECEDORESITEM.CODIGOFORNEC
FROM
    itemestoque i1
inner join 
    fornecedoresitem on
        fornecedoresitem.IDITEM=i1.codigo
WHERE
    COALESCE(FORNECEDORESITEM.CODIGOFORNEC, '')<>''

