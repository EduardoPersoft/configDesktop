SET TERM ^ ;
CREATE PROCEDURE GETMODELO (
    FILIAL integer,
    ID smallint,
    SALTO smallint )
RETURNS (
    NUMERO integer,
    CODMODELOFISCAL smallint,
    FORMAEMISSAONFE char(1),
    SERIE char(3),
    SEQUENCIA integer,
    CODIGOIBGE char(2),
    DATAHORA timestamp,
    "DATA" date,
    ambiente smallint,
    urlNfceConsulta varchar(100),
    urlNfceQrCode varchar(100
     )

AS
BEGIN
  /* write your code here */ 
  update
    MODELODOCTO
  set 
    ultimanota = ultimanota + :salto
  where 
    modelodocto.id=:id;
    
  select 
    MODELODOCTO.ULTIMANOTA,
    MODELODOCTO.CODMODELOFISCAL,
    MODELODOCTO.FORMAEMISSAONFE,
    MODELODOCTO.SERIE,
    MODELODOCTO.SEQUENCIA,
    modelodocto.AMBIENTE,
    cast('now' as timestamp),
    cast('now' as date)
  from
    MODELODOCTO
  where
    modelodocto.id = :id
  into
    :numero,
    codmodelofiscal,
    formaemissaonfe,
    serie,
    SEQUENCIA,
    :ambiente,
    :datahora,    
    :data;
    
  select
    estado.CODIGOIBGE,  from
    case :ambiente when 2 then estado.NFCEURLCONSULTAHOM else estado.NFCEURLCONSULTA end,
    case :ambiente when 2 then estado.NFCEURLQRCODEHOM else estado.NFCEURLQRCODE end
  inner join
    estado on
        estado.ESTADO=CADASTROPARCEIROS.UF
  where
    CADASTROPARCEIROS.cadastro=:filial
  into :codigoibge, nfceUrlConsulta, nfceUrlQRCODE;  
    
  suspend;  

END
^
SET TERM ; ^

GRANT EXECUTE
 ON PROCEDURE GETMODELO TO  SYSDBA WITH GRANT OPTION;

