INSERT INTO materialmovimentoestoque(
    FILIAL,
    idmovimento,
    idmovimentomaterial,
    iditem,
    quantidade,
    valor,
    sinal,
    recalculo,
    localarmazenamento,
    lote,
    concluido)   
SELECT 
    MATERIALMOVIMENTOESTOQUE.FILIAL,
    105697,
    row_number() over(),
    MATERIALMOVIMENTOESTOQUE.IDITEM,
    SUM(MATERIALMOVIMENTOESTOQUE.QUANTIDADE*
        MATERIALMOVIMENTOESTOQUE.SINAL)*(-1),
    coalesce(SUM(MATERIALMOVIMENTOESTOQUE.QUANTIDADE*
        MATERIALMOVIMENTOESTOQUE.SINAL)*ITEMCUSTODATA.CUSTOUNITARIO,ITEMCUSTODATA.CUSTOTOTAL)*(-1),
    1,
    'N',
    MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO,
    MATERIALMOVIMENTOESTOQUE.lote,
    'N'
from
    MATERIALMOVIMENTOESTOQUE
INNER join
    MOVIMENTOESTOQUE ON
        MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL and
        MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
LEFT join  
    ITEMCUSTODATA ON
        itemcustodata.filial=MATERIALMOVIMENTOESTOQUE.filial and
        itemcustodata.DATAINVENTARIO='31.12.2023' and
        itemcustodata.CODIGO=MATERIALMOVIMENTOESTOQUE.IDITEM 
where
    MOVIMENTOESTOQUE.FILIAL=1 and
    MOVIMENTOESTOQUE.EMISSAO<='31.12.2023' 
GROUP BY    
    MATERIALMOVIMENTOESTOQUE.FILIAL,
    MATERIALMOVIMENTOESTOQUE.IDITEM,
    itemcustodata.CUSTOUNITARIO,
    itemcustodata.CUSTOtotal,    
    MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO,
    MATERIALMOVIMENTOESTOQUE.lote
having 
    SUM(MATERIALMOVIMENTOESTOQUE.QUANTIDADE*
        MATERIALMOVIMENTOESTOQUE.SINAL)<>0    

        