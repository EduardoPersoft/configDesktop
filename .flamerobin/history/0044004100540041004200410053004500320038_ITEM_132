SELECT 
    TICKET.ID,
    TICKET.UUID,
    TICKET.DATAHORA,
    TICKET.MENSAGEM,
    TICKET.PARCEIRO,
    TICKET.DATAHORAALTERACAO,
    TICKET.USUARIOALTERACAO,
    USUARIOALTERACAO.USUARIO
    CADASTROPARCEIROS.NOME,
    TICKET.USUARIO,
    USUARIOTICKET.USUARIO
FROM 
    TICKET
INNER JOIN 
    USUARIO USUARIOTICKET ON 
    TICKET.USUARIO = USUARIOTICKET.ID
LEFT JOIN 
    CADASTROPARCEIROS ON 
    TICKET.PARCEIRO = CADASTROPARCEIROS.CADASTRO
LEFT JOIN 
    USUARIO USUARIOALTERACAO ON 
    CADASTROPARCEIROS.NOME = USUARIOALTERACAO.NOMECOMPLETO;

