select * from MERCADORIASPEDCOMPRA 
where  
mercadoriaspedcompra.filial=1
and mercadoriaspedcompra.baixa = 'N'
and not exists 
(select * from prazomercpedcompra
where prazomercpedcompra.filial=mercadoriaspedcompra.filial 
and prazomercpedcompra.IDNOTA=mercadoriaspedcompra.idmercadoria 
and prazomercpedcompra.IDITEM =mercadoriaspedcompra.IDMERCADORIA)