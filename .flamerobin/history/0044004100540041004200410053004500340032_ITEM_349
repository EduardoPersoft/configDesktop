select 
    contascontabeis.CONTACONTABIL,
    contascontabeis.DESCRICAO,
    cadastroparceiros.RAZAOSOCIAL,
    sum((LANTOCONTPAG.VALOR / TITULOPAG.VALORTITULO * TITULOSANEXADOS.VALOR)*
    case movbancarios.tipomovimento when 'D' then (-1) else 1 end),
        cast(MOVBANCARIOS.MOVIMENTACAO as date) as movimentacao,
    TITULOPAG.IDTITULO,
    titulopag.titulo,
    titulopag.FATURA,
    cast ('Pagar' as varchar(10))
    
    
from
    movbancarios
inner join
    titulosanexados on 
    MOVBANCARIOS.FILIAL=TITULOSANEXADOS.FILIAL and
    MOVBANCARIOS.IDCONTACORRENTE=TITULOSANEXADOS.IDCONTACORRENTE and
    MOVBANCARIOS.IDMOVTOBANCARIO=TITULOSANEXADOS.idmovtobanc

inner join
    TITULOPAG on 
    TITULOSANEXADOS.FILIAL=TITULOPAG.FILIAL and
    TITULOSANEXADOS.IDTITULO=TITULOPAG.IDTITULO
inner join 
    lantocontpag on 
    TITULOSANEXADOS.FILIAL=LANTOCONTPAG.FILIAL and
    TITULOSANEXADOS.IDTITULO= LANTOCONTPAG.idmovtobanc
inner join 
    ESTABELECIMENTO on 
    MOVBANCARIOS.FILIAL=ESTABELECIMENTO.CADASTRO 
inner join 
    CONTASCONTABEIS on
    ESTABELECIMENTO.PLANOCONTAS=CONTASCONTABEIS.IDPLANO and 
    LANTOCONTPAG.contacontabil =contascontabeis.CONTACONTABIL
inner join 
    CADASTROPARCEIROS on 
    TITULOPAG.PARCEIRO= CADASTROPARCEIROS.CADASTRO
--inner join
--    RCONTACORRENTE on 
--    rcontacorrente.relatorio='FLUXOCAIXA' and
--    rcontacorrente.contacorrente=titulopag.contacorrente
where
    MOVBANCARIOS.filial= 3941 and 
    MOVBANCARIOS.MOVIMENTACAO between '2023-09-01'  and '2023-09-30' and
    TITULOSANEXADOS.TIPOTITULO='P'
Group by 
    contascontabeis.CONTACONTABIL,
    contascontabeis.DESCRICAO,
    cadastroparceiros.RAZAOSOCIAL,
    MOVBANCARIOS.MOVIMENTACAO,
    TITULOPAG.IDTITULO,
    titulopag.titulo,
    titulopag.FATURA
order by 

    contascontabeis.CONTACONTABIL,
    contascontabeis.DESCRICAO,
    cadastroparceiros.RAZAOSOCIAL,
    MOVBANCARIOS.MOVIMENTACAO,
    TITULOPAG.IDTITULO,
    titulopag.titulo,
    titulopag.FATURA