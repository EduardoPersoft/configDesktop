select 
    m1.filial,
    m1.idlocal,
    m1.iditem,
    cast(m1.saldototal*(-1) as integer) as quantidade,
    m2.idlocal local2,
    m2.saldototal as saldo2
from 
    MATERIALLOCAL m1
inner JOIN
    materiallocal m2 on
        m1.filial=m2.filial AND
        m1.iditem=m2.iditem AND
        m1.idlocal<>m2.idlocal and
        m2.saldototal > 0
    
WHERE
    m1.filial=1
    --and m1.idlocal=1
    and m1.saldototal<0
    --and m2.idlocal=1793

order by
    m1.idlocal
    
    
