SELECT DISTINCT
    r.CODIGONOVO, 
    select  FIRST 1
        ITEMCUSTODATA.CUSTOUNITARIO
     from
        ITEMCUSTODATA
     where
        ITEMCUSTODATA.CODIGO=r.CODIGOBASE and
        COALESCE(ITEMCUSTODATA.CUSTOUNITARIO,0)>0
     order by
        ITEMCUSTODATA.DATAINVENTARIO DESC)
        
FROM 
    C_CONVERSAOMP r