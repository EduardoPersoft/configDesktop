select 
    registroContato.registro,
    registroContato.processamento,
    registroContato.abertura,
    registroContato.tipoOcorrencia tipoOcorrenciaId,
    TIPOOCORRENCIA.DESCRICAO tipoOcorrenciaDescricao,    
    registroContato.atendente atendenteId,
    atendente.USUARIO atendenteUsuario,
   
    registroContato.PARCEIRO,
    cadParceiro.nome,
    cadParceiro.telefone,
    registroContato.contato,
    
    registroContato.assunto,
    registroContato.descricao,
    
    registroContato.responsavel responsavelId,
    responsavel.usuario responsavelNome,   
    registroContato.previsaoResposta,
    registroContato.fechamento,
    
    registroContato.usuario,
    registroContato.dataAlteracao,
    
    case when REGISTROCONTATO.FECHAMENTO is not null then 'black'
    when registroContato.PREVISAORESPOSTA < cast('now' as date) then 'red' 
    else 'blue' end as p_cor
    
from 
    registroContato
inner join
    cadastroParceiros cadParceiro on
        cadParceiro.cadastro=registroContato.parceiro
inner join
    TIPOOCORRENCIA on
        tipoOcorrencia.id=registroContato.TIPOOCORRENCIA
inner join
    usuario atendente on
        atendente.id=registroContato.ATENDENTE
inner join
    usuario responsavel on
        responsavel.id=registroContato.RESPONSAVEL

where
    registroContato.ABERTURA between '2022-03-01' and '2022-12-31'