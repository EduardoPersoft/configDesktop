select  
    materialmovimentoestoque.*
from
    MATERIALMOVIMENTOESTOQUE
where exists( 
select 
    * 
from
    MOVIMENTOESTOQUE
where
    movimentoestoque.filial=MATERIALMOVIMENTOESTOQUE.filial and
    movimentoestoque.idmovimento=materialmovimentoestoque.idmovimento and
    MOVIMENTOESTOQUE.filial=110 and
    movimentoestoque.TIPOMOVIMENTO='17' and
    movimentoestoque.EMISSAO>='01.08.2024'
)