select
    mercadoriaspedcompra.codigo,
    sum(mercadoriaspedcompra.quantidade)
FROM
    notacompra
INNER JOIN
    mercadoriasnotacompra on 
        mercadoriasnotacompra.filial=notacompra.filial AND 
        mercadoriasnotacompra.idnota=notacompra.IDNOTA AND
WHERE
    notacompra.filial=5 AND
    notacompra.DATAEntrada='17.08.2021'