
SELECT 
    NOTAFISCAL.MOVIMENTOESTOQUEFILIAL,
    NOTAFISCAL.IDMOVIMENTO,
    (select 
            MOVIMENTOESTOQUE.IDMOVIMENTOESTOQUE
     from
        MOVIMENTOESTOQUE
     WHERE   
        movimentoestoque.filial=1 
        and movimentoestoque.idNOTAEXPEDICAO = NOTAFISCAL.IDNOTA) AS IDMOVIMENTOESTOQUE,
    NOTAFISCAL.*
FROM
    NOTAFISCAL
WHERE
    NOTAFISCAL.FILIAL = 1
    AND NOTAFISCAL.IDNOTA IN 
    (select 
            MOVIMENTOESTOQUE.IDNOTAEXPEDICAO
     from
        MOVIMENTOESTOQUE
     WHERE   
        movimentoestoque.filial=1 
        and movimentoestoque.idmovimento between 102053 and 102059)