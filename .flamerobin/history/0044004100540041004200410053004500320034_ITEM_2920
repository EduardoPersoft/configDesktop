--insert into
    --ITEMESTOQUECODIGOS
select
    DISTINCT
    ITEMESTOQUECODIGOS.CODIGO,
    ITEMESTOQUECODIGOS.CODIGOALTERNATIVO
from
    ITEMESTOQUECODIGOS I1
where 
    EXISTS 
    (SELECT 
        * 
     FROM 
        ITEMESTOQUECODIGOS I2
     WHERE   
        I2.CODIGO=I1.CODIGO AND
        I2.CODIGOALTERNATIVO=I1.CODIGO)