update
    ITEMCUSTODATA
set
    QUANTIDADE = QUANTIDADE +  COALESCE((select
        SUM(MATERIALMOVIMENTOESTOQUE.QUANTIDADE)
     from
        MATERIALMOVIMENTOESTOQUE
     inner join
        MOVIMENTOESTOQUE ON
            MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL and
            MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO and
            MOVIMENTOESTOQUE.TIPOMOVIMENTO='01' AND 
            MOVIMENTOESTOQUE.EMISSAO BETWEEN '01.01.2024' AND '31.01.2024'
     where
        MATERIALMOVIMENTOESTOQUE.FILIAL=ITEMCUSTODATA.FILIAL and
        MATERIALMOVIMENTOESTOQUE.IDITEM=ITEMCUSTODATA.CODIGO),0),
    CUSTOTOTAL = CUSTOTOTAL + 
    COALESCE((select
        SUM(MATERIALMOVIMENTOESTOQUE.VALOR)
     from
        MATERIALMOVIMENTOESTOQUE
     inner join
        MOVIMENTOESTOQUE ON
            MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL and
            MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO and
            MOVIMENTOESTOQUE.TIPOMOVIMENTO='01' AND 
            MOVIMENTOESTOQUE.EMISSAO BETWEEN '01.01.2024' AND '31.01.2024'
     where
        MATERIALMOVIMENTOESTOQUE.FILIAL=ITEMCUSTODATA.FILIAL and
        MATERIALMOVIMENTOESTOQUE.IDITEM=ITEMCUSTODATA.CODIGO),0)
WHERE 
    CODIGO LIKE  'MPP%' AND 
    DATAINVENTARIO='31.01.2024'