SET TERM ^ ;
ALTER PROCEDURE TOTAISPERIODO
RETURNS (
    FILIAL INTEGER,
    RAZAOFILIAL VARCHAR(60),
    DATAINICIAL DATE,
    DATAFINAL DATE,
    DETALHE VARCHAR(7),
    VLRATE15 NUMERIC(12,3),
    PERCENTUALATE15 FLOAT,
    VLRATE30 NUMERIC(12,3),
    PERCENTUALATE30 FLOAT,
    VLRATE45 NUMERIC(12,3),
    PERCENTUALATE45 FLOAT,
    VLRATE60 NUMERIC(12,3),
    PERCENTUALATE60 FLOAT,
    VLRATE75 NUMERIC(12,3),
    PERCENTUALATE75 FLOAT,
    VLRATE90 NUMERIC(12,3),
    PERCENTUALATE90 FLOAT,
    VLR90MAIS NUMERIC(12,3),
    PERCENTUAL90MAIS FLOAT,
    VLRFATURAS NUMERIC(12,3),
    MEDIADIAS NUMERIC(12,3) )

AS
declare variable pvalorfatura numeric (12,3);
declare variable pmediadias numeric (12,3);
declare variable psomavalorfatura numeric (12,3);
declare variable pdatavencimento date;
declare variable pdataemissao date;

begin

     mediadias=0;
     pmediadias=0;
     pvalorfatura=0;
     VLRATE15=0;
     VLRATE30=0;
     VLRATE45=0;
     VLRATE60=0;
     VLRATE75=0;
     VLRATE90=0;
     VLR90MAIS=0;
     vlrfaturas=0;
     percentualate15=0;
     percentualate30=0;
     percentualate45=0;
     percentualate60=0;
     percentualate75=0;
     percentualate90=0;
     PERCENTUAL90MAIS=0;


    SELECT ESTSIN.Estabelecimento,
           ESTSIN.Datainicial,
           ESTSIN.Datafinal,
           CADASTROPARCEIROS.Razaosocial
    FROM ESTSIN
    INNER JOIN CADASTROPARCEIROS ON (
            CADASTROPARCEIROS.CADASTRO=ESTSIN.Estabelecimento)
    INNER JOIN ESTABELECIMENTO ON (ESTABELECIMENTO.Cadastro=ESTSIN.ESTABELECIMENTO)
    WHERE RELATORIO='TOTAISPERIODO'
    INTO FILIAL,DATAINICIAL,DATAFINAL,razaofilial;

detalhe = 'VENDAS';

select sum(COALESCE(faturas.valorfatura,0))
from notafiscal
inner join faturas on (notafiscal.filial=faturas.filial and notafiscal.idnota=faturas.idnota)
where notafiscal.filial=:filial and
      notafiscal.cancelamento = 'N' and
      notafiscal.entradasaida = 'S' and
      notafiscal.dataemissao between :datainicial and :datafinal
      and faturas.valorfatura >0
into :vlrfaturas;

for select COALESCE(faturas.valorfatura,0),
           faturas.datavencimento,
           notafiscal.dataemissao
from notafiscal
inner join faturas on (notafiscal.filial=faturas.filial and notafiscal.idnota=faturas.idnota)
where notafiscal.filial=:filial and
      notafiscal.cancelamento = 'N' and
      notafiscal.entradasaida = 'S' and
      notafiscal.dataemissao between :datainicial and :datafinal
      and faturas.valorfatura >0
      into :pvalorfatura, :pdatavencimento, :pdataemissao do begin

      if (pdatavencimento  <= :pdataemissao+14) then
            vlrate15=vlrate15+pvalorfatura;
      if (pdatavencimento  between :pdataemissao+15 and :pdataemissao+29) then
            vlrate30=vlrate30+pvalorfatura;
      if (pdatavencimento  between :pdataemissao+30 and :pdataemissao+44) then
            vlrate45=vlrate45+pvalorfatura;
      if (pdatavencimento  between :pdataemissao+45 and :pdataemissao+59) then
            vlrate60=vlrate60+pvalorfatura;
      if (pdatavencimento  between :pdataemissao+60 and :pdataemissao+74) then
            vlrate75=vlrate75+pvalorfatura;
      if (pdatavencimento  between :pdataemissao+75 and :pdataemissao+89) then
            vlrate90=vlrate90+pvalorfatura;
      if (pdatavencimento  >:pdataemissao+89) then
            vlr90mais= vlr90mais+pvalorfatura;
      if (vlrfaturas=0) then MEDIADIAS=MEDIADIAS; else
            mediadias=mediadias+(pdatavencimento-pdataemissao)*pvalorfatura/vlrfaturas;
    end
PERCENTUALATE15 = (100 * VLRATE15 / (VLRATE15+VLRATE30+VLRATE45+VLRATE60+VLRATE75+VLRATE90+VLR90MAIS));
PERCENTUALATE30 = (100 * VLRATE30 / (VLRATE15+VLRATE30+VLRATE45+VLRATE60+VLRATE75+VLRATE90+VLR90MAIS));
PERCENTUALATE45 = (100 * VLRATE45 / (VLRATE15+VLRATE30+VLRATE45+VLRATE60+VLRATE75+VLRATE90+VLR90MAIS));
PERCENTUALATE60 = (100 * VLRATE60 / (VLRATE15+VLRATE30+VLRATE45+VLRATE60+VLRATE75+VLRATE90+VLR90MAIS));
PERCENTUALATE75 = (100 * VLRATE75 / (VLRATE15+VLRATE30+VLRATE45+VLRATE60+VLRATE75+VLRATE90+VLR90MAIS));
PERCENTUALATE90 = (100 * VLRATE90 / (VLRATE15+VLRATE30+VLRATE45+VLRATE60+VLRATE75+VLRATE90+VLR90MAIS));
PERCENTUAL90MAIS = (100 * VLR90MAIS / (VLRATE15+VLRATE30+VLRATE45+VLRATE60+VLRATE75+VLRATE90+VLR90MAIS));
suspend;

     mediadias=0;
     pmediadias=0;
     pvalorfatura=0;
     VLRATE15=0;
     VLRATE30=0;
     VLRATE45=0;
     VLRATE60=0;
     VLRATE75=0;
     VLRATE90=0;
     VLR90MAIS=0;
     vlrfaturas=0;
     percentualate15=0;
     percentualate30=0;
     percentualate45=0;
     percentualate60=0;
     percentualate75=0;
     percentualate90=0;
     PERCENTUAL90MAIS=0;

detalhe = 'COMPRAS';

select sum(COALESCE(faturas.valorfatura,0))
from notacompra notafiscal
inner join faturasnotacompra faturas on (notafiscal.filial=faturas.filial and notafiscal.idnota=faturas.idnota)
where notafiscal.filial=:filial and
      notafiscal.dataemissao between :datainicial and :datafinal and
      notafiscal.entradasaida = 'E'
      and faturas.valorfatura >0

into :vlrfaturas;

for select COALESCE (faturas.valorfatura,0),
                     faturas.datavencimento,
                     notafiscal.dataemissao
    
from  notacompra notafiscal
inner join faturasnotacompra faturas on (notafiscal.filial=faturas.filial and notafiscal.idnota=faturas.idnota)
where notafiscal.filial=:filial and
      notafiscal.dataemissao between :datainicial and :datafinal and
      notafiscal.entradasaida = 'E'
      and faturas.valorfatura >0
into :PVALORFATURA, :PDATAVENCIMENTO, :pdataemissao do begin

      if (pdatavencimento  <= :pdataemissao+14) then
            vlrate15=vlrate15+pvalorfatura;
      if (pdatavencimento  between :pdataemissao+15 and :pdataemissao+29) then
            vlrate30=vlrate30+pvalorfatura;
      if (pdatavencimento  between :pdataemissao+30 and :pdataemissao+44) then
            vlrate45=vlrate45+pvalorfatura;
      if (pdatavencimento  between :pdataemissao+45 and :pdataemissao+59) then
            vlrate60=vlrate60+pvalorfatura;
      if (pdatavencimento  between :pdataemissao+60 and :pdataemissao+74) then
            vlrate75=vlrate75+pvalorfatura;
      if (pdatavencimento  between :pdataemissao+75 and :pdataemissao+89) then
            vlrate90=vlrate90+pvalorfatura;
      if (pdatavencimento  >:pdataemissao+89) then
            vlr90mais= vlr90mais+pvalorfatura;
      if (vlrfaturas=0) then MEDIADIAS=MEDIADIAS; else
            mediadias=mediadias+(pdatavencimento-pdataemissao)*pvalorfatura/vlrfaturas;
 end

PERCENTUALATE15 = (100 * VLRATE15 / (VLRATE15+VLRATE30+VLRATE45+VLRATE60+VLRATE75+VLRATE90+VLR90MAIS));
PERCENTUALATE30 = (100 * VLRATE30 / (VLRATE15+VLRATE30+VLRATE45+VLRATE60+VLRATE75+VLRATE90+VLR90MAIS));
PERCENTUALATE45 = (100 * VLRATE45 / (VLRATE15+VLRATE30+VLRATE45+VLRATE60+VLRATE75+VLRATE90+VLR90MAIS));
PERCENTUALATE60 = (100 * VLRATE60 / (VLRATE15+VLRATE30+VLRATE45+VLRATE60+VLRATE75+VLRATE90+VLR90MAIS));
PERCENTUALATE75 = (100 * VLRATE75 / (VLRATE15+VLRATE30+VLRATE45+VLRATE60+VLRATE75+VLRATE90+VLR90MAIS));
PERCENTUALATE90 = (100 * VLRATE90 / (VLRATE15+VLRATE30+VLRATE45+VLRATE60+VLRATE75+VLRATE90+VLR90MAIS));
PERCENTUAL90MAIS = (100 * VLR90MAIS / (VLRATE15+VLRATE30+VLRATE45+VLRATE60+VLRATE75+VLRATE90+VLR90MAIS));
suspend;

end
^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE TOTAISPERIODO TO  SYSDBA;

