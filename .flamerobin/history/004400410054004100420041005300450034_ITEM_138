
SELECT
       EXTRACT(YEAR FROM ESTSIN.DATAFINAL) as ANO,
       CASE
           WHEN EXTRACT(MONTH FROM ESTSIN.DATAFINAL) < 10 THEN '0'
           ELSE ''
        END||EXTRACT(MONTH FROM ESTSIN.DATAFINAL) as mes,
        ITEMESTOQUE.CODIGO as COD_ITEM,
        ITEMESTOQUE.DESCRICAO as DESCR_ITEM,
        CLASSIFICACAOFISCAL.DESCRICAO AS COD_NCM,
        SUM(SALDOINICIALESTOQUE.SALDOANTERIOR) AS QTDE,
        ITEMESTOQUE.UNIDADE AS UNID_INV,

        SUM ( case
                  when coalesce (SALDOINICIALESTOQUE.SALDOANTERIOR,0)= 0 then 0
                  else CASE
                       WHEN SALDOINICIALESTOQUE.VALORANTERIOR<0 THEN 0
                       ELSE SALDOINICIALESTOQUE.VALORANTERIOR/
                       SALDOINICIALESTOQUE.SALDOANTERIOR end end) AS VL_UNIT,
                
        cast  ('000' as varchar (1)) as CST_ICMS,
        cast  ('' as varchar (1)) as CSOSN_ICMS,
        SUM((CASE
           WHEN SALDOINICIALESTOQUE.VALORANTERIOR<0 THEN 0
           ELSE SALDOINICIALESTOQUE.VALORANTERIOR
       END) /(1-(tributacaoicmsuf.ALIQUOTA/100))) as BC_ICMS,

                       
       tributacaoicmsuf.ALIQUOTA as ALIQ_ICMS,
       SUM(((CASE
           WHEN SALDOINICIALESTOQUE.VALORANTERIOR<0 THEN 0
           ELSE SALDOINICIALESTOQUE.VALORANTERIOR
       END) /(1-(tributacaoicmsuf.ALIQUOTA/100)))*tributacaoicmsuf.ALIQUOTA/100) as VL_ICMS,


     cast  ('' as varchar (1)) as ALIQ_PIS,
     cast  ('' as varchar (1)) as VL_PIS,
     cast  ('' as varchar (1)) as ALIQ_COFINS,
     cast  ('' as varchar (1)) as VL_COFINS ,
     cast  ('' as varchar (1)) as VL_ITEM_IR,
     cast  ('' as varchar (1)) as IVA_ST,
     
     cast  ('' as varchar (1)) as BC_ICMS_ST ,
     cast  ('' as varchar (1)) as ICMS_ST,
     cast  ('' as varchar (1)) as ALIQ_FCP,
     cast  ('' as varchar (1)) as FCP_ST,
			

    CASE
        WHEN CADTERCEIROS.DOCUMENTO IS NULL THEN 0
        ELSE 1 END IND_PROP,
    CADTERCEIROS.DOCUMENTO AS CNPJ,
    'SP' AS UF,
    cast  ('' as varchar (1)) as grupo,
           LOCAL.DESCRICAO AS LOCAL
    
FROM
    SALDOINICIALESTOQUELOCAL SALDOINICIALESTOQUE
INNER JOIN
      ESTSIN ON (ESTSIN.RELATORIO='SALDOANTERIORESTOQUE' )
INNER JOIN
      ITEMESTOQUE ON (SALDOINICIALESTOQUE.IDITEM=ITEMESTOQUE.CODIGO)

INNER JOIN
      TRIBUTACAOICMSUF ON
                       (TRIBUTACAOICMSUF.id=itemestoque.TRIBUTACAOICMS)
inner join
      CLASSIFICACAOFISCAL on
                          (itemestoque.CLASSIFISCAL=CLASSIFICACAOFISCAL.CFISCAL)

LEFT JOIN
     LOCAL ON
           (LOCAL.ID = SALDOINICIALESTOQUE.LOCAL)
LEFT JOIN CADASTROPARCEIROS CADTERCEIROS ON
           (CADTERCEIROS.LOCALENTREGA = LOCAL.ID)
WHERE 
    ITEMESTOQUE.TIPOPRODUTO IN ('1', '3', '4') AND
    (NOT (ITEMESTOQUE.TIPOPRODUTO = 4 AND
    ITEMESTOQUE.CODIGO BETWEEN '00000' AND '99999')) and
    TRIBUTACAOICMSUF.UF='SP'
GROUP BY
    1,2,
    ESTSIN.DATAFINAL,
    ITEMESTOQUE.CODIGO,
    SALDOINICIALESTOQUE.LOCAL, 
    CADTERCEIROS.DOCUMENTO,
    CADTERCEIROS.NOME,
    LOCAL.DESCRICAO,
    ITEMESTOQUE.DESCRICAO,
    ITEMESTOQUE.UNIDADE,
    tributacaoicmsuf.ALIQUOTA ,
    CLASSIFICACAOFISCAL.DESCRICAO
HAVING   
   SUM(SALDOINICIALESTOQUE.SALDOANTERIOR) > 0.00009
ORDER BY
      ITEMESTOQUE.CODIGO,
      LOCAL.DESCRICAO
