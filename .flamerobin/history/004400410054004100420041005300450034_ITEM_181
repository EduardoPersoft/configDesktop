SET TERM ^ ;
ALTER PROCEDURE C_ABASTECIMENTO (
    DATAINICIAL TIMESTAMP,
    DATAFINAL TIMESTAMP )
RETURNS (
    PLACA VARCHAR(10),
    LITROS NUMERIC(12,4),
    DATAANTERIOR TIMESTAMP,
    DATA TIMESTAMP,
    KMANTERIOR NUMERIC(12,4),
    KM NUMERIC(12,4),
    KMPLITROS NUMERIC(12,4),
    KMRODADA NUMERIC(12,4) )
AS

declare variable pPlaca char (10);
declare variable pdata date;
declare variable pKmInicial  numeric (12,4);
declare variable pKmFinal  numeric (12,4);


begin


pPlaca = '';
pdataInicial = null;
pDataFinal = null;
pLitros = null;


for select 
   itinerarios.PLACA ,
   cast (itinerarios.DATA as timestamp ),
   COALESCE ( itinerarios.ABASTECIMENTOKM,0),
   COALESCE (  itinerarios.ABASTECIMENTOLITROS,0),
   COALESCE ( itinerarios.kminicial, 0),
   COALESCE ( itinerarios.kmfinal,0)
from 
   itinerarios 
where 
   itinerarios.ABASTECIMENTOLITROS is not null and
   itinerarios.DATA between :datainicial  and :datafinal
order by 
   itinerarios.placa, itinerarios.data   
into
   :PPLACA, :PDATA, :ABASTECIMENTOKM, :LITROS,
   :pkminicial, :pkmfinal

do begin 

   if (:placa<>:pplaca) then begin
        :pplaca = :placa;
        :pdataInicial = null;
        :pKmInicial = null;
   end

   if (:pKmInicial is null) then begin
      :KmInicial = pkminicial;
      :dataAnterior = :Pdata;
   end else begin
      :KmFinal = pkmfinal;
      :data = :Pdata;
      :KmRodada = COALESCE (:KmFinal,0) - COALESCE (:KmInicial,0);
      if (coalesce (:litros,0)<>0) then 
        :kmplitros =  coalesce (:KmRodada,0) / :Litros ;

      suspend;

      :KmInicial = :kmfinal;
      :dataAnterior = :data;
   end
 end
 
end^
SET TERM ; ^


