update
    titulorec
set
    contacorrente =  (select
            movtitulorec.contacorrente
        from
            movtitulorec
        where
            titulorec.filial=MOVTITULOREC.filial and
            titulorec.idtitulo=movtitulorec.idtitulo and
            titulorec.IDMOVIMENTO-1=movtitulorec.IDMOVIMENTO and 
            titulorec.CONTACORRENTE<>movtitulorec.CONTACORRENTE and
            titulorec.TIPOBAIXA is null and 
            titulorec.filial=110),
    titulorec.TIPOTRANSACAO=(select
            movtitulorec.TIPOTRANSACAO
        from
            movtitulorec
        where
            titulorec.filial=MOVTITULOREC.filial and
            titulorec.idtitulo=movtitulorec.idtitulo and
            titulorec.IDMOVIMENTO-1=movtitulorec.IDMOVIMENTO and 
            titulorec.CONTACORRENTE<>movtitulorec.CONTACORRENTE and
            titulorec.TIPOBAIXA is null and 
            titulorec.filial=110)        
where
    exists (
        select
            *
        from
            movtitulorec
        where
            titulorec.filial=MOVTITULOREC.filial and
            titulorec.idtitulo=movtitulorec.idtitulo and
            titulorec.IDMOVIMENTO-1=movtitulorec.IDMOVIMENTO and 
            titulorec.CONTACORRENTE<>movtitulorec.CONTACORRENTE and
            titulorec.TIPOBAIXA is null and 
            titulorec.filial=110)
order by
    cadastro