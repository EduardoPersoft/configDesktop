select

C_COMISSAORECIBO.ID,

c_comissaorecibo.loja,

loja.nome nomeloja,

C_COMISSAORECIBO.FILIAL,

C_COMISSAORECIBO.IDNOTA,

C_COMISSAORECIBO.DATALIMITE,

C_COMISSAORECIBO.RAZAOVENDEDOR,

sum (C_COMISSAORECIBO.VALORCOMISSAO) as VALORCOMISSAO,

sum (C_COMISSAORECIBO.BASECOMISSAO)  as BASECOMISSAO

from C_COMISSAORECIBO ('C_CAPACOMISSAO')

inner join cadastroparceiros loja on (c_comissaorecibo.loja = loja.cadastro)


group by

C_COMISSAORECIBO.ID,

c_comissaorecibo.loja,

loja.nome,

C_COMISSAORECIBO.FILIAL,

5,

C_COMISSAORECIBO.DATALIMITE,

C_COMISSAORECIBO.RAZAOVENDEDOR