SELECT 
    CADASTROPARCEIROS.CADASTRO,
    CADASTROPARCEIROS.RAZAO,
    CADASTROPARCEIROS.NOME,
    CADASTROPARCEIROS.DOCUMENTO,
    T_CADASTRO.DOCUMENTO,
    T_cADASTRO.RAZAO
 FROM T_CADASTRO WHERE EXISTS (SELECT * FROM CADASTROPARCEIROS 
WHERE CADASTROPARCEIROS.CADASTRO=T_CADASTRO.CADASTRO 
AND CADASTROPARCEIROS.DOCUMENTO<>T_CADASTRO.DOCUMENTO)