SELECT
    pedido.idnota as Pedido,
    titulorec.fatura Fatura, 
    case C_FATURASPED.DESTINO when 'M' then 'Mercadorias' else 'Servico' end as Modo,
    cadastroparceiros.nome Cliente,
    TIPOCOBRANCA.DESCRICAO TipoCobranca,
    titulorec.emissao DtPedido,
    titulorec.baixa DtAdiantamento,
    titulorec.VALORTITULO valorAdiantamento,
    pedido.VLRTOTALNOTA valorNota
FROM
    c_faturasped
inner JOIN
    TITULOREC on 
        c_faturasped.filial=titulorec.filial AND
        c_faturasped.IDTITULO=titulorec.IDTITULO
inner JOIN
    pedido on
        pedido.filial=c_faturasped.filial AND
        pedido.IDNOTA=c_faturasped.idnota
inner JOIN
    cadastroparceiros on
        cadastroparceiros.cadastro=pedido.DESTINATARIO
inner JOIN
    TIPOCOBRANCA on
        TIPOCOBRANCA.TIPOCOBRANCA=titulorec.TIPOTRANSACAO
        

WHERE
    titulorec.baixa between '01.01.2022' and '31.01.2022' AND
    titulorec.emissao between '01.01.2022' and '31.01.2022' AND
    titulorec.TIPOBAIXA = 'P'    
order by
    pedido.idnota