select
    case coalesce(cadVendedor.cadastro, movimentoEstoque.filial) when movimentoEstoque.filial
    then 1 else cadVendedor.cadastro end,
    case coalesce(cadVendedor.cadastro, movimentoEstoque.filial) when movimentoEstoque.filial
    then 'EURO BRAKE' else cadVendedor.nome end,
    sum(coalesce(movimentoestoque.VALORFRETE,0)) as frete,
    sum(coalesce(c_coletas.VALORMEDIO,0)) as coleta,
    sum(coalesce(movimentoestoque.VALORFRETE,0))+
    sum(coalesce(c_coletas.VALORMEDIO,0)) as total,
    count(movimentoEstoque.idmovimento) qtdEntregas,
    (sum(coalesce(movimentoestoque.VALORFRETE,0))+
    sum(coalesce(c_coletas.VALORMEDIO,0)))/count(movimentoEstoque.idmovimento) custoMedio,
    cast(0 as decimal(12,3)) as valorFaturado,
    cast(0 as decimal(12,3)) as percentual
from
    movimentoestoque
left join 
    c_coletas on
        c_coletas.COLETA=movimentoestoque.COLETA
left join
    pedido on
        movimentoestoque.filial=pedido.filial and
        movimentoestoque.idpedido=pedido.idnota  
        
left join
    CADASTROPARCEIROS cadvendedor on    
        cadvendedor.cadastro=pedido.vendedor
where
     movimentoestoque.coletadata between '01.07.2025' and '31.07.2025' and
     TIPOMOVIMENTO='13'
group by
   1, 2
