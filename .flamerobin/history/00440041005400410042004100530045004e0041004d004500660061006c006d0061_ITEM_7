SELECT
    ITEMESTOQUE.CODIGO,
    ITEMESTOQUE.DESCRICAO,
    MATERIALFILIAL.CONSUMOMEDIOESTIMADO
FROM
    C_ITENSAZERO
INNER JOIN
    ITEMESTOQUE ON
        ITEMESTOQUE.CODIGO=C_ITENSAZERO.CODIGO
INNER JOIN
    MATERIALFILIAL ON
        MATERIALFILIAL.FILIAL=5 AND
        MATERIALFILIAL.IDITEM=C_ITENSAZERO.CODIGO