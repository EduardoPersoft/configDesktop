select 
    MOVBANCARIOS.MOVIMENTACAO,
    LANTOCONTPAG.CONTACONTABIL,
    contascontabeis.DESCRICAO,
    contascontabeis.NIVEL,
    contascontabeis.TIPOCONTA,
    sum((LANTOCONTPAG.VALOR / TITULOPAG.VALORTITULO * TITULOSANEXADOS.VALOR)*
        case movbancarios.tipomovimento when 'D' then (-1) else 1 end)
    
    
from
    movbancarios
inner join
    titulosanexados on 
    MOVBANCARIOS.FILIAL=TITULOSANEXADOS.FILIAL and
    MOVBANCARIOS.IDCONTACORRENTE=TITULOSANEXADOS.IDCONTACORRENTE and
    MOVBANCARIOS.IDMOVTOBANCARIO=TITULOSANEXADOS.idmovtobanc

inner join
    TITULOPAG on 
    TITULOSANEXADOS.FILIAL=TITULOPAG.FILIAL and
    TITULOSANEXADOS.IDTITULO=TITULOPAG.IDTITULO
inner join 
    LANTOCONTPAG on 
    TITULOSANEXADOS.FILIAL=LANTOCONTPAG.FILIAL and
    TITULOSANEXADOS.IDTITULO= LANTOCONTPAG.idmovtobanc
inner join 
    ESTABELECIMENTO on 
    MOVBANCARIOS.FILIAL=ESTABELECIMENTO.CADASTRO 
inner join 
    CONTASCONTABEIS on
    ESTABELECIMENTO.PLANOCONTAS=CONTASCONTABEIS.IDPLANO and 
    LANTOCONTPAG.contacontabil like contascontabeis.CONTACONTABIL||'%'
where
    MOVBANCARIOS.filial=110 and
    MOVBANCARIOS.MOVIMENTACAO between '01.01.2022' and '31.12.2022' and
    TITULOSANEXADOS.tipotitulo='P'
Group by 
    MOVBANCARIOS.MOVIMENTACAO,
    LANTOCONTPAG.CONTACONTABIL,
    contascontabeis.DESCRICAO,
    contascontabeis.NIVEL,
    contascontabeis.TIPOCONTA
