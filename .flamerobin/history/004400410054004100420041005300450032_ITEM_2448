where filial=5 and baixa = 'N'
plan join (MERCADORIASNOTACOMPRA INDEX (I_MERCITEMSAIDA),
            PLAN (MERCADORIASPEDCOMPRA INDEX (BAIXA_MERCADORIASPEDCOMPRA)))
--order by filial, idnota                                         

UPDATE
    MERCADORIASPEDCOMPRA
SET
    minimobaixa=quantidade,
    qtdeentregue=0,
    baixa='N'
WHERE
    filial=5 and exists (
    select * from pedidocompra
    where pedidocompra.filial=mercadoriaspedcompra.filial AND
    pedidocompra.idnota=mercadoriaspedcompra.idnota AND
    pedidocompra.datacadastro <'04.12.2020')
    

UPDATE
    MERCADORIASPEDCOMPRA
SET
    mercadoriaspedcompra.MINIMOBAIXA=quantidade ,
    mercadoriaspedcompra.qtdeentregue=0,
    baixa='S'
WHERE
    filial=5 and exists (
    select * from pedidocompra
    where pedidocompra.filial=mercadoriaspedcompra.filial AND
    pedidocompra.idnota=mercadoriaspedcompra.idnota AND
    pedidocompra.datacadastro <'01.01.2021')
    
    
    mercadoriaspedcompra.
create index c_i_mercpedcompra on mercadoriasnotacompra(filial,idpedido,idmercpedido)