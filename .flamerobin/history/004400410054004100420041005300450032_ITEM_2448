
  UPDATE MERCADORIASPEDCOMPRA SET QTDEENTREGUE= coalesce((select sum(mercadoriasnotacompra.quantidade) FROM mercadoriasnotacompra
                                                 where mercadoriasnotacompra.filial=mercadoriaspedcompra.filial and 
                                                 mercadoriasnotacompra.IDPEDIDO=mercadoriaspedcompra.idnota AND
                                                 mercadoriasnotacompra.IDMERCADORIA=mercadoriaspedcompra.IDMERCADORIA
                                                 ) ,0),
                                 

