SELECT DISTINCT C_PEDIDOSEMABERTO.filial,
                C_PEDIDOSEMABERTO.idnota,
                C_PEDIDOSEMABERTO.idmercadoria,
                C_PEDIDOSEMABERTO.datacadastro,
                C_PEDIDOSEMABERTO.dataentrega ,
                c_pedidosemaberto.DATAPREVISTA,
                C_PEDIDOSEMABERTO.clientecadastro ,
                C_PEDIDOSEMABERTO.clientenome ,
                C_PEDIDOSEMABERTO.produto,
                C_PEDIDOSEMABERTO.descricaoproduto,
                coalesce(VENDEDORESPED.VENDEDOR, -1),
                COALESCE(VENDEDOR.nome,'SEM VENDEDOR') AS VENDEDORNOME,
                case coalesce (c_pedidosemaberto.VALORIPI,0)
                    when 0 then C_PEDIDOSEMABERTO.valorsaldo else 
                    C_PEDIDOSEMABERTO.valorsaldo * (1+(coalesce (C_PEDIDOSEMABERTO.pipi,0)/100))end as valorsaldo,
                coalesce(C_PEDIDOSEMABERTO.VLRFATNAOBAIXADO,0),
                (case coalesce (c_pedidosemaberto.VALORIPI,0)
                    when 0 then C_PEDIDOSEMABERTO.valorsaldo else 
                    C_PEDIDOSEMABERTO.valorsaldo * (1+(coalesce (C_PEDIDOSEMABERTO.pipi,0)/100)) end)-coalesce(C_PEDIDOSEMABERTO.VLRFATNAOBAIXADO,0) as valorsaldo

FROM C_PEDIDOSEMABERTO(110)
LEFT JOIN VENDEDORESPED ON (VENDEDORESPED.filial = C_PEDIDOSEMABERTO.filial
                           AND VENDEDORESPED.idnota = C_PEDIDOSEMABERTO.idnota)
LEFT JOIN CADASTROPARCEIROS VENDEDOR ON (VENDEDOR.cadastro = VENDEDORESPED.vendedor)
where  C_PEDIDOSEMABERTO.DATAEMISSAO IS NOT NULL
ORDER BY 11, c_pedidosemaberto.DATAPREVISTA,
         C_PEDIDOSEMABERTO.IDNOTA,
         C_PEDIDOSEMABERTO.IDCOMPOSICAO
