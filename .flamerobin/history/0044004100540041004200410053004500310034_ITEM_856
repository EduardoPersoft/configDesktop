select
    distinct mercadoriasnotacompra.cfop
from
    notacompra
inner join
    mercadoriasnotacompra on
        mercadoriasnotacompra.filial=notacompra.filial and
        mercadoriasnotacompra.idnota=notacompra.IDNOTA
inner join
    cadastroparceiros cadfor on
        cadfor.cadastro=notacompra.DESTINATARIO
inner join
    itemestoque on
        itemestoque.codigo=mercadoriasnotacompra.CODIGO
where
    notacompra.filial=110 and
    notacompra.dataentrada between '01.07.2023' and '31.07.2023'