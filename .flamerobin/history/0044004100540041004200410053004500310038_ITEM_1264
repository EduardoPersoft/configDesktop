select 
    pedido.filial,
    pedido.idnota,
    pedido.DATACADASTRO,
    pedido.DATAREFERENCIA,
    pedido.DATAEMISSAO,
    (select
        min(fatped.DATAVENCIMENTO)
     from
        c_faturasped FATPED
     where
        fatped.filial=pedido.filial and
        fatped.idnota=pedido.idnota),
    pedido.C_DATACOMISSAO,
    coalesce(pedido.c_datacomissao,
       cast((select
        min(fatped.DATAVENCIMENTO)
     from
        c_faturasped FATPED
     where
        fatped.filial=pedido.filial and
        fatped.idnota=pedido.idnota) as date))
    
from
    PEDIDO
where 
    pedido.dataemissao is not null and 
    pedido.datacadastro >= '01.01.202' and
    pedido.DATAREFERENCIA<>coalesce(pedido.c_datacomissao,
       cast((select
        min(fatped.DATAVENCIMENTO)
     from
        c_faturasped FATPED
     where
        fatped.filial=pedido.filial and
        fatped.idnota=pedido.idnota) as date))
