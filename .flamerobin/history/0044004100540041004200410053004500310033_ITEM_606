select 
    itemestoque.codigo,
    itemestoque.descricao,
    itemestoque.LOCALIZACAO,
    grupomercadoria.descricao as grupo,
    sum(materiallocal.SALDOtotal)
from
    itemestoque
inner join
    grupomercadoria on
        grupomercadoria.grupo=itemestoque.GRUPO
left join
    materiallocal on
        materiallocal.iditem=itemestoque.codigo and 
        materiallocal.filial=1
group by
    itemestoque.codigo,
    itemestoque.descricao,
    itemestoque.LOCALIZACAO,
    grupomercadoria.descricao
    
