select
    SUM((COALESC(MOVIMENTOESTOQUE.SAIDAPRODUCAO, CAST('NOW' AS TIMESAMP)) -
    MOVIMENTOESTOQUE.ENTRADAPRODUCAO))
from
    MOVIMENTOESTOQUE
INNER join
    PEDIDO ON
        MOVIMENTOESTOQUE.FILIAL=PEDIDO.FILIAL and
        MOVIMENTOESTOQUE.IDPEDIDO=PEDIDO.IDNOTA
where
    MOVIMENTOESTOQUE.EMISSAO = '18.06.2023' and
    MOVIMENTOESTOQUE.TIPOMOVIMENTO='13'