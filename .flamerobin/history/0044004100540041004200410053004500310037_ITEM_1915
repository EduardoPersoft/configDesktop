SELECT
            materiallocal.FILIAL,
            '.' as lote,
            MATERIALLOCAL.IDLOCAL,
            MATERIALLOCAL.SALDOTOTAL-
            COALESCE(
            (SELECT sum(MATERIALMOVIMENTOESTOQUE.QUANTIDADE)
             FROM MATERIALMOVIMENTOESTOQUE
             INNER JOIN MOVIMENTOESTOQUE ON 
                MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL AND
                MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
             WHERE MATERIALMOVIMENTOESTOQUE.FILIAL=MATERIALLOCAL.FILIAL
             AND MATERIALMOVIMENTOESTOQUE.IDITEM=:CODIGO
             AND MATERIALMOVIMENTOESTOQUE.CONCLUIDO='N'
             AND MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO=MATERIALLOCAL.IDLOCAL
             AND MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO<>:EXPEDICAO
             AND MOVIMENTOESTOQUE.TIPOMOVIMENTO='13'),0)
        FROM
            MERCADORIASPED
        inner join 
            MATERIALLOCAL on
                materiallocal.iditem=mercadoriasped.codigo
        INNER JOIN
            LOCAL ON 
                LOCAL.ID=MATERIALLOCAL.IDLOCAL
        WHERE 
            mercadoriasped.filial=1 and
            mercadoriasped.idnota=293019 and 
            LOCAL.DISPONIVEL = 'S' AND
            MATERIALLOCAL.SALDOTOTAL-
            COALESCE(
                (SELECT MATERIALMOVIMENTOESTOQUE.QUANTIDADE
                 FROM MATERIALMOVIMENTOESTOQUE
                 INNER JOIN MOVIMENTOESTOQUE ON 
                    MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL AND
                    MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
                 WHERE MATERIALMOVIMENTOESTOQUE.FILIAL=MATERIALLOCAL.FILIAL
                 AND MATERIALMOVIMENTOESTOQUE.IDITEM=:CODIGO
                 AND MATERIALMOVIMENTOESTOQUE.CONCLUIDO='N'
                 AND MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO=MATERIALLOCAL.IDLOCAL
                 AND MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO<>:EXPEDICAO
                 AND MOVIMENTOESTOQUE.TIPOMOVIMENTO='13'),0)>0            
        ORDER BY
            mercadoriasped.idmercadoria,
            coalesce(local.prioridade,9999), local.id