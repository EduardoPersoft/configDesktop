 SELECT  
    COMENTARIOS.ID,
    COMENTARIOS.DATAHORA,
    COMENTARIOS.IDUSUARIO,
    USUARIO.USUARIO,
    COMENTARIOS.COMENTARIO,
    COMENTARIOS.DOCUMENTO,
    COMENTARIOS.UUID
FROM
    COMENTARIOS
INNER JOIN
    USUARIO ON
        USUARIO.ID=COMENTARIOS.IDUSUARIO
WHERE
    COMENTARIOS.DOCUMENTO='x' AND
    COMENTARIOS.UUID='y'
ORDER BY
    COMENTARIO.DATAHORA DESC
