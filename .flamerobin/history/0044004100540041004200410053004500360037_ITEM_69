SELECT MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO,
       MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL, 
       MATERIALMOVIMENTOESTOQUE.IDITEM,       
       MOVIMENTOESTOQUE.DOCUMENTO,
       PRODUTO.DESCRICAO,
       MATERIALMOVIMENTOESTOQUE.QUANTIDADE,
       PRODUTO.UNIDADE,
       PRODUTO.GRUPO,
       MOVIMENTOESTOQUE.EMISSAO,
       MOVIMENTOESTOQUE.USUARIO
from MATERIALMOVIMENTOESTOQUE
INNER JOIN MOVIMENTOESTOQUE ON (MATERIALMOVIMENTOESTOQUE.FILIAL=MOVIMENTOESTOQUE.FILIAL 
               AND MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO=MOVIMENTOESTOQUE.IDMOVIMENTO)
inner join COMPOSICAOITEM on (COMPOSICAOITEM.iditem=MATERIALMOVIMENTOESTOQUE.iditem)
inner join estabelecimento on (ESTABELECIMENTO.cadastro=MATERIALMOVIMENTOESTOQUE.filial)
INNER JOIN ITEMESTOQUE PRODUTO ON (MATERIALMOVIMENTOESTOQUE.IDITEM=PRODUTO.CODIGO)
INNER JOIN ITEMESTOQUE MATERIAL ON (COMPOSICAOITEM.IDMATERIAL=MATERIAL.CODIGO)
INNER JOIN ESTSIN ON (ESTSIN.RELATORIO='C_OP'
           AND ESTSIN.estabelecimento=MOVIMENTOESTOQUE.FILIAL
           AND MOVIMENTOESTOQUE.emissao BETWEEN
                   ESTSIN.datainicial AND ESTSIN.DATAFINAL
       AND MOVIMENTOESTOQUE.idmovimento BETWEEN
                    ESTSIN.idnotainicial AND ESTSIN.idnotafinal)
where movimentoestoque.tipomovimento=12
PLAN (ESTSIN INDEX (RDB$PRIMARY872),
      MOVIMENTOESTOQUE INDEX (MOVIMENTOESTOQUE_DATA),
      MATERIALMOVIMENTOESTOQUE INDEX (FK_MATERIALMOVIMENTOESTOQUE_1),
      ESTABELECIMENTO INDEX (RDB$PRIMARY131),
      PRODUTO index (RDB$PRIMARY21)
     )
ORDER BY MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO,MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL