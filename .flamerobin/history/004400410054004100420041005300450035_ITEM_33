/*
update 
    clientes
set
    clientes.CONSUMIDORFINAL = 'S'
*/
select
    *
from
    cadastroparceiros
where
    exists (
        select 
            * 
        from 
            clientes 
        where 
            cadastroparceiros.cadastro=clientes.cadastro and 
            cadastroparceiros.CONTRIBUINTE='N'
            )