SET TERM ^ ;
ALTER TRIGGER ATITEMPEDCOMPRA_UPDATE ACTIVE
BEFORE UPDATE POSITION 0
AS
BEGIN

  UPDATE MERCADORIASPEDCOMPRA SET QTDEENTREGUE= case when mercadoriaspedcompra.unidade = old.unidade then  (QTDEENTREGUE-old.QUANTIDADE)
                                                                                                        when mercadoriaspedcompra.unidade in ('PC', 'UN') and old.unidade = 'MIL' then QTDEENTREGUE-(old.QUANTIDADE*1000)
                                                                                                        when mercadoriaspedcompra.unidade in ('PC', 'UN') and old.unidade = 'CT' then QTDEENTREGUE-(old.QUANTIDADE*100) end
  WHERE MERCADORIASPEDCOMPRA.FILIAL=old.FILIAL
  AND MERCADORIASPEDCOMPRA.IDNOTA=old.IDPEDIDO
  AND MERCADORIASPEDCOMPRA.IDMERCADORIA=old.IDMERCPEDIDO;
  

  UPDATE MERCADORIASPEDCOMPRA SET QTDEENTREGUE= case when mercadoriaspedcompra.unidade = new.unidade then  (QTDEENTREGUE+NEW.QUANTIDADE)
                                                                                                        when mercadoriaspedcompra.unidade in ('PC', 'UN') and new.unidade = 'MIL' then QTDEENTREGUE+(NEW.QUANTIDADE*1000)
                                                                                                        when mercadoriaspedcompra.unidade in ('PC', 'UN') and new.unidade = 'CT' then QTDEENTREGUE+(NEW.QUANTIDADE*100) end
  WHERE MERCADORIASPEDCOMPRA.FILIAL=NEW.FILIAL
  AND MERCADORIASPEDCOMPRA.IDNOTA=NEW.IDPEDIDO
  AND MERCADORIASPEDCOMPRA.IDMERCADORIA=NEW.IDMERCPEDIDO;
  

  UPDATE MERCADORIASPEDCOMPRA SET QTDEENTREGUE=(QTDEENTREGUE+NEW.QUANTIDADE)-old.QUANTIDADE
  WHERE MERCADORIASPEDCOMPRA.FILIAL=NEW.FILIAL
  AND MERCADORIASPEDCOMPRA.IDNOTA=NEW.IDPEDIDO
  AND MERCADORIASPEDCOMPRA.IDMERCADORIA=NEW.IDMERCPEDIDO;
  
  
  UPDATE MERCADORIASPED SET QTDEENVIADA=(QTDEENVIADA-NEW.QUANTIDADE)+old.QUANTIDADE
  WHERE MERCADORIASPED.FILIAL=NEW.FILIAL
  AND MERCADORIASPED.IDNOTA=NEW.IDPEDVENDEV
  AND MERCADORIASPED.IDMERCADORIA=NEW.IDPEDVENMERCDEV;
  
  
END^
SET TERM ; ^
