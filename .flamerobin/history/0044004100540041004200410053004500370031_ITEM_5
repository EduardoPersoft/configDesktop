SET TERM ^ ;
CREATE trigger mercnota_atualizaexpedicao1 for mercadoriasnota
active before delete position 0
AS
begin
  /* Trigger text */
  if (OLD.idmovimento is not null) then
      update movimentoestoque set movimentoestoque.idnotaexpedicao = null
      where movimentoestoque.filial=mercadoriasnota.MOVIMENTOESTOQUEFILIAL
      and movimentoestoque.idmovimento=mercadoriasnota.idmovimento;
end

^
SET TERM ; ^


