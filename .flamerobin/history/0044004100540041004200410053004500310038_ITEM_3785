SELECT ITEMESTOQUE.CODIGO,
       ITEMESTOQUE.DESCRICAO,
       substring(MATERIALLOTE.LOTE from 1 for 3) as lote,
       MATERIALLOTE.C_LARGURA,
       sum(MATERIALLOTE.QUANTIDADE-
		COALESCE((SELECT SUM(COMPOSICAOOP.QUANTIDADE) FROM COMPOSICAOOP
		 INNER JOIN MATERIALMOVIMENTOESTOQUE ON 
		 (MATERIALMOVIMENTOESTOQUE.FILIAL=COMPOSICAOOP.FILIAL
		 AND MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO=COMPOSICAOOP.IDMOVIMENTO
		 AND MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL=COMPOSICAOOP.IDMOVIMENTOMATERIAL)
		 INNER JOIN MOVIMENTOESTOQUE ON
		 (MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL
		 AND MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO)
		 WHERE COMPOSICAOOP.FILIAL=MATERIALLOTEDISPONIVEL.FILIAL
		 AND COMPOSICAOOP.CODIGO=MATERIALLOTEDISPONIVEL.IDITEM
		 AND COMPOSICAOOP.LOTE=MATERIALLOTEDISPONIVEL.LOTE
		 AND MATERIALMOVIMENTOESTOQUE.CONCLUIDO='N'),0))

	   QUANTIDADE,
	   cast(null as date) PrevisaoChegada,
       cast(0 as decimal(12,2)) as RESERVA
FROM MATERIALLOTEDISPONIVEL 
INNER JOIN MATERIALLOTE ON (MATERIALLOTE.FILIAL=MATERIALLOTEDISPONIVEL.FILIAL 
   AND MATERIALLOTE.IDITEM=MATERIALLOTEDISPONIVEL.IDITEM
   AND MATERIALLOTE.LOTE=MATERIALLOTEDISPONIVEL.LOTE)
INNER JOIN ITEMESTOQUE ON (MATERIALLOTEDISPONIVEL.IDITEM=ITEMESTOQUE.CODIGO)
WHERE ITEMESTOQUE.C_MODELO IS NOT NULL
--AND MATERIALLOTEDISPONIVEL.LOTE<>'.'
GROUP BY 1,2,3,4,6
ORDER BY ITEMESTOQUE.DESCRICAO,4