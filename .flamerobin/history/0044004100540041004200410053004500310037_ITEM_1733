

select
    materialfilial.filial,
    itemestoque.codigo,
    itemestoque.descricao,
    materialfilial.c_localimportacao,
    itemestoque.C_LOCALIMPORTACAO,
    itemestoque.DATAALTERACAO
from
    MATERIALFILIAL
inner join
    itemestoque on
        materialfilial.iditem=itemestoque.codigo            
        
where
    itemestoque.codigo like '1%' and
    itemestoque.C_LOCALIMPORTACAO <> 
        (select 
            materialfilial.C_LOCALIMPORTACAO 
         from 
            materialfilial 
         where 
            filial=1 and 
            materialfilial.iditem=ITEMESTOQUE.codigo)
order by
    itemestoque.codigo