INSERT INTO COMENTARIOS 
    (ID, IDUSUARIO, DATAHORA, COMENTARIO, DOCUMENTO, UUID, PART)
SELECT
    COMENTARIOS.ID,
    COMENTARIOS.IDUSUARIO,
    COMENTARIOS.DATAHORA,
    COMENTARIOS.COMENTARIO,
    COMENTARIOS.DOCUMENTO,
    COMENTARIOS.UUID,
    MERCADORIASPEDCOMPRA.IDMERCADORIA
FROM
    COMENTARIOS
INNER JOIN
    PEDIDOCOMPRA ON
        PEDIDOCOMPRA.UUID = COMENTARIOS.UUID
INNER JOIN
    MERCADORIASPEDCOMPRA ON
        MERCADORIASPEDCOMPRA.FILIAL=PEDIDOCOMPRA.FILIAL AND
        MERCADORIASPEDCOMPRA.IDNOTA=PEDIDOCOMPRA.IDNOTA