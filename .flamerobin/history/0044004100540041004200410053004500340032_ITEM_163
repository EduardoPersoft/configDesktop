select
    0 as ordem,
    'E' as entradaSaida,
    nota.modelo,
    MODELODOCTO.MODELO,
    nota.dataemissao,
    cadpar.razaosocial,
    nota.numeronota,
    mercadorias.cfop,
    itemestoque.TIPOPRODUTO,

    sum(mercadorias.vlrfinalmercad)*(-1) as vlrfinalmercad ,
    
    sum(mercadorias.frete+
    mercadorias.seguro+
    mercadorias.OUTDESPACESSOR)*(-1) FRETE,
    
    sum(MERCADORIAS.VALORIPI) as valoripi*(-1),
    sum(case itemestoque.tipoproduto when '1' then mercadorias.valoripi else 0 end)*(-1) valoripiCredito,
    
    sum(mercadorias.vlrfinalmercad+
    mercadorias.frete+
    mercadorias.seguro+
    mercadorias.OUTDESPACESSOR+
    MERCADORIAS.VALORIPI)*(-1) TOTAL,
   
    sum(case when itemestoque.tipoproduto in ('1', '3') then mercadorias.valoricms else 0 end)*(-1) as valoricms,
    
    sum(coalesce(MATERIALMOVIMENTOESTOQUE.valor,0))*(-1) as valorestoque
       
from 
    notafiscal nota
inner join
    MERCADORIASNOTA mercadorias on
        mercadorias.filial=nota.filial and
        mercadorias.idnota=nota.IDNOTA
inner join
    cadastroparceiros cadpar on
        cadpar.cadastro=nota.DESTINATARIO
inner join
    itemestoque on
        itemestoque.codigo=mercadorias.CODIGO
left join
    modelodocto on
        modelodocto.id=nota.modelo
left join
    movimentoestoque on
        movimentoestoque.filial=nota.filial and
        movimentoestoque.IDNOTA=nota.idnota
left join
    materialmovimentoestoque on
        materialmovimentoestoque.filial=movimentoestoque.filial and
        materialmovimentoestoque.idmovimento=movimentoestoque.idmovimento and
        materialmovimentoestoque.idmovimentomaterial=mercadorias.idmercadoria
where
    nota.filial=110 and
    nota.dataemissao between '2023-08-01' and '2023-08-31' and
    nota.ENTRADASAIDA = 'S' and
    coalesce(nota.DEVOLUCAO, 'N') = 'S'
group by    
    nota.modelo,
    MODELODOCTO.MODELO,
    mercadorias.cfop,
    nota.dataemissao,
    cadpar.razaosocial,
    nota.numeronota,    
    itemestoque.TIPOPRODUTO
order by 
    1,2,nota.modelo,
    MODELODOCTO.MODELO,
    mercadorias.cfop,
    nota.dataemissao,
    cadpar.razaosocial,
    nota.numeronota,    
    itemestoque.TIPOPRODUTO    


