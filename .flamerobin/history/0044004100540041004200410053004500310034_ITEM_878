select
    FILIAL,
    IDNOTA,
    CODIGO,
    CFOP,
    VLRTOTALMERCAD,
    VALORICMS
from
    MERCADORIASNOTACOMPRA
INNER join
    ITEMESTOQUE ON
        ITEMESTOQUE.CODIGO=MERCADORIASNOTACOMPRA.CODIGO
where
    MERCADORIASNOTACOMPRA.FILIAL=110
    AND MERCADORIASNOTACOMPRA.CFOP IN ('1102', '2102', '3101')
    AND ITEMESTOQUE.TIPOPRODUTO='1'