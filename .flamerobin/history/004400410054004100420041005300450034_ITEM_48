select 
    filial,idnota,PEDIDOCOMPRA.TIPOPAGAMENTO
from
    PEDIDOCOMPRA
where 
    (select
        *
     from
        MERCADORIASPEDCOMPRA
     where
        mercadoriaspedcompra.filial=pedidocompra.filial
        and mercadoriaspedcompra.idnota=pedidocompra.idnota
        and mercadoriaspedcompra.baixa='N')