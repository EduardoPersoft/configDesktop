select 
    T_ESTOQUE0802.CODIGO,
    materiallocal.SALDOTOTAL,
    T_ESTOQUE0802.LOCACAO
from 
    T_ESTOQUE0802
inner JOIN
    materiallocal on
        materiallocal.filial=12826 AND
        materiallocal.iditem = T_ESTOQUE0802.CODIGO AND
        MATERIALLOCAL.IDLOCAL=1
        
WHERE 
    MATERIALLOCAL.SALDOTOTAL > 0.009
ORDER BY
    3