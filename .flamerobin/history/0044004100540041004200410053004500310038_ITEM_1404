select pedido.filial, 
       pedido.idnota, 
       pedido.c_loja,
       pedido.datacadastro,
       pedido.DATAEMISSAO,
       pedido.C_DATACOMISSAO,
       pedido.C_PEDIDOSUBSTITUIDO
from
        pedido
where
    pedido.c_loja=3 and
    (pedido.c_datacadastro >= '01.02.2023' or
     pedido.C_DATACOMISSAO >='01.02.2023')
