 select 
    cast('now' as date), 
    locallote.filial,
    locallote.iditem,
    itemestoque.descricao,
    locallote.lote,
    locallote."LOCAL",
    local.descricao,
    c_fornecedorpeca.descricao  fornecedorNome,
    itemestoque.referencia,
    locallote.quantidade saldoatual,
    inventario.data dataInventario,
    inventario.quantidade contado,
    inventario.quantidadeEstoque esperado,
    case when inventario.quantidade is null 
        then null
        else coalesce(inventario.quantidade,0)-coalesce(inventario.quantidadeEstoque,0)
    end as diferenca,    
    inventario.idmovimento,
    case 
        when inventario.data is null then 10
        when inventario.quantidade=inventario.quantidadeEstoque then 9
        when inventario.idmovimento is null then 1
        when inventario.idmovimento is not null then 9
    end  ,
    case when inventario.data is null then 'black'
         when inventario.quantidadeEstoque=inventario.quantidade then 'blue'
         when inventario.quantidadeEstoque>inventario.quantidade then 'red'
         else 'green'
    end as cor
from 
    locallote
inner join
    itemestoque on
        itemestoque.codigo=locallote.iditem
left join
    local on
        local.id=locallote."LOCAL"
left join
     c_fornecedorpeca on
        c_fornecedorpeca.id=itemestoque.C_FORNECEDOR
left join
    INVENTARIOESTOQUEDATA inventario on
        inventario.filial=locallote.filial and
        inventario.codigo=locallote.IDITEM and
        inventario.lote=locallote.lote and
        inventario."LOCAL"=locallote."LOCAL" and
        inventario.data = (select 
                                max(ultimoInventario.data)
                           from
                                INVENTARIOESTOQUEDATA ultimoInventario
                           where    
                                ultimoInventario.filial=inventario.filial and
                                ultimoInventario.codigo=inventario.codigo and
                                ultimoInventario.lote=inventario.lote and
                                ultimoInventario.local=inventario.local and
                                ultimoInventario.data>='01.01.2022')
where
    locallote.filial=1 and 
    (locallote.quantidade<>0 or (inventario.quantidade<>inventario.quantidadeestoque and 
                                inventario.idmovimento is null))
union                                

select 
    cast('now' as date), 
    inventario.filial,
    inventario.codigo iditem,
    itemestoque.descricao,
    inventario.lote,
    inventario."LOCAL",
    local.descricao,
    c_fornecedorpeca.descricao  fornecedorNome,
    itemestoque.referencia,
    0 as saldoatual,
    inventario.data dataInventario,
    inventario.quantidade contado,
    inventario.quantidadeEstoque esperado,
    case when inventario.quantidade is null 
        then null
        else coalesce(inventario.quantidade,0)-coalesce(inventario.quantidadeEstoque,0)
    end as diferenca,    
    inventario.idmovimento,
    case 
        when inventario.data is null then 10
        when inventario.quantidade=inventario.quantidadeEstoque then 9
        when inventario.idmovimento is null then 1
        when inventario.idmovimento is not null then 9
    end  ,
    case when inventario.data is null then 'black'
         when inventario.quantidadeEstoque=inventario.quantidade then 'blue'
         when inventario.quantidadeEstoque>inventario.quantidade then 'red'
         else 'green'
    end as cor
from 
    INVENTARIOESTOQUEDATA inventario
inner join
    itemestoque on
        itemestoque.codigo=inventario.codigo
left join
    local on
        local.id=inventario.local
left join
     c_fornecedorpeca on
        c_fornecedorpeca.id=itemestoque.C_FORNECEDOR
where    
    inventario.filial=1 and
    not exists (select 
                    * 
                from 
                    locallote 
                where 
                    locallote.filial=inventario.filial and
                    locallote.IDITEM=inventario.codigo and
                    locallote.local=inventario."LOCAL" and
                    locallote.lote=inventario.lote and
                    locallote.quantidade > 0)     and 
    inventario.data = (select 
                     max(ultimoInventario.data)
                 from
                     INVENTARIOESTOQUEDATA ultimoInventario
                   where    
                     ultimoInventario.filial=inventario.filial and
                     ultimoInventario.codigo=inventario.codigo and
                     ultimoInventario.lote=inventario.lote and
                     ultimoInventario.local=inventario.local and
                     ultimoInventario.data>='01.01.2022')  and   

    inventario.quantidade<>inventario.quantidadeestoque and 
    inventario.idmovimento is null
order by
    16,
    11,
    9, 
    3
