update 
    mercadoriasnota
set 
    mercadoriasnota.CSTIBSCBS='000',
    mercadoriasnota.CCLASSTRIB='000001'
where
    exists  ( select * from NOTAFISCAL
              where notafiscal.filial=mercadoriasnota.filial 
              and notafiscal.idnota=mercadoriasnota.idnota 
              and notafiscal.dataemissao is null)
    
