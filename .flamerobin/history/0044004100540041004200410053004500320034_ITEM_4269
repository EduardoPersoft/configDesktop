SELECT ITEMESTOQUE.CODIGO ITEMESTOQUE_CODIGO,

       case itemestoque.ESTOCADO when 'N' 
       then coalesce(itemestoque.itembase,itemestoque.codigo) 
       else itemestoque.codigo end as codigoestoque,
       
       ITEMESTOQUE.DESCRICAO ITEMESTOQUE_DESCRICAO,
       ITEMESTOQUE.UNIDADE ITEMESTOQUE_UNIDADE,


       COALESCE(LP2.PRECO, LP1.preco) LISTAPRECO_PRECO,  
	   COALESCE(LP2.PRECO, LP1.preco) LISTAPRECO_PRECOORIGINAL,  
       COALESCE(ESTABELECIMENTO.LDESCVENDAS,0) MERCPED_PDESCCOMALPERMITIDO,
       COALESCE(COALESCE(LP2.DESCONTOITEM, LP1.DESCONTOITEM), 0) MERCPED_PDESCPRPERMITIDO,

       COALESCE(LP2.COMISSAO, LP1.COMISSAO)               MERCPED_COMISSAO               ,
       COALESCE(LP2.MARGEMLUCRO, LP1.MARGEMLUCRO)            MERCPED_MARGEMLUCRO            ,
       COALESCE(LP2.MARGEMCONTRIBUICAO, LP1.MARGEMCONTRIBUICAO)     MERCPED_MARGEMCONTRIBUICAO     ,
       case coalesce(l1.Precovariavel, l0.precoVariavel) when '0' then 0 else cast(coalesce(COALESCE(LP2.VARIAVEL, LP1.VARIAVEL),0) as integer) end MERCPED_VARIAVEL,
       COALESCE(LP2.CUSTOCONSIDERADO,LP1.CUSTOCONSIDERADO)        MERCPED_CUSTO                  ,	
       
       case when lp2.produto is null 
       then COALESCE(l0.ALTERAPRECO, 'S') 
       else COALESCE(l1.ALTERAPRECO, 'S')
       end as ALTERARPRECO, 

       ITEMESTOQUEXARQUIVO.NOMEARQUIVO ITEMESTOQUE_NOMEARQUIVO,	   	   
       ITEMESTOQUE.definicao ITEMESTOQUE_DEFINICAO,
       ITEMESTOQUE.DESCRIMINACAO ITEMESTOQUE_DESCRIMINACAO,
       ITEMESTOQUE.REFERENCIA ITEMESTOQUE_REFERENCIA,
       GRUPOMERCADORIA.DESCRICAO AS ITEMESTOQUE_GRUPO,
       FAMILIA.DESCRICAO AS ITEMESTOQUE_FAMILIA,

	   ITEMESTOQUE.ESTOCADO ITEMESTOQUE_ESTOCADO,
       coalesce(ITEMESTOQUE.pesoliquido, 0) as  ITEMESTOQUE_PESOLIQUIDO,
       coalesce(ITEMESTOQUE.pesobruto, 0) as ITEMESTOQUE_PESOBRUTO,
       coalesce(ITEMESTOQUE.quantidadeunidade, 1) ITEMESTOQUE_QUANTIDADEUNIDADE,
       ITEMESTOQUE.quantidadevolume ITEMESTOQUE_QUANTIDADEVOLUME,
       coalesce(ITEMESTOQUE.fatorunidades,1) ITEMESTOQUE_FATORUNIDADES,
       ITEMESTOQUE.UNIDADE ITEMESTOQUE_UNIDADE,

       classificacaofiscal.cfiscal CF_CFISCAL,
       classificacaofiscal.descricao CF_DESCRICAO,
       classificacaofiscal.cest cest,
       CLASSIFICACAOFISCAL.cst CF_CST,
       COALESCE(CLASSIFICACAOFISCAL.aliquota,0) CF_ALIQUOTA ,
       classificacaofiscal.cstpis CF_CSTPIS,
       classificacaofiscal.ppis CF_PPIS,
       classificacaofiscal.cstcofins CF_CSTCOFINS,
       classificacaofiscal.pCOFINS CF_PCOFINS,
       classificacaofiscal.aliqnacional CF_ALIQNACIONAL,
       classificacaofiscal.aliqimportada CF_ALIQIMPORTADA,
       classificacaofiscal.aliqMun CF_Municipal,
       classificacaofiscal.aliqEst CF_Estadual,

       COALESCE(NATUREZAOPERACAO.ipi,'S') NATUREZAOPERACAO_IPI,
       COALESCE(NATUREZAOPERACAO.icms,'S') NATUREZAOPERACAO_ICMS,
       COALESCE(NATUREZAOPERACAO.substtributaria,'S') SUBSTITUICAOTRIBUTARIA,
       NATUREZAOPERACAO.codigotributacao NATUREZAOPERACAO_CODIGOTRIBUT,
       NATUREZAOPERACAO.cstipi NATUREZAOPERACAO_CSTIPI,
       naturezaoperacao.piscofins NATUREZAOPERACAO_PISCOFINS,
       NATUREZAOPERACAO.cstpis NATUREZAOPERACAO_CSTPIS,
       NATUREZAOPERACAO.cstcofins NATUREZAOPERACAO_CSTCOFINS,
       NATUREZAOPERACAO.cfop NATUREZAOPERACAO_CFOP,
       NATUREZAOPERACAO.cfoprevenda NATUREZAOPERACAO_CFOPREVENDA,
       NATUREZAOPERACAO.CFOPSUBSTITUICAO,
       NATUREZAOPERACAO.CFOPSUBSTITUICAOSUBSTITUTO,
       NATUREZAOPERACAO.CFOPSUBSTITUICAOREVENDA,
       NATUREZAOPERACAO.CFOPSUBSTITUICAOJARECOLHIDO,
       NATUREZAOPERACAO.CFOPSUBSTITUIDO,

       COALESCE(ESTABELECIMENTO.aliquotasimples,0) ESTABELECIMENTO_ALIQUOTASIMPLES,
       COALESCE(ESTABELECIMENTO.pis,0) ESTABLECIMENTO_PIS,
       COALESCE(ESTABELECIMENTO.cofins,0) ESTABLECIMENTO_COFINS,
       coalesce(ESTABELECIMENTO.comercialSomente, 'N') comercialSomente,

       ITEMESTOQUE.tributacaoicms ITEMESTOQUE_TRIBUTACAOICMS,
       COALESCE(C_CADASTROPARCEIROS.contribuinte,'N') C_CADASTROPARCEIROS_CONTR,
       COALESCE(ESTADO.picmsinterestadual,0) ESTADO_PICMSINTERESTADUAL,

       E_CADASTROPARCEIROS.UF E_CADASTROPARCEIROS_UF,
       COALESCE(E_TRIBUTACAOICMS.ALIQUOTA,0) E_TRIBUTACAOICMS_ALIQUOTA,
       COALESCE(E_TRIBUTACAOICMS.FCP,0) E_TRIBUTACAOICMS_FCP,
       E_TRIBUTACAOICMS.TIPOSUBSTITUICAO E_ICMS_TIPOST,
       COALESCE(E_TRIBUTACAOICMS.LUCROSUBSTITUICAO,0) E_ICMS_IVAST,
       E_TRIBUTACAOICMS.IVAAJUSTADO,       
       E_TRIBUTACAOICMS.CONSUMIDORFINAL,
       E_TRIBUTACAOICMS.AJUSTARBASESTCONSUMIDORFINAL,
       
       C_CADASTROPARCEIROS.UF C_CADASTROPARCEIROS_UF,
       COALESCE(C_TRIBUTACAOICMS.ALIQUOTA,0) C_TRIBUTACAOICMS_ALIQUOTA,
       COALESCE(C_TRIBUTACAOICMS.FCP,0) C_TRIBUTACAOICMS_FCP,
       C_TRIBUTACAOICMS.TIPOSUBSTITUICAO C_ICMS_TIPOST,
       COALESCE(C_TRIBUTACAOICMS.LUCROSUBSTITUICAO,0) C_ICMS_IVAST,
       C_TRIBUTACAOICMS.IVAAJUSTADO,       
       C_TRIBUTACAOICMS.CONSUMIDORFINAL,
       C_TRIBUTACAOICMS.AJUSTARBASESTCONSUMIDORFINAL,
 
 
       cast(ITEMESTOQUE.codigotributacao as integer) ITEMESTOQUE_CODIGOTRIBUTACAO,
        ITEMESTOQUE.TIPOPRODUTO ITEMESTOQUE_TIPOPRODUTO,
       COALESCE(clientes.reducaoipi,0) as CLIENTES_REDUCAOIPI,
       coalesce(CLIENTES.CONSUMIDORFINAL, 'N') consumidorfinal,  
        
       coalesce((select 
            sum(materiallocal.saldototal)
        from 
            MATERIALLOCAL 
        inner JOIN
            local on
                local.ID=materiallocal.IDLOCAL
        where
            MATERIALLOCAL.FILIAL=E_CADASTROPARCEIROS.CADASTRO AND            
            MATERIALLOCAL.IDITEM=case itemestoque.estocado when 'N'
                                 then coalesce(itemestoque.itembase, itemestoque.codigo)
                            else itemestoque.codigo end and
            local.DISPONIVEL='S'),0)
        -
        coalesce((select 
            sum(m2.quantidade - coalesce(m2.qtdeenviada,0))
         FROM
            MERCADORIASPED m2
         INNER JOIN
            PEDIDO p2 ON
                p2.FILIAL=m2.FILIAL AND
                p2.IDNOTA=m2.IDNOTA and
                p2.cancelamento='N' and
                p2.dataemissao is not null 
         WHERE
            m2.FILIAL=E_CADASTROPARCEIROS.CADASTRO AND
            m2.baixa='N' AND
            m2.codigoestoque=case itemestoque.estocado when 'N'
                                 then coalesce(itemestoque.itembase, itemestoque.codigo)
                                 else itemestoque.codigo end 
                         ),0)
             MERCPED_ESTOQUEDISPONIVEL,
    
       ( SELECT
            FIRST 1
            NOTAFISCAL.DATACADASTRO
        FROM
            NOTAFISCAL
        INNER JOIN
            MERCADORIASNOTA ON
                MERCADORIASNOTA.FILIAL=NOTAFISCAL.FILIAL AND
                MERCADORIASNOTA.IDNOTA=NOTAFISCAL.IDNOTA
        WHERE
            NOTAFISCAL.FILIAL=E_CADASTROPARCEIROS.CADASTRO AND
            NOTAFISCAL.DESTINATARIO=C_CADASTROPARCEIROS.CADASTRO AND
            MERCADORIASNOTA.CODIGO=ITEMESTOQUE.CODIGO
        ORDER BY 
            NOTAFISCAL.DATACADASTRO DESC, NOTAFISCAL.IDNOTA DESC) as MERCPED_DATAULTIMACOMPRA,
       ( SELECT
            FIRST 1
            MERCADORIASNOTA.PRECOUNITARIO
        FROM
            NOTAFISCAL
        INNER JOIN
            MERCADORIASNOTA ON
                MERCADORIASNOTA.FILIAL=NOTAFISCAL.FILIAL AND
                MERCADORIASNOTA.IDNOTA=NOTAFISCAL.IDNOTA
        WHERE
            NOTAFISCAL.FILIAL=E_CADASTROPARCEIROS.CADASTRO AND
            NOTAFISCAL.DESTINATARIO=C_CADASTROPARCEIROS.CADASTRO AND
            MERCADORIASNOTA.CODIGO=ITEMESTOQUE.CODIGO
        ORDER BY 
            NOTAFISCAL.DATACADASTRO DESC, NOTAFISCAL.IDNOTA DESC) as MERCPED_PRECOULTIMACOMPRA,

       (select first 1 resumocompras.EMISSAO from RESUMOCOMPRAS
        where resumocompras.item=COALESCE(ITEMESTOQUE.ITEMBASE, itemestoque.codigo)
        order by emissao desc) as ultimaCompra

FROM itemestoque

INNER JOIN cadastroparceiros E_CADASTROPARCEIROS ON (E_CADASTROPARCEIROS.CADASTRO=12826)

LEFT JOIN GRUPOMERCADORIA ON (GRUPOMERCADORIA.GRUPO=ITEMESTOQUE.GRUPO)
LEFT JOIN FAMILIA ON (FAMILIA.ID=ITEMESTOQUE.FAMILIA)
left JOIN TRIBUTACAOICMSUF E_TRIBUTACAOICMS ON (E_TRIBUTACAOICMS.ID=ITEMESTOQUE.tributacaoicms
        AND E_TRIBUTACAOICMS.UF=E_CADASTROPARCEIROS.UF)
left JOIN CADASTROPARCEIROS C_CADASTROPARCEIROS ON (C_CADASTROPARCEIROS.CADASTRO=166)
left JOIN TRIBUTACAOICMSUF C_TRIBUTACAOICMS ON (C_TRIBUTACAOICMS.ID=ITEMESTOQUE.tributacaoicms
        AND C_TRIBUTACAOICMS.UF=C_CADASTROPARCEIROS.UF)
left JOIN ESTADO ON (ESTADO.estado=C_CADASTROPARCEIROS.UF)
LEFT JOIN CLASSIFICACAOFISCAL ON (ITEMESTOQUE.classifiscal=CLASSIFICACAOFISCAL.cfiscal)
LEFT JOIN CLIENTES ON (CLIENTES.CADASTRO=C_CADASTROPARCEIROS.CADASTRO)
LEFT JOIN NATUREZAOPERACAO ON (NATUREZAOPERACAO.ID=52)
LEFT JOIN ESTABELECIMENTO ON (ESTABELECIMENTO.CADASTRO=E_CADASTROPARCEIROS.cadastro)

LEFT JOIN LISTAPRECOPRODUTO LP1 ON (LP1.LISTA=3
								AND LP1.PRODUTO=itemestoque.codigo)
LEFT JOIN LISTAPRECO L0 ON L0.LISTA=LP1.LISTA
LEFT JOIN LISTAPRECO L1 ON L1.LISTAREFERENCIA=LP1.LISTA
LEFT JOIN LISTAPRECOPRODUTO LP2 ON (LP2.LISTA=L1.LISTA
								AND LP2.PRODUTO=itemestoque.codigo)
LEFT JOIN ITEMESTOQUEXARQUIVO ON (
    ITEMESTOQUEXARQUIVO.CODIGO=ITEMESTOQUE.CODIGO AND
    ITEMESTOQUEXARQUIVO.ORDEM=0)
WHERE ITEMESTOQUE.CODIGO='1002103'

