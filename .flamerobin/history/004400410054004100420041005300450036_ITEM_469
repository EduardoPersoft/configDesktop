SET TERM ^ ;
ALTER PROCEDURE IMPPED
RETURNS (
    FILIAL INTEGER,
    RAZAOFILIAL VARCHAR(50),
    IDNOTA INTEGER,
    CLIENTE INTEGER,
    NOMECLIENTE VARCHAR(50),
    AREAGEOGRAFICA SMALLINT,
    DESCRAREAGEOGR VARCHAR(30),
    LOGRADOURO VARCHAR(50),
    NUMERO INTEGER,
    BAIRRO VARCHAR(30),
    COMPLEMENTO VARCHAR(20),
    CIDADE VARCHAR(30),
    UF VARCHAR(2),
    CEP VARCHAR(8),
    DOCUMENTO VARCHAR(14),
    INSCESTADUAL VARCHAR(20),
    INSCMUNICIPAL VARCHAR(20),
    EMAIL VARCHAR(50),
    TELEFONE VARCHAR(20),
    FAX VARCHAR(20),
    PRINCIPALCONTATO VARCHAR(40),
    NUMEROPEDIDO VARCHAR(20),
    DATAEMISSAO TIMESTAMP,
    CFOP INTEGER,
    NATUREZAOPERACAO VARCHAR(30),
    VLRIPITOTAL DOUBLE PRECISION,
    VLRDESPESAS DOUBLE PRECISION,
    VLRZONAFRANCA DOUBLE PRECISION,
    VLRSUBSTRIB DOUBLE PRECISION,
    VLRTOTALNOTA DOUBLE PRECISION,
    VLRDESCONTO DOUBLE PRECISION,
    VLRACRESCIMO DOUBLE PRECISION,
    TIPOPAGTO VARCHAR(30),
    CONDICAOPAGTO VARCHAR(30),
    TIPODETALHE VARCHAR(15),
    CODIGO VARCHAR(20),
    DESCRICAO BLOB SUB_TYPE 0,
    QUANTIDADE DOUBLE PRECISION,
    UNIDADE VARCHAR(3),
    PRUNITARIO DOUBLE PRECISION,
    VLRIPIMERC DOUBLE PRECISION,
    VLRTOTITEM DOUBLE PRECISION,
    VLRFINALITEM DOUBLE PRECISION,
    ENTREGA TIMESTAMP,
    VLRPARCIAL DOUBLE PRECISION,
    QTDEVOLUME DOUBLE PRECISION,
    PESOLIQUIDO DOUBLE PRECISION,
    PESOBRUTO DOUBLE PRECISION,
    COMENTARIO BLOB SUB_TYPE 0,
    OBSERVACAO BLOB SUB_TYPE 0,
    MSGADICIONAL BLOB SUB_TYPE 0,
    VENDEDOR INTEGER,
    NOMEVEND VARCHAR(50),
    COMISSAOVENDA DOUBLE PRECISION,
    COMISSAORECEB DOUBLE PRECISION,
    CODTRANSP INTEGER,
    NOMETRANSP VARCHAR(50),
    FONETRANSP VARCHAR(30),
    LIMITECREDITO DOUBLE PRECISION,
    CREDITOEXCEDIDO DOUBLE PRECISION,
    PEDIDOSEMABERTO DOUBLE PRECISION,
    TITULOSEMABERTO DOUBLE PRECISION,
    TITULOSEMATRASO DOUBLE PRECISION,
    NOTASEMABERTO DOUBLE PRECISION,
    LOCAL VARCHAR(40),
    CODIGOBARRA CHAR(13),
    COMANDOSALVAR CHAR(13),
    COMANDOCONCLUIR CHAR(13),
    COMANDOPESOVOLUME CHAR(13),
    COMANDOTRANS CHAR(13),
    COMANDONOVO CHAR(13),
    NOMEFORNECEDOR VARCHAR(60) )
AS
declare variable p_dadosentrega char(1);
declare variable p_logrentrega varchar(50);
declare variable p_numentrega integer;
declare variable p_bairroentrega varchar(30);
declare variable p_complentrega varchar(20);
declare variable p_cidentrega varchar(30);
declare variable p_ufentrega varchar(2);
declare variable p_cepentrega varchar(8);
declare variable p_docentrega varchar(14);
declare variable p_inscestentrega varchar(20);
declare variable p_frete double precision;
declare variable p_seguro double precision;
declare variable p_outras double precision;
declare variable p_acrescmerc double precision;
declare variable p_acrescserv double precision;
declare variable p_descmercped double precision;
declare variable p_descindmerc double precision;
declare variable p_descservped double precision;
declare variable p_descindserv double precision;
declare variable p_zonafranca char(1);
declare variable p_totalicms double precision;
declare variable p_substrib char(1);
declare variable p_recolhido double precision;
declare variable p_id integer;
declare variable v_id integer;
declare variable v_totalmercped double precision;
declare variable v_totalservped double precision;
declare variable v_totalemaberto double precision;
BEGIN
  FOR SELECT PEDIDO.FILIAL, CADASTROFILIAL.RAZAOSOCIAL AS FILIALRAZAO,
             PEDIDO.IDNOTA, PEDIDO.DESTINATARIO,
             CADASTROCLIENTE.NOME AS NOMECL, CLIENTES.LIMITECREDITO, 
             CADASTROCLIENTE.LOGRADOURO, CADASTROCLIENTE.NUMERO,
             CADASTROCLIENTE.BAIRRO, CADASTROCLIENTE.COMPLEMENTO,
             CADASTROCLIENTE.CIDADE, CADASTROCLIENTE.UF,
             CADASTROCLIENTE.CEP, CADASTROCLIENTE.DOCUMENTO,
             CADASTROCLIENTE.INSCESTADUAL, CADASTROCLIENTE.EMAIL,
             CADASTROCLIENTE.TELEFONE, CADASTROCLIENTE.FAX,
             CADASTROCLIENTE.PRINCIPALCONTATO, PEDIDO.DADOSENTREGA,
             PEDIDO.LOGRADOUROENTREGA, PEDIDO.NUMEROENTREGA, 
             PEDIDO.BAIRROENTREGA, PEDIDO.COMPLEMENTOENTREGA,
             PEDIDO.CIDADEENTREGA, PEDIDO.UFENTREGA, 
             PEDIDO.CEPENTREGA, PEDIDO.DOCUMENTOENTREGA, 
             PEDIDO.INSCRESTADENTREGA, CADASTROCLIENTE.INSCMUNICIPAL,
         CADASTROCLIENTE.AREAGEOGRAFICA, 
             AREAGEOGRAFICA.DESCRICAO AS AREAGEODESC,
         PEDIDO.NUMERONOTA, PEDIDO.DATAEMISSAO, 
             PEDIDO.VALORIPI, PEDIDO.VALORFRETE, PEDIDO.VALORSEGURO,
             PEDIDO.VLROUTDESPACESSORIA, PEDIDO.ZONAFRANCA, 
             PEDIDO.TOTVALORICMS, PEDIDO.SUBSTRIBUTARIA, 
             PEDIDO.VLRICMSRECOLHIDO, PEDIDO.VLRTOTALNOTA, 
             PEDIDO.VLRACRESCMERCAD, PEDIDO.VLRACRESCSERVICOS, 
             PEDIDO.VLRDESCINDPRODUTO, PEDIDO.VLRDESCINDSERVICOS, 
             PEDIDO.VLRDESCMERCADORIAS, PEDIDO.VLRDESCSERVICOS,
         PEDIDO.CFOP, PEDIDO.NATUREZAOPERACAO, 
             PEDIDO.QUANTIDADEVOLUME, PEDIDO.PESOLIQUIDO, 
             PEDIDO.PESOBRUTO, PEDIDO.COMENTARIO, PEDIDO.OBSERVACAO,
             PEDIDO.MSGDADOSADICIONAIS, PEDIDO.CODIGOTRANSP, 
             CADASTROTRANSP.NOME, CADASTROTRANSP.TELEFONE,
             TIPOCOBRANCA.DESCRICAO AS TIPOCOBR, 
             CONDICAOPAGAMENTO.DESCRICAO AS CONDPAGTO,

             pedido.NUMERONOTA + (pedido.FILIAL*1000000) + 2100000000000 as codigobarra,

             '2900000000001' AS  COMANDOSALVAR,
             '2900000000002' AS COMANDONOVO,
--             '2900000000003' AS COMANDOORIGEM
             '2900000000004' AS COMANDOPESOVOLUME ,
             '2900000000005' AS COMANDOCONCLUIR,
             '2900000000006' AS COMANDOTRANS

      FROM PEDIDO
      INNER JOIN ESTSIN ON ((ESTSIN.RELATORIO='FATURAMENTO') AND 
                            (PEDIDO.FILIAL=ESTSIN.ESTABELECIMENTO) AND
                            (PEDIDO.idnota BETWEEN ESTSIN.IDNOTAINICIAL AND ESTSIN.IDNOTAFINAL))
      INNER JOIN CADASTROPARCEIROS CADASTROFILIAL ON (PEDIDO.FILIAL=CADASTROFILIAL.CADASTRO)
      INNER JOIN CADASTROPARCEIROS CADASTROCLIENTE ON (PEDIDO.DESTINATARIO=CADASTROCLIENTE.CADASTRO)
      INNER JOIN CADASTROPARCEIROS CADASTROTRANSP ON (PEDIDO.CODIGOTRANSP=CADASTROTRANSP.CADASTRO)
      LEFT JOIN CLIENTES ON (CADASTROCLIENTE.CADASTRO=CLIENTES.CADASTRO)
      LEFT JOIN AREAGEOGRAFICA ON (CADASTROCLIENTE.AREAGEOGRAFICA=AREAGEOGRAFICA.AREAGE)
      LEFT JOIN CONDICAOPAGAMENTO ON (PEDIDO.CONDICAOPAGAMENTO=CONDICAOPAGAMENTO.ID)
      LEFT JOIN TIPOCOBRANCA ON (PEDIDO.TIPOCOBRANCA=TIPOCOBRANCA.TIPOCOBRANCA)
      WHERE NOT (PEDIDO.DATAEMISSAO IS NULL)
      AND   PEDIDO.DATACANCELAMENTO IS NULL
      ORDER BY PEDIDO.FILIAL, PEDIDO.NUMERONOTA
      INTO :FILIAL, :RAZAOFILIAL, :IDNOTA, :CLIENTE, :NOMECLIENTE, 
           :LIMITECREDITO, :LOGRADOURO, :NUMERO, :BAIRRO, :COMPLEMENTO, :CIDADE, :UF, 
           :CEP, :DOCUMENTO, :INSCESTADUAL, :EMAIL, :TELEFONE, :FAX, 
           :PRINCIPALCONTATO, :P_DADOSENTREGA, :P_LOGRENTREGA,
           :P_NUMENTREGA, :P_BAIRROENTREGA, :P_COMPLENTREGA,
           :P_CIDENTREGA, :P_UFENTREGA, :P_CEPENTREGA,
           :P_DOCENTREGA, :P_INSCESTENTREGA, :INSCMUNICIPAL,
           :AREAGEOGRAFICA, :DESCRAREAGEOGR, :NUMEROPEDIDO,
           :DATAEMISSAO, :VLRIPITOTAL, :P_FRETE, :P_SEGURO, :P_OUTRAS,
           :P_ZONAFRANCA, :P_TOTALICMS, :P_SUBSTRIB, :P_RECOLHIDO,
           :VLRTOTALNOTA, :P_ACRESCMERC, :P_ACRESCSERV, 
           :P_DESCINDMERC, :P_DESCINDSERV, :P_DESCMERCPED, 
           :P_DESCSERVPED, :CFOP, :NATUREZAOPERACAO, :QTDEVOLUME, 
           :PESOLIQUIDO, :PESOBRUTO, :COMENTARIO, :OBSERVACAO,
           :MSGADICIONAL, :CODTRANSP, :NOMETRANSP, :FONETRANSP, 
           :TIPOPAGTO, :CONDICAOPAGTO, :codigobarra,
           :COMANDOSALVAR,  :COMANDONOVO, :COMANDOPESOVOLUME ,
           :COMANDOCONCLUIR, :COMANDOTRANS
  DO BEGIN
     CREDITOEXCEDIDO = NULL;
     PEDIDOSEMABERTO = NULL;
     TITULOSEMABERTO = NULL;
     TITULOSEMATRASO = NULL;
     NOTASEMABERTO = NULL;


     SELECT SUM(MERCADORIASPED.VLRFINALMERCAD) TOTAL
     FROM  PEDIDO
     INNER JOIN MERCADORIASPED ON (MERCADORIASPED.FILIAL = PEDIDO.FILIAL
                               AND MERCADORIASPED.IDNOTA = PEDIDO.IDNOTA)
     WHERE PEDIDO.FILIAL=:FILIAL
     AND   PEDIDO.DESTINATARIO=:CLIENTE
     AND   MERCADORIASPED.BAIXA='N'
     INTO  :V_TOTALMERCPED;   
     IF (:V_TOTALMERCPED IS NULL) THEN
        V_TOTALMERCPED = 0;
      
     SELECT SUM(SERVICOSPED.VLRFINALSERVICO) TOTAL 
     FROM PEDIDO
     INNER JOIN SERVICOSPED ON (SERVICOSPED.FILIAL = PEDIDO.FILIAL
                            AND SERVICOSPED.IDNOTA = PEDIDO.IDNOTA)
     WHERE PEDIDO.FILIAL=:FILIAL
     AND   PEDIDO.DESTINATARIO=:CLIENTE
     AND   SERVICOSPED.BAIXA='N'
     INTO  :V_TOTALSERVPED;  
     IF (:V_TOTALSERVPED IS NULL) THEN
        V_TOTALSERVPED = 0; 
     IF ((:V_TOTALMERCPED > 0) OR (:V_TOTALSERVPED > 0)) THEN
        PEDIDOSEMABERTO = :V_TOTALMERCPED + :V_TOTALSERVPED;

     SELECT SUM(NOTAFISCAL.VLRTOTALNOTA) TOTAL
     FROM  NOTAFISCAL
     WHERE NOTAFISCAL.FILIAL=:FILIAL
     AND   NOTAFISCAL.DESTINATARIO=:CLIENTE
     AND   NOTAFISCAL.DATAEMISSAO IS NULL
     INTO :NOTASEMABERTO;
    
     SELECT SUM(TITULOREC.VALOREMABERTO) TOTAL
     FROM  TITULOREC
     WHERE TITULOREC.FILIAL=:FILIAL
     AND   TITULOREC.PARCEIRO=:CLIENTE
     AND   TITULOREC.BAIXA IS NULL
     INTO :TITULOSEMABERTO;
   
     SELECT SUM(TITULOREC.VALOREMABERTO) TOTAL
     FROM  TITULOREC
     WHERE TITULOREC.FILIAL=:FILIAL
     AND   TITULOREC.PARCEIRO=:CLIENTE
     AND   TITULOREC.BAIXA IS NULL
     AND   TITULOREC.VENCIMENTO < CURRENT_TIMESTAMP
     INTO :TITULOSEMATRASO;

     IF (:LIMITECREDITO > 0) THEN BEGIN
        IF (:TITULOSEMABERTO IS NULL) THEN
           TITULOSEMABERTO = 0;
        IF (:NOTASEMABERTO IS NULL) THEN
           NOTASEMABERTO = 0;
        V_TOTALEMABERTO = :V_TOTALMERCPED + :V_TOTALSERVPED + 
                          :TITULOSEMABERTO + :NOTASEMABERTO;
        IF (:V_TOTALEMABERTO > :LIMITECREDITO) THEN
           CREDITOEXCEDIDO = :V_TOTALEMABERTO - :LIMITECREDITO;
        IF (:NOTASEMABERTO = 0) THEN
           NOTASEMABERTO = NULL;
        IF (:TITULOSEMABERTO = 0) THEN
           TITULOSEMABERTO = NULL;
     END ELSE IF (:LIMITECREDITO = 0) THEN
        LIMITECREDITO = NULL;

     VENDEDOR = NULL;
     NOMEVEND = NULL;
     COMISSAOVENDA = NULL;
     COMISSAORECEB = NULL;
     IF (:P_DADOSENTREGA = 'S') THEN BEGIN
        LOGRADOURO = :P_LOGRENTREGA;
        NUMERO = :P_NUMENTREGA;
        BAIRRO = :P_BAIRROENTREGA;
        COMPLEMENTO = :P_COMPLENTREGA;
        CIDADE = :P_CIDENTREGA;
        UF = :P_UFENTREGA;
        CEP = :P_CEPENTREGA;
        DOCUMENTO = :P_DOCENTREGA;
        INSCESTADUAL = :P_INSCESTENTREGA;
     END
     IF (:P_DESCINDMERC IS NULL) THEN
        P_DESCINDMERC = 0; 
     IF (:P_DESCINDSERV IS NULL) THEN
        P_DESCINDSERV = 0; 
     IF (:P_DESCMERCPED IS NULL) THEN
        P_DESCMERCPED = 0; 
     IF (:P_DESCSERVPED IS NULL) THEN
        P_DESCSERVPED = 0; 
     IF (:P_ZONAFRANCA = 'S') THEN
        VLRZONAFRANCA = P_TOTALICMS;
     ELSE
        VLRZONAFRANCA = NULL;
     IF (:P_SUBSTRIB = 'S') THEN
        VLRSUBSTRIB = P_RECOLHIDO;
     ELSE
        VLRSUBSTRIB = NULL;
     VLRDESCONTO = NULL;
     VLRACRESCIMO = NULL;
     VLRFINALITEM = NULL;
     V_ID = NULL;

     FOR SELECT
               Itemestoque.C_mrfornecedor As CODIGO,
               MERCADORIASPED.DESCRICAO,
               --- PRAZOMERCPED.QTDE,
               coalesce (MATERIALMOVIMENTOESTOQUE.QUANTIDADE,PRAZOMERCPED.QTDE),
               MERCADORIASPED.UNIDADE,
               MERCADORIASPED.PRECOUNITARIO,
               MERCADORIASPED.VALORIPI,
               MERCADORIASPED.VLRTOTALMERCAD,
               (PRAZOMERCPED.DIAS+:DATAEMISSAO) AS ENTREGA,
               MERCADORIASPED.IDMERCADORIA,
               local.DESCRICAO as local,
               C_FORNECEDORPECA.DESCRICAO

         FROM
             MERCADORIASPED
         INNER JOIN PRAZOMERCPED ON
                    (MERCADORIASPED.FILIAL=PRAZOMERCPED.FILIAL AND
                    MERCADORIASPED.IDNOTA=PRAZOMERCPED.IDNOTA AND
                    MERCADORIASPED.IDMERCADORIA=PRAZOMERCPED.IDITEM)
         Inner join itemestoque on
                                (mercadoriasped.Codigo=itemestoque.Codigo)
         left join
               MATERIALMOVIMENTOESTOQUE on
                                            (MATERIALMOVIMENTOESTOQUE.FILIAL=mercadoriasped.FILIAL and
                                            MATERIALMOVIMENTOESTOQUE.IDPEDIDO=mercadoriasped.idnota and
                                            MATERIALMOVIMENTOESTOQUE.IDMERCADORIA=mercadoriasped.IDMERCADORIA)
         left join MOVIMENTOESTOQUE on
                                       (MATERIALMOVIMENTOESTOQUE.FILIAL=MOVIMENTOESTOQUE.FILIAL and
                                        MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO=MOVIMENTOESTOQUE.IDMOVIMENTO AND
                                        movimentoestoque.tipomovimento='13')
         left join local on
                            (local.ID=coalesce (MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO,1))

         left JOIN
             C_FORNECEDORPECA
                                ON (ITEMESTOQUE.C_FORNECEDOR=C_FORNECEDORPECA.ID)

         WHERE
              MERCADORIASPED.FILIAL=:FILIAL AND
              MERCADORIASPED.IDNOTA=:IDNOTA 
         ORDER BY
               MERCADORIASPED.CODIGO
         INTO :CODIGO, :DESCRICAO, :QUANTIDADE, :UNIDADE, :PRUNITARIO, 
              :VLRIPIMERC, :VLRTOTITEM, :ENTREGA, :P_ID , :local, :NOMEFORNECEDOR
     DO BEGIN


        IF (:P_FRETE IS NULL) THEN
           P_FRETE = 0;
        IF (:P_SEGURO IS NULL) THEN
           P_SEGURO = 0;
        IF (:P_OUTRAS IS NULL) THEN
           P_OUTRAS = 0;
        IF ((:P_DESCINDMERC > 0) OR (:P_DESCMERCPED > 0)) THEN
           VLRDESCONTO = :P_DESCINDMERC+P_DESCMERCPED;
        IF (:P_ACRESCMERC > 0) THEN
           VLRACRESCIMO = :P_ACRESCMERC;
        IF (:VLRIPIMERC IS NULL) THEN
           VLRIPIMERC = 0;
        VLRDESPESAS = :P_FRETE + :P_SEGURO + :P_OUTRAS;
        VLRPARCIAL = :VLRDESPESAS;
        IF (:VLRACRESCIMO IS NOT NULL) THEN
           VLRPARCIAL = VLRPARCIAL+:VLRACRESCIMO;
        IF (:VLRSUBSTRIB IS NOT NULL) THEN
           VLRPARCIAL = :VLRPARCIAL + :VLRSUBSTRIB;
        IF (:VLRIPITOTAL IS NOT NULL) THEN
           VLRPARCIAL = :VLRPARCIAL + :VLRIPITOTAL;
        IF (:VLRZONAFRANCA IS NOT NULL) THEN
           VLRPARCIAL = :VLRPARCIAL - :VLRZONAFRANCA;
        IF (:VLRDESCONTO IS NOT NULL) THEN
           VLRPARCIAL = :VLRPARCIAL - :VLRDESCONTO;
        IF (:P_ZONAFRANCA = 'S') THEN
           VLRIPIMERC = NULL;
        VLRFINALITEM = :VLRTOTITEM + :VLRIPIMERC;
        IF (:P_ID = :V_ID) THEN BEGIN
           CODIGO = NULL;
           DESCRICAO = NULL;
--           UNIDADE = NULL;
           PRUNITARIO = NULL; 
           VLRIPIMERC = NULL;
           VLRTOTITEM = NULL;
           VLRFINALITEM = NULL;

        END
        V_ID = P_ID;
        TIPODETALHE = 'MERCADORIAS';
        IF (:VLRDESPESAS = 0) THEN
           VLRDESPESAS = NULL;
        SUSPEND;
     END 

     VLRIPIMERC = NULL;
     VLRDESCONTO = NULL;
     VLRACRESCIMO = NULL;
     V_ID = NULL;
     FOR SELECT CAST(SERVICOSPED.CODIGO AS VARCHAR(8)), SERVICOSPED.DESCRICAO,
                PRAZOSERVPED.QTDE, SERVICOSPED.UNIDADE,
                SERVICOSPED.PRECOUNITARIO, 
                SERVICOSPED.VLRTOTSERVICO, SERVICOSPED.VLRFINALSERVICO,
                (PRAZOSERVPED.DIAS+:DATAEMISSAO) AS ENTREGA,
                SERVICOSPED.IDSERVICO
         FROM SERVICOSPED
         INNER JOIN PRAZOSERVPED ON (
                    SERVICOSPED.FILIAL=PRAZOSERVPED.FILIAL AND
                    SERVICOSPED.IDNOTA=PRAZOSERVPED.IDNOTA AND
                    SERVICOSPED.IDSERVICO=PRAZOSERVPED.IDITEM)
         WHERE SERVICOSPED.FILIAL=:FILIAL
         AND   SERVICOSPED.IDNOTA=:IDNOTA
         ORDER BY SERVICOSPED.CODIGO
         INTO :CODIGO, :DESCRICAO, :QUANTIDADE, :UNIDADE, :PRUNITARIO, 
              :VLRTOTITEM, VLRFINALITEM, :ENTREGA, :P_ID
     DO BEGIN
        VLRPARCIAL = 0;
        IF ((:P_DESCINDSERV > 0) OR (:P_DESCSERVPED > 0)) THEN
           VLRDESCONTO = :P_DESCINDSERV+P_DESCSERVPED;
        IF (:P_ACRESCSERV > 0) THEN
           VLRACRESCIMO = :P_ACRESCSERV;
        IF (:VLRACRESCIMO IS NOT NULL) THEN
           VLRPARCIAL = :VLRACRESCIMO;
        IF (:VLRDESCONTO IS NOT NULL) THEN
           VLRPARCIAL = :VLRPARCIAL - :VLRDESCONTO;
        IF (:P_ID = :V_ID) THEN BEGIN
           CODIGO = NULL;
           DESCRICAO = NULL;
           UNIDADE = NULL;
           PRUNITARIO = NULL; 
           VLRTOTITEM = NULL;
           VLRFINALITEM = NULL;
        END
        V_ID = P_ID;
        TIPODETALHE = 'SERVI??OS';
        SUSPEND;
     END

     CODIGO = NULL;
     DESCRICAO = NULL;
     QUANTIDADE = NULL;
     UNIDADE = NULL;
     PRUNITARIO = NULL;
     VLRIPIMERC = NULL;
     VLRTOTITEM = NULL;
     VLRFINALITEM = NULL;
     ENTREGA = NULL;
     VLRPARCIAL = NULL;
     VLRDESCONTO = NULL;
     VLRACRESCIMO = NULL;
     VLRDESPESAS = NULL;
     VLRSUBSTRIB = NULL;
     VLRIPITOTAL = NULL;
     VLRZONAFRANCA = NULL;
     NOMEFORNECEDOR=NULL;
     local = null;
     FOR SELECT VENDEDORESPED.VENDEDOR, CADASTROPARCEIROS.nome AS NOMEVEND,
                VENDEDORESPED.COMISSAOVENDA, VENDEDORESPED.COMISSAORECEBIMENTO
         FROM VENDEDORESPED
         INNER JOIN CADASTROPARCEIROS ON (VENDEDORESPED.VENDEDOR=CADASTROPARCEIROS.CADASTRO)
         WHERE (VENDEDORESPED.FILIAL=:FILIAL AND VENDEDORESPED.IDNOTA=:IDNOTA)
         INTO :VENDEDOR, :NOMEVEND, :COMISSAOVENDA, :COMISSAORECEB
     DO BEGIN  
        TIPODETALHE = 'VENDEDORES';
        SUSPEND;
     END
   END
END^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE IMPPED TO  SYSDBA;

