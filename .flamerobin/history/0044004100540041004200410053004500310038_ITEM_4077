SELECT 
       modelodocto.id PROPDEFAULT_MODELO,
       COALESCE(MODELODOCTO.calcularpeso,'S') MODELODOCTO_CALCULARPESO,
       COALESCE(MODELODOCTO.tipocobranca,0) MODELODOCTO_TIPOCOBRANCA,
       COALESCE(MODELODOCTO.bancocobranca,0) MODELODOCTO_BANCOCOBRANCA,
       COALESCE(MODELODOCTO.condicaopagto,0) MODELODOCTO_CONDICAOPAGTO,
       CONDICAOPAGAMENTO.DESCRICAO MODELODOCTO_CONDICAOPAGTOD,
       CONDICAOPAGAMENTO.NOTAPEDIDO,
       MODELODOCTO.pjurosatraso PEDIDO_pjurosatraso,
       MODELODOCTO.DESCONTOMERCADORIA PEDIDO_MSGDESCMERCADORIAS,
       MODELODOCTO.acrescimomercadoria PEDIDO_MSGACRESCMERCADORIA
from 
    modelodocto
LEFT JOIN 
    CONDICAOPAGAMENTO ON 
        CONDICAOPAGAMENTO.ID=modelodocto.CONDICAOPAGTO
where 
    modelodocto.id=44
