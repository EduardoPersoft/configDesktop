select 
    titulopag.titulo,
    titulopag.fatura,
    titulopag.vencimeno,
    titulopag.baixa,
    titulopag.TIPOBAIXA,
    titulopag.valortitulo,
    substring(titulopag.OBSERVACOES from 1 for 1000)
from 
    TITULOPAG
where
    titulopag.fiLial=5 and
    titulopag.parceiro=19848 and
    titulopag.vencimento between '01.10.2022' and '31.12.2022'