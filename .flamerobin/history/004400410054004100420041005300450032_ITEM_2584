UPDATE
    PEDIDOCOMPRA
set 
    PEDIDOCOMPRA.VLRFINALMERCADORIAS =  (SELECT SUM(MERCADORIASPEDCOMPRA.VLRFINALMERCAD) FROM MERCADORIASPEDCOMPRA
                                        WHERE MERCADORIASPEDCOMPRA.FILIAL=PEDIDOCOMPRA.FILIAL AND
                                        MERCADORIASPEDCOMPRA.IDNOTA=PEDIDOCOMPRA.IDNOTA),
    PEDIDOCOMPRA.VLRTOTALMERCADORIAS =  (SELECT SUM(MERCADORIASPEDCOMPRA.VLRTOTALMERCAD) FROM MERCADORIASPEDCOMPRA
                                        WHERE MERCADORIASPEDCOMPRA.FILIAL=PEDIDOCOMPRA.FILIAL AND
                                        MERCADORIASPEDCOMPRA.IDNOTA=PEDIDOCOMPRA.IDNOTA),
    PEDIDOCOMPRA.VLRTOTALMERCADORIAS =  (SELECT SUM(MERCADORIASPEDCOMPRA.VLRTOTALMERCAD) FROM MERCADORIASPEDCOMPRA
                                        WHERE MERCADORIASPEDCOMPRA.FILIAL=PEDIDOCOMPRA.FILIAL AND
                                        MERCADORIASPEDCOMPRA.IDNOTA=PEDIDOCOMPRA.IDNOTA)

WHERE
    mercadoriaspedcompra.baixa='N' 