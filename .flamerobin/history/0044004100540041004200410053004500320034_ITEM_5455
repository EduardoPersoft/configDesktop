UPDATE
    PEDIDOCOMPRA
SET
    PEDIDOCOMPRA.VLRFINALMERCADORIAS = (SELECT SUM(MERCADORIASPEDCOMPRA.VLRFINALMERCAD) FROM MERCADORIASPEDCOMPRA WHERE MERCADORIASPEDCOMPRA.FILIAL=PEDIDOCOMPRA.FILIAL AND  MERCADORIASPEDCOMPRA.IDNOTA=PEDIDOCOMPRA.IDNOTA),
    PEDIDOCOMPRA.VLRTOTALMERCADORIAS= (SELECT SUM(MERCADORIASPEDCOMPRA.VLRFINALMERCAD) FROM MERCADORIASPEDCOMPRA WHERE MERCADORIASPEDCOMPRA.FILIAL=PEDIDOCOMPRA.FILIAL AND  MERCADORIASPEDCOMPRA.IDNOTA=PEDIDOCOMPRA.IDNOTA),
    PEDIDOCOMPRA.VLRTOTALNOTA = (SELECT SUM(MERCADORIASPEDCOMPRA.VLRFINALMERCAD) FROM MERCADORIASPEDCOMPRA WHERE MERCADORIASPEDCOMPRA.FILIAL=PEDIDOCOMPRA.FILIAL AND  MERCADORIASPEDCOMPRA.IDNOTA=PEDIDOCOMPRA.IDNOTA)
WHERE
    PEDIDOCOMPRA.FILIAL = 5 AND
    PEDIDOCOMPRA.IDNOTA = 67279 
