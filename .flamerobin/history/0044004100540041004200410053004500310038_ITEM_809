select 
    pedido.c_loja,
    c_centrocustoxlocal.CENTROCUSTO,

from 
    MOVIMENTOESTOQUE
inner join
    pedido on
        pedido.filial=movimentoestoque.filial and
        pedido.idnota=movimentoestoque.idpedido
left join
    c_centrocustoxlocal on
        c_Centrocustoxlocal.idlocal=pedido.c_loja        
   
where
    movimentoestoque.filial=1 and
    movimentoestoque.TIPOMOVIMENTO = '07' and 
    movimentoestoque.emissao between '01.01.2022' and '30.06.2022'
    
