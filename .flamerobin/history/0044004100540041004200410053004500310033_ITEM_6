 for SELECT
 MERCADORIASORC.CODIGO,
  (mercadoriasORC.VLRFINALMERCAD+mercadoriasORC.ACRESCIMONOTA)-mercadoriasORC.DESCONTONOTA,
 MERCADORIASORC.IDNOTA,
 MERCADORIASORC.IDMERCADORIA,
 VENDEDORESORC.VENDEDOR,
 cadven.razaosocial as razaovendedor ,
 COALESCE (GRUPOMERCADORIA.C_COLUNA,0),
 orcamento.destinatario
 from MERCADORIASORC
 LEFT join ORCAMENTO on (MERCADORIASORC.filial=ORCAMENTO.FILIAL
                            and MERCADORIASORC.idnota=ORCAMENTO.idnota)
 LEFT join VENDEDORESORC on (VENDEDORESORC.filial=ORCAMENTO.FILIAL
                           and VENDEDORESORC.idnota=ORCAMENTO.idnota)
 LEFT join CADASTROPARCEIROS cadven on (VENDEDORESORC.VENDEDOR=cadven.CADASTRO)
 LEFT JOIN ITEMESTOQUE ON (ITEMESTOQUE.CODIGO=MERCADORIASORC.CODIGO)
 left JOIN GRUPOMERCADORIA ON (ITEMESTOQUE.GRUPO=GRUPOMERCADORIA.GRUPO)
 where  ORCAMENTO.filial=1
 and ORCAMENTO.DATAEMISSAO IS NOT NULL
 and ORCAMENTO.DATAEMISSAO between '01.05.2021' an '31.05.2021'
 AND coalesce  (ORCAMENTO.CANCELAMENTO,'N')<>'S'
 UNION
 
 SELECT
 CAST  (SERVICOSORC.CODIGO AS VARCHAR (15)),
  (SERVICOSORC.VLRFINALSERVICO+SERVICOSORC.ACRESCIMONOTA)-SERVICOSORC.DESCONTONOTA,
 SERVICOSORC.IDNOTA,
 SERVICOSORC.IDSERVICO,
 VENDEDORESORC.VENDEDOR,
 cadven.razaosocial as razaovendedor ,
 COALESCE (GRUPOSERVICO.C_COLUNA,0),
 orcamento.destinatario
 from SERVICOSORC
 LEFT join ORCAMENTO on (SERVICOSORC.filial=ORCAMENTO.FILIAL
                            and SERVICOSORC.idnota=ORCAMENTO.idnota)
 LEFT join VENDEDORESORC on (VENDEDORESORC.filial=ORCAMENTO.FILIAL
                           and VENDEDORESORC.idnota=ORCAMENTO.idnota)
 LEFT join CADASTROPARCEIROS cadven on (VENDEDORESORC.VENDEDOR=cadven.CADASTRO)
 LEFT JOIN SERVICO ON (SERVICO.CODIGO=SERVICOSORC.CODIGO)
 left JOIN GRUPOSERVICO ON (SERVICO.GRUPOSERVICO=GRUPOSERVICO.GRUPO)
 where  ORCAMENTO.filial=1
 and ORCAMENTO.DATAEMISSAO IS NOT NULL
 and ORCAMENTO.DATAEMISSAO between '01.05.2021' an '31.05.2021'
 AND coalesce  (ORCAMENTO.CANCELAMENTO,'N')<>'S'