select 
    distinct
    PEDIDO.DESTINATARIO,
    PEDIDO.DATAREFERENCIA,
    PEDIDO.FILIAL,    
    PEDIDO.IDNOTA,
    PEDIDO.vlrtotalnota
from 
    mercadoriasped
inner join
    PEDIDO on
        pedido.filial=mercadoriasped.filial and
        pedido.idnota=mercadoriasped.idnota
where
    pedido.datacancelamento is null and 
    mercadoriasped.baixa='N' and
    pedido.destinatario=5
