select
    cadfor.cadastro,
    cadfor.nome,
    count(distinct notacompra.idnota) as qtdCompras,
    count(distinct mercadoriasnotacompra.codigo) qtdItensComprados
from
    NOTACOMPRA
inner join
    CADASTROPARCEIROS cadfor
        on cadfor.cadastro=notacompra.DESTINATARIO
inner join
    mercadoriasnotacompra on
        notacompra.filial=mercadoriasnotacompra.filial and
        notacompra.idnota=mercadoriasnotacompra.idnota
where
    notacompra.filial=5 and
    notacompra.DATAEMISSAO between '01.08.2021' and '31.07.2022'
group by         
    cadfor.cadastro,
    cadfor.nome