select
    itemestoque.codigo,
    itemestoque.descricao,
    itemestoque.itembase as local,
    materiallocal.idlocal,
    materiallocal.saldototal
from
    ITEMESTOQUE
inner join
    materiallocal on
        materiallocal.filial=5 and 
        materiallocal.iditem=itemestoque.codigo
        
where
    itemestoque.itembase is not null and itemestoque.ESTOCADO='S' and materiallocal.SALDOTOTAL>0