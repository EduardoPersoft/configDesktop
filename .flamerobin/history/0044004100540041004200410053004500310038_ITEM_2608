select 
    movimentoestoque.emissao,
    materialmovimentoestoque.iditem,
    sum(materialmovimentoestoque.quantidade),
    sum(materialmovimentoestoque.valor)
from 
    MOVIMENTOESTOQUE
inner join
    materialmovimentoestoque on
        MATERIALMOVIMENTOESTOQUE.filial=movimentoestoque.filial and
        materialmovimentoestoque.idmovimento=movimentoestoque.IDMOVIMENTO
where
    movimentoestoque.filial=1 and
    movimentoestoque.emissao between '01.06.2024' and '3.06.2024' and
    movimentoestoque.TIPOMOVIMENTO in ('01', '02', '05', '15')
group by
    movimentoestoque.emissao,
    MATERIALMOVIMENTOESTOQUE.iditem    
