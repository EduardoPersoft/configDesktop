--insert into
    --ITEMESTOQUECODIGOS
select
    DISTINCT
    ITEMESTOQUECODIGOS.CODIGO,
    ITEMESTOQUECODIGOS.CODIGOALTERNATIVO
from
    ITEMESTOQUECODIGOS
where 
    EXISTS 
    (SELECT 
        * 
     FROM 
        ITEMESTOQUECODIGOS
     WHERE   
        ITEMESTOQUECODIGOS.CODIGO=ITEMESTOQUECODIGOS.CODIGO AND
        ITEMESTOQUECODIGOS.CODIGOALTERNATIVO=ITEMESTOQUECODIGOS.CODIGO)