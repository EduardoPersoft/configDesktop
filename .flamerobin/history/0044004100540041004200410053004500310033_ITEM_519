SELECT
       I1.CODIGO,
       I1.REFERENCIA,
       I1.DESCRICAO,
       I1.unidade,
       ARQ1.NOMEARQUIVO,       


       (select 
            sum(materiallocal.saldototal)
        from 
            MATERIALLOCAL 
        inner JOIN
            local on
                local.ID=materiallocal.IDLOCAL
        where
            MATERIALLOCAL.FILIAL= 5 AND
            MATERIALLOCAL.IDITEM=case i1.estocado when 'N'
                                 then coalesce(i1.itembase, i1.codigo)
                                 else i1.codigo end and
            local.DISPONIVEL='S') saldo,

       (SELECT FIRST 1 LISTAPRECOPRODUTO.preco 
         FROM LISTAPRECOPRODUTO
        WHERE LISTAPRECOPRODUTO.LISTA=(select listapreco.lista from listapreco where listapreco.listapadrao='S')
        AND LISTAPRECOPRODUTO.PRODUTO=I1.CODIGO
        order by quantidade) AS PRECO
      
        
      
        
FROM itemestoque i1
LEFT JOIN CLASSIFICACAOFISCAL ON (CLASSIFICACAOFISCAL.CFISCAL=I1.CLASSIFISCAL)
LEFT JOIN ITEMESTOQUEXARQUIVO ARQ1 ON (ARQ1.CODIGO=I1.CODIGO AND ARQ1.ORDEM=0)
LEFT JOIN ITEMESTOQUEXARQUIVO ARQ2 ON (ARQ2.CODIGO=I1.CODIGO AND ARQ2.ORDEM=1)
LEFT JOIN FAMILIA ON (FAMILIA.ID=I1.FAMILIA)
LEFT JOIN UNIDADE ON (UNIDADE.UNIDADE=CASE COALESCE(I1.UNIDADE2, '') WHEN ''
                                      THEN I1.UNIDADE
                                      ELSE I1.UNIDADE2 END)                                      
WHERE I1.TIPOPRODUTO IN (3,4)
