update
    PEDIDO
set 
    vendedor = (select vendedoresped.vendedor from VENDEDORESPED
                where vendedoresped.filial=pedido.filial and
                vendedoresped.idnota=pedido.idnota),
    atendente = (select vendedoresped.vendedor from VENDEDORESPED
                where vendedoresped.filial=pedido.filial and
                vendedoresped.idnota=pedido.idnota)            
where 
    pedido.DATACADASTRO>='01.01.2024' and
    pedido.vendedor is null or
    pedido.atendente is null