INSERT INTO VENDEDORESNOTA (FILIAL, IDNOTA, VENDEDOR, COMISSAOVENDA)
SELECT 
    NOTAFISCAL.FILIAL,
    NOTAFISCAL.IDNOTA,
    CLIENTES.VENDEDOR,
    5
FROM
    NOTAFISCAL
INNER JOIN 
    CLIENTES ON
        NOTAFISCAL.DESTINATARIO=CLIENTES.CADASTRO
WHERE
    NOTAFISCAL.FILIAL=5 AND
    NOTAFISCAL.DATAEMISSAO BETWEEN '01.03.2021' AND '31.03.2021' AND
    CLIENTES.VENDEDOR IS NOT NULL