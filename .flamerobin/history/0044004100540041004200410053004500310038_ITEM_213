SELECT  CADASTROPARCEIROS.CADASTRO,
        CADASTROPARCEIROS.NOME,
        VENDEDORVENDEDOR.CANALRELACIONADO,
        USUARIO.ID,
        LOJA.Canalrelacionado ESTABELECIMENTO
FROM USUARIO
INNER JOIN VENDEDOR VENDEDORVENDEDOR ON (VENDEDORVENDEDOR.USUARIORELACIONADO=USUARIO.ID)
INNER JOIN CADASTROPARCEIROS ON (CADASTROPARCEIROS.CADASTRO=VENDEDORVENDEDOR.CADASTRO)
LEFT JOIN VENDEDOR LOJA ON (LOJA.CADASTRO=VENDEDORVENDEDOR.Canalrelacionado)
WHERE VENDEDORVENDEDOR.tipovendedor=4
order by id
