SELECT
    
    TITULOREC.FILIAL,

    TITULOREC.IDTITULO id,
    TITULOREC.TITULO,
    TITULOREC.FATURA,

    TITULOREC.PARCEIRO idparceiro,
    CADASTROPARCEIROS.NOME,
    CADASTROPARCEIROS.RAZAOSOCIAL,
    
    TITULOREC.VALORTITULO,

    TITULOREC.VENCIMENTO,
    TITULOREC.EMISSAO,

    TIPOCOBRANCA.DESCRICAO DESCRICAOCOBRANCA,    
    TITULOREC.CONTACORRENTE,
    CONTACORRENTE.DESCRICAOCONTA,
    TITULOREC.NUMBOLBANCO,

    titulorec.codretorno,

    'N' AS P_MARCA,
    
    CASE WHEN TITULOREC.BAIXA IS NOT NULL THEN 8421504
    WHEN TITULOREC.VENCIMENTO<CAST('NOW' AS DATE) THEN 255
    ELSE 0 END AS P_STATUSCOR
  
FROM TITULOREC

INNER JOIN CADASTROPARCEIROS ON (TITULOREC.PARCEIRO = CADASTROPARCEIROS.CADASTRO)
left JOIN CONTACORRENTE ON(TITULOREC.FILIAL=CONTACORRENTE.FILIAL AND
                                                          TITULOREC.CONTACORRENTE=CONTACORRENTE.CODIGO)
left JOIN TIPOCOBRANCA ON (TITULOREC.TIPOTRANSACAO=TIPOCOBRANCA.TIPOCOBRANCA)

WHERE
    TITULOREC.FILIAL=1 AND
    COALESCE(TITULOREC.TIPOBAIXA, 'S') <> 'E' AND
    TITULOREC.EMISSAO BETWEEN '01.01.2024' AND '31.12.2024'