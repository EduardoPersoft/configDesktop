SELECT CADASTROPARCEIROS.razaosocial,
       ITEMESTOQUE.descricao,
       ITEMESTOQUE.unidade,
       RESUMOLANCAMENTOS.*
FROM RESUMOLANCAMENTOS
INNER JOIN CADASTROPARCEIROS ON (CADASTROPARCEIROS.cadastro = RESUMOLANCAMENTOS.filial)
INNER JOIN ITEMESTOQUE ON (ITEMESTOQUE.codigo = RESUMOLANCAMENTOS.codigo)
where (RESUMOLANCAMENTOS.QTDINICIAL>=0.009
OR RESUMOLANCAMENTOS.QTDENTRADA<>0
OR RESUMOLANCAMENTOS.QTDSAIDA<>0
OR RESUMOLANCAMENTOS.QTDFINAL>=0.009)
