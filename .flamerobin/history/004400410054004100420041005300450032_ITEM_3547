select 
    itemestoque.codigo,
    itemestoque.descricao,
    GRUPOMERCADORIA.descricao
from 
    ITEMESTOQUE
inner JOIN
    GRUPOMERCADORIA on
        grupomercadoria.GRUPO=itemestoque.grupo
where 
coalesce(coalesce(cast(itemestoque.DATACADASTRO as date), cast(itemestoque.DATAALTERACAO as date)),'01.08.2019') <= '01.08.2019' 

and not EXISTS
(select 
    *
FROM
    Materialmovimentoestoque
WHERE
    materialmovimentoestoque.filial=1 AND
    materialmovimentoestoque.iditem=itemestoque.codigo)

