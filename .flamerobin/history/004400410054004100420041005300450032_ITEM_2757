SELECT
    DISTINCT
    ORCAMENTO.FILIAL,
    ORCAMENTO.IDNOTA,
    ORCAMENTO.DATACADASTRO,
    CADCLI.NOME,
    ORCAMENTO.VLRTOTALNOTA,
    CASE WHEN ORCAMENTO.cancelamento ='S' THEN 'CANCELADO'
       WHEN EXISTS
       (SELECT * FROM PEDIDO
        WHERE PEDIDO.FILIAL=ORCAMENTO.FILIAL
        AND PEDIDO.IDORCAMENTO=ORCAMENTO.IDNOTA) THEN 'PEDIDO '||
            (SELECT PEDIDO.IDNOTA FROM PEDIDO
             WHERE PEDIDO.FILIAL=ORCAMENTO.FILIAL
             AND PEDIDO.IDORCAMENTO=ORCAMENTO.IDNOTA)
       WHEN ORCAMENTO.dataemissao IS NOT NULL THEN 'PRONTO'
       WHEN ORCAMENTO.DATAPERDA IS NOT NULL THEN 'PERDIDO'
       ELSE 'RASCUNHO' END AS STATUS
FROM 
    MERCADORIASORC
INNER JOIN
    ORCAMENTO ON
        ORCAMENTO.FILIAL = MERCADORIASORC.FILIAL
        AND ORCAMENTO.IDNOTA = MERCADORIASORC.IDNOTA
INNER JOIN 
    CADASTROPARCEIROS CADCLI ON
        CADCLI.CADASTRO = ORCAMENTO.DESTINATARIO
LEFT JOIN 
    CADASTROPARCEIROS CADTRANS ON   
        CADTRANS.CADASTRO = ORCAMENTO.CODIGOTRANSP 