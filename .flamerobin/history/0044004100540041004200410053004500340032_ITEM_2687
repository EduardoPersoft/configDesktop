select 
    movimentoestoque.filial,
    movimentoestoque.data,
    movimentoestoque.idmovimento,
    materialmovimentoestoque.IDMOVIMENTOMATERIAL,
    materialmovimentoestoque.iditem,
    materialmovimentoestoque.quantidade,
    materialmovimentoestoque.valor,
    materialmovimentoestoque.sinal 
from 
    MOVIMENTOESTOQUE
inner join
    DOCUMENTOSASSOCIADOS on
        documentosassociados.filial=movimentoestoque.filial and
        DOCUMENTOSASSOCIADOS.IDMOVIMENTOENTRADA=movimentoestoque.IDMOVIMENTO
inner join
    materialmovimentoestoque on
        materialmovimentoestoque.filial=movimentoestoque.filial and
        materialmovimentoestoque.idmovimento=movimentoestoque.idmovimento
where 
    movimentoestoque.filial=110
    and movimentoestoque.TIPOMOVIMENTO='04'
    and moviemntoestoque.emissao between '01.07.2024' and '31.07.2024'
