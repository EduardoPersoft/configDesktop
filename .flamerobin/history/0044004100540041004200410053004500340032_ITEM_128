select
    CONTASCONTABEIS.CONTACONTABIL,
    CONTASCONTABEIS.descricao,
    sum(VALORMOVIMENTO) valor,
    sum(case MOVIMENTOBANCARIOLANCAMENTOS.CONTACONTABIL when CONTASCONTABEIS.CONTACONTABIL
         then MOVIMENTOBANCARIOLANCAMENTOS.VALORMOVIMENTO else 0 end)
from
    MOVTOOBANCARIOLANCAMENTOS('01.08.2023', '31.08.2023', 341, 'PRIMEFLEX', 4)
left join
    CONTASCONTABEIS on
        CONTASCONTABEIS.idplano=4 and
        MOVTOOBANCARIOLANCAMENTOS.contacontabil like CONTASCONTABEIS.CONTACONTABIL||'%'
group by    
    CONTASCONTABEIS.CONTACONTABIL,
    CONTASCONTABEIS.descricao
