select
    distinct
    itemestoque.C_CODMOEDA,
    itemestoque.CLASSIFISCAL
from
    ITEMESTOQUE
where 
    not exists (
        select 
            * 
        from 
            C_FATORES
        where
            c_fatores.CFISCAL=itemestoque.CLASSIFISCAL and
            c_fatores.IDLOCAL=itemestoque.C_CODMOEDA)
and
    itemestoque.C_CODMOEDA is not null