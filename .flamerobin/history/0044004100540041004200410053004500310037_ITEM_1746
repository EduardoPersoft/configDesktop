select 
materialmovimentoestoque.*, movimentoestoque.idpedido
from
MATERIALMOVIMENTOESTOQUE
inner join MOVIMENTOESTOQUE on
    materialmovimentoestoque.filial=movimentoestoque.filial and
    materialmovimentoestoque.idmovimento=movimentoestoque.IDMOVIMENTO
where 
    movimentoestoque.TIPOMOVIMENTO='13' and
    MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO=1792 and
    movimentoestoque.IDNOTAEXPEDICAO is null and 
    materialmovimentoestoque.iditem ='6113619'