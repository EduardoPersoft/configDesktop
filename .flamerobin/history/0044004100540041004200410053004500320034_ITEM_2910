insert into
    ITEMESTOQUECODIGOS
select
    DISTINCT
    C_ITEMESTQOUTCOD.codigo,
    C_ITEMESTQOUTCOD.CODIGOALTERNATIVO
from
    C_ITEMESTQOUTCOD
where 
    NOT EXISTS 
    (SELECT 
        * 
     FROM 
        ITEMESTOQUECODIGOS
     WHERE   
        C_ITEMESTQOUTCOD.CODIGO=ITEMESTOQUECODIGOS.CODIGO AND
        C_ITEMESTQOUTCOD.CODIGOALTERNATIVO=ITEMESTOQUECODIGOS.CODIGOALTERNATIVO)