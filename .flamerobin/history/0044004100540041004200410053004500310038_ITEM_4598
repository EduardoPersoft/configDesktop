update 
    TITULOPAG
set
    titulopag.DATAREFERENCIA = titulopag.VENCIMENTO
where 
    titulopag.VENCIMENTO>='01.12.2025' 
    exists (
    select * from LANTOCONTPAG
    where lantocontpag.FILIAL=TITULOPAG.filial and
    lantocontpag.IDMOVTOBANC=TITULOPAG.IDTITULO and
    lantocontpag.CONTACONTABIL like '203%'
    )