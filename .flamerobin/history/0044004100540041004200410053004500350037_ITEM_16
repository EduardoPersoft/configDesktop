SELECT 
    C_LISTACUSTO.iditem,
    C_LISTACUSTO.id,
    C_LISTACUSTO.descricao,
    C_LISTACUSTO.custo,
    CLASSIFICACAOFISCAL.ALIQUOTA
FROM 
    C_LISTACUSTO
INNER join
    ITEMESTOQUE ON
        ITEMESTOQUE.CODIGO=C_LISTACUSTO.IDITEM
INNER join
    CLASSIFICACAOFISCAL ON
        CLASSIFICACAOFISCAL.CFISCAL=ITEMESTOQUE.CLASSIFISCAL
where 
    c_listacusto.iditem='01240007'
