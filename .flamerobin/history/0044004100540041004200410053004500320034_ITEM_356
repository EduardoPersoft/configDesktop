SELECT
    itemestoque.codigo,
    itemestoque.DESCRICAO,
    itemestoque.localizacao
from 
    itemestoque
    
inner JOIN 
    materiallocal on
        materiallocal.IDLOCAL=1 AND
        materiallocal.iditem=itemestoque.codigo AND
        materiallocal.filial=5

WHERE
    materiallocal.SALDOTOTAL = 0
    
order by 
    localizacao,codigo