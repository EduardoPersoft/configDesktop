SELECT
    mercadoriasnotacompra.*
FROM
    MERCADORIASNOTACOMPRA
inner JOIN  
    notacompra on
        notacompra.filial=mercadoriasnotacompra.filial and 
        notacompra.idnota=mercadoriasnotacompra.idnota
WHERE 
    MERCADORIASNOTACOMPRA.STATUSCONFERENCIA IS NULL AND
    notacompra.ENTRADASAIDA='25.08.2021'