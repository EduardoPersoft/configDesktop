    SELECT
    c_i_movest3.*
from
    c_i_movest3
inner JOIN
    movimentoestoque on
        movimentoestoque.filial=c_i_movest3.filial AND
        movimentoestoque.DOCUMENTO=substring(c_i_movest3.DOCTO from 1 for 10)
WHERE
    c_i_movest3.codtiposaida = 2 and
    c_i_movest3.data>='01.04.2021' AND
    c_i_movest3.codpeca = '13567'
