SELECT
    MATERIALMOVIMENTOESTOQUE.iditem,    
    MATERIALMOVIMENTOESTOQUE.lote,    
    materialmovimentoestoque.LOCALARMAZENAMENTO,
    tipoitemestoque.DESCRICAO,
    SUM(MATERIALMOVIMENTOESTOQUE.QUANTIDADE*materialmovimentoestoque.sinal*ITEMCUSTODATA.custounitario)
   
FROM
    materialmovimentoestoque
INNER JOIN
    MOVIMENTOESTOQUE ON
        MOVIMENTOESTOQUE.FILIAL=materialmovimentoestoque.FILIAL AND
        MOVIMENTOESTOQUE.idmovimento=materialmovimentoestoque.IDMOVIMENTO
INNER JOIN
    ITEMESTOQUE ON
        ITEMESTOQUE.CODIGO=materialmovimentoestoque.iditem
INNER JOIN
     MATERIALFILIAL ON
        MATERIALFILIAL.FILIAL=materialmovimentoestoque.FILIAL AND
        MATERIALFILIAL.IDITEM=MATERIALMOVIMENTOESTOQUE.IDITEM 
INNER JOIN
    TIPOiTEMeSTOQUE ON
        tipoitemestoque.ID=ITEMESTOQUE.tipoproduto
INNER JOIN
     ITEMCUSTODATA ON
        ITEMCUSTODATA.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL AND
        ITEMCUSTODATA.CODIGO=MATERIALMOVIMENTOESTOQUE.IDITEM 
WHERE
    ITEMCUSTODATA.datainventario='31.12.2023' AND
    MOVIMENTOESTOQUE.EMISSAO<=ITEMCUSTODATA.DATAINVENTARIO
GROUP BY 
    MATERIALMOVIMENTOESTOQUE.iditem,    
    MATERIALMOVIMENTOESTOQUE.lote,    
    MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO,
    tipoitemestoque.DESCRICAO
having
SUM(MATERIALMOVIMENTOESTOQUE.QUANTIDADE*materialmovimentoestoque.sinal*ITEMCUSTODATA.custounitario)<-0.09