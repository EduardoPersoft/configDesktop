update 
    MOVIMENTOESTOQUE
set
    movimentoestoque.emissao='31.12.2023'
where 
    movimentoestoque.filial=110
    and movimentoestoque.emissao>='01.01.2024'
    and movimentoestoque.TIPOMOVIMENTO in ('10', '11') 
    and (movimentoestoque.LOCALARMAZENAMENTO=3 or movimentoestoque.LOCALTRANSFERENCIA=3)