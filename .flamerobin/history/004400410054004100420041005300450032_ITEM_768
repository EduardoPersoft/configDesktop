SELECT
    sum(titulorec.VALOREMABERTO) titulosEmAberto,
    sum(CASE when titulorec.vencimento+ESTABELECIMENTO.diasatraso > 
                  cast('now' as date) 
                  then titulorec.VALOREMABERTO else 0 end) atraso,
   
from
    TITULOREC
inner JOIN  
    estabelecimento on 
        estabelecimento.cadastr=titulorec.filial
WHERE
    titulorec.filial=5
    titulorec.parceiro=5
    