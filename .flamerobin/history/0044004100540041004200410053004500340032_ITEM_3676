update
    servicospedcompra 
set
    servicoSpedcompra.C_FILIALPEDVEN=1,
    servicoSpedcompra.C_IDPEDVEN=(select first 1
                                    mercadoriasped.idnota
                                  from
                                    mercadoriasped
                                  where 
                                    mercadoriasped.baixa='N' and
                                    mercadoriasped.codigo=servicospedcompra.C_CODIGO
                                    ),
    servicoSpedcompra.C_IDMERCVEN=(select first 1
                                    mercadoriasped.idmercadoria
                                  from
                                    mercadoriasped
                                  where 
                                    mercadoriasped.baixa='N' and
                                    mercadoriasped.codigo=servicospedcompra.C_CODIGO
                                    )
                                    
where 
    servicospedcompra.baixa='N';
update
    servicosped
set
    servicosped.C_FILiALPEDVEN=110,
    servicosped.C_IDPEDVEN=(select first 1
                                    mercadoriasped.idnota
                                  from
                                    mercadoriasped
                                  where 
                                    mercadoriasped.baixa='N' and
                                    mercadoriasped.codigo=servicosped.C_itemestoque
                                    ),
    servicosped.C_IDMERCVEN=(select first 1
                                    mercadoriasped.idmercadoria
                                  from
                                    mercadoriasped
                                  where 
                                    mercadoriasped.baixa='N' and
                                    mercadoriasped.codigo=servicosped.C_itemestoque
                                    )
                                    
where 
    servicosped.baixa='N';