SELECT 
    MERCADORIASORC.FILIAL,
    MERCADORIASORC.IDNOTA,
    MERCADORIASORC.IDMERCADORIA,
    C_LISTACUSTO.id,
    C_LISTACUSTO.descricao,
    C_LISTACUSTO.custo,
    CLASSIFICACAOFISCAL.ALIQUOTA
FROM 
     MERCADORIASORC
inner join 
    C_LISTACUSTO  on
        C_LISTACUSTO.IDITEM=mercadoriasorc.CODIGO
inner join
    CLASSIFICACAOFISCAL on
        CLASSIFICACAOFISCAL.CFISCAL=mercadoriasorc.CLASSIFISCAL
WHERE
    MERCADORIASORC.FILIAL=1 AND
    MERCADORIASORC.IDNOTA=25
order by
    MERCADORIASORC.FILIAL,
    MERCADORIASORC.IDNOTA,
    MERCADORIASORC.IDMERCADORIA,
    C_LISTACUSTO.id

