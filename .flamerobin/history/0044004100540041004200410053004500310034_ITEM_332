select 
    materialmovimentoestoque.* 
from 
    movimentoestoque
inner join 
    materialmovimentoestoque on
        materialmovimentoestoque.filial=movimentoestoque.filial and
        materialmovimentoestoque.imovimento=movimentoestoque.IDMOVIMENTO
where 
    movimentoestoque.tipomovimento='12' and 
    movimentoestoque.filial=110 
order by 
    movimentoestoque.idmovimento desc