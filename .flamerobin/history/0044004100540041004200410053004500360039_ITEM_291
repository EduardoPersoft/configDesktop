insert into c_destinoavulso(
    id, datasolicitacao, motorista, coleta, 
    datacoleta, tipoparada, observacao, 
    localizacao)            
select 
    cast(c_paradascoleta.coleta as integer) + c_paradascoleta.id,
    c_paradascoleta.datacoleta,
    (select first 1
        movimentoestoque.MOTORISTA
     from   
        MOVIMENTOESTOQUE
     where
        movimentoestoque.COLETA=c_paradascoleta.coleta),
    c_paradascoleta.datacoleta,
    c_paradascoleta.TIPOPARADA,
    c_paradascoleta.OBSERVACAO,
    c_paradascoleta.localizacao
from c_paradascoleta