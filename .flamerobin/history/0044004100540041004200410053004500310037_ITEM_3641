select    
    1 as id,
    CADASTROPARCEIROS.nome,
    (select
        count(orcamento.idnota)
     from
        ORCAMENTO
     inner join
        VENDEDORESORC on
            vendedoresorc.filial=orcamento.filial and
            vendedoresorc.idnota=orcamento.idnota and
            vendedoresorc.vendedor=CADASTROPARCEIROS.CADASTRO
    where
        orcamento.datacadastro>cast('now' as date)-extract(day from cast('now' as date)) and
        orcamento.dataCancelamento is null)+ 
    (select    
        count(pedido.idnota)    
    from
        pedido
    inner join
        vendedoresped on 
            VENDEDORESPED.filial=pedido.filial and
            vendedoresped.idnota=pedido.IDNOTA and
            vendedoresped.vendedor=cadastroparceiros.cadastro
    where
        pedido.datacadastro>cast('now' as date)-extract(day from cast('now' as date)) and
        pedido.IDORCAMENTO is null and
        pedido.dataCancelamento is null)        
         as qtdOrcamento,
    (select    
        count(pedido.idnota)    
    from
        pedido
    inner join
        vendedoresped on 
            VENDEDORESPED.filial=pedido.filial and
            vendedoresped.idnota=pedido.IDNOTA and
            vendedoresped.vendedor=cadastroparceiros.cadastro
    where
        pedido.datacadastro>cast('now' as date)-extract(day from cast('now' as date)) and
        pedido.dataCancelamento is null) as qtdPedido
                        
from
    vendedor
inner join
    cadastroparceiros on
        vendedor.cadastro=CADASTROPARCEIROS.cadastro
where
    CADASTROPARCEIROS.status=1 and
        (select
        count(orcamento.idnota)
     from
        ORCAMENTO
     inner join
        VENDEDORESORC on
            vendedoresorc.filial=orcamento.filial and
            vendedoresorc.idnota=orcamento.idnota and
            vendedoresorc.vendedor=CADASTROPARCEIROS.CADASTRO
    where
        orcamento.datacadastro>cast('now' as date)-extract(day from cast('now' as date)) and
        orcamento.dataCancelamento is null) > 0 or 
(select    
        count(pedido.idnota)    
    from
        pedido
    inner join
        vendedoresped on 
            VENDEDORESPED.filial=pedido.filial and
            vendedoresped.idnota=pedido.IDNOTA and
            vendedoresped.vendedor=cadastroparceiros.cadastro
    where
        pedido.datacadastro>cast('now' as date)-extract(day from cast('now' as date)) and
        pedido.dataCancelamento is null) > 0        
        
order by
    CADASTROPARCEIROS.nome
