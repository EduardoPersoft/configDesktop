SELECT

   case estatistica.DETALHADOPOR
   when 'Clientes' then ESTATISTICA.CODCLIENTE
   when 'Área Geografica' then CAST(AREAGEOGRAFICA.AREAGE AS VARCHAR (15))
   when 'Ramo de Atividade' then SUBSTRING(ramoatividade.ramoatividade FROM 1 FOR 15)
   when 'Canal de Distribuição' then CAST (CANALDISTRIBUICAO.CANALDIST AS VARCHAR (15)) 
   when 'Estado' then CAST (CLIENTE.UF AS VARCHAR (15))
   when 'Vendedor' then CAST (VENDEDORVENDA.CADASTRO AS VARCHAR (15))
   when 'Canal Relacionado' then CAST (CANAL.CADASTRO AS VARCHAR (15))
   when 'Produtos e Serviços' then CAST (ESTATISTICA.CODMERC AS VARCHAR (15))
   when 'Grupo de Produtos e Serviços' then CAST (ESTATISTICA.GRUPO AS VARCHAR (15)) 
   when 'Família' then CAST (estatistica.familia AS VARCHAR (15))
   when 'Produto' then CAST (ESTATISTICA.IDITEMCOMP AS VARCHAR(15))
   when 'Cidade Estado' then CAST(CLIENTE.UF AS VARCHAR(15)) 
   when 'Vendedor do Cliente' then CAST(CLIENTES.VENDEDOR AS VARCHAR(15))
   when 'CFOP' then CAST(ESTATISTICA.cfop AS VARCHAR(15))
   when 'Item Base' then case (coalesce (ESTATISTICA.itembase,'0')) WHEN '0' then
        CAST(ESTATISTICA.CODMERC AS VARCHAR(15)) else
        CAST (ESTATISTICA.itembase AS VARCHAR(15)
        )END end  AS CODIGO,

   case estatistica.DETALHADOPOR
   when 'Clientes' then ESTATISTICA.CLIENTE
   when 'Área Geografica' then AREAGEOGRAFICA.descricao
   when 'Ramo de Atividade' then ramoatividade.descricao
   when 'Canal de Distribuição' then CANALDISTRIBUICAO.descricao
   when 'Estado' then ESTADO.NOME
   when 'Vendedor' then VENDEDORVENDA.NOME
   when 'Canal Relacionado' then canal.NOME
   when 'Produtos e Serviços' then ESTATISTICA.descr
   when 'Grupo de Produtos e Serviços' then ESTATISTICA.descrgrupo
   when 'Família' then ESTATISTica.familiadescricao
   when 'Produto' then ESTATISTICA.descrcomp
   when 'Cidade Estado' then CLIENTE.cidade 
   when 'Vendedor do Cliente' then VENDEDORCLIENTE.NOME
   when 'CFOP' then CAST(ESTATISTICA.cfop AS VARCHAR(15))
   when 'Item Base' then case (coalesce (ESTATISTICA.itembase,'0')) WHEN '0' then
         CAST(ESTATISTICA.descr AS VARCHAR(240)) else
         CAST (ESTATISTICA.itembasedesc AS VARCHAR(240))
         END end AS DESCRICAO,

   case estatistica.SEPARADOPOR
   when 'Clientes' then ESTATISTICA.CODCLIENTE
   when 'Área Geografica' then CAST(AREAGEOGRAFICA.AREAGE AS VARCHAR (15))
   when 'Ramo de Atividade' then SUBSTRING(ramoatividade.ramoatividade FROM 1 FOR 15)
   when 'Canal de Distribuição' then CAST (CANALDISTRIBUICAO.CANALDIST AS VARCHAR (15)) 
   when 'Estado' then CAST (CLIENTE.UF AS VARCHAR (15))
   when 'Vendedor' then CAST (VENDEDORVENDA.CADASTRO AS VARCHAR (15))
   when 'Canal Relacionado' then CAST (canal.CADASTRO AS VARCHAR (15))
   when 'Produtos e Serviços' then CAST (ESTATISTICA.CODMERC AS VARCHAR (15))
   when 'Grupo de Produtos e Serviços' then CAST (ESTATISTICA.GRUPO AS VARCHAR (15)) 
   when 'Família' then CAST (ESTATISTICA.familia AS VARCHAR (15))
   when 'Produto' then CAST (ESTATISTICA.IDITEMCOMP AS VARCHAR(15))
   when 'Cidade Estado' then CAST(CLIENTE.UF AS VARCHAR(15)) 
   when 'Vendedor do Cliente' then CAST(CLIENTES.VENDEDOR AS VARCHAR(15))
   when 'CFOP' then CAST(ESTATISTICA.cfop AS VARCHAR(15))  
   ELSE CAST('' AS VARCHAR(15)) END  AS GRPCODIGO,

   case estatistica.SEPARADOPOR
   when 'Clientes' then ESTATISTICA.CLIENTE
   when 'Área Geografica' then AREAGEOGRAFICA.descricao
   when 'Ramo de Atividade' then ramoatividade.descricao
   when 'Canal de Distribuição' then CANALDISTRIBUICAO.descricao
   when 'Estado' then ESTADO.NOME
   when 'Vendedor' then VENDEDORVENDA.NOME
   when 'Canal Relacionado' then canal.NOME
   when 'Produtos e Serviços' then ESTATISTICA.descr
   when 'Grupo de Produtos e Serviços' then ESTATISTICA.descrgrupo
   when 'Família' then ESTATISTICA.familiadescricao
   when 'Produto' then ESTATISTICA.descrcomp
   when 'Cidade Estado' then CLIENTE.cidade 
   when 'Vendedor do Cliente' then VENDEDORCLIENTE.NOME
   when 'CFOP' then CAST(ESTATISTICA.cfop AS VARCHAR(15))
   ELSE CAST('' AS VARCHAR(8)) END  AS GRPDESCRICAO,

   ESTATISTICA.DATAINICIAL, ESTATISTICA.DATAFINAL,
   ESTATISTICA.MATERIALINICIAL, ESTATISTICA.MATERIALFINAL, 
   ESTATISTICA.SERVICOINICIAL, ESTATISTICA.SERVICOFINAL, 
   ESTATISTICA.CONSOLIDADO, ESTATISTICA.DESCRICAO_ESTSIN, 
   ESTATISTICA.FILIAL AS ESTABELECIMENTO, ESTATISTICA.NOME,
   ESTATISTICA.DATAINICIO1, ESTATISTICA.DATAFIM1,
   ESTATISTICA.DATAINICIO2, ESTATISTICA.DATAFIM2,
   ESTATISTICA.DATAINICIO3, ESTATISTICA.DATAFIM3,
   ESTATISTICA.DATAINICIO4, ESTATISTICA.DATAFIM4,
   ESTATISTICA.DATAINICIO5, ESTATISTICA.DATAFIM5,
   ESTATISTICA.DATAINICIO6, ESTATISTICA.DATAFIM6,
   ESTATISTICA.DATAINICIO7, ESTATISTICA.DATAFIM7,
   ESTATISTICA.DATAINICIO8, ESTATISTICA.DATAFIM8,
   ESTATISTICA.DATAINICIO9, ESTATISTICA.DATAFIM9,
   ESTATISTICA.DATAINICIO10, ESTATISTICA.DATAFIM10,
   ESTATISTICA.DATAINICIO11, ESTATISTICA.DATAFIM11,
   ESTATISTICA.DATAINICIO12, ESTATISTICA.DATAFIM12,
   ESTATISTICA.OPCAO,
  SUM(ESTATISTICA.VALOR1) AS VALOR1, SUM(ESTATISTICA.VALOR2) AS VALOR2,
  SUM(ESTATISTICA.VALOR3) AS VALOR3, SUM(ESTATISTICA.VALOR4) AS VALOR4,
  SUM(ESTATISTICA.VALOR5) AS VALOR5, SUM(ESTATISTICA.VALOR6) AS VALOR6,
  SUM(ESTATISTICA.VALOR7) AS VALOR7, SUM(ESTATISTICA.VALOR8) AS VALOR8,
  SUM(ESTATISTICA.VALOR9) AS VALOR9, SUM(ESTATISTICA.VALOR10) AS VALOR10,
  SUM(ESTATISTICA.VALOR11) AS VALOR11, SUM(ESTATISTICA.VALOR12) AS VALOR12,
  SUM(COALESCE(ESTATISTICA.VALOR1,0) + COALESCE(ESTATISTICA.VALOR2,0) + COALESCE(ESTATISTICA.VALOR3,0) + 
           COALESCE(ESTATISTICA.VALOR4,0) + COALESCE(ESTATISTICA.VALOR5,0) + COALESCE(ESTATISTICA.VALOR6,0) +
           COALESCE(ESTATISTICA.VALOR7,0) + COALESCE(ESTATISTICA.VALOR8,0) + COALESCE(ESTATISTICA.VALOR9,0) + 
           COALESCE(ESTATISTICA.VALOR10,0) + COALESCE(ESTATISTICA.VALOR11,0) + COALESCE(ESTATISTICA.VALOR12,0)) AS TOTAL,
  estatistica.filial,
  estatistica.razaofilial,
  case estatistica.opcao
  when 0 then 'Valor'
  when 1 THEN 'Unidade'
  WHEN 2 THEN 'Quantidade'
  END as opcaodesc,
  case estatistica.comipi
  when 'S' then 'Com IPI'
  WHEN 'N' THEN 'Sem IPI'
  END as COMIPI,
  'Nota Fiscal' as tipo
 FROM ESTATISTICA ('ESTATSIN')
 INNER JOIN CADASTROPARCEIROS CLIENTE ON (ESTATISTICA.CODCLIENTE=CLIENTE.CADASTRO)
 LEFT JOIN clientes ON (CLIENTE.CADASTRO=CLIENTES.CADASTRO)
 LEFT JOIN CADASTROPARCEIROS VENDEDORCLIENTE ON (VENDEDORCLIENTE.CADASTRO=CLIENTES.VENDEDOR) 
 LEFT JOIN canaldistribuicao ON (CANALDISTRIBUICAO.canaldist=CLIENTES.canaldistribuicao)
 LEFT JOIN CADASTROPARCEIROS VENDEDORVENDA ON (VENDEDORVENDA.CADASTRO =ESTATISTICA.VENDEDOR)
 LEFT JOIN AREAGEOGRAFICA ON (CLIENTE.AREAGEOGRAFICA = AREAGEOGRAFICA.AREAGE)
 LEFT JOIN ramoatividade ON (CLIENTE.ramoatividade = ramoatividade.ramoatividade)
 LEFT JOIN ESTADO ON (CLIENTE.uf = estado.estado)
 left join cadastroparceiros canal ON (canal.cadastro=estatistica.canalrelacionado)
 GROUP BY 3,4,1, 2,
   ESTATISTICA.DATAINICIAL, ESTATISTICA.DATAFINAL, 
   ESTATISTICA.MATERIALINICIAL, ESTATISTICA.MATERIALFINAL, 
   ESTATISTICA.SERVICOINICIAL, ESTATISTICA.SERVICOFINAL, ESTATISTICA.CONSOLIDADO, ESTATISTICA.DESCRICAO_ESTSIN, 
   ESTATISTICA.FILIAL, ESTATISTICA.NOME,
   ESTATISTICA.DATAINICIO1, ESTATISTICA.DATAFIM1,
   ESTATISTICA.DATAINICIO2, ESTATISTICA.DATAFIM2,
   ESTATISTICA.DATAINICIO3, ESTATISTICA.DATAFIM3,
   ESTATISTICA.DATAINICIO4, ESTATISTICA.DATAFIM4,
   ESTATISTICA.DATAINICIO5, ESTATISTICA.DATAFIM5,
   ESTATISTICA.DATAINICIO6, ESTATISTICA.DATAFIM6,
   ESTATISTICA.DATAINICIO7, ESTATISTICA.DATAFIM7,
   ESTATISTICA.DATAINICIO8, ESTATISTICA.DATAFIM8,
   ESTATISTICA.DATAINICIO9, ESTATISTICA.DATAFIM9,
   ESTATISTICA.DATAINICIO10, ESTATISTICA.DATAFIM10,
   ESTATISTICA.DATAINICIO11, ESTATISTICA.DATAFIM11,
   ESTATISTICA.DATAINICIO12, ESTATISTICA.DATAFIM12,
   ESTATISTICA.OPCAO,
   estatistica.filial,
   estatistica.razaofilial,
   estatistica.comipi