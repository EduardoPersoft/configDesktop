SELECT
    NOTAFISCAL.FILIAL,
    filial.nome,
    NOTAFISCAL.IDNOTA,
    NOTAFISCAL.UUID,
    notafiscal.numeronota,
    notafiscal.dataemissao,
    NOTAFISCAL.DESTINATARIO idparceiro,
    CADASTROPARCEIROS.NOME,
    CADASTROPARCEIROS.RAZAOSOCIAL,   

    NOTAFISCAL.CONTACORRENTECOBRAN,
    CONTACORRENTE.DESCRICAOCONTA,
    banco.CODCAMARACOMP,   

    notafiscal.TIPOCOBRANCA, 
    TIPOCOBRANCA.DESCRICAO DESCRICAOCOBRANCA,   
    TIPOCOBRANCA.TPAG,
     
    notafiscal.IDVENDACARTAO,
    NOTAFISCAL.BANDEIRACARTAO,
    NOTAFISCAL.VLRTOTALNOTA,
    NOTAFISCAL.CONDICAOPAGAMENTO,
    CONDICAOPAGAMENTO.DESCRICAO as CONDICAOPAGAMENTO,
    movimentoestoque.motorista,
    (select 
        count(CONDICAOPAGAMENTOITEM.DIAS)
     from
        CONDICAOPAGAMENTOITEM
     where
        CONDICAOPAGAMENTOITEM.codigo=CONDICAOPAGAMENTO.id) as qtdFaturas,
    
    (SELECT first 1
        faturas.valorfatura
     from
        faturas
    where
        faturas.filial=notaFiscal.filial and
        faturas.idnota=notafiscal.idnota) valortotal 
  
FROM NOTAFISCAL

inner join 
     CADASTROPARCEIROS filial on
     filial.cadastro=NOTAFISCAL.filial
INNER JOIN 
    CADASTROPARCEIROS ON 
        (NOTAFISCAL.destinatario = CADASTROPARCEIROS.CADASTRO)        
left JOIN 
    CONTACORRENTE ON
        (CONTACORRENTE.FILIAL=NOTAFISCAL.FILIAL AND
         CONTACORRENTE.CODIGO=notafiscal.CONTACORRENTECOBRAN)
left join 
    TIPOCOBRANCA ON 
        (notafiscal.TIPOCOBRANCA=TIPOCOBRANCA.TIPOCOBRANCA)
left join
    banco on
        banco.banco=contacorrente.banco
left join 
    CONDICAOPAGAMENTO on 
        (CONDICAOPAGAMENTO.ID=NOTAFISCAL.CONDICAOPAGAMENTO)
left join 
   movimentoestoque on
       movimentoestoque.filial=notafiscal.filial and
       movimentoestoque.idnotaexpedicao=notafiscal.idnota and 
       movimentoestoque.tipomovimento='13'
where
    NOTAFISCAL.FILIAL=1  and 
    NOTAFISCAL.DATAEMISSAO between '01.01.2025' and '31.12.2025' and 
    notafiscal.dataCancelamento is  null  and 
    exists (select * from faturas where faturas.filial=notafiscal.filial and faturas.idnota=notafiscal.idnota)
order by
    notafiscal.dataEmissao,
    notaFiscal.numeroNota