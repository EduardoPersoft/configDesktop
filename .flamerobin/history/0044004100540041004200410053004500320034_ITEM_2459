SELECT
    ITEM.CODIGO,
    ITEM.DESCRICAO,
    ITEM.CODIGOBARRA,
    ITEM.REFERENCIA,
    ITEM.GRUPO,
    ITEM.FAMILIA,
    ITEM.CLASSIFISCAL,
    ITEM.TRIBUTACAOICMS,
    ITEM.CODIGOTRIBUTACAO,
    ITEM.TIPOPRODUTO,
    ITEMESTOQUEXARQUIVO.nomearquivo,
    ITEMBASE.CODIGO ITEMBASECODIGO,
    ITEMBASE.DESCRICAO ITEMBASEDESCRICAO,
    ITEM.DEFINICAO,
    ITEM.DESCRIMINACAO,
    FABRICANTE.CADASTRO FABRICANTECADASTRO,
    FABRICANTE.NOME FABRICANTENOME,
    ITEM.DISPONIVELECOMMERCE
FROM 
    ITEMESTOQUE ITEM
LEFT JOIN
    ITEMESTOQUE ITEMBASE ON
        ITEMBASE.CODIGO=ITEM.ITEMBASE
LEFT JOIN
    ITEMESTOQUEXARQUIVO ARQUIVO ON
        ARQUIVO.CODIGO=ITEM.CODIGO and
        ARQUIVO.ORDEM=0
LEFT JOIN
    CADASTROPARCEIROS FABRICANTE ON
        FABRICANTE.CADASTRO=ITEM.FABRICANTE

WHERE
    ITEM.CODIGO = '06190'


