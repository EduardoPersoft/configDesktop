SELECT

C_PLANCTOCONTABEISPAGOS3.CONTACONTABIL,
C_PLANCTOCONTABEISPAGOS3.DATAINICIAL,
C_PLANCTOCONTABEISPAGOS3.DATAFINAL,
case (CONTASCONTABEIS.TIPOCONTA)
     when 'S' then CONTASCONTABEIS.DESCRICAO
     else '' end as descsintetica,
case (CONTASCONTABEIS.TIPOCONTA)
     when 'A' then CONTASCONTABEIS.DESCRICAO
     else '' end as descanalitica,
sum (C_PLANCTOCONTABEISPAGOS3.VALORFABRICA)as VALORFABRICA,
sum (C_PLANCTOCONTABEISPAGOS3.VALORLARCENTER)as VALORLARCENTER,
sum (C_PLANCTOCONTABEISPAGOS3.VALORGABRIEL)as VALORGABRIEL,
sum (C_PLANCTOCONTABEISPAGOS3.VALORDED)as VALORDED,
sum (C_PLANCTOCONTABEISPAGOS3.VALORRIO)as VALORRIO,
sum (C_PLANCTOCONTABEISPAGOS3.VALORADM)as VALORADM,
sum (C_PLANCTOCONTABEISPAGOS3.VALORMARKETING)as VALORMARKETING,
sum (C_PLANCTOCONTABEISPAGOS3.VALORCOMERCIAL)as VALORCOMERCIAL,
sum (C_PLANCTOCONTABEISPAGOS3.VALOREXPEDICAO)as VALOREXPEDICAO,
sum (C_PLANCTOCONTABEISPAGOS3.VALORCOLOCACAO)as VALORCOLOCACAO,
sum (C_PLANCTOCONTABEISPAGOS3.VALORCHRONOS)as VALORCHRONOS,
(sum (C_PLANCTOCONTABEISPAGOS3.VALORFABRICA)+
sum (C_PLANCTOCONTABEISPAGOS3.VALORLARCENTER)+
sum (C_PLANCTOCONTABEISPAGOS3.VALORGABRIEL)+
sum (C_PLANCTOCONTABEISPAGOS3.VALORDED)+
sum (C_PLANCTOCONTABEISPAGOS3.VALORRIO)+
sum (C_PLANCTOCONTABEISPAGOS3.VALORADM)+
sum (C_PLANCTOCONTABEISPAGOS3.VALORMARKETING)+
sum (C_PLANCTOCONTABEISPAGOS3.VALORCOMERCIAL)+
sum (C_PLANCTOCONTABEISPAGOS3.VALOREXPEDICAO)+
sum (C_PLANCTOCONTABEISPAGOS3.VALORCHRONOS)+
sum (C_PLANCTOCONTABEISPAGOS3.VALORCOLOCACAO)
) as somacolunas,
COALESCE (c_fluxo.ID,99) as c_fluxo,
COALESCE (c_fluxo.DESCRICAO, 'SEM GRUPO') as c_fluxodesc,

case CONTASCONTABEIS.TIPOCONTA when 'S' then 0 else sum (C_PLANCTOCONTABEISPAGOS3.VALORFABRICA) end as totalfabrica,
case CONTASCONTABEIS.TIPOCONTA when 'S' then 0 else sum (C_PLANCTOCONTABEISPAGOS3.VALORLARCENTER) end as totallarcenter,
case CONTASCONTABEIS.TIPOCONTA when 'S' then 0 else sum (C_PLANCTOCONTABEISPAGOS3.VALORGABRIEL) end as totalgabriel,
case CONTASCONTABEIS.TIPOCONTA when 'S' then 0 else sum (C_PLANCTOCONTABEISPAGOS3.VALORDED) end as totalded,
case CONTASCONTABEIS.TIPOCONTA when 'S' then 0 else sum (C_PLANCTOCONTABEISPAGOS3.VALORRIO) end as totalrio,
case CONTASCONTABEIS.TIPOCONTA when 'S' then 0 else sum (C_PLANCTOCONTABEISPAGOS3.VALORCHRONOS) end as totalchronos,
case CONTASCONTABEIS.TIPOCONTA when 'S' then 0 else sum (C_PLANCTOCONTABEISPAGOS3.VALORADM) end as totaladm,
case CONTASCONTABEIS.TIPOCONTA when 'S' then 0 else sum (C_PLANCTOCONTABEISPAGOS3.VALORMARKETING) end as totalmarketing,
case CONTASCONTABEIS.TIPOCONTA when 'S' then 0 else sum (C_PLANCTOCONTABEISPAGOS3.VALORCOMERCIAL) end as totalcomercial,
case CONTASCONTABEIS.TIPOCONTA when 'S' then 0 else sum (C_PLANCTOCONTABEISPAGOS3.VALOREXPEDICAO) end as totalEXPEDICAO,
case CONTASCONTABEIS.TIPOCONTA when 'S' then 0 else sum (C_PLANCTOCONTABEISPAGOS3.VALORCOLOCACAO) end as totalCOLOCACAO,

case CONTASCONTABEIS.TIPOCONTA when 'S' then 0 else 
(sum (C_PLANCTOCONTABEISPAGOS3.VALORFABRICA)+
sum (C_PLANCTOCONTABEISPAGOS3.VALORLARCENTER)+
sum (C_PLANCTOCONTABEISPAGOS3.VALORGABRIEL)+
sum (C_PLANCTOCONTABEISPAGOS3.VALORDED)+
sum (C_PLANCTOCONTABEISPAGOS3.VALORRIO)+
sum (C_PLANCTOCONTABEISPAGOS3.VALORADM)+
sum (C_PLANCTOCONTABEISPAGOS3.VALORMARKETING)+
sum (C_PLANCTOCONTABEISPAGOS3.VALORCOMERCIAL)+
sum (C_PLANCTOCONTABEISPAGOS3.VALOREXPEDICAO)+
sum (C_PLANCTOCONTABEISPAGOS3.VALORCHRONOS)+
sum (C_PLANCTOCONTABEISPAGOS3.VALORCOLOCACAO)) end as totalsoma

from C_PLANCTOCONTABEISPAGOS3
inner join ESTABELECIMENTO on (ESTABELECIMENTO.CADASTRO=C_PLANCTOCONTABEISPAGOS3.FILIAL)
left join CONTASCONTABEIS on (CONTASCONTABEIS.IDPLANO=estabelecimento.planocontas and
          cONTASCONTABEIS.CONTACONTABIL=C_PLANCTOCONTABEISPAGOS3.CONTACONTABIL)
left join c_fluxo on (CONTASCONTABEIS.C_FLUXO=C_FLUXO.id)


GROUP by
CONTASCONTABEIS.TIPOCONTA,
CONTASCONTABEIS.DESCRICAO,
c_fluxo.ID,
c_fluxo.DESCRICAO ,
C_PLANCTOCONTABEISPAGOS3.CONTACONTABIL,
C_PLANCTOCONTABEISPAGOS3.DATAINICIAL,
C_PLANCTOCONTABEISPAGOS3.DATAFINAL

order by c_fluxo.ID , C_PLANCTOCONTABEISPAGOS3.CONTACONTABIL
