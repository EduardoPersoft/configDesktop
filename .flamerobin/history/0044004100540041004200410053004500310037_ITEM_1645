insert into ITEMESTOQUECODIGOS(CODIGO, CODIGOALTERNATIVO)
select 
    ITEMESTOQUE.CODIGO,
    ITEMESTOQUE.C_ORIGINAL
from
    ITEMESTOQUE
where
    ITEMESTOQUE.C_ORIGINAL IS NOT NULL and
    EXISTS (
        SELECT
            *
        from
            ITEMESTOQUECODIGOS
        where
            ITEMESTOQUECODIGOS.CODIGO=ITEMESTOQUE.CODIGO and
            ITEMESTOQUECODIGOS.CODIGOALTERNATIVO=ITEMESTOQUE.C_ORIGINAL)
    