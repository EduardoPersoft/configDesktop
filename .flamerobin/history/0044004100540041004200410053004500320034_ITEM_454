UPDATE
    CLASSIFICACAOFISCAL
SET
    classificacaofiscal.ALIQUOTA = (
        select 
            max(mercadoriasnotacompra.pipi)
        FROM    
            MERCADORIASNOTACOMPRA
        WHERE
            mercadoriasnotacompra.CLASSIFISCAL=classificacaofiscal.cfiscal)
WHERE
    exists (
        select 
            *
        FROM    
            MERCADORIASNOTACOMPRA
        WHERE
            mercadoriasnotacompra.CLASSIFISCAL=classificacaofiscal.cfiscal)
    
