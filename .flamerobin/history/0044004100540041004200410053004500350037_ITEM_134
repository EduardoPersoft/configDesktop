SELECT 
    HISTORIA.ID,
    HISTORIA.UUID,
    HISTORIA.DATAHORA,
    HISTORIA.MENSAGEM,    
    HISTORIA.uuidassunto,
    ASSUNTOHISTORIA.TIPO,
    TIPOASSUNTO.DESCRICAO TIPODESCRICAO,
    ASSUNTOHISTORIA.DESCRICAO DESCRICAOASSUNTO,
    HISTORIA.PARCEIRO,
    CADASTROPARCEIROS.NOME,
    HISTORIA.CONTATO,
    HISTORIA.DATAHORAALTERACAO,
    HISTORIA.USUARIOALTERACAO,
    USUARIOALTERACAO.USUARIO,
    HISTORIA.USUARIO,
    USUARIOHISTORIA.USUARIO,
    ORIGEMHISTORIA.ID,
    ORIGEMHISTORIA.DESCRICAO,
    HISTORIA.PARCEIRO,
    CADASTROPARCEIROS.NOME,
    CAST(HISTORIA.DATAHORA AS DATE) DATA
FROM 
    VENDEDOR
INNER JOIN 
    HISTORIA ON 
        HISTORIA.USUARIO=VENDEDOR.USUARIORELACIONADO
INNER JOIN 
    USUARIO USUARIOHISTORIA ON 
        HISTORIA.USUARIO = USUARIOHISTORIA.ID
INNER join
    VENDEDOR C_ESPECIFICADOR ON 
        C_ESPECIFICADOR.CADASTRO = HISTORIA.PARCEIRO
LEFT JOIN 
    CADASTROPARCEIROS ON 
        HISTORIA.PARCEIRO = CADASTROPARCEIROS.CADASTRO
LEFT JOIN 
    USUARIO USUARIOALTERACAO ON 
        historia.usuarioAlteracao = usuarioalteracao.id AND 
        CADASTROPARCEIROS.NOME = USUARIOALTERACAO.NOMECOMPLETO
LEFT JOIN 
    ORIGEMHISTORIA ON 
        HISTORIA.ORIGEM=ORIGEMHISTORIA.ID
LEFT join
    ASSUNTOHISTORIA ON
        ASSUNTOHISTORIA.UUID=HISTORIA.UUIDASSUNTO
LEFT join
    TIPOASSUNTO ON
        TIPOASSUNTO.ID=ASSUNTOHISTORIA.TIPO
where
    VENDEDOR.CADASTRO = ? AND
    CAST(HISTORIA.DATAHORA AS DATE) BETWEEN ? AND ?

order by
    historia.datahora,
    historia.id
