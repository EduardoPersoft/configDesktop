SELECT
    TITULOPAG.FILIAL,
    filial.nome,
    TITULOPAG.IDTITULO id,
    TITULOPAG.TITULO,
    TITULOPAG.FATURA,
    TITULOPAG.PARCEIRO idparceiro,
    CADASTROPARCEIROS.NOME,
    CADASTROPARCEIROS.RAZAOSOCIAL,
    TITULOPAG.VALORTITULO,
    TITULOPAG.TOTALPAGO,
    TITULOPAG.TOTALABATIDO,
    TITULOPAG.VALOREMABERTO,
    TITULOPAG.TOTALDESCONTO,
    TITULOPAG.TOTALJUROS,
    TITULOPAG.totalpago+TITULOPAG.totaljuros-TITULOPAG.totaldesconto totalPagamento,
    TITULOPAG.EMISSAO,
    TITULOPAG.VENCIMENTO,
    TITULOPAG.PROGRAMACAO,
    TITULOPAG.baixa,
    TITULOPAG.TIPOTRANSACAO,
    TIPOPAGAMENTO.DESCRICAO DESCRICAOCOBRANCA,    
    TITULOPAG.CONTACORRENTE,
    CONTACORRENTE.DESCRICAOCONTA,
    'N' AS P_MARCA,
    
    CASE WHEN TITULOPAG.BAIXA IS NOT NULL THEN 8421504
    WHEN TITULOPAG.VENCIMENTO<CAST('NOW' AS DATE) THEN 255
    ELSE 0 END AS P_STATUSCOR
  
FROM 
    MOVTOTITULOPAG titulopag
INNER JOIN 
    CADASTROPARCEIROS ON 
        TITULOPAG.PARCEIRO = CADASTROPARCEIROS.CADASTRO
inner join 
     CADASTROPARCEIROS filial on
        filial.cadastro=TITULOPAG.filial
left JOIN CONTACORRENTE ON
     TITULOPAG.FILIAL=CONTACORRENTE.FILIAL AND
     TITULOPAG.CONTACORRENTE=CONTACORRENTE.CODIGO
left JOIN TIPOPAGAMENTO ON 
     TITULOPAG.TIPOTRANSACAO=TIPOPAGAMENTO.id
where
    TITULOPAG.FILIAL=1 and
    TITULOPAG.TIPOMOVTO IN ('D', 'F') and 
    titulopag.DTMOVTOTITULO between '01.04.2025' and '30.04.2025'


 
