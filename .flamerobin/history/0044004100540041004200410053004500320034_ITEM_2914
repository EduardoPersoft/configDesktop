insert into
    ITEMESTOQUECODIGOS
select
    DISTINCT
    ITEMESTOQUECODIGOS.CODIGO,
    ITEMESTOQUECODIGOS.CODIGO
from
    ITEMESTOQUECODIGOS
where 
    NOT EXISTS 
    (SELECT 
        * 
     FROM 
        ITEMESTOQUECODIGOS
     WHERE   
        ITEMESTOQUECODIGOS.CODIGO=ITEMESTOQUECODIGOS.CODIGO
        ITEMESTOQUECODIGOS.CODIGOALTERNATIVO=ITEMESTOQUECODIGOS.CODIGO)