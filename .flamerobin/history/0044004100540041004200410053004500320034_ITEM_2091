SELECT 
    a.CADASTRO, 
    a.MOEDA, 
    a.CONTACORRENTE, 
    a.TIPOPAGAMENTO, 
    TIPOPAGAMENTO.descricao,
    a.BANCO,
    B1.DESCRICAO,
    a.DESCRICAO, 
    a.CODPAGTOINSS, 
    a.CODRECOLHIMENTOIRF,     
    a.CONDICAOPAGAMENTO,
    CONDICAOPAGAMENTO.DESCRICAO, 
    a.ZONAFRANCA, 
    a.SUBSTITUIRTRIBUTARIA, 
    a.AGENCIACOBRADORA,
    a.DIGAGENCIACOBRADORA, 
    a.CODJUROSMORA, 
    a.CODDESCONTO, 
    a.BANCOPAGADOR,
    a.JUROSDIARIOATRASO, 
    a.MULTAATRASO, 
    a.DESCONTOFINANCEIRO,
    a.DIASDESCFINANCEIRO, 
    a.CODMUNICIPIO, 
    a.PERCENTUALIRF, 
    a.PERCENTUALINSS,
    a.PERCENTUALCSLL, 
    a.PERCENTUALPIS, 
    a.PERCENTUALCOFINS, 
    a.CODIGOCSLL,
    a.CODIGOPIS, 
    a.CODIGOCOFINS, 
    a.NUMCONTACORRENTE, 
    a.DIGITOCONTACORRENTE,
    a.PERCENTUALISS, 
    a.DIGITOAGCC, 
    a.FINALIDADEDOCTO, 
    a.TIPOCONTA,
    a.CODCAMARACOMPENSACAO, 
    a.DOCUMENTOCONTA, 
    a.BANCO2, 
    a.AGENCIACOBRADORA2,
    a.NUMCONTACORRENTE2, 
    a.DIGITOCONTACORRENTE2, 
    a.DIGITOAGCC2,
    a.DIGAGENCIACOBRADORA2, 
    a.FINALIDADEDOCTO2, 
    a.TIPOCONTA2,
    a.CODCAMARACOMPENSACAO2, 
    a.DOCUMENTOCONTA2, 
    a.C_INVESTIMENTO,
    a.C_TOTALBALANCINHO, 
    a.C_DESCRICAOBALANCINHO, 
    a.CONTACONTABIL, 
    a.PROVISIONA,
    a.FATURAMENTOMINIMO, 
    a.PIX, 
    a.PIX2
FROM 
    FORNECEDORES a 
LEFT JOIN
    TIPOPAGAMENTO ON
        TIPOPAGAMENTO.ID=a.TIPOPAGAMENTO
LEFT JOIN
    BANCO B1 ON
        B1.BANCO=A.BANCO
LEFT JOIN
    CONDICAOPAGAMENTO ON
        CONDICAOPAGAMENTO.ID=A.CONDICAOPAGAMENTO
WHERE
    a.CADASTRO = 1082
