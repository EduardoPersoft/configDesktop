select 
    COUNT(FORNECEDORESITEM.IDITEM),
    FORNECEDORESITEM.FORNECEDOR
FROM
    MATERIALFILIAL
INNER join
    FORNECEDORESITEM ON
        FORNECEDORESITEM.IDITEM=MATERIALFILIAL.IDITEM
INNER join
    MATERIALLOCAL ON
        MATERIALLOCAL.FILIAL=MATERIALFILIAL.FILIAL and
        MATERIALLOCAL.IDITEM=MATERIALFILIAL.IDITEM
WHERE
    MATERiALFILIAL.FILIAL=5 AND
    COALESCE(MATERIALFILIAL.SALDOMAXIMO,MATERIALFILIAL.CONSUMOMEDIO)*0.4<SUM(MATERIALLOCAL.SALDOTOTAL)    
GROUP BY
    FORNECEDORESITEM.FORNECEDOR
HAVING    
    