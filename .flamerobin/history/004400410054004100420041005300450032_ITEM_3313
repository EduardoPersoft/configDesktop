SELECT 
    *
FROM
    MERCADORIASPEDCOMPRA
WHERE
    MERCADORIASPEDCOMPRA.FILIAL=5 AND 
    EXISTS (
        SELECT
            *
        FROM
            T_MERCPEDERRADO
        WHERE
            T_MERCPEDERRADO.CODIGO=MERCADORIASPEDCOMPRA.CODIGO AND
            T_MERCPEDERRADO.PEDIDO=MERCADORIASPEDCOMPRA.IDNOTA)