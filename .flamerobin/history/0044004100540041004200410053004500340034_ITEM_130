SELECT DISTINCT 
       cast('N' as char(1)) as P_MARCA,
       MOVIMENTOESTOQUE.FILIAL,
       MOVIMENTOESTOQUE.IDMOVIMENTO,
       MOVIMENTOESTOQUE.DOCUMENTO,
       PEDIDO.UUID,
       MOVIMENTOESTOQUE.EMISSAO,
       CADCLI.CADASTRO,
       CADCLI.RAZAOSOCIAL,
       CADCLI.NOME AS NOMECLI,
       CADCLI.LOGRADOURO,
       CADCLI.NUMERO,
       CADCLI.COMPLEMENTO,
       CADCLI.BAIRRO,
       CADCLI.CIDADE,
       CADCLI.UF,
       CADCLI.CEP,   
       MOVIMENTOESTOQUE.motorista,
       coalesce(notafiscal.codigotransp,MOVIMENTOESTOQUE.TRANSPORTADORA),
       TRANSP.nome,
       MOVIMENTOESTOQUE.QUANTIDADEVOLUMES,
       MOVIMENTOESTOQUE.coleta,
       MOVIMENTOESTOQUE.coletadata,    
       MODELODOCTO.MODELO,
       NOTAFISCAL.NUMERONOTA,
       MOVIMENTOESTOQUE.DATAENTREGA,
       CASE WHEN EXISTS (SELECT * FROM MATERIALMOVIMENTOESTOQUE
                WHERE MATERIALMOVIMENTOESTOQUE.filial = MOVIMENTOESTOQUE.filial
                AND MATERIALMOVIMENTOESTOQUE.idmovimento = MOVIMENTOESTOQUE.idmovimento
                AND MATERIALMOVIMENTOESTOQUE.concluido = 'N') THEN 'N'
            ELSE 'S' END CONCLUIDO

FROM
    MOVIMENTOESTOQUE
LEFT JOIN
    PEDIDO ON PEDIDO.FILIAL=MOVIMENTOESTOQUE.FILIAL AND PEDIDO.IDNOTA=MOVIMENTOESTOQUE.IDPEDIDO
LEFT JOIN 
    MATERIALMOVIMENTOESTOQUE ON
        MATERIALMOVIMENTOESTOQUE.FILIAL=MOVIMENTOESTOQUE.FILIAL
        AND MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO=MOVIMENTOESTOQUE.IDMOVIMENTO
LEFT JOIN
    CADASTROPARCEIROS CADCLI ON
        CADCLI.CADASTRO=PEDIDO.DESTINATARIO
LEFT JOIN 
    NOTAFISCAL ON 
        NOTAFISCAL.MOVIMENTOESTOQUEFILIAL=MOVIMENTOESTOQUE.FILIAL 
         and notafiscal.idnota=movimentoestoque.idnotaexpedicao
        AND NOTAFISCAL.DATACANCELAMENTO IS NULL
LEFT JOIN 
    MERCADORIASNOTA ON
        MERCADORIASNOTA.FILIAL=NOTAFISCAL.FILIAL
        AND MERCADORIASNOTA.IDNOTA=NOTAFISCAL.IDNOTA
LEFT JOIN 
    CADASTROPARCEIROS TRANSP ON 
     (TRANSP.CADASTRO = coalesce(notafiscal.codigotransp,MOVIMENTOESTOQUE.transportadora))

LEFT JOIN
    MODELODOCTO ON
        MODELODOCTO.ID = NOTAFISCAL.MODELO
where
    movimentoestoque.filial=1 and 
    movimentoestoque.tipomovimento='13' and
    movimentoestoque.emissao between '01.01.2024' and '31.01.2024' 
    
ORDER BY 
        MOVIMENTOESTOQUE.IDMOVIMENTO DESC