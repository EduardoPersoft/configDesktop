SET TERM ^ ;
ALTER PROCEDURE C_IMPORTARPRODUTOS (
    FILIAL INTEGER )
AS
DECLARE VARIABLE V_I INTEGER;
DECLARE VARIABLE V_CLASSIFICACAOFISCAL VARCHAR(30);
DECLARE VARIABLE V_CODIGO VARCHAR(15);
DECLARE VARIABLE V_DESCRICAO VARCHAR(240);
DECLARE VARIABLE V_ID INTEGER;
DECLARE VARIABLE V_GRUPO INTEGER;
DECLARE VARIABLE V_LOCACAO VARCHAR(50);
DECLARE VARIABLE V_MULTIPLO DECIMAL(12,4);
DECLARE VARIABLE V_TIPOPECA INTEGER;
DECLARE VARIABLE V_UNIDADE VARCHAR(10);
DECLARE VARIABLE V_CF VARCHAR(3);
DECLARE VARIABLE V_LOTE DECIMAL(12,3);
DECLARE VARIABLE V_ULTIMOCUSTO DECIMAL(12,3);
DECLARE VARIABLE V_PRECOVENDA DECIMAL(12,3);
DECLARE VARIABLE V_CSTMEDIO DECIMAL(12,3);
DECLARE VARIABLE V_ESTOQUE DECIMAL(12,3);
declare variable v_pedido decimal(12,3);
declare variable idMercadoriaCompra integer;
declare variable qtdPedido integer;
DECLARE VARIABLE V_CODIGOORIGINAL VARCHAR(100);
BEGIN

   /*
   DELETE FROM GRUPOMERCADORIA;   
   INSERT INTO GRUPOMERCADORIA(GRUPO,DESCRICAO)
   SELECT DISTINCT
    SUBSTRING(CODIGOORIGINAL FROM 1 FOR 2),
    SUBSTRING(CODIGOORIGINAL FROM 3 FOR 30)
   FROM 
    C_I_ITENSESTOQUE
   where
    SUBSTRING(CODIGOORIGINAL FROM 3 FOR 30)<>'';

   DELETE FROM CLASSIFICACAOFISCAL;
   V_I = 0;
   FOR SELECT DISTINCT C_I_REGISTROINVENTARIO.CLASSIFICACAOFISCAL FROM C_I_REGISTROINVENTARIO
   INTO :V_CLASSIFICACAOFISCAL DO BEGIN
    INSERT INTO CLASSIFICACAOFISCAL(CFISCAL, DESCRICAO) VALUES (:V_I, :V_CLASSIFICACAOFISCAL);
    V_I = V_I + 1;
   END
   
   DELETE FROM UNIDADE;
   INSERT INTO UNIDADE(UNIDADE) SELECT DISTINCT C_I_REGISTROINVENTARIO.UNIDADE FROM C_I_REGISTROINVENTARIO;

   DELETE FROM FAMILIA;
   INSERT INTO FAMILIA(ID,DESCRICAO) select DISTINCT TIPOPECA, DESCRICAOPECA from c_i_posicaoestoque ; 
    
   DELETE FROM ITEMESTOQUE;

   delete from mercadoriaspedcompra where filial=:filial and idnota=1;
*/

   idMercadoriaCompra = 0; 
   


   INSERT INTO ITEMESTOQUE(
    CODIGO,CODIGOBARRA,TIPOPRODUTO, SEMIACABADO, EMBALAGEM, CODIGOTRIBUTACAO, TRIBUTACAOICMS, ESTOCADO, ITEMESTOQUE.SEMANASPARACOMPRA) 
   SELECT CODIGO,CODIGO,3,'N','N',0,1,'S',4 FROM C_I_ITENSESTOQUE WHERE NOT EXISTS (SELECT * FROM ITEMESTOQUE WHERE ITEMESTOQUE.CODIGO=C_I_ITENSESTOQUE.CODIGO);

   INSERT INTO MATERIALFILIAL(FILIAL, IDITEM, TEMPOREPOSICAO, SALDOMINIMO, SALDOMAXIMO)
   SELECT 
        :FILIAL, CODIGO, 7, 0, 0
   FROM
        C_I_ITENSESTOQUE 
   WHERE 
        NOT EXISTS 
            (SELECT 
                * 
             FROM 
                MATERIALFILIAL 
            WHERE 
                MATERIALFILIAL.FILIAL=:FILIAL AND 
                MATERIALFILIAL.IDITEM=C_I_ITENSESTOQUE.CODIGO);
   
   INSERT INTO MATERIALLOCAL(FILIAL, IDITEM, IDLOCAL)
   SELECT
        :FILIAL, CODIGO, 1 
    FROM 
        C_I_ITENSESTOQUE 
    WHERE 
        NOT EXISTS 
            (SELECT 
                * 
            FROM 
                MATERIALLOCAL 
            WHERE 
                MATERIALLOCAL.FILIAL=:FILIAL AND 
                MATERIALLOCAL.IDITEM=C_I_ITENSESTOQUE.CODIGO 
                AND MATERIALLOCAL.IDLOCAL=1);

   INSERT INTO LISTAPRECOPRODUTO(LISTA, PRODUTO, QUANTIDADE)
   SELECT 
    1,
    C_I_ITENSESTOQUE.CODIGO, 0
   FROM
    C_I_ITENSESTOQUE
   WHERE NOT EXISTS(
        SELECT * FROM LISTAPRECOPRODUTO
        WHERE LISTAPRECOPRODUTO.PRODUTO=C_I_ITENSESTOQUE.CODIGO
        AND LISTAPRECOPRODUTO.LISTA=1);
           
   FOR
    SELECT
        CODIGO,
        DESCRICAO,
        CAST(CODIGO AS INTEGER), 
        c_i_itensestoque.codigooriginal
    FROM 
        C_I_ITENSESTOQUE
    INTO
        :V_CODIGO,
        :V_DESCRICAO,
        :V_ID,
        :V_CODIGOORIGINAL DO BEGIN
        UPDATE 
            ITEMESTOQUE
        SET
            CODIGOBARRA = :V_CODIGO,
            DESCRICAO = :V_DESCRICAO,
            C_ID = :V_ID,
            REFERENCIA = :V_CODIGOORIGINAL
        WHERE
            CODIGO = :V_CODIGO;
    END
  

   FOR 
    SELECT 
        C_I_POSICAOESTOQUE.CODIGO,
        C_I_POSICAOESTOQUE.GRUPO,
        C_I_POSICAOESTOQUE.LOCACAO,
        C_I_POSICAOESTOQUE.MULTIPLO,
        C_I_POSICAOESTOQUE.TIPOPECA,
        C_I_POSICAOESTOQUE.LOTE,
        COALESCE(C_I_POSICAOESTOQUE.ULTIMOCUSTO,0),
        COALESCE(C_I_POSICAOESTOQUE.PRECOVENDA,0),
        COALESCE(C_I_POSICAOESTOQUE.CSTMEDIO, 0),
        COALESCE(C_I_POSICAOESTOQUE.ESTOQUE, 0),
        coalesce(C_I_POSICAOESTOQUE.pedido, 0)
    FROM
        C_I_POSICAOESTOQUE
    INTO
        :V_CODIGO,
        :V_GRUPO,
        :V_LOCACAO,
        :V_MULTIPLO,
        :V_TIPOPECA,
        :V_LOTE,
        :V_ULTIMOCUSTO,
        :v_PRECOVENDA,
        :V_CSTMEDIO,
        :V_ESTOQUE,
        :V_PEDIDO DO BEGIN

        if(cast(V_CODIGO as integer)<100000) then
            V_CODIGO = substring(cast(cast(V_CODIGO as integer)+100000 as varchar(15)) from 2 for 14);     
        
       UPDATE 
            ITEMESTOQUE
       SET
            GRUPO = case when :V_GRUPO > 32000 then null else :v_grupo end,
            LOCALIZACAO = :V_LOCACAO,
            QUANTIDADEUNIDADE = :V_MULTIPLO,
            FAMILIA = :V_TIPOPECA
       WHERE
            CODIGO = :V_CODIGO;
/*
       UPDATE
            MATERIALFILIAL
        SET 
  --          MATERIALFILIAL.SALDOMAXIMO=:V_LOTE,
            MATERIALFILIAL.CUSTOMEDIO=:v_cstmedio,
            MATERIALFILIAL.VALORTOTALESTOCADO=:v_cstmedio*:v_ESTOQUE 
       WHERE
            FILIAL = :FILIAL AND
            IDITEM = :V_CODIGO;

       UPDATE
            MATERIALLOCAL
        SET 
            MATERIALLOCAL.SALDOTOTAL=:V_ESTOQUE
       WHERE
            FILIAL = :FILIAL AND
            IDITEM = :V_CODIGO AND
            IDLOCAL=1;
  */     
       UPDATE 
            LISTAPRECOPRODUTO
       SET
            LISTAPRECOPRODUTO.CUSTOCONSIDERADO = :V_ULTIMOCUSTO,
            LISTAPRECOPRODUTO.PRECO = :V_PRECOVENDA
        WHERE
            LISTAPRECOPRODUTO.LISTA = 1 AND
            LISTAPRECOPRODUTO.PRODUTO = :V_CODIGO;


    END
  
  FOR  
    SELECT
        C_I_REGISTROINVENTARIO.CODIGO,
        C_I_REGISTROINVENTARIO.UNIDADE,
        C_I_REGISTROINVENTARIO.CLASSIFICACAOFISCAL,
        COALESCE(C_I_REGISTROINVENTARIO.CUSTOMEDIO, 0),
        COALESCE(C_I_REGISTROINVENTARIO.QUANTIDADE, 0),
        coalesce(C_I_REGISTROINVENTARIO.CUSTOTOTAL, 0)
    FROM 
        C_I_REGISTROINVENTARIO   
    INTO 
        :V_CODIGO,
        :V_UNIDADE,
        :V_CLASSIFICACAOFISCAL,
        :V_CSTMEDIO,
        :V_ESTOQUE,
        :V_PEDIDO 
    DO BEGIN
    
        SELECT 
            CLASSIFICACAOFISCAL.CFISCAL
        FROM
            CLASSIFICACAOFISCAL
        WHERE 
            CLASSIFICACAOFISCAL.DESCRICAO=:V_CLASSIFICACAOFISCAL
        INTO 
            :V_CF;
        UPDATE
            ITEMESTOQUE
        SET
            CLASSIFISCAL = :v_cf,
            UNIDADE = :V_UNIDADE
        WHERE
            CODIGO = :V_CODIGO;
            
        /*
            
       UPDATE
            MATERIALFILIAL
        SET 
            MATERIALFILIAL.CUSTOMEDIO=:v_cstmedio,
            MATERIALFILIAL.VALORTOTALESTOCADO=:v_cstmedio*:v_ESTOQUE 
       WHERE
            FILIAL = :FILIAL AND
            IDITEM = :V_CODIGO;

       UPDATE
            MATERIALLOCAL
        SET 
            MATERIALLOCAL.SALDOTOTAL=:V_ESTOQUE
       WHERE
            FILIAL = :FILIAL AND
            IDITEM = :V_CODIGO AND
            IDLOCAL=1;
          */  
    END
  
   
END^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE C_IMPORTARPRODUTOS TO  SYSDBA;

