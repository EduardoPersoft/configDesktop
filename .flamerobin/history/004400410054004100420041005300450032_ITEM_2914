SELECT  
    MERCADORIASNOTA.CLASSIFISCAL,
    MERCADORIASNOTA.SITUACAOTRIBUT,
    MERCADORIASNOTA.CFOP,
    NOTAFISCAL.UF
FROM
    NOTAFISCAL
INNER JOIN
    MERCADORIASNOTA ON
        MERCADORIASNOTA.FILIAL=NOTAFISCAL.FILIAL AND
        MERCADORIASNOTA.IDNOTA=NOTAFISCAL.IDNOTA
WHERE
    NOTAFISCAL.FILIAL=5 AND
    NOTAFISCAL.DATAEMISSAO BETWEEN '01.01.2021' AND '31.12.2021' AND
    NOTAFISCAL.MODELO=1
    
    