SELECT 
    MATERIALMOVIMENTOESTOQUE.*
from
    MOVIMENTOESTOQUE
INNER join
    MATERIALMOVIMENTOESTOQUE ON
        MATERIALMOVIMENTOESTOQUE.FILIAL=MOVIMENTOESTOQUE.FILIAL and
        MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO=MOVIMENTOESTOQUE.IDMOVIMENTO 
wherE
    MOVIMENTOESTOQUE.FILIAL=110 and
    MOVIMENTOESTOQUE.TIPOMOVIMENTO = '01' AND
    MOVIMENTOESTOQUE.EMISSAO BETWEEN '01.01.2024' AND '31.01.2024' and
    MATERIALMOVIMENTOESTOQUE.CODIGO LIKE 'MPP%'