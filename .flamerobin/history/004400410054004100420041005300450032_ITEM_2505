UPDATE
    MERCADORIASPEDCOMPRA M1
SET
    MINIMOBAIXA=0,
    MERCADORIASPEDCOMPRA.QTDEENTREGUE=0
WHERE
    M1.FILIAL=5 AND
    M1.BAIXA = 'N' AND
/*
    EXISTS (
    SELECT * FROM MERCADORIASPEDCOMPRA M2
    WHERE
    M2.FILIAL=M1.FILIAL AND
    M2.CODIGO=M1.CODIGO AND
    M2.IDNOTA>M1.IDNOTA AND
    M2.BAIXA='N') AND
*/
    EXISTS
        (SELECT *
        
     FROM 
        MERCADORIASNOTACOMPRA
     INNER JOIN 
        NOTACOMPRA ON (
            NOTACOMPRA.FILIAL=MERCADORIASNOTACOMPRA.FILIAL AND
            NOTACOMPRA.IDNOTA=MERCADORIASNOTACOMPRA.IDNOTA)
     WHERE 
        NOTACOMPRA.FILIAL=M1.FILIAL AND
        --NOTACOMPRA.DESTINATARIO = PEDIDOCOMPRA.DESTINATARIO AND 
        MERCADORIASNOTACOMPRA.CODIGO=M1.CODIGO AND
        NOTACOMPRA.DATAENTRADA>PEDIDOCOMPRA.DATACADASTRO 
        ) AND
    (SELECT 
        FIRST 1 MATERIALLOCAL.SALDOTOTAL
     FROM 
        MATERIALLOCAL
     WHERE 
        MATERIALLOCAL.FILIAL=M1.FILIAL AND
        MATERIALLOCAL.IDITEM=M1.CODIGO) >(SELECT 
        MATERIALFILIAL.CONSUMOMEDIO
     FROM 
        MATERIALFILIAL
     WHERE 
        MATERIALFILIAL.FILIAL=M1.FILIAL AND
        MATERIALFILIAL.IDITEM=M1.CODIGO) * .3        
ORDER BY
CODIGO