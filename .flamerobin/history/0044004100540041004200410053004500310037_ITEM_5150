select c_coletas.*, c_coletas.VALORMEDIO*c_coletas.QTDEXPEDICOES,
(select count(idmovimento)
 from MOVIMENTOESTOQUE
 where movimentoestoque.COLETA=c_coletas.COLETA
 and MOVIMENTOestoque.TIPOMOVIMENTO='13'),
 (select count(idmovimento)
 from MOVIMENTOESTOQUE
 where movimentoestoque.COLETA=c_coletas.COLETA
 and MOVIMENTOestoque.TIPOMOVIMENTO='13')*c_coletas.VALORMEDIO
from c_coletas
where c_coletas.DATACOLETA between '30.05.2025' and '27.06.2025'