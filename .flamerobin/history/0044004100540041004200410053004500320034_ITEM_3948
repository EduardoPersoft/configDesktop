
update
    MERCADORIASPED
set 
    mercadoriasped.minimo=qtdeenvaida
where
    filial=5 and
    baixa = 'N' and 
    exists 
    (select
        *
     from
        MERCADORIASNOTA
     where
        mercadoriasnota.filial=mercadoriasped.filial and
        mercadoriasnota.idpedido=mercadoriasped.idnota and 
        mercadoriasnota.idmercpedido=mercadoriasped.idmercadoria)