SET TERM ^ ;
ALTER PROCEDURE PROC_CUSTOMEDIO (
    P_FILIAL integer,
    P_IDITEM varchar(15),
    P_LOTE char(12) )
RETURNS (
    CUSTOMEDIO double precision )

AS
declare variable varvlrtotal double precision;
declare variable varqtdtotal double precision;
declare variable varcusto double precision;
BEGIN

  if (P_LOTE IS NULL) then begin
    SELECT MATERIALFILIAL.VALORTOTALESTOCADO,
       SUM(MATERIALLOCAL.SALDOTOTAL) TOTALQTDE 
    FROM MATERIALFILIAL
    INNER JOIN MATERIALLOCAL ON
       (MATERIALLOCAL.FILIAL = MATERIALFILIAL.FILIAL
       AND MATERIALLOCAL.IDITEM = MATERIALFILIAL.IDITEM)
    WHERE MATERIALFILIAL.FILIAL=:P_FILIAL
    AND   MATERIALFILIAL.IDITEM=:P_IDITEM
    GROUP BY MATERIALFILIAL.VALORTOTALESTOCADO
    INTO :VARVLRTOTAL, :VARQTDTOTAL;
    IF ((:VARQTDTOTAL = 0) OR (:VARQTDTOTAL IS NULL)) THEN BEGIN
      VARCUSTO = 0;
    END ELSE BEGIN
      VARCUSTO = :VARVLRTOTAL/:VARQTDTOTAL;
    END

    IF (:VARCUSTO IS NULL) THEN
      VARCUSTO = 0;
 
    CUSTOMEDIO =:VARCUSTO;

    if (customedio<=0.009) then
      SELECT MATERIALFILIAL.customedio FROM MATERIALFILIAL
      WHERE MATERIALFILIAL.FILIAL=:P_FILIAL
      AND   MATERIALFILIAL.IDITEM=:P_IDITEM
      INTO :CUSTOMEDIO;

  END else

     SELECT COALESCE(MATERIALLOTE.CUSTOMEDIO,0) FROM MATERIALLOTE
     WHERE MATERIALLOTE.FILIAL=:P_FILIAL
     AND MATERIALLOTE.IDITEM=:P_IDITEM
     AND MATERIALLOTE.LOTE=:P_LOTE
     INTO :CUSTOMEDIO;


  if (customedio is null) then
     customedio=0;

  SUSPEND;

END
^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE PROC_CUSTOMEDIO TO  SYSDBA;

