SET TERM ^ ;
ALTER PROCEDURE C_FATURAMENTONOTA (
    PDATAINICIAL TIMESTAMP,
    PDATAFINAL TIMESTAMP,
    PFILIAL INTEGER )
RETURNS (
    CODIGO VARCHAR(15),
    VLRFINALMERCAD NUMERIC(12,3),
    IDNOTA INTEGER,
    IDMERCADORIA INTEGER,
    VENDEDOR INTEGER,
    RAZAOVENDEDOR VARCHAR(60),
    DESTINATARIO INTEGER,
    DATAINICIAL TIMESTAMP,
    DATAFINAL TIMESTAMP,
    FILIAL INTEGER,
    C_COLUNA SMALLINT )
AS
declare variable pgrupo smallint;
declare variable PVENDEDOR INTEGER;
declare variable v_idnotasaida integer;
declare variable v_devolucaofaturamento char(1);
 begin

 datainicial=pdatainicial;
 datafinal=pdatafinal;
 filial=pfilial;
 
  for SELECT
    orcamento.idnota,
    orcamento.DESTINATARIO,
    NATUREZAOPERACAO.DEVOLUCAO
 FROM
    NOTAFISCAL ORCAMENTO
 INNER JOIN
    NATUREZAOPERACAO ON
        NATUREZAOPERACAO.ID=ORCAMENTO.OPERACAO
 where  
    ORCAMENTO.filial=:PFILIAL
    and ORCAMENTO.DATACADASTRO between :DATAINICIAL and :datafinal
    and ORCAMENTO.DATAEMISSAO IS NOT NULL
    and coalesce (NATUREZAOPERACAO.FATURA,'N')='S'
    AND coalesce  (ORCAMENTO.CANCELAMENTO,'N')<>'S'
 into :IDNOTA, :destinatario, :V_DEVOLUCAOFATURAMENTO do BEGIN
    
    
    SELECT
        FIRST 1
        VENDEDORESORC.VENDEDOR,
        CADVEN.RAZAOSOCIAL
    FROM
        VENDEDORESNOTA VENDEDORESORC
    INNER JOIN
        CADASTROPARCEIROS CADVEN ON
            CADVEN.CADASTRO=VENDEDORESORC.VENDEDOR
    WHERE
        VENDEDORESORC.FILIAL=:FILIAL
        AND VENDEDORESORC.IDNOTA=:IDNOTA
    INTO :VENDEDOR, :RAZAOVENDEDOR;

    
    for SELECT
        MERCADORIASORC.IDMERCADORIA,
        MERCADORIASORC.CODIGO,
        (mercadoriasORC.VLRFINALMERCAD+mercadoriasORC.ACRESCIMONOTA)-mercadoriasORC.DESCONTONOTA,
        COALESCE (GRUPOMERCADORIA.C_COLUNA,0),
        MERCADORIASORC.IDNOTASAIDA
    from 
        MERCADORIASNOTA MERCADORIASORC
    LEFT JOIN 
        ITEMESTOQUE ON 
            (ITEMESTOQUE.CODIGO=MERCADORIASORC.CODIGO)
    Left JOIN 
        GRUPOMERCADORIA ON 
            (ITEMESTOQUE.GRUPO=GRUPOMERCADORIA.GRUPO)
    WHERE 
        MERCADORIASORC.FILIAL=:FILIAL 
        AND MERCADORIASORC.IDNOTA=:IDNOTA
    into :IDMERCADORIA, :codigo, :VLRFINALMERCAD , :C_COLUNA, V_IDNOTASAIDA DO BEGIN
        IF(V_DEVOLUCAOFATURAMENTO='S') THEN BEGIN
            SELECT
                FIRST 1
                VENDEDORESORC.VENDEDOR,
                CADVEN.RAZAOSOCIAL
            FROM
                VENDEDORESNOTA VENDEDORESORC
            INNER JOIN
                CADASTROPARCEIROS CADVEN ON
                    CADVEN.CADASTRO=VENDEDORESORC.VENDEDOR
            WHERE
                VENDEDORESORC.FILIAL=:FILIAL
                AND VENDEDORESORC.IDNOTA=:V_IDNOTASAIDA
            INTO :VENDEDOR, :RAZAOVENDEDOR;
            VLRFINALMERCAD = VLRFINALMERCAD * (-1);
        END
        SUSPEND;
    END
 
    FOR SELECT
        SERVICOSORC.IDSERVICO,
        CAST  (SERVICOSORC.CODIGO AS VARCHAR (15)),
        (SERVICOSORC.VLRFINALSERVICO+SERVICOSORC.ACRESCIMONOTA)-SERVICOSORC.DESCONTONOTA,
        COALESCE (GRUPOSERVICO.C_COLUNA,0)
    from SERVICOSNOTA SERVICOSORC
    LEFT JOIN 
        SERVICO ON 
            (SERVICO.CODIGO=SERVICOSORC.CODIGO)
    left JOIN 
        GRUPOSERVICO ON 
            (SERVICO.GRUPOSERVICO=GRUPOSERVICO.GRUPO)
    where 
        SERVICOSORC.FILIAL=:FILIAL 
        AND SERVICOSORC.IDNOTA=:IDNOTA
    into :IDMERCADORIA,:codigo, :VLRFINALMERCAD, :C_COLUNA DO
        SUSPEND;

END
end^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE C_FATURAMENTONOTA TO  SYSDBA;

