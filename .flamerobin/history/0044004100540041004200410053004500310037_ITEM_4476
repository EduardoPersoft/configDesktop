    M1.FILIAL,
    M1.IDMOVIMENTO,
    M1.IDMOVIMENTOMATERIAL,
    M1.IDITEM,
    ITEMMATERIAL.CODIGOBARRA EAN,
    ITEMMATERIAL.DESCRICAO,
    ITEMMATERIAL.PESOLIQUIDO,
    ITEMMATERIAL.REFERENCIA,
    ITEMMATERIAL.DEFINICAO,
    ITEMMATERIAL.LOCALIZACAO,
    ITEMESTOQUEXARQUIVO.NOMEARQUIVO ITEMESTOQUE_NOMEARQUIVO,	   	   
    GRUPOMERCADORIA.DESCRICAO AS GRUPO,
    ITEMMATERIAL.FAMILIA AS FAMILIA, 
    FAMILIA.DESCRICAO AS FAMILIA, 
    M1.LOTE,
    M1.QUANTIDADE,
    ITEMMATERIAL.UNIDADE,
    M1.VALOR,
    M1.SINAL,
    M1.LOCALARMAZENAMENTO, LOCAL.DESCRICAO, M1.FILIALLOCAL, M1.IDPEDIDO, M1.IDMERCADORIA,
    M1.IDCOMPOSICAO,
    MERCADORIASPED.codigo,
    MERCADORIASPED.QUANTIDADE,
    M1.PRODUTO,
    M1.TEMPO,
    M1.SETUP,
    M1.IDCENTROCUSTO,
    CENTROCUSTOS.DESCRICAO,
    M1.CENTROCUSTO,
    M1.RECURSO,
    M1.ENTRADAPRODUCAO,
    M1.SAIDAPRODUCAO,
    M1.PERDA,
    M1.PERDASPREVISTAS,
/*
    case m1.concluido when 'S' then m1.quantidade
    else
    coalesce((
     Select 
        sum(M2.quantidade)
     from
        movimentoestoque
     inner JOIN
