SELECT
    ITEMESTOQUE.CODIGO,
    ITEMESTOQUE.DESCRICAO,
    MATERIALFILIAL.CONSUMOMEDIO
FROM
    ITEMESTOQUE
INNER JOIN
    MATERIALFILIAL ON
        MATERIALFILIAL.FILIAL=5 AND
        ITEMESTOQUE.CODIGO=MATERIALFILIAL.IDITEM
INNER JOIN 
    FORNECEDORESITEM ON
        FORNECEDORESITEM.IDITEM=ITEMESTOQUE.CODIGO AND
        FORNECEDORESITEM.FORNECEDOR=33402
        
