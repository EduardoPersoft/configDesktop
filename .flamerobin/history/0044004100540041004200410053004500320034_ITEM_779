SELECT
    itemestoque.codigo,
    itemestoque.DESCRICAO,
    itemestoque.localizacao,
    (SELECT COUNT(COMPOSICAOITEM.IDMATERIAL) FROM COMPOSICAOITEM
     WHERE COMPOSICAOITEM.IDITEM=ITEMESTOQUE.CODIGO)
from 
    itemestoque
    
inner JOIN 
    materiallocal on
        materiallocal.IDLOCAL=1 AND
        materiallocal.iditem=itemestoque.codigo AND
        materiallocal.filial=5

WHERE
    materiallocal.SALDOTOTAL = 0 AND
    NOT EXISTS(SELECT * FROM INVENTARIOESTOQUEDATA WHERE INVENTARIOESTOQUEDATA.CODIGO=ITEMESTOQUE.CODIGO) AND
    itemestoque.TIPOPRODUTO = '3'
ORDER BY
    1,
    4
