SELECT 
    C_MAPAPRODUCAO.filial,
    C_MAPAPRODUCAO.IDMOVIMENTO,
    C_MAPAPRODUCAO.IDMOVIMENTOMATERIAL,
    C_MAPAPRODUCAO.DATACADASTROPRODUCAO,
    C_MAPAPRODUCAO.IDNOTA,
    C_MAPAPRODUCAO.DATAEMISSAO,    
    C_MAPAPRODUCAO.NOMEDOCLIENTE,
    C_MAPAPRODUCAO.VENDEDOR,
    CADVEN.NOME,
    C_MAPAPRODUCAO.IDMERCADORIA,
    C_MAPAPRODUCAO.CODIGO,
    C_MAPAPRODUCAO.PRODUTO,
    C_MAPAPRODUCAO.TCE,
    C_MAPAPRODUCAO.ESPESSURA,
    C_MAPAPRODUCAO.CORES,
    C_MAPAPRODUCAO.ACABAMENTO,
    C_MAPAPRODUCAO.LARGURA,
    C_MAPAPRODUCAO.COMPRIMENTO,
    C_MAPAPRODUCAO.M2,
    C_MAPAPRODUCAO.UP,
    C_MAPAPRODUCAO.UPPORM2,
    C_MAPAPRODUCAO.PRAZODIAS,
    C_MAPAPRODUCAO.PRAZOENTREGA,
    C_MAPAPRODUCAO.C_CORTE,
    C_MAPAPRODUCAO.C_TUFTINGFUNDO,
    C_MAPAPRODUCAO.C_REVISAO,
    C_MAPAPRODUCAO.C_LATEX,
    C_MAPAPRODUCAO.C_REVISAOFINAL,
    C_MAPAPRODUCAO.C_DTESCULPIDO,
    C_MAPAPRODUCAO.DATAFABRICACAO,
    C_MAPAPRODUCAO.DATAFATURAMENTO,
    C_MAPAPRODUCAO.DATAENTREGA,
    C_MAPAPRODUCAO.ATRASO, 

    C_MAPAPRODUCAO.PREVISAOLATEX,
    C_MAPAPRODUCAO.ATRASOLATEX,
    C_MAPAPRODUCAO.STATUS,
    
    cast('N' as char(1)) as P_MARCA 
FROM 
    C_MAPAPRODUCAO(1, '2024-01-01', '2025-12-31') 
LEFT JOIN
    CADASTROPARCEIROS CADVEN ON
        CADVEN.CADASTRO=C_MAPAPRODUCAO.VENDEDOR
where
    c_revisaofinal is null