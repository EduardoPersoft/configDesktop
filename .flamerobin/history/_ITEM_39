SELECT
    MOVIMENTOESTOQUE.FILIAL,
    MOVIMENTOESTOQUE.IDMOVIMENTO,
    MOVIMENTOESTOQUE.EMISSAO,
    MOVIMENTOESTOQUE.PROCESSAMENTO,
    TIPOMOVIMENTOESTOQUE.DESCRICAO,
    TIPOMOVIMENTOESTOQUE.SIGLA,
    MOVIMENTOESTOQUE.DOCUMENTO,
    CADASTROPARCEIROS.NOME
FROM
    MOVIMENTOESTOQUE
INNER JOIN
    TIPOMOVIMENTOESTOQUE ON
        TIPOMOVIMENTOESTOQUE.ID=MOVIMENTOESTOQUE.TIPOMOVIMENTO
LEFT JOIN
    NOTAFISCAL ON
        NOTAFISCAL.FILIAL=MOVIMENTOESTOQUE.FILIAL AND
        NOTAFISCAL.IDNOTA=MOVIMENTOESTOQUE.IDNOTA
LEFT JOIN
    NOTACOMPRA ON
        NOTACOMPRA.FILIAL=MOVIMENTOESTOQUE.FILIAL AND
        NOTACOMPRA.IDNOTA=MOVIMENTOESTOQUE.IDNOTACOMPRA
LEFT JOIN
    PEDIDO ON
        PEDIDO.FILIAL=MOVIMENTOESTOQUE.FILIAL AND
        PEDIDO.IDNOTA=MOVIMENTOESTOQUE.IDPEDIDO
LEFT JOIN 
    CADASTROPARCEIROS ON
        CADASTROPARCEIROS.CADASTRO=COALESCE(NOTAFISCAL.DESTINATARIO, 
                                            COALESCE(NOTACOMPRA.DESTINATARIO,
                                                     PEDIDO.DESTINATARIO))
WHERE
    MOVIMENTOESTOQUE.FILIAL = 5 AND
    MOVIMENTOESTOQUE.EMISSAO BETWEEN '01.06.2020' AND '30.06.2020'
    