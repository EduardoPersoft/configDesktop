SELECT
    MERCADORIASNOTA.CODIGO,
    CLASSIFICACAOFISCAL.DESCRICAO,
    MERCADORIASNOTA.CFOP,
    MERCADORIASNOTA.SITUACAOTRIBUT,
    MERCADORIASNOTA.PRECOLISTA,
    MERCADORIASNOTA.VLRFINALMERCAD,
    MERCADORIASNOTA.VLRICMSRECOLHIDO    
FROM
    MERCADORIASNOTA
INNER JOIN
    CLASSIFICACAOFISCAL ON
        MERCADORIASNOTA.CLASSIFISCAL=MERCADORIASNOTA.CLASSIFISCAL
WHERE
    MERCADORIASNOTA.FILIAL=5 AND
    CLASSIFICACAOFISCAL.DESCRICAO='74152900' AND
    SUBSTRING(MERCADORIASNOTA.CFOP FROM 1 FOR 1)='6'
ORDER BY
    IDNOTA DESC