select
    pedido.DATAREFERENCIA,
    pedido.idnota,
    pedido.IDORCAMENTO,
    cadcli.nome,
    pedido.vlrtotalnota,
    orcamento.VLRTOTALNOTA
from
    PEDIDO
inner join 
    CADASTROPARCEIROS cadcli on
        cadcli.cadastro=pedido.destinatario
left join
    orcamento on
        orcamento.filial=pedido.filial and
        orcamento.idnota=pedido.IDORCAMENTO