select
    (select first 1
        materialfilial.filial
     from
        materialfilial
     where
        materialfilial.iditem=itemestoque.codigo
     ),
    itemestoque.codigo,
    itemestoque.codigoBarra,
    itemestoque.referencia,
    itemestoque.descricao
from
    itemestoque
order by
    itemestoque.codigo
