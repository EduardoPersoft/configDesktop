select 
    DISTINCT
    notafiscal.filial,
    notafiscal.idnota,
    notafiscal.numeronota,
    notafiscal.dataemissao,
    notafiscal.destinatario,
    mercadoriasnota.idpedido,
    mercadoriasnota.idmercadoria,
    
    MERCADORIASNOTA.VLRFINALMERCAD,
    pedido.c_tipo
from 
    NOTAFISCAL
inner join
    mercadoriasnota on
        mercadoriasnota.filial=notafiscal.filial and
        mercadoriasnota.idnota=notafiscal.IDNOTA
left join
    pedido on
        pedido.filial=mercadoriasnota.filialped and
        pedido.idnota=mercadoriasnota.idpedido
where 
    notafiscal.filial=1 
    and notafiscal.DATAEMISSAO between '01.08.2024' and '31.08.2024'
    and notafiscal.modelo =16
    AND NOTAFISCAL.CANCELAMENTO='N'
    and notafiscal.destinatario not in (select estabelecimento.cadastro from estabelecimento)
    and pedido.c_tipo in (3,4,5)
order by 
        notafiscal.dataemissao

