select 
    CADASTROPARCEIROS.GRUPOEMPRESARIAL,
   sum (TITULOREC.VALORTITULO) valorTitulo,
    sum (TITULOREC.TOTALPAGO) totalPago,
    sum (TITULOREC.TOTALABATIDO) abatido,
    sum (TITULOREC.VALOREMABERTO) emAberto,
   sum  (CASE WHEN TITULOREC.TIPOBAIXA IS NULL AND
    COALESCE(TITULOREC.NAOLIMITEFINANCEIRO, 'N')='N' AND
    TITULOREC.VENCIMENTO+COALESCE(ESTABELECIMENTO.DIASATRASO,0)<CAST('NOW' AS DATE) THEN TITULOREC.VALOREMABERTO ELSE 0 END) AS VALOREMATRASO,
    cast( sum (CASE WHEN TITULOREC.TIPOBAIXA = 'P' then
    TITULOREC.DATAPAGAMENTO-TITULOREC.VENCIMENTO ELSE 0 END * TITULOREC.VALORTITULO)/sum (TITULOREC.VALORTITULO) AS integer) AS MEDIAEMATRASO
from 
    CADASTROPARCEIROS
inner join
    TITULOREC on
        titulorec.parceiro=CADASTROPARCEIROS.cadastro
INNER JOIN 
    ESTABELECIMENTO ON 
    TITULOREC.FILIAL=ESTABELECIMENTO.CADASTRO
INNER JOIN 
    TIPOCOBRANCA ON  
    TITULOREC.TIPOTRANSACAO=TIPOCOBRANCA.TIPOCOBRANCA
WHERE 
    CADASTROPARCEIROS.GRUPOEMPRESARIAL=555  and
    coalesce(tipoBaixa,'')<>'E' 
group by 
    CADASTROPARCEIROS.GRUPOEMPRESARIAL
