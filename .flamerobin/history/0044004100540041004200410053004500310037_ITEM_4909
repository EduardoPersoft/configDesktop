select * from titulorec 
where titulorec.baixa='02.06.2025'
and titulorec.DATAPAGAMENTO='02.06.2025'
and titulorec.TIPOBAIXA='P'
and titulorec.CONTACORRENTE=21 
and titulorec.TIPOTRANSACAO=11
and exists
(select * from MOVTITULOREC
where movtitulorec.filial=titulorec.filial 
and movtitulorec.IDTITULO=titulorec.IDTITULO
and movtitulorec.TIPOMOVTO='D')