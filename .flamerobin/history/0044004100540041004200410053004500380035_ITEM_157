
select
    MERCADORIASPED.FILIAL,
    MERCADORIASPED.IDNOTA,
    MERCADORIASPED.IDMERCADORIA,
    MERCADORIASPED.CODIGO,
    MERCADORIASPED.DESREDUZIDA,
    CASE WHEN MERCADORIASPED.CODIGO in ('P001', 'P002', 'P003', 'P004') THEN MERCADORIASPED.CODIGO 
         ELSE 'P'||SUBSTRING(MERCADORIASPED.CODIGO FROM 3 FOR 3) END
FROM 
   MERCADORIASORC MERCADORIASPED
