select 
    m2.codigo,m2.quantidade, m2.qtdeenviada
    FROM
            MERCADORIASPED m2
         INNER JOIN
            PEDIDO p2 ON
                p2.FILIAL=m2.FILIAL AND
                p2.IDNOTA=m2.IDNOTA and
                p2.cancelamento='N' and
                p2.dataemissao is not null 
         WHERE
            m2.baixa='N' AND
            m2.codigo='P004'