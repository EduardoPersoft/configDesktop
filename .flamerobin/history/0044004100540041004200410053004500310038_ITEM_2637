select 
    notafiscal.filial,
    notafiscal.idnota,
    notafiscal.VLRTOTALNOTA
from 
    NOTAFISCAL
inner join
    mercadoriasnota on
        mercadoriasnota.filial=notafiscal.filial and
        mercadoriasnota.idnota=notafiscal.IDNOTA
inner join
    pedido on
        pedido.filial=mercadoriasnota.filialped and
        pedido.idnota=mercadoriasnota.idnota
where 
    notafiscal.filial=1 
    and notafiscal.DATAEMISSAO between '01.01.2024' and '31.01.2024'
    and notafiscal.modelo =16
    and pedido.c_tipo=4
