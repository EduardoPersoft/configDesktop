select 
    CLASSIFICACAOFISCAL.DESCRICAO,
    itemestoque.codigo,
    itemestoque.descricao,
    count(mercadoriasnota.idnota),
    sum(mercadoriasnota.quantidade)
from
    NOTAFISCAL
inner join
    mercadoriasnota on
        mercadoriasnota.filial=notafiscal.filial and
        mercadoriasnota.idnota=notafiscal.idnota
inner join 
    itemestoque on
        itemestoque.codigo=mercadoriasnota.CODIGO
inner join 
    CLASSIFICACAOFISCAL on
        classificacaofiscal.CFISCAL=itemestoque.CLASSIFISCAL
where 
    notafiscal.filial=5 
group by
    itemestoque.codigo,
    itemestoque.descricao,
    CLASSIFICACAOFISCAL.DESCRICAO
order by
    CLASSIFICACAOFISCAL.DESCRICAO,
    itemestoque.codigo
    