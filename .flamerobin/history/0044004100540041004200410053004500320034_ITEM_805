SELECT 
       MATERIALMOVIMENTOESTOQUE.FILIAL,
       MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO,
       COALESCE(MATERIALMOVIMENTOESTOQUE.idpedido, MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO) AS IDPEDIDO,
       COALESCE(MATERIALMOVIMENTOESTOQUE.idmercadoria, MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL) AS IDMERCADORIA,
       COALESCE(MATERIALMOVIMENTOESTOQUE.idcomposicao, 1) AS IDCOMPOSICAO,
       MATERIALMOVIMENTOESTOQUE.iditem COMPONENTE,
       MATERIALMOVIMENTOESTOQUE.quantidade AS QTDEXPEDIDA,
       MOVIMENTOESTOQUE.localarmazenamento,
       MATERIALMOVIMENTOESTOQUE.lote--,
       /*
       COALESCE(MERCADORIASPED.codigo,MATERIALMOVIMENTOESTOQUE.IDITEM) AS CODIGOPEDIDO,
       COALESCE(MERCADORIASPED.quantidade,MATERIALMOVIMENTOESTOQUE.quantidade) QTDPEDIDO,
       COALESCE(MERCADORIASPED.precolista,1)  * (1 - pedido.REDUTORIMPOSTOS / 100) precolista,
       COALESCE(MERCADORIASPED.precounitario,1) * (1 - pedido.REDUTORIMPOSTOS / 100) precounitario ,
       coalesce(MERCADORIASPED.descontonota,0) * (1 - pedido.REDUTORIMPOSTOS / 100) as descontonota,
       coalesce(MERCADORIASPED.vlrdescproduto,0) * (1 - pedido.REDUTORIMPOSTOS / 100) vlrdescproduto,
       coalesce(MERCADORIASPED.acrescimonota,0)  * (1 - pedido.REDUTORIMPOSTOS / 100) as acrescimonota,
       COALESCE(COMPOSICAOMERCPED.quantidade,MATERIALMOVIMENTOESTOQUE.QUANTIDADE) QTDCOMPONENTE,
       
       MATERIALMOVIMENTOESTOQUE.CONCLUIDO,
       MOVIMENTOESTOQUE.pesoliquido,
       MOVIMENTOESTOQUE.PESOBRUTO,
       MOVIMENTOESTOQUE.quantidadevolumes,
       MOVIMENTOESTOQUE.MARCAVOLUME,
       MOVIMENTOESTOQUE.TRANSPORTADORA,
       MERCADORIASPED.DESCRICAO AS DESCRICAOPEDIDO,
       coalesce(MERCADORIASPED.FATORESTOQUE, 1) as fatorestoque,
       coalesce(MERCADORIASPED.UNIDADE, itemestoque.unidade) as unidade
       */
FROM MATERIALMOVIMENTOESTOQUE
/*
INNER JOIN MOVIMENTOESTOQUE ON (MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL
     AND MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO)
INNER JOIN ITEMESTOQUE ON (ITEMESTOQUE.CODIGO=MATERIALMOVIMENTOESTOQUE.IDITEM)
LEFT JOIN MERCADORIASPED ON (
    MERCADORIASPED.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL
    AND MERCADORIASPED.IDNOTA=MATERIALMOVIMENTOESTOQUE.IDPEDIDO
    AND MERCADORIASPED.idmercadoria=MATERIALMOVIMENTOESTOQUE.idmercadoria)

left join pedido on 
    mercadoriasped.filial = pedido.filial AND
    mercadoriasped.idnota = pedido.idnota
LEFT JOIN COMPOSICAOMERCPED ON (
    composicaomercped.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL
    AND COMPOSICAOMERCPED.IDNOTA=MATERIALMOVIMENTOESTOQUE.IDPEDIDO
    AND COMPOSICAOMERCPED.IDMERCADORIA=MATERIALMOVIMENTOESTOQUE.IDMERCADORIA
    AND COMPOSICAOMERCPED.idcomposicao=MATERIALMOVIMENTOESTOQUE.IDCOMPOSICAO)*/
WHERE MATERIALMOVIMENTOESTOQUE.FILIAL=:FILIAL 
AND MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO=:IDMOVIMENTO
/*
AND NOT EXISTS
(SELECT * FROM NOTAFISCAL
 WHERE NOTAFISCAL.FILIAL=MATERIALMOVIMENTOESTOQUE.filial
 AND NOTAFISCAL.idmovimento=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
 AND NOTAFISCAL.cancelamento<>'S')
ORDER BY MATERIALMOVIMENTOESTOQUE.idpedido,
       MATERIALMOVIMENTOESTOQUE.idmercadoria,
       MATERIALMOVIMENTOESTOQUE.idcomposicao*/