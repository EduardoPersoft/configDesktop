select
    MOVBANCARIOS.filial,
    movbancarios.IDCONTACORRENTE,
    movbancarios.IDMOVTOBANCARIO,
    movbancarios.HISTORICOEXTRATO,
    LANTOCONTBANC.CONTACONTABIL,
    LANTOCONTBANC.VALOR * CASE MOVBANCARIOS.TIPOMOVIMENTO WHEN 'C' THEN 1 ELSE -1 END AS VALOR
from
    movbancarios
INNER join
    LANTOCONTBANC ON
        LANTOCONTBANC.FILIAL=MOVBANCARIOS.FILIAL and
        LANTOCONTBANC.IDCONTACORRENTE=MOVBANCARIOS.IDCONTACORRENTE and
        LANTOCONTBANC.IDMOVTOBANC=MOVBANCARIOS.IDMOVTOBANCARIO
where
    movbancarios.filial=1 and
    movbancarios.MOVIMENTACAO between '01.07.2023' and '31.07.2023'