select
    CONTASCONTABEIS.DESCRICAO,
    TITULOPAG.TITULO,
    TITULOPAG.FATURA,
    CADFOR.NOME,
    TITULOPAG.EMISSAO,
    TITULOPAG.VENCIMENTO,
    TITULOPAG.BAIXA,

    LANTOCONTPAG.VALOR
from
    TITULOPAG
INNER join
    CADASTROPARCEIROS CADFOR ON
        CADFOR.CADASTRO=TITULOPAG.PARCEIRO
INNER join
    LANTOCONTPAG ON
        TITULOPAG.FILIAL=LANTOCONTPAG.FILIAL and
        TITULOPAG.IDTITULO=LANTOCONTPAG.IDMOVTOBANC
INNER JOIN 
    CONTASCONTABEIS ON
    CONTASCONTABEIS.IDPLANO=4 and
    CONTASCONTABEIS.CONTACONTABIL=LANTOCONTPAG.CONTACONTABIL
where
    TITULOPAG.FILIAL=1 and
    TITULOPAG.BAIXA BETWEEN '01.01.2025' AND '31.03.2025' and
    LANTOCONTPAG.CONTACONTABIL BETWEEN '20402' AND '20406' and
    lantocontpag.CENTROCUSTO between '5105' and '5105' and
    TITULOPAG.TIPOBAIXA='P'
union
select
    CONTASCONTABEIS.DESCRICAO,
    movbancarios.NRDOCUMENTO,
    '',
    movbancarios.HISTORICOEXTRATO,
    MOVBANCARIOS.MOVIMENTACAO,
    MOVBANCARIOS.MOVIMENTACAO,
    MOVBANCARIOS.MOVIMENTACAO,

    LANTOCONTbanc.VALOR
from
    movbancarios
INNER join
    LANTOCONTBANC ON
        MOVBANCARIOS.FILIAL=LANTOCONTBANC.FILIAL and
        MOVBANCARIOS.IDCONTACORRENTE=LANTOCONTBANC.IDCONTACORRENTE and
        MOVBANCARIOS.IDMOVTOBANCARIO=LANTOCONTBANC.IDMOVTOBANC
INNER JOIN 
    CONTASCONTABEIS ON
    CONTASCONTABEIS.IDPLANO=4 and
    CONTASCONTABEIS.CONTACONTABIL=LANTOCONTBANC.CONTACONTABIL
where
    movbancarios.FILIAL=1 and
    MOVBANCARIOS.MOVIMENTACAO BETWEEN '01.01.2025' AND '31.03.2025' and
    LANTOCONTbanc.CONTACONTABIL BETWEEN '20402' AND '20406' and
    LANTOCONTbanc.CENTROCUSTO between '5105' and '5105' 
    
