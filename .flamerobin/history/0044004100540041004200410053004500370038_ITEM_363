update  
    ITEMCUSTODATA P1
set
    P1.CUSTOUNITARIO=
CAST((select sum(COALESCE(COMPOSICAOITEM.QUANTIDADE*P2.CUSTOUNITARIO ,0))/ITEMESTOQUE.BASEPRODUCAO
 FROM COMPOSICAOITEM
 INNER JOIN ITEMESTOQUE ON ITEMESTOQUE.CODIGO=P1.CODIGO
 INNER JOIN ITEMCUSTODATA P2 ON 
  P2.DATAINVENTARIO=P1.DATAINVENTARIO and
  P2.CODIGO=COMPOSICAOITEM.IDMATERIAL and
  p2.DATAINVENTARIO = '2025-09-30'                           
 WHERE COMPOSICAOITEM.IDITEM=P1.CODIGO
 GROUP BY ITEMESTOQUE.CODIGO,ITEMESTOQUE.BASEPRODUCAO) AS DECIMAL(12,3)) 
 
where
    (P1.CODIGO BETWEEN '00000000' AND '99999999' or 
    P1.CODIGO BETWEEN 'R00000000' AND 'R99999999') and
    P1.DATAINVENTARIO = '2025-09-30' and
    exists (select * from composicaoitem where COMPOSICAOITEM.IDITEM=p1.codigo)