select
    TIPOMOVIMENTOESTOQUE.descricao,
    movimentoestoque.documento,
    materialmovimentoestoque.iditem,
    itemestoque.DESCRICAO,
    MATERIALMOVIMENTOESTOQUE.quantidade,
    itemestoque.unidade,
    materialmovimentoestoque.valor,
    materialmovimentoestoque.valor/
    materialmovimentoestoque.quantidade
from
    MOVIMENTOESTOQUE
inner join
    MATERIALMOVIMENTOESTOQUE on
        materialmovimentoestoque.filial=movimentoestoque.FILIAL and
        materialmovimentoestoque.idmovimento=movimentoestoque.IDMOVIMENTO
inner join
    itemestoque on
        itemestoque.codigo=MATERIALMOVIMENTOESTOQUE.IDITEM
inner join
    tipomovimentoestoque on
        TIPOMOVIMENTOESTOQUE.ID=movimentoestoque.TIPOMOVIMENTO
where
    movimentoestoque.filial=1 and
    movimentoestoque.EMISSAO between '01.11.2023' and '30.11.2023' and
    movimentoestoque.TIPOMOVIMENTO not in ('12', '13') and 
    itemestoque.descricao like '%PLACA%'
    
    