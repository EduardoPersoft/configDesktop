update
    MERCADORIASNOTA   
set 
    qtdbaixa=0
where
    exists (select
                *
            from
                NOTAFISCAL
            where   
                notafiscal.filial=MERCADORIASNOTA.filial and
                notafiscal.idnota=mercadoriasnota.idnota and
                notafiscal.operacao=1061)