select 
    FORNECEDORESITEM.IDITEM,
    FORNECEDORESITEM.FORNECEDOR,
    MATERIALFILIAL.SALDOMAXIMO,
    MATERIALFILIAL.CONSUMOMEDIO,
    SUM(MATERIALLOCAL.SALDOTOTAL) SALDO
FROM
    MATERIALFILIAL
INNER join
    FORNECEDORESITEM ON
        FORNECEDORESITEM.IDITEM=MATERIALFILIAL.IDITEM
INNER join
    MATERIALLOCAL ON
        MATERIALLOCAL.FILIAL=MATERIALFILIAL.FILIAL and
        MATERIALLOCAL.IDITEM=MATERIALFILIAL.IDITEM
WHERE
    MATERiALFILIAL.FILIAL=5 and
    
GROUP BY
    FORNECEDORESITEM.FORNECEDOR,
    MATERIALFILIAL.SALDOMAXIMO,
    MATERIALFILIAL.CUSTOMEDIO
    