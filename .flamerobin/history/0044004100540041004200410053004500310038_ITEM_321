SELECT 
    '2' as tipo,
    case itemestoque.tipoproduto 
        when 0 then case itemestoque.EMBALAGEM when 'S' then '02' else '01' END 
        when 3 then '00'
        when 4 then case itemestoque.SEMIACABADO when 'S' then '03' else '04' END 
    end as tipoitem,
    
        
    case when extract(month from estsin.datafinal) < 10 then '0' else '' end||
    extract(month from estsin.datafinal)||'/'||extract(year from estsin.datafinal) mes_ano,   
    ITEMESTOQUE.CODIGO,
    sum(SALDOINICIALESTOQUE.SALDOANTERIOR) as qtde,
    case when cadterceiros.documento is null then 0 else 1 end tp_estoque,
    cadterceiros.DOCUMENTO as cnpj_particip,
    cadterceiros.nome as participante,
    LOCAL.DESCRICAO as local,
    itemestoque.descricao,
    itemestoque.unidade,
    case when sum(saldoinicialestoque.valoranterior)<0 then 0 else sum(saldoinicialestoque.valoranterior)  end  as vlr
    
FROM SALDOINICIALESTOQUElocal saldoinicialestoque
INNER JOIN ESTSIN ON (ESTSIN.RELATORIO='SALDOANTERIORESTOQUE' )
INNER JOIN ITEMESTOQUE ON (SALDOINICIALESTOQUE.IDITEM=ITEMESTOQUE.CODIGO)
LEFT JOIN LOCAL ON 
    LOCAL.ID = SALDOINICIALESTOQUE.LOCAL
left join cadastroparceiros cadterceiros on
    cadterceiros.LOCALentrega = local.id
where 
    itemestoque.TIPOPRODUTO in (1, 3, 4) AND
    (not (itemestoque.tipoproduto = 4 and itemestoque.codigo between '00000' and '99999' or substring(itemestoque.codigo from 1 for 1)='X') )
group by
    estsin.datafinal, itemestoque.codigo,  SALDOINICIALESTOQUE.LOCAL, 
    cadterceiros.DOCUMENTO,
    cadterceiros.nome,
    local.descricao,
    itemestoque.descricao,
    itemestoque.unidade
HAVING   
   SUM(SALDOINICIALESTOQUE.SALDOANTERIOR) > 0.00009
order by codigo, local