declare variable mes_ref numeric(6,0);
declare variable cod_aj_apur varchar(8);
declare variable descr_compl_aj varchar(256);
declare variable vl_aj_apur decimal(12,2);
declare variable vl_sld_dev_ant_fcp decimal(12,2);
declare variable v_devolucao char(1);
begin
  delete from SPEDFISCAL_0;
  delete from SPEDFISCAL_A;
  delete from SPEDFISCAL_C;
  delete from SPEDFISCAL_D;
  delete from SPEDFISCAL_E;
  delete from SPEDFISCAL_F;
  delete from SPEDFISCAL_G;
  delete from SPEDFISCAL_H;
  delete from SPEDFISCAL_K;
  delete from SPEDFISCAL_M;
  delete from SPEDFISCAL_1;
  delete from SPEDFISCAL_9;

  V_QTD0 = 0;
  select SPEDFISCAL.ESTABELECIMENTO, SPEDFISCAL.COD_VER, SPEDFISCAL.TIPO_ESCRIT, SPEDFISCAL.IND_SIT_ESP,
         SPEDFISCAL.NUM_REC_ANTERIOR, SPEDFISCAL.DT_INI, SPEDFISCAL.DT_FIM, SPEDFISCAL.IND_NAT_PJ, SPEDFISCAL.IND_ATIV,
         SPEDFISCAL.COD_INC_TRIB, SPEDFISCAL.IND_APRO_CRE, SPEDFISCAL.COD_TIPO_CONT, SPEDFISCAL.REC_BRU_NCUM_TRIB_MI,
         SPEDFISCAL.REC_BRU_NCUM_NT_MI, SPEDFISCAL.REC_BRU_CUM, SPEDFISCAL.REC_BR_TOTAL, SPEDFISCAL.REC_BRU_NCUM_EXP,
         SPEDFISCAL.IND_PERFIL, CADASTROPARCEIROS.DOCUMENTO, CADASTROPARCEIROS.RAZAOSOCIAL, CADASTROPARCEIROS.UF,
         MUNICIPIO.UF || MUNICIPIO.MUNICIPIO, CLIENTES.INSCSUFRAMA, CADASTROPARCEIROS.NOME,
         CADASTROPARCEIROS.LOGRADOURO, CADASTROPARCEIROS.NUMERO, SUBSTRING (CADASTROPARCEIROS.COMPLEMENTO from 1 for 20),
         substring (CADASTROPARCEIROS.BAIRRO from 1 for 30), CADASTROPARCEIROS.UF, CADASTROPARCEIROS.CEP, CADASTROPARCEIROS.DOCUMENTO, CADASTROPARCEIROS.INSCESTADUAL
  from SPEDFISCAL
  inner join CADASTROPARCEIROS on (CADASTROPARCEIROS.CADASTRO = SPEDFISCAL.ESTABELECIMENTO)
  left join MUNICIPIO on (CADASTROPARCEIROS.UF = MUNICIPIO.UF_SIGLA and
        upper(CADASTROPARCEIROS.CIDADE) = upper(MUNICIPIO.MUNICIPIO_NOME))
  left join CLIENTES on (CADASTROPARCEIROS.CADASTRO = CLIENTES.CADASTRO)
  where SPEDFISCAL.ESTABELECIMENTO = :FILIAL
  into V_FILIALBASEA, COD_VER, TIPO_ESCRIT, IND_SIT_ESP, NUM_REC_ANTERIOR, DT_INI, DT_FIM, IND_NAT_PJ, IND_ATIV,
       COD_INC_TRIB, IND_APRO_CRE, COD_TIPO_CONT, REC_BRU_NCUM_TRIB_MI, REC_BRU_NCUM_NT_MI, REC_BRU_CUM, REC_BR_TOTAL,
       REC_BRU_NCUM_EXP, IND_PERFIL, V_CNPJBASE, NOME, UF, COD_MUN, SUFRAMA, :NOMEFANTASIA, :ENDERECO, :NUM, :COMPL,
       :BAIRRO, :UF, :CEP, :CNPJ, :IE;

  COD_VER = '012';

  V_FILIALBASEC = V_FILIALBASEA;
  CNPJ = V_CNPJBASE;

  SEQUENCIA0 = 1;
  SEQUENCIAA = 1;
  SEQUENCIAD = 1;
  SEQUENCIAC = 1;
  SEQUENCIAH = 1;

  insert into SPEDFISCAL_0 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, COD_VER, TIPO_ESCRIT, IND_SIT_ESP, NUM_REC_ANTERIOR,
                            DT_INI, DT_FIM, NOME, CNPJ, IE, UF, COD_MUN, SUFRAMA, IND_NAT_PJ, IND_ATIV, IND_PERFIL)
  values (:SEQUENCIA0, '0000', 1, 0, :COD_VER, :TIPO_ESCRIT, :IND_SIT_ESP, :NUM_REC_ANTERIOR, :DT_INI, :DT_FIM, :NOME,
          :CNPJ, :IE, :UF, :COD_MUN, :SUFRAMA, :IND_NAT_PJ, :IND_ATIV, :IND_PERFIL);

  V_QTD0 = V_QTD0 + 1;

  SEQUENCIA0 = SEQUENCIA0 + 1;

  insert into SPEDFISCAL_0 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, IND_MOV)
  values (:SEQUENCIA0, '0001', 2, 1, 0);

  NOME = '';

  V_QTD0 = V_QTD0 + 1;
  SEQUENCIA0 = SEQUENCIA0 + 1;

  insert into SPEDFISCAL_0 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, ENDERECO, NUM, COMPL, BAIRRO, CEP, FONE, FAX, NOME)
  values (:SEQUENCIA0, '0005', 3, 2, :ENDERECO, :NUM, :COMPL, :BAIRRO, :CEP, :FONE, :FAX, :NOMEFANTASIA);

  select ESTABELECIMENTO.NOMECONTADOR, ESTABELECIMENTO.CPFCONTADOR, ESTABELECIMENTO.CNPJCONTADOR,
         ESTABELECIMENTO.LOGRADOUROCONTADOR, ESTABELECIMENTO.NUMEROCONTADOR, ESTABELECIMENTO.COMPLEMENTOCONTADOR,
         ESTABELECIMENTO.BAIRROCONTADOR, ESTABELECIMENTO.CEPCONTADOR, MUNICIPIO.UF || MUNICIPIO.MUNICIPIO,
         ESTABELECIMENTO.CRC, ESTABELECIMENTO.EMAILCONTADOR
  from ESTABELECIMENTO
  inner join MUNICIPIO on (MUNICIPIO.UF_SIGLA = ESTABELECIMENTO.UFCONTADOR and
        upper(MUNICIPIO.MUNICIPIO_NOME) = upper(ESTABELECIMENTO.CIDADECONTADOR))
  where ESTABELECIMENTO.CADASTRO = :FILIAL
  into NOME, CPF, CNPJ, ENDERECO, NUM, COMPL, BAIRRO, CEP, COD_MUN, CRC, EMAIL;

  if (coalesce(NOME, '') <> '') then
  begin
    SEQUENCIA0 = SEQUENCIA0 + 1;
    V_QTD0 = V_QTD0 + 1;
    insert into SPEDFISCAL_0 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, NOME, CPF, CNPJ, ENDERECO, NUM, COMPL, BAIRRO, CEP,
                              COD_MUN, CRC, EMAIL)
    values (:SEQUENCIA0, '0100', 4, 2, :NOME, :CPF, :CNPJ, :ENDERECO, :NUM, :COMPL, :BAIRRO, :CEP, :COD_MUN, :CRC, :EMAIL);
  end

  V_UFESTABELECIMENTO = UF;
  VL_TOT_DEBITOS = 0;
  VL_TOT_CREDITOS = 0;

  for select cast('NS' as char(2)) as ORIGEM, NOTAFISCAL.DATAEMISSAO, NOTAFISCAL.IDNOTA,
             case NOTAFISCAL.ENTRADASAIDA
               when 'S' then 1
               else 0
             end,
             0 as EMISSOR, NOTAFISCAL.DESTINATARIO, MODELODOCTO.CODMODELOFISCAL,
             case
               when NOTAFISCAL.CANCELAMENTO = 'S' then '02'
               when NOTAFISCAL.TIPONOTA = '2' then '06'
               else '00'
             end,
             MODELODOCTO.SERIE, cast(NOTAFISCAL.NUMERONOTA as varchar(10)), NOTAFISCAL.CHAVE,
             case
               when NOTAFISCAL.DATAENTRADASAIDA is null then NOTAFISCAL.DATAEMISSAO
               else NOTAFISCAL.DATAENTRADASAIDA
             end,
             NOTAFISCAL.VLRTOTALNOTA,
             case
               when exists(select *
                           from FATURAS
                           where FATURAS.FILIAL = NOTAFISCAL.FILIAL and
                                 FATURAS.IDNOTA = NOTAFISCAL.IDNOTA and
                                 FATURAS.DATAVENCIMENTO <> NOTAFISCAL.DATAEMISSAO) then '0'
               when exists(select *
                           from FATURAS
                           where FATURAS.FILIAL = NOTAFISCAL.FILIAL and
                                 FATURAS.IDNOTA = NOTAFISCAL.IDNOTA and
                                 FATURAS.DATAVENCIMENTO = NOTAFISCAL.DATAEMISSAO) then '1'
               else '2'
             end,
             coalesce(NOTAFISCAL.VLRDESCMERCADORIAS, 0) + coalesce(NOTAFISCAL.VLRDESCSERVICOS, 0) + coalesce(NOTAFISCAL.VLRDESCINDPRODUTO, 0) + coalesce(NOTAFISCAL.VLRDESCINDSERVICOS, 0),
             case NOTAFISCAL.ZONAFRANCA
               when 'S' then NOTAFISCAL.TOTVALORICMS
               else 0
             end,
             case
               when NOTAFISCAL.VALORFRETE = 0 then '9'
               when NOTAFISCAL.FRETE = 'R' then '1'
               else '2'
             end,
             NOTAFISCAL.VLRFINALMERCADORIAS, NOTAFISCAL.VALORFRETE, NOTAFISCAL.VALORSEGURO,
             NOTAFISCAL.VLROUTDESPACESSORIA, NOTAFISCAL.VLRBASESUBSTITUTO, NOTAFISCAL.VLRICMSRECOLHIDO,
             NOTAFISCAL.VLRPISPASEPMERC, NOTAFISCAL.VLRCOFINSMERC, 0, 0, NOTAFISCAL.DI,
             case NATUREZAOPERACAO.ESTOQUE
               when 'S' then '0'
               else '1'
             end,
             NOTAFISCAL.OPERACAO, NOTAFISCAL.UF, NOTAFISCAL.ICMSDESTINOFCP, NOTAFISCAL.ICMSDESTINOVALOR, NOTAFISCAL.ICMSORIGEMVALORINTERESTADUAL
      from NOTAFISCAL
      inner join MODELODOCTO on (NOTAFISCAL.MODELO = MODELODOCTO.ID)
      left join NATUREZAOPERACAO on (NATUREZAOPERACAO.ID = NOTAFISCAL.OPERACAO)
      where NOTAFISCAL.FILIAL = :FILIAL and
            NOTAFISCAL.DATAEMISSAO between :DT_INI and :DT_FIM and
            MODELODOCTO.BLOCOSPED = 'C' and
            cast(MODELODOCTO.CODMODELOFISCAL as char(2)) in ('55', '1', '1B', '4', '5')
      union
      select cast('NC' as char(2)) as ORIGEM, NOTACOMPRA.DATAEMISSAO, NOTAFISCAL.IDNOTA, 0 as IND_OPER, 1 as EMISSOR,
             NOTAFISCAL.DESTINATARIO, MODELODOCTO.CODMODELOFISCAL, '00' as COD_SIT, coalesce(notacompra.serie, modelodocto.serie),
             NOTACOMPRA.NRNOTAFORNECEDOR, NOTAFISCAL.CHAVE,
             case
               when NOTACOMPRA.DATAENTRADA is null then NOTACOMPRA.DATAEMISSAO
               else NOTAFISCAL.DATAENTRADA
             end,
             NOTAFISCAL.VLRTOTALNOTA,
             case
               when exists(select *
                           from FATURASNOTACOMPRA FATURAS
                           where FATURAS.FILIAL = NOTAFISCAL.FILIAL and
                                 FATURAS.IDNOTA = NOTAFISCAL.IDNOTA and
                                 FATURAS.DATAVENCIMENTO <> NOTAFISCAL.DATAEMISSAO) then '0'
               when exists(select *
                           from FATURAS
                           where FATURAS.FILIAL = NOTAFISCAL.FILIAL and
                                 FATURAS.IDNOTA = NOTAFISCAL.IDNOTA and
                                 FATURAS.DATAVENCIMENTO = NOTAFISCAL.DATAEMISSAO) then '1'
               else '2'
             end,
             coalesce(NOTAFISCAL.VLRDESCMERCADORIAS, 0) + coalesce(NOTAFISCAL.VLRDESCSERVICOS, 0) + coalesce(NOTAFISCAL.VLRDESCINDPRODUTO, 0) + coalesce(NOTAFISCAL.VLRDESCINDSERVICOS, 0),
             case NOTAFISCAL.ZONAFRANCA
               when 'S' then NOTAFISCAL.TOTVALORICMS
               else 0
             end,
             case
               when NOTAFISCAL.VALORFRETE = 0 then '9'
               else '1'
             end,
             NOTAFISCAL.VLRFINALMERCADORIAS, NOTAFISCAL.VALORFRETE, NOTAFISCAL.VALORSEGURO,
             NOTAFISCAL.VLROUTDESPACESSORIA,
             case NOTAFISCAL.DEVOLUCAO
               when 'S' then NOTAFISCAL.VLRBASESUBSTITUTO
               else 0
             end,
             case NOTAFISCAL.DEVOLUCAO
               when 'S' then NOTAFISCAL.VLRICMSRECOLHIDO
               else 0
             end,
             NOTAFISCAL.VALORPIS, NOTAFISCAL.VALORCOFINS, 0, 0, cast(null as varchar(12)) as NUM_DOC_IMP,
             case NATUREZAOPERACAO.ESTOQUE
               when 'S' then '0'
               else '1'
             end,
             NOTAFISCAL.OPERACAO as COD_NAT, NOTAFISCAL.UF, cast(0.00 as decimal(12,2)) as ICMSDESTINOFCP,
             cast(0.00 as decimal(12,2)) as ICMSDESTINOVALOR, cast(0.00 as decimal(12,2)) as ICMSORIGEMVALOR
      from NOTACOMPRA NOTAFISCAL
      inner join MODELODOCTO on (NOTAFISCAL.MODELO = MODELODOCTO.ID)
      left join NATUREZAOPERACAO on (NATUREZAOPERACAO.ID = NOTAFISCAL.OPERACAO)
      where NOTAFISCAL.FILIAL = :FILIAL and
            NOTACOMPRA.DATAENTRADA between :DT_INI and :DT_FIM and
            MODELODOCTO.BLOCOSPED = 'C' and
            cast(MODELODOCTO.CODMODELOFISCAL as char(2)) in ('55', '1', '1B', '4', '5')
      into ORIGEM, DT_DOC, V_IDNOTA, IND_OPER, IND_EMIT, COD_PART, COD_MOD, COD_SIT, SER, NUM_DOC, CHV_NFE,
           DT_E_S, VL_DOC, IND_PGTO, VL_DESC, VL_ABAT_NT, IND_FRT, VL_MERC, VL_FRT, VL_SEG, VL_OUT_DA, VL_BC_ICMS_ST,
           VL_ICMS_ST, VL_PIS, VL_COFINS, VL_PIS_ST, VL_COFINS_ST, NUM_DOC_IMP, IND_MOV_EST, COD_NAT, UF,
           VL_FCP_UF_DEST, VL_ICMS_UF_DEST, VL_ICMS_UF_REM
  do
  begin

    if (:ORIGEM = 'NS') then
    begin
      select sum(
             case MERCADORIASNOTA.ICMSORIGEMBASE
               when 0 then MERCADORIASNOTA.ICMSBASE
               else MERCADORIASNOTA.ICMSORIGEMBASE
             end),
             sum(
             case MERCADORIASNOTA.ICMSORIGEMBASE
               when 0 then MERCADORIASNOTA.VALORICMS
               else MERCADORIASNOTA.ICMSORIGEMVALOR
             end)
      from ITEMESTOQUE
      inner join MERCADORIASNOTA on (ITEMESTOQUE.CODIGO = MERCADORIASNOTA.CODIGO)
      inner join NOTAFISCAL on (MERCADORIASNOTA.FILIAL = NOTAFISCAL.FILIAL and
            MERCADORIASNOTA.IDNOTA = NOTAFISCAL.IDNOTA)
      where MERCADORIASNOTA.FILIAL = :FILIAL and
            MERCADORIASNOTA.IDNOTA = :V_IDNOTA
      into :VL_BC_ICMS, :VL_ICMS;
    end
    else
    if (:ORIGEM = 'NC') then
    begin
      select sum(
             case
               when ITEMESTOQUE.TIPOPRODUTO not in ('1', '3', '4') then 0
               else case
                      when (mercadoriasnota.vlricmsrecolhido>0 and NOTAFISCAL.DEVOLUCAO = 'N') then 0
                      else MERCADORIASNOTA.ICMSBASE
                    end
             end),
             sum(
             case
               when ITEMESTOQUE.TIPOPRODUTO not in ('1', '3', '4') then 0
               else case
                      when (mercadoriasnota.vlricmsrecolhido>0 and NOTAFISCAL.DEVOLUCAO = 'N') then 0
                      else MERCADORIASNOTA.VALORICMS
                    end
             end)
      from ITEMESTOQUE
      inner join MERCADORIASNOTACOMPRA MERCADORIASNOTA on (ITEMESTOQUE.CODIGO = MERCADORIASNOTA.CODIGO)
      inner join NOTACOMPRA NOTAFISCAL on (MERCADORIASNOTA.FILIAL = NOTAFISCAL.FILIAL and
            MERCADORIASNOTA.IDNOTA = NOTAFISCAL.IDNOTA)
      where MERCADORIASNOTA.FILIAL = :FILIAL and
            MERCADORIASNOTA.IDNOTA = :V_IDNOTA
      into :VL_BC_ICMS, :VL_ICMS;
    end

    if (:ORIGEM = 'NS') then
    begin
      select sum(
             case
               when MERCADORIASNOTA.CSTIPI in (0, 50) then MERCADORIASNOTA.VALORIPI
               else 0
             end)
      from MERCADORIASNOTA
      where MERCADORIASNOTA.FILIAL = :FILIAL and
            MERCADORIASNOTA.IDNOTA = :V_IDNOTA
      into :VL_IPI;
    end
    else
    if (:ORIGEM = 'NC') then
    begin
      select sum(
             case
               when MERCADORIASNOTA.CSTIPI in (0) then MERCADORIASNOTA.VALORIPI
               else 0
             end)
      from MERCADORIASNOTACOMPRA MERCADORIASNOTA
      where MERCADORIASNOTA.FILIAL = :FILIAL and
            MERCADORIASNOTA.IDNOTA = :V_IDNOTA
      into :VL_IPI;
    end

     if (:COD_SIT = '02') then
    begin
      COD_PART = null;
      DT_DOC = null;
      DT_E_S = null;
      VL_DOC = null;
      IND_PGTO = null;
      VL_DESC = null;
      VL_ABAT_NT = null;
      VL_MERC = null;
      IND_FRT = null;
      VL_FRT = null;
      VL_SEG = null;
      VL_OUT_DA = null;
      VL_BC_ICMS = null;
      VL_ICMS = null;
      VL_BC_ICMS_ST = null;
      VL_ICMS_ST = null;
      VL_IPI = null;
      VL_PIS = null;
      VL_COFINS = null;
      VL_PIS_ST = null;
      VL_COFINS_ST = null;
    end

    SEQUENCIAC = SEQUENCIAC + 1;
    ORDEM = 0;
    NIVEL = 3;
    if (VL_BC_ICMS < 0.00 or VL_ICMS < 0.00) then
    begin
      VL_BC_ICMS = 0.00;
      VL_ICMS = 0.00;
      aliq_icms = 0.00;
    end
    insert into SPEDFISCAL_C (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, IND_OPER, IND_EMIT, COD_PART, COD_MOD, COD_SIT, SER,
                              NUM_DOC, CHV_NFE, DT_DOC, DT_E_S, VL_DOC, IND_PGTO, VL_DESC, VL_MERC, VL_ABAT_NT, IND_FRT,
                              VL_FRT, VL_SEG, VL_OUT_DA, VL_BC_ICMS, VL_ICMS, VL_BC_ICMS_ST, VL_ICMS_ST, VL_IPI, VL_PIS,
                              VL_COFINS, VL_PIS_ST, VL_COFINS_ST, COD_NAT)
    values (:SEQUENCIAC, 'C100', :ORDEM, 2, :IND_OPER, :IND_EMIT, :COD_PART, :COD_MOD, :COD_SIT, :SER, :NUM_DOC,
            :CHV_NFE, :DT_DOC, :DT_E_S, :VL_DOC, :IND_PGTO, :VL_DESC, :VL_MERC, :VL_ABAT_NT, :IND_FRT, :VL_FRT, :VL_SEG,
            :VL_OUT_DA, :VL_BC_ICMS, :VL_ICMS, :VL_BC_ICMS_ST, :VL_ICMS_ST, :VL_IPI, :VL_PIS, :VL_COFINS, :VL_PIS_ST,
            :VL_COFINS_ST, :COD_NAT);

    if (:UF <> :V_UFESTABELECIMENTO and
        :COD_SIT <> '02') then
    begin
      if (VL_ICMS_UF_DEST > 0.00) then
      begin
        SEQUENCIAC = SEQUENCIAC + 1;
        IF (IND_OPER=1) THEN
            insert into SPEDFISCAL_C (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, IND_OPER, UF, VL_FCP_UF_DEST, VL_ICMS_UF_DEST,VL_ICMS_UF_REM)
            values (:SEQUENCIAC, 'C101', 0, 3, :IND_OPER,  :UF, :VL_FCP_UF_DEST, :VL_ICMS_UF_DEST, :VL_ICMS_UF_REM);
        ELSE
            insert into SPEDFISCAL_C (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, IND_OPER, UF, VL_FCP_UF_DEST, VL_ICMS_UF_DEST,VL_ICMS_UF_REM)
            values (:SEQUENCIAC, 'C101', 0, 3, :IND_OPER, :UF, :VL_FCP_UF_DEST, :VL_ICMS_UF_REM, :VL_ICMS_UF_DEST );
      end
    end

    if (NUM_DOC_IMP <> '' and ind_oper = 0) then
    begin
      SEQUENCIAC = SEQUENCIAC + 1;
      insert into SPEDFISCAL_C (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, COD_DOC_IMP, NUM_DOC_IMP, VL_PIS_IMP, VL_COFINS_IMP)
      values (:SEQUENCIAC, 'C120', 0, 3, '0', :NUM_DOC_IMP, :VL_PIS, :VL_COFINS);
    end
    NUM_ITEM = 0;

     if (:ORIGEM = 'NS' and
        :COD_SIT <> '02') then
    begin
      for select sum(coalesce(mercadoriasnota.vlrfinalmercad,0)+COALESCE(mercadoriasnota.acrescimonota,0)+coalesce(mercadoriasnota.frete, 0)+coalesce(mercadoriasnota.seguro,0)+coalesce(mercadoriasnota.outdespacessor,0)+coalesce(mercadoriasnota.vlricmsrecolhido,0)+coalesce(mercadoriasnota.valoripi,0)+coalesce(mercadoriasnota.icmsstfcpvalor,0)+
                     case substring(mercadoriasnota.cfop from 1 for 1) when 3 then
                     coalesce(mercadoriasnota.vlrtaxasiscomex,0)+coalesce(mercadoriasnota.vlrmarinhamerc,0)+coalesce(mercadoriasnota.vlrdespaduaneiras,0)+coalesce(mercadoriasnota.vlrpispasep,0)+coalesce(mercadoriasnota.vlrcofins,0)+(
                     case MERCADORIASNOTA.ICMSORIGEMBASE
                          when 0 then MERCADORIASNOTA.VALORICMS
                          else MERCADORIASNOTA.ICMSORIGEMVALOR
                     end) else 0 end)- sum(coalesce(MERCADORIASNOTA.DESCONTONOTA, 0)),
                 sum(coalesce(MERCADORIASNOTA.VLRDESCPRODUTO, 0) + coalesce(MERCADORIASNOTA.DESCONTONOTA, 0)) as DESCONTOS,
                 case substring(MERCADORIASNOTA.SITUACAOTRIBUT from 4 for 1)
                   when '' then MERCADORIASNOTA.SITUACAOTRIBUT
                   else substring(MERCADORIASNOTA.SITUACAOTRIBUT from 2 for 3)
                 end,
                 MERCADORIASNOTA.CFOP,
                 sum(
                 case MERCADORIASNOTA.ICMSORIGEMBASE
                   when 0 then MERCADORIASNOTA.ICMSBASE
                   else MERCADORIASNOTA.ICMSORIGEMBASE
                 end),
                 case MERCADORIASNOTA.ICMSORIGEMBASE
                   when 0 then MERCADORIASNOTA.ALIQUOTAICMS
                   else MERCADORIASNOTA.ICMSORIGEMALIQUOTA
                 end,
                 sum(
                 case MERCADORIASNOTA.ICMSORIGEMBASE
                   when 0 then MERCADORIASNOTA.VALORICMS
                   else MERCADORIASNOTA.ICMSORIGEMVALOR
                 end),
                 sum(MERCADORIASNOTA.VLRBASESUBST) as VLRBASESUBST, sum(MERCADORIASNOTA.VLRICMSRECOLHIDO), sum(
                 case
                   when MERCADORIASNOTA.CSTIPI in (0, 50) then MERCADORIASNOTA.VALORIPI
                   else 0
                 end)
          from MERCADORIASNOTA
          inner join ITEMESTOQUE on (MERCADORIASNOTA.CODIGO = ITEMESTOQUE.CODIGO)
          where MERCADORIASNOTA.FILIAL = :FILIAL and
                MERCADORIASNOTA.IDNOTA = :V_IDNOTA
          group by 3, 4, 6
          into VL_ITEM, VL_DESC, CST_ICMS, CFOP, VL_BC_ICMS, ALIQ_ICMS, VL_ICMS, VL_BC_ICMS_ST, VL_ICMS_ST, VL_IPI
      do
      begin
        NUM_ITEM = NUM_ITEM + 1;

        SEQUENCIAC = SEQUENCIAC + 1;

        if (VL_BC_ICMS < 0.00 or VL_ICMS < 0.00) then
        begin
          VL_BC_ICMS = 0.00;
          VL_ICMS = 0.00;
          aliq_icms = 0.00;
        end

        if (substring(CFOP from 1 for 1) in ('1', '2', '3')) then
          VL_TOT_CREDITOS = VL_TOT_CREDITOS + VL_ICMS;
        if (substring(CFOP from 1 for 1) in ('5', '6', '7')) then
          VL_TOT_DEBITOS = VL_TOT_DEBITOS + VL_ICMS;

        VL_RED_BASE = VL_ITEM - (VL_DESC + VL_IPI);
        VL_RED_BASE = VL_RED_BASE - VL_BC_ICMS;
        if (VL_RED_BASE < 0) then
          VL_RED_BASE = 0;
        --              cod_enq='999';
        insert into SPEDFISCAL_C (SEQUENCIA, SEGMENTO, ORDEM, NIVEL,VL_ITEM, VL_DESC, IND_MOV, CST_ICMS, CFOP, VL_OPR,
                                 VL_BC_ICMS, ALIQ_ICMS, VL_ICMS, VL_BC_ICMS_ST, VL_ICMS_ST, VL_IPI, VL_DESC)
        values (:SEQUENCIAC, 'C190', 0, 3, :VL_ITEM, :VL_DESC, :IND_MOV, :CST_ICMS, :CFOP, :VL_ITEM,
               :VL_BC_ICMS, :ALIQ_ICMS, :VL_ICMS, :VL_BC_ICMS_ST, :VL_ICMS_ST,:VL_IPI, :VL_RED_BASE);

        NUM_ITEM = NUM_ITEM + 1;
      end
      NUM_ITEM = 0;
    end
    else
    if (:ORIGEM = 'NC') then
    begin
      if (:IND_EMIT = 1) then
      begin
        for select MERCADORIASNOTA.CODIGO, MERCADORIASNOTA.DESREDUZIDA, MERCADORIASNOTA.QUANTIDADE,
                   MERCADORIASNOTA.UNIDADE,
                   MERCADORIASNOTA.VLRFINALMERCAD - (coalesce(MERCADORIASNOTA.VLRDESCPRODUTO, 0) + coalesce(MERCADORIASNOTA.DESCONTONOTA, 0)),
                   coalesce(MERCADORIASNOTA.VLRDESCPRODUTO, 0) + coalesce(MERCADORIASNOTA.DESCONTONOTA, 0),
                   case substring(MERCADORIASNOTA.SITUACAOTRIBUT from 4 for 1)
                     when '' then MERCADORIASNOTA.SITUACAOTRIBUT
                     else substring(MERCADORIASNOTA.SITUACAOTRIBUT from 2 for 3)
                   end,
                   MERCADORIASNOTA.CFOP,
                   case
                     when ITEMESTOQUE.TIPOPRODUTO not in ('1', '3', '4') then 0
                     else case
                            when (mercadoriasnota.vlricmsrecolhido>0 and NOTACOMPRA.DEVOLUCAO = 'N') then 0
                            else MERCADORIASNOTA.ICMSBASE
                          end
                   end,
                   MERCADORIASNOTA.ALIQUOTAICMS,
                   case
                     when ITEMESTOQUE.TIPOPRODUTO not in ('1', '3', '4') then 0
                     else case
                            when (mercadoriasnota.vlricmsrecolhido>0 and NOTACOMPRA.DEVOLUCAO = 'N') then 0
                            else MERCADORIASNOTA.VALORICMS
                          end
                   end,
                   case NOTACOMPRA.DEVOLUCAO
                     when 'S' then MERCADORIASNOTA.VLRBASESUBST
                     else 0
                   end,
                   MERCADORIASNOTA.ALIQUOTASUBSTITUTO,
                   case NOTACOMPRA.DEVOLUCAO
                     when 'S' then MERCADORIASNOTA.VLRICMSRECOLHIDO
                     else 0
                   end,
                   substring ( MERCADORIASNOTA.CSTIPI from 1 for 2),
                   MERCADORIASNOTA.IPIBASE, MERCADORIASNOTA.PIPI,
                   (
                   case
                     when MERCADORIASNOTA.CSTIPI in (0) then MERCADORIASNOTA.VALORIPI
                     else 0
                   end),
                   MERCADORIASNOTA.CSTPIS, MERCADORIASNOTA.BASEPIS, MERCADORIASNOTA.PPIS, MERCADORIASNOTA.VLRPISPASEP,
                   MERCADORIASNOTA.CSTCOFINS, MERCADORIASNOTA.BASECOFINS, MERCADORIASNOTA.PCOFINS,
                   MERCADORIASNOTA.VLRCOFINS,
                   case NATUREZAOPERACAO
                     when 'S' then 0
                     else 1
                   end,
                   notacompra.devolucao
            from MERCADORIASNOTACOMPRA MERCADORIASNOTA
            inner join ITEMESTOQUE on (MERCADORIASNOTA.CODIGO = ITEMESTOQUE.CODIGO)
            inner join NOTACOMPRA on (MERCADORIASNOTA.FILIAL = NOTACOMPRA.FILIAL and
                  MERCADORIASNOTA.IDNOTA = NOTACOMPRA.IDNOTA)
            inner join NATUREZAOPERACAO on (NOTACOMPRA.OPERACAO = NATUREZAOPERACAO.ID)
            where MERCADORIASNOTA.FILIAL = :FILIAL and
                  MERCADORIASNOTA.IDNOTA = :V_IDNOTA
            order by MERCADORIASNOTA.IDMERCADORIA
            into COD_ITEM, DESCR_COMPL, QTD, UNID, VL_ITEM, VL_DESC, CST_ICMS, CFOP, VL_BC_ICMS, ALIQ_ICMS, VL_ICMS,
                 VL_BC_ICMS_ST, ALIQ_ST, VL_ICMS_ST, CST_IPI, VL_BC_IPI, ALIQ_IPI, VL_IPI, CST_PIS, VL_BC_PIS,
                 ALIQ_PIS, VL_PIS, CST_COFINS, VL_BC_COFINS, ALIQ_COFINS, VL_COFINS, IND_MOV, :v_devolucao
        do
        begin
          NUM_ITEM = NUM_ITEM + 1;
          SEQUENCIAC = SEQUENCIAC + 1;
          COD_ENQ = '';

          if(:v_devolucao = 'S' and :cst_icms in ('060','160','260')) then
          begin
                 VL_BC_ICMS=0.00;
                 ALIQ_ICMS=0.00;
                 VL_ICMS=0.00;
                 VL_BC_ICMS_ST=0.00;
                 ALIQ_ST=0.00;
                 VL_ICMS_ST=0.00;
                 VL_BC_IPI=0.00;
                 ALIQ_IPI=0.00;
                 VL_IPI=0.00;
          end

          insert into SPEDFISCAL_C (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, NUM_ITEM, COD_ITEM, DESCR_COMPL, QTD, UNID,
                                   VL_ITEM, VL_DESC, IND_MOV, CST_ICMS, CFOP, COD_NAT, VL_BC_ICMS, ALIQ_ICMS, VL_ICMS,
                                    VL_BC_ICMS_ST, ALIQ_ST, VL_ICMS_ST, IND_APUR, CST_IPI, COD_ENQ, VL_BC_IPI, ALIQ_IPI,
                                    VL_IPI, CST_PIS, VL_BC_PIS, ALIQ_PIS, VL_PIS, CST_COFINS, VL_BC_COFINS, ALIQ_COFINS, VL_COFINS)
          values (:SEQUENCIAC, 'C170', 0, 3, :NUM_ITEM, :COD_ITEM, :DESCR_COMPL, :QTD, :UNID, :VL_ITEM, :VL_DESC,
                  :IND_MOV, :CST_ICMS, :CFOP, :COD_NAT, :VL_BC_ICMS, :ALIQ_ICMS, :VL_ICMS,:VL_BC_ICMS_ST, :ALIQ_ST,
                  :VL_ICMS_ST, :IND_APUR, :CST_IPI, :COD_ENQ, :VL_BC_IPI, :ALIQ_IPI, :VL_IPI,:CST_PIS, :VL_BC_PIS,
                  :ALIQ_PIS, :VL_PIS, :CST_COFINS, :VL_BC_COFINS, :ALIQ_COFINS, :VL_COFINS);
        end
      end
      for select sum(coalesce(mercadoriasnota.vlrfinalmercad,0)+COALESCE(mercadoriasnota.acrescimonota,0)+coalesce(mercadoriasnota.frete, 0)+coalesce(mercadoriasnota.seguro,0)+coalesce(mercadoriasnota.outdespacessor,0)+coalesce(mercadoriasnota.vlricmsrecolhido,0)+coalesce(mercadoriasnota.valoripi,0))- sum(coalesce(MERCADORIASNOTA.DESCONTONOTA, 0)),
                 sum(coalesce(MERCADORIASNOTA.VLRDESCPRODUTO, 0) + coalesce(MERCADORIASNOTA.DESCONTONOTA, 0)) as DESCONTOS,
                 case substring(MERCADORIASNOTA.SITUACAOTRIBUT from 4 for 1)
                   when '' then MERCADORIASNOTA.SITUACAOTRIBUT
                   else substring(MERCADORIASNOTA.SITUACAOTRIBUT from 2 for 3)
                 end,
                 MERCADORIASNOTA.CFOP,
                 sum(
                 case
                   when ITEMESTOQUE.TIPOPRODUTO not in ('1', '3', '4') then 0
                   else case
                          when (mercadoriasnota.vlricmsrecolhido>0 and NOTACOMPRA.DEVOLUCAO = 'N') then 0
                          else MERCADORIASNOTA.ICMSBASE
                        end
                 end),
                 MERCADORIASNOTA.ALIQUOTAICMS,
                 sum(
                 case
                   when ITEMESTOQUE.TIPOPRODUTO not in ('1', '3', '4') then 0
                   else case
                          when (mercadoriasnota.vlricmsrecolhido>0 and NOTACOMPRA.DEVOLUCAO = 'N') then 0
                          else MERCADORIASNOTA.VALORICMS
                        end
                 end),
                 sum(
                 case NOTACOMPRA.DEVOLUCAO
                   when 'S' then MERCADORIASNOTA.VLRBASESUBST
                   else 0
                 end) as VLRBASESUBST,
                 sum(
                 case NOTACOMPRA.DEVOLUCAO
                   when 'S' then MERCADORIASNOTA.VLRICMSRECOLHIDO
                   else 0
                 end),
                  sum(
                 case
                   when MERCADORIASNOTA.CSTIPI in (0) then MERCADORIASNOTA.VALORIPI
                   else 0
                 end), notacompra.devolucao
          from MERCADORIASNOTACOMPRA MERCADORIASNOTA
          inner join ITEMESTOQUE on (MERCADORIASNOTA.CODIGO = ITEMESTOQUE.CODIGO)
          inner join NOTACOMPRA on (MERCADORIASNOTA.FILIAL = NOTACOMPRA.FILIAL and
                MERCADORIASNOTA.IDNOTA = NOTACOMPRA.IDNOTA)
          inner join NATUREZAOPERACAO on (NOTACOMPRA.OPERACAO = NATUREZAOPERACAO.ID)
          where MERCADORIASNOTA.FILIAL = :FILIAL and
                MERCADORIASNOTA.IDNOTA = :V_IDNOTA
          group by 3, 4, 6, 11
          into VL_ITEM, VL_DESC, CST_ICMS, CFOP, VL_BC_ICMS, ALIQ_ICMS, VL_ICMS, VL_BC_ICMS_ST, VL_ICMS_ST, VL_IPI, :v_devolucao
      do
      begin
        NUM_ITEM = NUM_ITEM + 1;

        SEQUENCIAC = SEQUENCIAC + 1;
        VL_TOT_CREDITOS = VL_TOT_CREDITOS + VL_ICMS;
        VL_RED_BASE = VL_ITEM - (VL_DESC + VL_IPI);
        VL_RED_BASE = VL_RED_BASE - VL_BC_ICMS;
        if (VL_RED_BASE < 0) then
          VL_RED_BASE = 0;
          if(:v_devolucao = 'S' and :cst_icms in ('060','160','260')) then
          begin
                 VL_BC_ICMS=0.00;
                 ALIQ_ICMS=0.00;
                 VL_ICMS=0.00;
                 VL_BC_ICMS_ST=0.00;
                 ALIQ_ST=0.00;
                 VL_ICMS_ST=0.00;
                 VL_BC_IPI=0.00;
                 ALIQ_IPI=0.00;
                 VL_IPI=0.00;
          end

        insert into SPEDFISCAL_C (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, VL_ITEM, VL_DESC, IND_MOV,CST_ICMS, CFOP, VL_OPR,
                                 VL_BC_ICMS, ALIQ_ICMS, VL_ICMS,VL_BC_ICMS_ST, VL_ICMS_ST,VL_IPI, VL_DESC)
        values (:SEQUENCIAC, 'C190', 0, 3, :VL_ITEM, :VL_DESC, :IND_MOV,:CST_ICMS, :CFOP, :VL_ITEM,
                :VL_BC_ICMS, :ALIQ_ICMS, :VL_ICMS, :VL_BC_ICMS_ST, :VL_ICMS_ST,:VL_IPI, :VL_RED_BASE);

        NUM_ITEM = NUM_ITEM + 1;
      end

    end

  end

  for select distinct SPEDFISCAL_C.COD_PART,
                      case
                        when coalesce(CADASTROPARCEIROS.CODIGOPAIS, '') = '' then 1058
                        else CADASTROPARCEIROS.CODIGOPAIS
                      end,
                      case CADASTROPARCEIROS.TIPOPESSOA
                        when 'J' then CADASTROPARCEIROS.DOCUMENTO
                        else ''
                      end,
                      case CADASTROPARCEIROS.TIPOPESSOA
                        when 'F' then CADASTROPARCEIROS.DOCUMENTO
                        else ''
                      end,
                      case CADASTROPARCEIROS.TIPOPESSOA
                        when 'J' then case upper(CADASTROPARCEIROS.INSCESTADUAL)
                                        when 'ISENTA' then ''
                                        when 'ISENTO' then ''
                                        else CADASTROPARCEIROS.INSCESTADUAL
                                      end
                        else ''
                      end,
                      MUNICIPIO.UF || MUNICIPIO.MUNICIPIO, CLIENTES.INSCSUFRAMA, CADASTROPARCEIROS.RAZAOSOCIAL,
                      CADASTROPARCEIROS.LOGRADOURO, CADASTROPARCEIROS.NUMERO,
                      SUBSTRING ( CADASTROPARCEIROS.COMPLEMENTO from 1 for 20),
                      substring ( CADASTROPARCEIROS.BAIRRO from 1 for 30)
      from SPEDFISCAL_C
      inner join CADASTROPARCEIROS on (SPEDFISCAL_C.COD_PART = CADASTROPARCEIROS.CADASTRO)
      left join MUNICIPIO on (CADASTROPARCEIROS.UF = MUNICIPIO.UF_SIGLA and
            upper(CADASTROPARCEIROS.CIDADE) = upper(MUNICIPIO.MUNICIPIO_NOME))
      left join CLIENTES on (CADASTROPARCEIROS.CADASTRO = CLIENTES.CADASTRO)
      where SPEDFISCAL_C.SEGMENTO = 'C100' and
            not exists(select *
                       from SPEDFISCAL_0
                       where SPEDFISCAL_0.SEGMENTO = '0150' and
                             SPEDFISCAL_0.COD_PART = CADASTROPARCEIROS.CADASTRO)
      into :COD_PART, COD_PAIS, CNPJ, CPF, IE, COD_MUN, SUFRAMA, NOME, ENDERECO, NUM, COMPL, BAIRRO
  do
  begin
    if (COD_PAIS <> '1058') then
      COD_MUN = '9999999';

    SEQUENCIA0 = SEQUENCIA0 + 1;
    insert into SPEDFISCAL_0 (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, COD_PART, NOME, COD_PAIS, CNPJ, CPF, IE, COD_MUN,
                              SUFRAMA, ENDERECO, NUM, COMPL, BAIRRO)
    values (:SEQUENCIA0, '0150', 0, 2, :COD_PART, :NOME, :COD_PAIS, :CNPJ, :CPF, :IE, :COD_MUN, :SUFRAMA, :ENDERECO,
            :NUM, :COMPL, :BAIRRO);
  end

  SEQUENCIAH = 1;
  VL_TOT_ITEM = 0;

  DT_INV = :DT_FIM;
  
  if (extract(month from :DT_FIM) = 2) then
  begin
    DT_INV = '31.' || '12.' ||(extract(year from :DT_FIM) - 1);
  
    update ESTSIN
    set ESTABELECIMENTO = :FILIAL,
      DATAINICIAL = :DT_INV, --:dt_fim,
      DATAFINAL = :DT_INV, --:dt_fim,
      MATERIALINICIAL = '',
      MATERIALFINAL = 'zzzzzzzz'
    where RELATORIO = 'SALDOANTERIORESTOQUE';
  
    SEQUENCIAH = SEQUENCIAH + 1; 

    for select distinct ITEMESTOQUE.CODIGO, ITEMESTOQUE.UNIDADE, SALDOINICIALESTOQUE.VALORANTERIOR,
                      SALDOINICIALESTOQUE.SALDOANTERIOR,
                      (SALDOINICIALESTOQUE.VALORANTERIOR / SALDOINICIALESTOQUE.SALDOANTERIOR)
      FROM SALDOINICIALESTOQUE
      INNER JOIN ITEMESTOQUE ON (SALDOINICIALESTOQUE.IDITEM=ITEMESTOQUE.CODIGO)
      inner join ESTSIN on (ESTSIN.RELATORIO = 'SALDOANTERIORESTOQUE' and
            ESTSIN.ESTABELECIMENTO = :FILIAL and
            (ITEMESTOQUE.CODIGO between ESTSIN.MATERIALINICIAL and ESTSIN.MATERIALFINAL))
      INNER JOIN TRIBUTACAOICMSUF ON (TRIBUTACAOICMSUF.ID=ITEMESTOQUE.TRIBUTACAOICMS AND
                                TRIBUTACAOICMSUF.UF=:v_ufestabelecimento)
      LEFT JOIN CLASSIFICACAOFISCAL ON (CLASSIFICACAOFISCAL.CFISCAL=ITEMESTOQUE.CLASSIFISCAL)
      WHERE (ITEMESTOQUE.TIPOPRODUTO in ('1' , '3', '4') and (SALDOINICIALESTOQUE.SALDOANTERIOR > 0.0009) and (SALDOINICIALESTOQUE.valoranterior > 0))
      into :COD_ITEM, :UNID, :VL_ITEM, :QTD, :VL_UNIT_H
    do
    begin
        VL_TOT_ITEM = VL_TOT_ITEM + VL_ITEM; --ok

      SEQUENCIAH = SEQUENCIAH + 1;
      insert into SPEDFISCAL_H (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, COD_ITEM, UNID, QTD, VL_UNIT, VL_ITEM, IND_PROP)
      values (:SEQUENCIAH, 'H010', 3, 3, :COD_ITEM, :UNID, :QTD, :VL_UNIT_H, :VL_ITEM, 0);
     end

    insert into SPEDFISCAL_H (SEQUENCIA, SEGMENTO, ORDEM, NIVEL, DT_INV, VL_INV, MOT_INV)
    values (2, 'H005', 0, 2, :DT_INV, :VL_TOT_ITEM, '01');
  end

