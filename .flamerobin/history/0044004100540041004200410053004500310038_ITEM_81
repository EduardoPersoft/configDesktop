SELECT
    MOVIMENTOESTOQUE.FILIAL,
    MOVIMENTOESTOQUE.IDMOVIMENTO,
    MOVIMENTOESTOQUE.EMISSAO,
    MATERIALMOVIMENTOESTOQUE.C_TUFTINGFUNDO,
    MOVIMENTOESTOQUE.DOCUMENTO,
    COMPOSICAOITEM.CODIGO
FROM
    MATERIALMOVIMENTOESTOQUE
INNER JOIN 
    MOVIMENTOESTOQUE ON
        MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL AND
        MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
INNER JOIN
    COMPOSICAOOP ON
        COMPOSICAOOP.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL  AND
        COMPOSICAOOP.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO AND
        COMPOSICAOOP.IDMOVIMENTOMATERIAL=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL
WHERE
    MATERIALMOVIMENTOESTOQUE.C_TUFTINGFUNDO>='01.09.2021' AND
    COMPOSICAOOP.CODIGO='01.12.5066'
    
    