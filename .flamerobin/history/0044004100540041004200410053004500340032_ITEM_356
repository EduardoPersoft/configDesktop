update
    MATERIALMOVIMENTOESTOQUE
set
    LOTE = (SELECT C_AJMOVTOLOTE.LOTE FROM C_AJMOVTOLOTE
            WHERE C_AJMOVTOLOTE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL
            AND C_AJMOVTOLOTE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
            AND C_AJMOVTOLOTE.IDMOVIMENTOMATERIAL=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL)
where
    EXISTS (SELECT C_AJMOVTOLOTE.LOTE FROM C_AJMOVTOLOTE
            WHERE C_AJMOVTOLOTE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL
            AND C_AJMOVTOLOTE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
            AND C_AJMOVTOLOTE.IDMOVIMENTOMATERIAL=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL)
