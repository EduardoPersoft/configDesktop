select
    first 600
    produto.codigo,
    produto.descricao,
    sum(mercadoriasnota.quantidade),
    produto.unidade
from
    notafiscal
inner join
    mercadoriasnota on
        mercadoriasnota.filial=notafiscal.filial and
        mercadoriasnota.idnota=notafiscal.idnota
inner join
    itemestoque codigonota on
        codigonota.codigo=mercadoriasnota.CODIGO
inner join
    itemestoque produto on
        produto.codigo = coalesce(codigonota.itembase,codigonota.codigo)
where        
    notafiscal.filial=5 and
    notafiscal.dataemissao>='01.01.2020'
group by    
        produto.codigo,
    produto.descricao,
    produto.unidade
order by    
    sum(mercadoriasnota.quantidade) desc