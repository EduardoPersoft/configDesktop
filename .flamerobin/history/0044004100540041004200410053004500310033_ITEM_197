drop TRIGGER COMENTARIOS

CREATE TRIGGER COMENTARIOS_BI FOR COMENTARIOS
ACTIVE BEFORE INSERT POSITION 0
AS
BEGIN
   NEW.ID = GEN_ID("G_COMENTARIO",1);
   NEW.DATAHORA = CAST('NOW' AS TIMESTAMP);
END

CREATE TABLE COMENTARIOS(
ID INTEGER NOT NULL,
IDUSUARIO INTEGER,
DATAHOTA TIMESTAMP,
COMENTARIO VARCHAR(250),
DOCUMENTO VARCHAR(30),
UUID VARCHAR(36),
CONSTRAINT PK_COMENTARIOS PRIMARY KEY (ID))