update
    MATERIALMOVIMENTOESTOQUE
set 
    MATERIALMOVIMENTOESTOQUE.idCENTROCUSTO = case MATERIALMOVIMENTOESTOQUE.IDCENTROCUSTO 
    when '101' then '1101'
    when '102' then '1105'
    when '103' then '1102'
    when '104' then '1103'
