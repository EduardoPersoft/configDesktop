update
    MOVIMENTOESTOQUE
set
    movimentoestoque.LOCALARMAZENAMENTo=6
where
    movimentoestoque.tipomovimento='13' and
    movimentoestoque.filial=110 and
    exists (
        select 
            *
        from
            MATERIALMOVIMENTOESTOQUE
        where
            MATERIALMOVIMENTOESTOQUE.filial=movimentoestoque.filial and
            materialmovimentoestoque.idmovimento=movimentoestoque.idmovimento and
            materialmovimentoestoque.concluido = 'N')