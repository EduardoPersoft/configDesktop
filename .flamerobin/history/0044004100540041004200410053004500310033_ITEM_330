select 
    mercadoriasped.filial "filial",
    mercadoriasped.idnota "idNota",
    mercadoriasped.idmercadoria "idMercadora",
    pedido.datacadastro "dataCadastro",
    cadastroparceiros.nome "nome",
    mercadoriasped.quantidade "quantidade"
FROM
    mercadoriasped
inner JOIN
    pedido on
        mercadoriasped.filial=pedido.filial and 
        mercadoriasped.idnota=pedido.IDNOTA
inner JOIN
    cadastroparceiros on
        cadastroparceiros.cadastro = pedido.destinatario
WHERE
    mercadoriasped.filial=1 AND
    mercadoriasped.baixa = 'N' AND
    mercadoriasped.codigo = '9801005-Y'