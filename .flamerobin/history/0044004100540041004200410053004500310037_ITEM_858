SET TERM ^ ;
ALTER PROCEDURE C_LOGECOMMERCEPEDIDONF (
    FILIAL INTEGER,
    IDNOTA INTEGER )

AS
DECLARE VARIABLE QTD INTEGER; 
DECLARE VARIABLE QTDcarrinho INTEGER; 
BEGIN

    select count(carrinho.login) from CARRINHO
    where carrinho.filial=:filial and carrinho.id=:idnota
    into :qtdcarrinho;
    
    if (qtdcarrinho>0) then begin


        SELECT COUNT(*) 
        FROM C_LOGPEDIDONFECOMMERCE
        WHERE C_LOGPEDIDONFECOMMERCE.FILIAL=:FILIAL 
        AND C_LOGPEDIDONFECOMMERCE.IDNOTA=:IDNOTA
        INTO :QTD;
        IF (QTD=0) THEN BEGIN
            INSERT INTO C_LOGPEDIDONFECOMMERCE(FILIAL, IDNOTA, INCLUSAO) VALUES (:FILIAL, :IDNOTA, 'N');
        END
        UPDATE C_LOGPEDIDONFECOMMERCE 
        SET C_LOGPEDIDONFECOMMERCE.STATUS_CODE = NULL
        WHERE C_LOGPEDIDONFECOMMERCE.FILIAL=:FILIAL
        AND C_LOGPEDIDONFECOMMERCE.IDNOTA=:IDNOTA;
        
    end
END
^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE C_LOGECOMMERCEPEDIDONF TO  SYSDBA WITH GRANT OPTION;

