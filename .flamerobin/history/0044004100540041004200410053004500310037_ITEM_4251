SELECT (SELECT CFOPESPECIAL.CFOP FROM CFOPESPECIAL(NOTAFISCAL.FILIAL, NOTAFISCAL.IDNOTA))
       CFOP_ESPECIAL,
       NOTAFISCAL.FILIAL,
       NOTAFISCAL.IDNOTA,
       NOTAFISCAL.DATACADASTRO,
       NOTAFISCAL.DATAEMISSAO,
       NOTAFISCAL.NUMERONOTA,
       NOTAFISCAL.VLRTOTALNOTA,
       CADASTROPARCEIROS.CADASTRO,
       CADASTROPARCEIROS.RAZAOSOCIAL,
       CADASTROPARCEIROS.NOME,
       CADASTROPARCEIROS.DOCUMENTO,
       NOTAFISCAL.NATUREZAOPERACAO,
      CASE CADASTROPARCEIROS.aprovado WHEN 'S' THEN 0 ELSE 255 END AS P_STATUSCOR
FROM  NOTAFISCAL
inner join  CADASTROPARCEIROS on (NOTAFISCAL.DESTINATARIO=CADASTROPARCEIROS.CADASTRO)
inner join  ESTABELECIMENTO on (NOTAFISCAL.FILIAL=ESTABELECIMENTO.CADASTRO)
inner join modelodocto on (notafiscal.modelo=modelodocto.id)
LEFT JOIN 
    NFECTRL ON
        NFECTRL.FILIAL=NOTAFISCAL.FILIAL and
        NFECTRL.IDNOTA=NOTAFISCAL.IDNOTA
WHERE FILIAL=:FILIAL
AND modelodocto.tipodocto='NV' 
AND (NOTAFISCAL.DATAEMISSAO IS NULL OR
     ( COALESCE(NFECTRL.IDRESULTADO, 0)<>55 and  
        NOTAFISCAL.DATACANCELAMENTO is null))