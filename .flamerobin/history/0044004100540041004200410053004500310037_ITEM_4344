select 
    * 
from 
    mercadoriasnota 
inner join 
    mercadoriasped on
        mercadoriasped.filial=mercadoriasnota.filialped and
        mercadoriasped.idnota=mercadoriasnota.idpedido and
        mercadoriasped.IDMERCADORIA=mercadoriasnota.IDMERCADORIA
where 
    mercadoriasped.quantiade<>mercadoriasnota.quantidade