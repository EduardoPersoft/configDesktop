SET TERM ^ ;
ALTER PROCEDURE IMPPED2 (
    RELATORIO VARCHAR(20) )
RETURNS (
    FILIAL INTEGER,
    RAZAOFILIAL VARCHAR(60),
    NOMEFILIAL VARCHAR(60),
    DOCUMENTOFILIAL VARCHAR(18),
    INSCESTADUALFILIAL VARCHAR(20),
    INSCMUNICIPALFILIAL VARCHAR(20),
    LOGRADOUROFILIAL VARCHAR(50),
    NUMEROFILIAL INTEGER,
    COMPLEMENTOFILIAL VARCHAR(20),
    BAIRROFILIAL VARCHAR(30),
    CIDADEFILIAL VARCHAR(30),
    UFFILIAL VARCHAR(2),
    CEPFILIAL VARCHAR(9),
    TELEFONEFILIAL VARCHAR(20),
    TELEFONECOMERCIALFILIAL VARCHAR(20),
    FAXFILIAL VARCHAR(20),
    PRINCIPALCONTATOFILIAL VARCHAR(40),
    EMAILFILIAL VARCHAR(50),
    WEBFILIAL VARCHAR(100),
    NOMEUSUARIO VARCHAR(60),
    TELEFONEUSUARIO VARCHAR(20),
    FAXUSUARIO VARCHAR(20),
    EMAILUSUARIO VARCHAR(50),
    DEPARTAMENTOUSUARIO VARCHAR(30),
    CARGOUSUARIO VARCHAR(20),
    IDNOTA INTEGER,
    NUMEROPEDIDO VARCHAR(20),
    DATAEMISSAO TIMESTAMP,
    DATACADASTRO TIMESTAMP,
    DESTINATARIO INTEGER,
    RAZAO VARCHAR(60),
    NOME VARCHAR(40),
    LOGRADOURO VARCHAR(50),
    NUMERO INTEGER,
    BAIRRO VARCHAR(30),
    COMPLEMENTO VARCHAR(20),
    CIDADE VARCHAR(30),
    UF VARCHAR(2),
    CEP VARCHAR(9),
    DOCUMENTO VARCHAR(18),
    INSCESTADUAL VARCHAR(20),
    INSCMUNICIPAL VARCHAR(20),
    EMAIL VARCHAR(50),
    TELEFONE VARCHAR(20),
    TELEFONECOMERCIAL VARCHAR(20),
    CELULAR VARCHAR(20),
    FAX VARCHAR(20),
    PRINCIPALCONTATO VARCHAR(40),
    LOGRADOUROENTREGA VARCHAR(50),
    NUMEROENTREGA INTEGER,
    COMPLEMENTOENTREGA VARCHAR(20),
    BAIRROENTREGA VARCHAR(30),
    CIDADEENTREGA VARCHAR(30),
    UFENTREGA VARCHAR(2),
    CEPENTREGA VARCHAR(9),
    LOCALENTREGA VARCHAR(400),
    LOGRADOUROCOBRANCA VARCHAR(50),
    NUMEROCOBRANCA INTEGER,
    BAIRROCOBRANCA VARCHAR(30),
    COMPLEMENTOCOBRANCA VARCHAR(20),
    CIDADECOBRANCA VARCHAR(30),
    UFCOBRANCA VARCHAR(2),
    CEPCOBRANCA VARCHAR(9),
    LOCALCOBRANCA VARCHAR(400),
    NOMEUSUARIOAPROVACAO VARCHAR(60),
    TELEFONEUSUARIOAPROVACAO VARCHAR(20),
    FAXUSUARIOAPROVACAO VARCHAR(20),
    EMAILUSUARIOAPROVACAO VARCHAR(50),
    DEPARTAMENTOUSUARIOAPROVACAO VARCHAR(30),
    CARGOUSUARIOAPROVACAO VARCHAR(20),
    VENDEDOR INTEGER,
    RAZAOVENDEDOR VARCHAR(60),
    NOMEVENDEDOR VARCHAR(60),
    TELEFONEVENDEDOR VARCHAR(20),
    TELEFONECOMERCIALVENDEDOR VARCHAR(20),
    CELULARVENDEDOR VARCHAR(20),
    FAXVENDEDOR VARCHAR(20),
    EMAILVENDEDOR VARCHAR(50),
    CFOP INTEGER,
    NATUREZAOPERACAO VARCHAR(30),
    TIPOPAGTO VARCHAR(30),
    CONDICAOPAGTO VARCHAR(30),
    TIPOFRETE CHAR(20),
    VLRDESCONTO DOUBLE PRECISION,
    MSGDESCMERCADORIAS VARCHAR(120),
    VLRDESCINDPRODUTO DOUBLE PRECISION,
    MSGDESCPRODUTOS VARCHAR(120),
    VLRACRESCIMO DOUBLE PRECISION,
    MSGACRESCMERCADORIA VARCHAR(120),
    VLRMERCADORIAS DOUBLE PRECISION,
    VLRICMS DOUBLE PRECISION,
    VLRZONAFRANCA DOUBLE PRECISION,
    VLRSUBSTRIB DOUBLE PRECISION,
    VLRIPITOTAL DOUBLE PRECISION,
    VLRFRETE DOUBLE PRECISION,
    VLRSEGURO DOUBLE PRECISION,
    VLRDESPESAS DOUBLE PRECISION,
    VLRSERVICO DOUBLE PRECISION,
    VLRTOTAPEDIDO DOUBLE PRECISION,
    CODTRANSP INTEGER,
    NOMETRANSP VARCHAR(60),
    RAZAOTRANSP VARCHAR(60),
    FONETRANSP VARCHAR(30),
    COMERCIALTRANSP VARCHAR(20),
    CELULARTRANSP VARCHAR(20),
    EMAILTRANSP VARCHAR(50),
    NOMECONTATOTRANSP VARCHAR(40),
    QTDEVOLUME DOUBLE PRECISION,
    PESOLIQUIDO DOUBLE PRECISION,
    PESOBRUTO DOUBLE PRECISION,
    DETALHECF VARCHAR(400),
    DETALHEENTREGA DATE,
    COMENTARIO BLOB SUB_TYPE 0,
    OBSERVACAO BLOB SUB_TYPE 0,
    MSGADICIONAL BLOB SUB_TYPE 0,
    ORDEM INTEGER,
    IDITEM INTEGER,
    CODIGO VARCHAR(15),
    DESCRICAO BLOB SUB_TYPE 0,
    DESCRICAOREDUZIDA VARCHAR(240),
    DESCRICAODETALHE VARCHAR(50),
    DESCRICAOTOTAL VARCHAR(50),
    QUANTIDADE DOUBLE PRECISION,
    UNIDADE VARCHAR(3),
    PRUNITARIO DOUBLE PRECISION,
    PRLISTA DOUBLE PRECISION,
    PIPIMERC DOUBLE PRECISION,
    VLRIPIMERC DOUBLE PRECISION,
    VLRTOTITEM DOUBLE PRECISION,
    PICMS DOUBLE PRECISION,
    CF VARCHAR(12),
    CODCF CHAR(3),
    SEUNUMERO VARCHAR(20),
    DIAHOJE INTEGER,
    MESHOJEEXTENSO VARCHAR(15),
    ANOHOJE INTEGER,
    MSGDESCRMERCADORIAS VARCHAR(150),
    VLRDESCINDSERVICOS DOUBLE PRECISION,
    VLRACRESCSERVICOS DOUBLE PRECISION,
    VLRDESCSERVICOS DOUBLE PRECISION,
    MSGDESCINDSERVICOS VARCHAR(150),
    MSGDESCSERVICOS VARCHAR(150),
    VLRFINALSERVICOS DOUBLE PRECISION,
    MSGACRESCSERVICOS VARCHAR(150),
    MSGDESCRSERVICOS VARCHAR(150),
    LOGO BLOB SUB_TYPE 0,
    PREDUCAO DOUBLE PRECISION,
    MENSAGEMREUDCAOICMS VARCHAR(100),
    REDUCAOESTADOMENSAGEM BLOB SUB_TYPE 0,
    MENSAGEMPEDIDO VARCHAR(2048),
    C_PASSO NUMERIC(9,3),
    C_PISTAS INTEGER,
    C_LARGURAFINAL NUMERIC(9,3),
    C_LARGURAMATERIAPRIMA NUMERIC(9,3),
    C_CODIGOLAMINACAO VARCHAR(15),
    C_CODIGOESTRUTURA VARCHAR(15),
    C_GRAMATURATOTAL NUMERIC(9,3),
    C_GRAMATURAQUIMICOS NUMERIC(9,3),
    C_GRAMATURAESTRUTURA NUMERIC(9,3),
    C_GRAMATURALAMINIACAO NUMERIC(9,3),
    C_DESCRICAOLAMINACAO VARCHAR(240),
    C_DESCTAMANHOPOUCHE VARCHAR(60),
    C_POUCHE VARCHAR(1),
    C_FORNECEDORPOUCHE VARCHAR(70),
    C_TIPOPOUCHE VARCHAR(25),
    C_ALTURAPOUCHE NUMERIC(7,3),
    C_LARGURAPOUCHE NUMERIC(7,3),
    C_SANFONAFUNDO NUMERIC(7,3),
    C_SANFONALATERAL NUMERIC(7,3),
    C_PAINEISFV NUMERIC(7,3),
    C_SOLDA NUMERIC(7,3),
    C_LARGURAF NUMERIC(7,3),
    C_DESCRICAOPOUCH VARCHAR(2000),
    C_PESOBOBINA NUMERIC(6,3),
    C_TUBETEIMPRESSAO NUMERIC(6,3),
    C_DIAMETROBOBINA DOUBLE PRECISION,
    C_SENTIDOBOBINAMENTOIMPRESSAO VARCHAR(20),
    C_CODIGO VARCHAR(15),
    C_NOMECOMERCIAL VARCHAR(30),
    C_CORTE1 NUMERIC(12,3),
    C_CORTE2 NUMERIC(12,3),
    C_CORTE3 NUMERIC(12,3),
    C_CORTE4 NUMERIC(12,3),
    C_NAOPAGINAESTRUTURA VARCHAR(1),
    C_PAGINABANDA VARCHAR(1),
    C_DESCRICAOREDUZIDA VARCHAR(240),
    C_IMPRESSAO VARCHAR(1),
    C_SEQUENCIA INTEGER,
    C_GRAMATURATINTA NUMERIC(12,3),
    STATUSPEDIDO VARCHAR(32) )
AS
declare variable PDATAHOJE timestamp;
declare variable PQTDITEM integer;
declare variable PIDINICIAL integer;
declare variable PIDFINAL integer;
declare variable PCF varchar(12);
declare variable PCODCF char(3);
declare variable PDIAS integer;
declare variable PIDITEM integer;
declare variable PQTD integer;
declare variable PUNIDADE varchar(3);
declare variable PQTDTOTAL varchar(10);
declare variable PQTDPRAZOS varchar(10);
declare variable PDIAANTERIOR integer;
declare variable PVLRTOTAL double precision;
declare variable PPIPI decimal(2,2);
declare variable PPREDUCAOIPI double precision;
declare variable POPERACAO smallint;
declare variable PFATURA varchar(1);
declare variable PDATAREFERENCIA timestamp;
declare variable P_ORDEM smallint;
declare variable P_CODIGOPRODUTO varchar(15);
declare variable P_MATERIAPRIMABASE varchar(15);
declare variable P_PESOPOREMBALAGEM numeric(9,3);
declare variable P_LARGURAFINAL numeric(9,3);
declare variable P_PASSO numeric(9,3);
declare variable P_PISTAS integer;
declare variable P_LARGURAMATERIAPRIMA numeric(9,3);
declare variable P_CODIGOESTRUTURA varchar(15);
declare variable P_GRAMATURATOTAL numeric(9,3);
declare variable P_DESCRICAOESTRUTURA varchar(240);
declare variable P_GRAMATURAFILME numeric(9,3);
declare variable P_GRAMATURAADESIVO numeric(9,3);
declare variable P_GRAMATURAESTRUTURA numeric(9,3);
declare variable P_FILME varchar(15);
declare variable P_ADESIVO varchar(15);
declare variable P_CODIGOLAMINACAO varchar(15);
declare variable P_DESCRICAOLAMINACAO varchar(240);
declare variable P_DESCACBAMENTOPOUCHE varchar(240);
declare variable P_OBSACBAMENTOPOUCHE varchar(240);
declare variable P_ACABAMENTOPOUCHE integer;
declare variable P_POUCHE varchar(1);
declare variable p_descricaoitembase varchar(240) ;
declare variable p_gramaturaitembase numeric(9,3) ;
declare variable p_idmercpedido integer;
declare variable p_novorepeticaoalterado char(1);


begin
  C_GRAMATURAQUIMICOS = 0;
  C_GRAMATURATOTAL = 0;
  C_DESCRICAOPOUCH = ' ';
  C_POUCHE = 'N';
  C_PAGINABANDA = '';

  select CADASTROPARCEIROS.CADASTRO, CADASTROPARCEIROS.RAZAOSOCIAL, CADASTROPARCEIROS.NOME,
         case
           when (CADASTROPARCEIROS.DOCUMENTO <> '') and (not CADASTROPARCEIROS.DOCUMENTO is null) then case CADASTROPARCEIROS.TIPOPESSOA
                                                                                                         when 'F' then cast(substring(CADASTROPARCEIROS.DOCUMENTO from 1 for 3) || '.' || substring(CADASTROPARCEIROS.DOCUMENTO from 4 for 3) || '.' || substring(CADASTROPARCEIROS.DOCUMENTO from 7 for 3) || '-' || substring(CADASTROPARCEIROS.DOCUMENTO from 10 for 2) as varchar(18))
                                                                                                         when 'J' then cast(substring(CADASTROPARCEIROS.DOCUMENTO from 1 for 2) || '.' || substring(CADASTROPARCEIROS.DOCUMENTO from 3 for 3) || '.' || substring(CADASTROPARCEIROS.DOCUMENTO from 6 for 3) || '/' || substring(CADASTROPARCEIROS.DOCUMENTO from 9 for 4) || '-' || substring(CADASTROPARCEIROS.DOCUMENTO from 13 for 2) as varchar(18))
                                                                                                         else null
                                                                                                       end
           else null
         end as DOCUMENTO,
         CADASTROPARCEIROS.INSCESTADUAL, CADASTROPARCEIROS.INSCMUNICIPAL, CADASTROPARCEIROS.LOGRADOURO,
         CADASTROPARCEIROS.NUMERO, CADASTROPARCEIROS.COMPLEMENTO, CADASTROPARCEIROS.BAIRRO, CADASTROPARCEIROS.CIDADE,
         CADASTROPARCEIROS.UF,
         substring(CADASTROPARCEIROS.CEP from 1 for 5) || '-' || substring(CADASTROPARCEIROS.CEP from 6 for 3),
         CADASTROPARCEIROS.TELEFONE, CADASTROPARCEIROS.TELEFONECOMERCIAL, CADASTROPARCEIROS.FAX,
         CADASTROPARCEIROS.PRINCIPALCONTATO, CADASTROPARCEIROS.EMAIL, CADASTROPARCEIROS.WEB, ESTSIN.IDNOTAINICIAL,
         ESTSIN.IDNOTAFINAL, USUARIO.NOMECOMPLETO, USUARIO.TELEFONE, USUARIO.FAX, USUARIO.EMAIL, USUARIO.DEPARTAMENTO,
         USUARIO.CARGO, ESTABELECIMENTO.LOGO, ESTABELECIMENTO.C_MENSAGEMPEDIDO
  from ESTSIN
  inner join CADASTROPARCEIROS on (CADASTROPARCEIROS.CADASTRO = ESTSIN.ESTABELECIMENTO)
  inner join ESTABELECIMENTO on (ESTABELECIMENTO.CADASTRO = ESTSIN.ESTABELECIMENTO)
  inner join USUARIO on (USUARIO.USUARIO = ESTSIN.USUARIO)
  where ESTSIN.RELATORIO = :RELATORIO
  into :FILIAL, :RAZAOFILIAL, :NOMEFILIAL, :DOCUMENTOFILIAL, :INSCESTADUALFILIAL, :INSCMUNICIPALFILIAL,
       :LOGRADOUROFILIAL, :NUMEROFILIAL, :COMPLEMENTOFILIAL, :BAIRROFILIAL, :CIDADEFILIAL, :UFFILIAL, :CEPFILIAL,
       :TELEFONEFILIAL, :TELEFONECOMERCIALFILIAL, :FAXFILIAL, :PRINCIPALCONTATOFILIAL, :EMAILFILIAL, :WEBFILIAL,
       :PIDINICIAL, :PIDFINAL, :NOMEUSUARIO, :TELEFONEUSUARIO, :FAXUSUARIO, :EMAILUSUARIO, :DEPARTAMENTOUSUARIO,
       :CARGOUSUARIO, :LOGO, MENSAGEMPEDIDO;

  for select PEDIDO.IDNOTA, PEDIDO.NUMERONOTA, PEDIDO.DATAEMISSAO, PEDIDO.DATACADASTRO, CADASTROPARCEIROS.RAZAOSOCIAL,
             CADASTROPARCEIROS.NOME, CADASTROPARCEIROS.LOGRADOURO, CADASTROPARCEIROS.NUMERO,
             CADASTROPARCEIROS.COMPLEMENTO, CADASTROPARCEIROS.BAIRRO, CADASTROPARCEIROS.CIDADE, CADASTROPARCEIROS.UF,
             substring(CADASTROPARCEIROS.CEP from 1 for 5) || '-' || substring(CADASTROPARCEIROS.CEP from 6 for 3),
             case
               when (CADASTROPARCEIROS.DOCUMENTO <> '') and (not CADASTROPARCEIROS.DOCUMENTO is null) then case CADASTROPARCEIROS.TIPOPESSOA
                                                                                                             when 'F' then cast(substring(CADASTROPARCEIROS.DOCUMENTO from 1 for 3) || '.' || substring(CADASTROPARCEIROS.DOCUMENTO from 4 for 3) || '.' || substring(CADASTROPARCEIROS.DOCUMENTO from 7 for 3) || '-' || substring(CADASTROPARCEIROS.DOCUMENTO from 10 for 2) as varchar(18))
                                                                                                             when 'J' then cast(substring(CADASTROPARCEIROS.DOCUMENTO from 1 for 2) || '.' || substring(CADASTROPARCEIROS.DOCUMENTO from 3 for 3) || '.' || substring(CADASTROPARCEIROS.DOCUMENTO from 6 for 3) || '/' || substring(CADASTROPARCEIROS.DOCUMENTO from 9 for 4) || '-' || substring(CADASTROPARCEIROS.DOCUMENTO from 13 for 2) as varchar(18))
                                                                                                             else null
                                                                                                           end
               else null
             end as DOCUMENTO,
             CADASTROPARCEIROS.INSCESTADUAL, CADASTROPARCEIROS.INSCMUNICIPAL,
             case
               when coalesce(PEDIDO.EMAIL, '') <> '' then PEDIDO.EMAIL
               else CADASTROPARCEIROS.EMAIL
             end,
             CADASTROPARCEIROS.TELEFONE, CADASTROPARCEIROS.TELEFONECOMERCIAL, CADASTROPARCEIROS.CELULAR,
             CADASTROPARCEIROS.FAX,
             case
               when coalesce(PEDIDO.CONTATO, '') <> '' then PEDIDO.CONTATO
               else CADASTROPARCEIROS.PRINCIPALCONTATO
             end,
             COALESCE  (CADASTROPARCEIROS.C_NAOPAGINAESTRUTURA,'N'),

             PEDIDO.LOGRADOUROENTREGA, PEDIDO.NUMEROENTREGA,
             PEDIDO.COMPLEMENTOENTREGA, PEDIDO.BAIRROENTREGA, PEDIDO.CIDADEENTREGA, PEDIDO.UFENTREGA,
             substring(PEDIDO.CEPENTREGA from 1 for 5) || '-' || substring(PEDIDO.CEPENTREGA from 6 for 3),
             USUARIO.NOMECOMPLETO, USUARIO.TELEFONE, USUARIO.FAX, USUARIO.EMAIL, USUARIO.DEPARTAMENTO, USUARIO.CARGO,
             PEDIDO.CFOP, PEDIDO.NATUREZAOPERACAO, TIPOCOBRANCA.DESCRICAO, CONDICAOPAGAMENTO.DESCRICAO,
             PEDIDO.VLRDESCMERCADORIAS, PEDIDO.MSGDESCMERCADORIAS, PEDIDO.VLRDESCINDPRODUTO, PEDIDO.MSGDESCPRODUTOS,
             PEDIDO.VLRACRESCMERCAD, PEDIDO.MSGACRESCMERCADORIA, PEDIDO.VLRFINALMERCADORIAS,
             case PEDIDO.ZONAFRANCA
               when 'S' then 0
               else PEDIDO.TOTVALORICMS
             end,
             case PEDIDO.ZONAFRANCA
               when 'N' then 0
               else PEDIDO.TOTVALORICMS
             end,
             PEDIDO.VALORIPI, PEDIDO.VLRICMSRECOLHIDO, PEDIDO.VALORFRETE, PEDIDO.VALORSEGURO,
             PEDIDO.VLROUTDESPACESSORIA, coalesce(PEDIDO.VLRFINALSERVICOS, 0), PEDIDO.VLRTOTALNOTA, PEDIDO.CODIGOTRANSP,
             PEDIDO.QUANTIDADEVOLUME, PEDIDO.PESOLIQUIDO, PEDIDO.PESOBRUTO,
             case PEDIDO.FRETE
               when 'R' then 'CIF'
               else 'FOB'
             end,
             PEDIDO.MSGDADOSADICIONAIS, PEDIDO.COMENTARIO, PEDIDO.OBSERVACAO, PEDIDO.NUMPEDIDOCLIENTE,
             PEDIDO.MSGDESCRMERCADORIAS, PEDIDO.VLRDESCINDSERVICOS, PEDIDO.VLRACRESCSERVICOS, PEDIDO.VLRDESCSERVICOS,
             PEDIDO.MSGDESCINDSERVICOS, PEDIDO.MSGDESCSERVICOS, coalesce(PEDIDO.VLRFINALSERVICOS, 0),
             PEDIDO.MSGACRESCSERVICOS, PEDIDO.MSGDESCRSERVICOS, PEDIDO.DESTINATARIO, coalesce(PEDIDO.PREDUCAOIPI, 0),
             PEDIDO.OPERACAO, coalesce(PEDIDO.DATAREFERENCIA, PEDIDO.DATACADASTRO) as DATAREFERENCIA, pedido.c_novorepeticaoalterado
      from PEDIDO

      inner join CADASTROPARCEIROS on (PEDIDO.DESTINATARIO = CADASTROPARCEIROS.CADASTRO)
      left join TIPOCOBRANCA on (TIPOCOBRANCA.TIPOCOBRANCA = PEDIDO.TIPOCOBRANCA)
      left join CONDICAOPAGAMENTO on (CONDICAOPAGAMENTO.ID = PEDIDO.CONDICAOPAGAMENTO)
      left join USUARIO on (PEDIDO.USUARIOEMISSAO = USUARIO.USUARIO)
      where PEDIDO.FILIAL = :FILIAL and
            PEDIDO.IDNOTA between :PIDINICIAL and :PIDFINAL and
            PEDIDO.DATACANCELAMENTO is null
      into :IDNOTA, :NUMEROPEDIDO, :DATAEMISSAO, :DATACADASTRO, :RAZAO, :NOME, :LOGRADOURO, :NUMERO, :COMPLEMENTO,
           :BAIRRO, :CIDADE, :UF, :CEP, :DOCUMENTO, :INSCESTADUAL, :INSCMUNICIPAL, :EMAIL, :TELEFONE,
           :TELEFONECOMERCIAL, :CELULAR, :FAX, :PRINCIPALCONTATO, :C_NAOPAGINAESTRUTURA, :LOGRADOUROENTREGA,
           :NUMEROENTREGA, :COMPLEMENTOENTREGA, :BAIRROENTREGA, :CIDADEENTREGA, :UFENTREGA, :CEPENTREGA,
           :NOMEUSUARIOAPROVACAO, :TELEFONEUSUARIOAPROVACAO, :FAXUSUARIOAPROVACAO, :EMAILUSUARIOAPROVACAO,
           :DEPARTAMENTOUSUARIOAPROVACAO, :CARGOUSUARIOAPROVACAO, :CFOP, :NATUREZAOPERACAO, :TIPOPAGTO, :CONDICAOPAGTO,
           :VLRDESCONTO, :MSGDESCMERCADORIAS, :VLRDESCINDPRODUTO, :MSGDESCPRODUTOS, :VLRACRESCIMO, :MSGACRESCMERCADORIA,
           :VLRMERCADORIAS, :VLRICMS, :VLRZONAFRANCA, :VLRIPITOTAL, :VLRSUBSTRIB, :VLRFRETE, :VLRSEGURO, :VLRDESPESAS,
           :VLRSERVICO, :VLRTOTAPEDIDO, :CODTRANSP, :QTDEVOLUME, :PESOLIQUIDO, :PESOBRUTO, :TIPOFRETE, :MSGADICIONAL,
           :COMENTARIO, :OBSERVACAO, :SEUNUMERO, :MSGDESCRMERCADORIAS, :VLRDESCINDSERVICOS, :VLRACRESCSERVICOS,
           :VLRDESCSERVICOS, :MSGDESCINDSERVICOS, :MSGDESCSERVICOS, :VLRFINALSERVICOS, :MSGACRESCSERVICOS,
           :MSGDESCRSERVICOS, :DESTINATARIO, :PPREDUCAOIPI, :POPERACAO, :PDATAREFERENCIA, :p_novorepeticaoalterado

  do
  begin
    statuspedido = case :p_novorepeticaoalterado
                        when 'N' then '***NOVO***'
                        when 'R' then '***REPETI??O SEM ALTERA??O***'
                        when 'A' then '***REPETI??O COM ALTERA??O***'
                   end;
    PDATAHOJE = cast(PDATAREFERENCIA as timestamp);
    DIAHOJE = extract(day from PDATAREFERENCIA);
    ANOHOJE = extract(year from PDATAREFERENCIA);
    MESHOJEEXTENSO = case extract(month from PDATAREFERENCIA)
                       when 1 then 'Janeiro'
                       when 2 then 'Fevereiro'
                       when 3 then 'Mar?o'
                       when 4 then 'Abril'
                       when 5 then 'Maio'
                       when 6 then 'Junho'
                       when 7 then 'Julho'
                       when 8 then 'Agosto'
                       when 9 then 'Setembro'
                       when 10 then 'Outubro'
                       when 11 then 'Novembro'
                       when 12 then 'Dezembro'
                     end;

    select REDUCAOESTADO.PREDUCAO, REDUCAOESTADO.MENSAGEM
    from PEDIDO
    inner join NATUREZAOPERACAO on (PEDIDO.OPERACAO = NATUREZAOPERACAO.ID)
    inner join REDUCAOESTADO on (REDUCAOESTADO.ID = NATUREZAOPERACAO.REDUCAOICMS)
    where PEDIDO.FILIAL = :FILIAL and
          PEDIDO.IDNOTA = :IDNOTA
    into :PREDUCAO, :REDUCAOESTADOMENSAGEM;

    if (coalesce(PREDUCAO, 0) <> 0) then
      MENSAGEMREUDCAOICMS = 'REDU??O DE BASE DO ICMS EM ' || cast(PREDUCAO as numeric(3,2)) || '%';

    select NATUREZAOPERACAO.FATURA
    from NATUREZAOPERACAO
    where NATUREZAOPERACAO.ID = :POPERACAO
    into :PFATURA;

    if (coalesce(:LOGRADOUROENTREGA, '') = '') then
    begin
      LOCALENTREGA = 'O MESMO';
      LOGRADOUROENTREGA = LOGRADOURO;
      NUMEROENTREGA = NUMERO;
      COMPLEMENTOENTREGA = COMPLEMENTO;
      BAIRROENTREGA = BAIRRO;
      CIDADEENTREGA = CIDADE;
      UFENTREGA = UF;
      CEPENTREGA = CEP;
    end
    else
      LOCALENTREGA = coalesce(LOGRADOUROENTREGA, '') || ', ' || coalesce(NUMEROENTREGA, '') || ' ' || coalesce(COMPLEMENTOENTREGA, '') || ' ' || coalesce(BAIRROENTREGA, '') || ' ' || coalesce(CIDADEENTREGA, '') || ' ' || coalesce(UFENTREGA, '');

    select CLIENTES.LOGRADOUROCOBRANCA, CLIENTES.NUMEROCOBRANCA, CLIENTES.COMPLEMENTOCOBRANCA, CLIENTES.BAIRROCOBRANCA,
           CLIENTES.CIDADECOBRANCA, CLIENTES.UFCOBRANCA,
           substring(CLIENTES.CEPCOBRANCA from 1 for 5) || '-' || substring(CLIENTES.CEPCOBRANCA from 6 for 3)
    from CLIENTES
    where CLIENTES.CADASTRO = :DESTINATARIO
    into :LOGRADOUROCOBRANCA, :NUMEROCOBRANCA, :COMPLEMENTOCOBRANCA, :BAIRROCOBRANCA, :CIDADECOBRANCA, :UFCOBRANCA,
         :CEPCOBRANCA;
    if (coalesce(:LOGRADOUROCOBRANCA, '') = '') then
    begin
      LOCALCOBRANCA = 'O MESMO';
      LOGRADOUROCOBRANCA = LOGRADOURO;
      NUMEROCOBRANCA = NUMERO;
      COMPLEMENTOCOBRANCA = COMPLEMENTO;
      BAIRROCOBRANCA = BAIRRO;
      CIDADECOBRANCA = CIDADE;
      UFCOBRANCA = UF;
      CEPCOBRANCA = CEP;
    end
    else
      LOCALCOBRANCA = LOGRADOUROCOBRANCA || ', ' || NUMEROCOBRANCA || ' ' || COMPLEMENTOCOBRANCA || ' ' || BAIRROCOBRANCA || ' ' || CIDADECOBRANCA || ' ' || UFCOBRANCA || ' ' || CEPCOBRANCA;
    select first 1 VENDEDORESPED.VENDEDOR, CADASTROPARCEIROS.RAZAOSOCIAL, CADASTROPARCEIROS.NOME,
                   CADASTROPARCEIROS.TELEFONE, CADASTROPARCEIROS.CELULAR, CADASTROPARCEIROS.TELEFONECOMERCIAL,
                   CADASTROPARCEIROS.FAX, CADASTROPARCEIROS.EMAIL
    from VENDEDORESPED
    inner join CADASTROPARCEIROS on (CADASTROPARCEIROS.CADASTRO = VENDEDORESPED.VENDEDOR)
    where VENDEDORESPED.FILIAL = :FILIAL and
          VENDEDORESPED.IDNOTA = :IDNOTA
    into :VENDEDOR, :RAZAOVENDEDOR, :NOMEVENDEDOR, :TELEFONEVENDEDOR, :CELULARVENDEDOR, :TELEFONECOMERCIALVENDEDOR,
         :FAXVENDEDOR, :EMAILVENDEDOR;

    select USUARIO.NOMECOMPLETO, USUARIO.TELEFONE, USUARIO.FAX, USUARIO.EMAIL, USUARIO.DEPARTAMENTO, USUARIO.CARGO
    from VENDEDOR
    inner join USUARIO on (VENDEDOR.USUARIORELACIONADO = USUARIO.ID)
    where VENDEDOR.CADASTRO = :VENDEDOR
    into :NOMEUSUARIOAPROVACAO, :TELEFONEUSUARIOAPROVACAO, :FAXUSUARIOAPROVACAO, :EMAILUSUARIOAPROVACAO,
         :DEPARTAMENTOUSUARIOAPROVACAO, :CARGOUSUARIOAPROVACAO;

    select CADASTROPARCEIROS.NOME, CADASTROPARCEIROS.RAZAOSOCIAL, CADASTROPARCEIROS.TELEFONE,
           CADASTROPARCEIROS.TELEFONECOMERCIAL, CADASTROPARCEIROS.CELULAR, CADASTROPARCEIROS.EMAIL,
           CADASTROPARCEIROS.PRINCIPALCONTATO
    from CADASTROPARCEIROS
    where CADASTROPARCEIROS.CADASTRO = :CODTRANSP
    into :NOMETRANSP, :RAZAOTRANSP, :FONETRANSP, :COMERCIALTRANSP, :CELULARTRANSP, :EMAILTRANSP, :NOMECONTATOTRANSP;

    select min(PRAZOMERCPED.DIAS) + :DATACADASTRO
    from PRAZOMERCPED
    inner join MERCADORIASPED on (MERCADORIASPED.FILIAL = PRAZOMERCPED.FILIAL and
          MERCADORIASPED.IDNOTA = PRAZOMERCPED.IDNOTA and
          MERCADORIASPED.IDMERCADORIA = PRAZOMERCPED.IDITEM)
    where PRAZOMERCPED.FILIAL = :FILIAL and
          PRAZOMERCPED.IDNOTA = :IDNOTA
    into :DETALHEENTREGA;

    select MIN ( mercadoriasped.idmercadoria )
    from MERCADORIASPED
    where MERCADORIASPED.filial = :FILIAL and
          MERCADORIASPED.IDNOTA = :IDNOTA
          into:P_IDMERCPEDIDO ;

    if (:VLRSERVICO > 0) then
    begin
      select min(PRAZOMERCPED.DIAS) + :DATACADASTRO
      from PRAZOSERVPED PRAZOMERCPED
      inner join SERVICOSPED MERCADORIASPED on (MERCADORIASPED.FILIAL = PRAZOMERCPED.FILIAL and
            MERCADORIASPED.IDNOTA = PRAZOMERCPED.IDNOTA and
            MERCADORIASPED.IDSERVICO = PRAZOMERCPED.IDITEM)
      where PRAZOMERCPED.FILIAL = :FILIAL and
            PRAZOMERCPED.IDNOTA = :IDNOTA
      into :DETALHEENTREGA;
    end

    DETALHECF = '';
    for select distinct CLASSIFICACAOFISCAL.CFISCAL, CLASSIFICACAOFISCAL.DESCRICAO, cast(CLASSIFICACAOFISCAL.ALIQUOTA as decimal(2,2))

        from MERCADORIASPED
        inner join CLASSIFICACAOFISCAL on (MERCADORIASPED.CLASSIFISCAL = CLASSIFICACAOFISCAL.CFISCAL)
        where MERCADORIASPED.FILIAL = :FILIAL and
              MERCADORIASPED.IDNOTA = :IDNOTA
        into :PCODCF, :PCF, :PPIPI
    do
    begin
      if (VLRIPITOTAL <> 0) then
      begin
        if (DETALHECF <> '') then
          DETALHECF = substring(DETALHECF || '
' from 1 for 400);
        DETALHECF = substring(DETALHECF || PCODCF || ' - ' || PCF from 1 for 400);
        if (PPIPI > 0) then
          DETALHECF = substring(DETALHECF || ' IPI ' || PPIPI || '% ' from 1 for 400);
      end
      else
        DETALHECF = 'ISENTO';
    end

    ORDEM = 0;
    PVLRTOTAL = 0;
    PQTDITEM = 0;
    for select MERCADORIASPED.IDMERCADORIA, MERCADORIASPED.CODIGO, MERCADORIASPED.DESCRICAO, MERCADORIASPED.DESREDUZIDA,
               MERCADORIASPED.QUANTIDADE, MERCADORIASPED.UNIDADE, MERCADORIASPED.PRECOUNITARIO,
               MERCADORIASPED.PRECOLISTA, MERCADORIASPED.PIPI, MERCADORIASPED.VALORIPI, MERCADORIASPED.VLRTOTALMERCAD,
               MERCADORIASPED.ALIQUOTAICMS, MERCADORIASPED.CLASSIFISCAL,
               coalesce(C_GRAMATURATOTAL, 0) as GRAMATURATOTAL, ITEMDESCRICAO.C_IMPRESSAO

        from MERCADORIASPED
        inner join ITEMESTOQUE ITEMDESCRICAO on (ITEMDESCRICAO.CODIGO = MERCADORIASPED.CODIGO)
        where MERCADORIASPED.FILIAL = :FILIAL and
              MERCADORIASPED.IDNOTA = :IDNOTA
        order by MERCADORIASPED.IDMERCADORIA
        into :IDITEM, :CODIGO, :DESCRICAO, :DESCRICAOREDUZIDA, :QUANTIDADE, :UNIDADE, :PRUNITARIO, :PRLISTA, :PIPIMERC,
             :VLRIPIMERC, :VLRTOTITEM, :PICMS, :CODCF, :C_GRAMATURATOTAL, C_IMPRESSAO

    do
    begin

      if (iditem=P_IDMERCPEDIDO) then
            P_CODIGOPRODUTO = :CODIGO;

      C_DESCRICAOREDUZIDA = DESCRICAOREDUZIDA;

      suspend;
    end

    IDITEM = null;
    CODIGO = null;
    DESCRICAO = null;
    DESCRICAOREDUZIDA = null;
    C_GRAMATURATOTAL = null;
    QUANTIDADE = null;
    UNIDADE = null;
    PRUNITARIO = null;
    PRLISTA = null;
    PIPIMERC = null;
    VLRIPIMERC = null;
    VLRTOTITEM = null;
    PICMS = null;
    CODCF = null;
    CF = null;

    ORDEM = ORDEM + 1;
    if (coalesce(:VLRDESCINDPRODUTO, 0) + coalesce(:VLRDESCONTO, 0) + coalesce(VLRACRESCIMO, 0) > 0) then
    begin
      if (PQTDITEM > 1) then
      begin
        ORDEM = 100;
        DESCRICAOTOTAL = 'SUBTOTAL DAS MERCADORIAS';
        VLRTOTITEM = PVLRTOTAL;
        suspend;
      end
      DESCRICAOTOTAL = '';
      ORDEM = 101;
      if (VLRDESCINDPRODUTO > 0) then
      begin
        if (coalesce(MSGDESCPRODUTOS, '') = '') then
          DESCRICAODETALHE = 'DESCONTO INDIVIDUAL';
        else
          DESCRICAODETALHE = MSGDESCPRODUTOS;
        VLRTOTITEM = VLRDESCINDPRODUTO * (-1);
        suspend;
      end
      if (VLRDESCONTO > 0) then
      begin
        if (coalesce(MSGDESCMERCADORIAS, '') = '') then
          DESCRICAODETALHE = 'DESCONTO MERCADORIAS';
        else
          DESCRICAODETALHE = MSGDESCMERCADORIAS;
        VLRTOTITEM = VLRDESCONTO * (-1);
        suspend;
      end
      if (VLRACRESCIMO > 0) then
      begin
        if (coalesce(MSGACRESCMERCADORIA, '') = '') then
          DESCRICAODETALHE = 'ACR?SCIMO MERCADORIAS';
        else
          DESCRICAODETALHE = MSGACRESCMERCADORIA;
        VLRTOTITEM = VLRACRESCIMO;
        suspend;
      end
      DESCRICAODETALHE = '';
    end

    if (coalesce(VLRIPITOTAL, 0) + coalesce(VLRZONAFRANCA, 0) + coalesce(VLRSUBSTRIB, 0) + coalesce(VLRFRETE, 0) + coalesce(VLRSEGURO, 0) + coalesce(VLRDESPESAS, 0) > 0) then
    begin
      ORDEM = 200;
      if (VLRMERCADORIAS > 0) then
        DESCRICAOTOTAL = 'TOTAL MERCADORIAS';
      VLRTOTITEM = :VLRMERCADORIAS;

      suspend;
      DESCRICAOTOTAL = '';
      ORDEM = 201;
      if (VLRIPITOTAL > 0) then
      begin
        DESCRICAODETALHE = 'TOTAL DO IPI';
        VLRTOTITEM = VLRIPITOTAL;
        suspend;
      end
      if (VLRZONAFRANCA > 0) then
      begin
        DESCRICAODETALHE = 'DESCONTO ZONA FRANCA';
        VLRTOTITEM = VLRZONAFRANCA * (-1);
        suspend;
      end
      if (VLRSUBSTRIB > 0) then
      begin
        DESCRICAODETALHE = 'SUBSTITUI??O TRIBUT?RIA';
        VLRTOTITEM = VLRSUBSTRIB;
        suspend;
      end

      if (VLRFRETE > 0) then
      begin
        DESCRICAODETALHE = 'FRETE';
        VLRTOTITEM = VLRFRETE;
        suspend;
      end
      if (:VLRSEGURO > 0) then
      begin
        DESCRICAODETALHE = 'SEGURO';
        VLRTOTITEM = VLRSEGURO;
        suspend;
      end
      if (:VLRDESPESAS > 0) then
      begin
        DESCRICAODETALHE = 'OUTRAS DESPESAS ACESSORIAS';
        VLRTOTITEM = VLRDESPESAS;
        suspend;
      end
      DESCRICAODETALHE = '';
    end

    ORDEM = 0;
    PVLRTOTAL = 0;
    PQTDITEM = 0;
    for select SERVICOSPED.IDSERVICO, cast(SERVICOSPED.CODIGO as varchar(15)), SERVICOSPED.DESCRICAO,
               SERVICOSPED.DESREDUZIDA, coalesce(SERVICOSPED.QUANTIDADE, 0), SERVICOSPED.UNIDADE,
               SERVICOSPED.PRECOUNITARIO, SERVICOSPED.PRECOLISTA, SERVICOSPED.VLRTOTSERVICO
        from SERVICOSPED
        where SERVICOSPED.FILIAL = :FILIAL and
              SERVICOSPED.IDNOTA = :IDNOTA
        order by SERVICOSPED.IDSERVICO
        into :IDITEM, :CODIGO, :DESCRICAO, :DESCRICAOREDUZIDA, :QUANTIDADE, :UNIDADE, :PRUNITARIO, :PRLISTA,
             :VLRTOTITEM
    do
    begin
      PVLRTOTAL = PVLRTOTAL + VLRTOTITEM;
      PQTDITEM = PQTDITEM + 1;

      suspend;
    end

    IDITEM = null;
    CODIGO = null;
    DESCRICAO = null;
    DESCRICAOREDUZIDA = null;
    QUANTIDADE = null;
    UNIDADE = null;
    PRUNITARIO = null;
    PRLISTA = null;
    VLRTOTITEM = null;
    ORDEM = ORDEM + 1;
    DESCRICAODETALHE = '';

       if (msgdescrservicos is not null) then begin
         descricaodetalhe = msgdescrservicos;
       suspend;
       end

    DESCRICAODETALHE = '';
    if (coalesce(:VLRDESCINDSERVICOS, 0) + coalesce(:VLRDESCSERVICOS, 0) + coalesce(:VLRACRESCSERVICOS, 0) > 0) then
    begin
      if (PQTDITEM > 1) then
      begin
        ORDEM = 100;
        DESCRICAOTOTAL = 'SUBTOTAL DOS SERVI?OS';
        VLRTOTITEM = PVLRTOTAL;
        suspend;
      end
      DESCRICAOTOTAL = '';
      ORDEM = 101;
      if (:VLRDESCINDSERVICOS > 0) then
      begin
        if (coalesce(MSGDESCINDSERVICOS, '') = '') then
          DESCRICAODETALHE = 'DESCONTO INDIVIDUAL';
        else
          DESCRICAODETALHE = MSGDESCINDSERVICOS;
        VLRTOTITEM = VLRDESCINDSERVICOS * (-1);
        suspend;
      end
      if (VLRDESCSERVICOS > 0) then
      begin
        if (coalesce(MSGDESCSERVICOS, '') = '') then
          DESCRICAODETALHE = 'DESCONTO SERVI?OS';
        else
          DESCRICAODETALHE = MSGDESCSERVICOS;
        VLRTOTITEM = VLRDESCSERVICOS * (-1);
        suspend;
      end
      if (VLRACRESCSERVICOS > 0) then
      begin
        if (coalesce(MSGACRESCSERVICOS, '') = '') then
          DESCRICAODETALHE = 'ACR?SCIMO SERVI?OS';
        else
          DESCRICAODETALHE = MSGACRESCSERVICOS;
        VLRTOTITEM = VLRACRESCSERVICOS;
        suspend;
      end
      DESCRICAODETALHE = '';
    end

    if (:VLRSERVICO > 0) then
    begin
      DESCRICAODETALHE = 'TOTAL DE SERVI?OS';
      VLRTOTITEM = VLRSERVICO;
      suspend;
    end
    DESCRICAODETALHE = '';

    DESCRICAOTOTAL = '**** TOTAL DO PEDIDO';
    VLRTOTITEM = :VLRTOTAPEDIDO;

    suspend;
    DESCRICAOTOTAL = '';

  end

  ---PARTE DO POUCH, LAMINA??O E PERSONALIZADAS

  VLRTOTITEM = null;
  P_ORDEM = 0;
  P_FILME = '';

  for select ITEMESTOQUEPRODUTO.C_MATERIAPRIMABASE, coalesce(ITEMESTOQUEPRODUTO.C_PESOPOREMBALAGEM, 0),
             coalesce(ITEMESTOQUEPRODUTO.C_POUCHE, 'N'), coalesce(ITEMESTOQUEPRODUTO.C_LARGURAFINAL, 0),
             coalesce(ITEMESTOQUEPRODUTO.C_PASSO, 0), coalesce(ITEMESTOQUEPRODUTO.C_PISTAS, 0),
             coalesce(ITEMESTOQUEPRODUTO.C_LARGURAMATERIAPRIMA, 0),
             case(coalesce(ITEMESTOQUEPRODUTO.C_POUCHE, 'N'))
               when 'N' then ''
               else 'Dimens?es: ' || ITEMESTOQUEPRODUTO.C_LARGURAFINAL || ' mm x ' || ITEMESTOQUEPRODUTO.C_PASSO || ' mm '
             end as P_DESCTAMANHOPOUCHE,
             ITEMESTOQUEESTRUTURA.CODIGO, coalesce(ITEMESTOQUEESTRUTURA.C_GRAMATURA, 0),
             coalesce(ITEMESTOQUEPRODUTO.C_GRAMATURATOTAL, 0), ITEMESTOQUEESTRUTURA.DESCRICAO,
             coalesce(ITEMESTOQUEESTRUTURA.C_DESCRICAOREDUZIDA, '') as NOMECOMERICAL,
             coalesce(C_LAMINACAO.GRAMATURAFILME,ITEMESTOQUEPRODUTO.C_GRAMATURA),
             coalesce(C_LAMINACAO.GRAMATURAADESIVO, 0), C_LAMINACAO.FILME,
             C_LAMINACAO.ADESIVO, ITEMESTOQUELAMINACAO.CODIGO,
             coalesce(ITEMESTOQUELAMINACAO.DESCRICAO,ITEMESTOQUEESTRUTURA.DESCRICAO),
             ITEMESTOQUEPRODUTO.C_PESOBOBINA, ITEMESTOQUEPRODUTO.c_tubeteacabamento, ITEMESTOQUEPRODUTO.C_DIAMETROBOBINA,
             ITEMESTOQUEPRODUTO.c_sentidobobinamentoacabamento, C_LAMINACAO.SEQUENCIA,
             coalesce (itemestoquebase.descricao,ITEMESTOQUEPRODUTO.DESCRICAO),
             itemestoqueproduto.c_gramatura,
             itemestoqueproduto.C_GRAMATURATINTA

      from   ITEMESTOQUE ITEMESTOQUEPRODUTO

      left join C_LAMINACAO  on (C_LAMINACAO.CODIGO = ITEMESTOQUEPRODUTO.CODIGO)
      left join ITEMESTOQUE ITEMESTOQUEESTRUTURA on (ITEMESTOQUEPRODUTO.ITEMBASE = ITEMESTOQUEESTRUTURA.CODIGO)
      left join ITEMESTOQUE ITEMESTOQUELAMINACAO on (ITEMESTOQUELAMINACAO.CODIGO = C_LAMINACAO.FILME)
      left join ITEMESTOQUE ITEMESTOQUEbase on (ITEMESTOQUEbase.CODIGO = ITEMESTOQUEPRODUTO.c_materiaprimabase)

      where ITEMESTOQUEPRODUTO.CODIGO = :P_CODIGOPRODUTO

      into :P_MATERIAPRIMABASE, :P_PESOPOREMBALAGEM, :C_POUCHE, :P_LARGURAFINAL, :P_PASSO, :P_PISTAS,
           :P_LARGURAMATERIAPRIMA, :C_DESCTAMANHOPOUCHE, :P_CODIGOESTRUTURA, :P_GRAMATURAESTRUTURA, :P_GRAMATURATOTAL,
           :P_DESCRICAOESTRUTURA, :C_NOMECOMERCIAL, :P_GRAMATURAFILME, :P_GRAMATURAADESIVO, :P_FILME, :P_ADESIVO,
           :P_CODIGOLAMINACAO, :P_DESCRICAOLAMINACAO, :C_PESOBOBINA, :C_TUBETEIMPRESSAO, :C_DIAMETROBOBINA,
           :C_SENTIDOBOBINAMENTOIMPRESSAO, :C_SEQUENCIA, :p_descricaoitembase, :p_gramaturaitembase, :C_GRAMATURATINTA

  do
  begin



    select '(' || ITEMESTOQUE.C_FORNECEDORPOUCHE || ') - ' || CADASTROPARCEIROS.RAZAOSOCIAL, ITEMESTOQUE.C_POUCHE,
           ITEMESTOQUE.C_TIPOPOUCHE, ITEMESTOQUE.C_ALTURAPOUCHE, ITEMESTOQUE.C_LARGURAPOUCHE,
           ITEMESTOQUE.C_SANFONAFUNDO, ITEMESTOQUE.C_SANFONALATERAL, ITEMESTOQUE.C_PAINEISFV, ITEMESTOQUE.C_SOLDA,
           ITEMESTOQUE.C_LARGURAF, ITEMESTOQUE.C_CORTE1, ITEMESTOQUE.C_CORTE2, ITEMESTOQUE.C_CORTE3,
           ITEMESTOQUE.C_CORTE4,
           case(coalesce(ITEMESTOQUE.C_POUCHE, 'N'))
             when 'N' then ''
             else ITEMESTOQUE.C_LARGURAFINAL || ' mm x ' || ITEMESTOQUE.C_PASSO || ' mm '
           end as P_DESCTAMANHOPOUCHE

    from ITEMESTOQUE
    left join CADASTROPARCEIROS on (CADASTROPARCEIROS.CADASTRO = ITEMESTOQUE.C_FORNECEDORPOUCHE)
    where ITEMESTOQUE.CODIGO = :P_CODIGOPRODUTO
    into :C_FORNECEDORPOUCHE, :C_POUCHE, :C_TIPOPOUCHE, :C_ALTURAPOUCHE, :C_LARGURAPOUCHE, :C_SANFONAFUNDO,
         :C_SANFONALATERAL, :C_PAINEISFV, :C_SOLDA, :C_LARGURAF, :C_CORTE1, :C_CORTE2, :C_CORTE3, :C_CORTE4,
         :C_DESCTAMANHOPOUCHE;

    C_POUCHE=COALESCE(c_pouche,  'N');

    if (C_POUCHE = 'N') then
      C_TIPOPOUCHE = '';

    if (C_PAGINABANDA = '') then
    begin
      C_PAGINABANDA = 'S';
      suspend;
      C_PAGINABANDA = 'N';
    end

    if (P_ORDEM = 0 and
        C_NAOPAGINAESTRUTURA = 'N') then
    begin

      C_CODIGOLAMINACAO = P_CODIGOESTRUTURA;
      C_DESCRICAOLAMINACAO = p_descricaoitembase;
      C_GRAMATURALAMINIACAO = P_GRAMATURAitembase;

      for select C_ITEMESTOQUEXACABAMENTO.OBSERVACAO, C_ITEMESTOQUEXACABAMENTO.ACABAMENTO, C_ACABAMENTO.DESCRICAO
          from C_ITEMESTOQUEXACABAMENTO
          left join C_ACABAMENTO on (C_ACABAMENTO.ACABAMENTO = C_ITEMESTOQUEXACABAMENTO.ACABAMENTO)
          where C_ITEMESTOQUEXACABAMENTO.CODIGO = :P_CODIGOPRODUTO
          into :P_OBSACBAMENTOPOUCHE, :P_ACABAMENTOPOUCHE, :P_DESCACBAMENTOPOUCHE
      do
      begin
        if (C_DESCRICAOPOUCH = ' ') then
          C_DESCRICAOPOUCH = C_DESCRICAOPOUCH || P_DESCACBAMENTOPOUCHE;
        else
          C_DESCRICAOPOUCH = C_DESCRICAOPOUCH || ' / ' || P_DESCACBAMENTOPOUCHE;
      end
      select CLASSIFICACAOFISCAL.DESCRICAO
      from CLASSIFICACAOFISCAL
      where CLASSIFICACAOFISCAL.CFISCAL = :CODCF
      into :CF;
      PVLRTOTAL = PVLRTOTAL + VLRTOTITEM;
      PQTDITEM = PQTDITEM + 1;
      P_ORDEM = 1;

    end

    if (C_NAOPAGINAESTRUTURA = 'N' and
        C_SEQUENCIA = 0) then
      suspend;

    C_PASSO = P_PASSO;
    C_PISTAS = P_PISTAS;
    C_LARGURAFINAL = P_LARGURAFINAL;
    C_LARGURAMATERIAPRIMA = P_LARGURAMATERIAPRIMA;
    C_CODIGOLAMINACAO = P_CODIGOLAMINACAO;
    C_DESCRICAOLAMINACAO = P_DESCRICAOLAMINACAO;
    C_CODIGOESTRUTURA = P_CODIGOESTRUTURA;
    C_GRAMATURALAMINIACAO = P_GRAMATURAFILME;
    C_GRAMATURAESTRUTURA = P_GRAMATURAESTRUTURA;
    C_GRAMATURAQUIMICOS = C_GRAMATURAQUIMICOS + P_GRAMATURAADESIVO;
    C_GRAMATURATOTAL = P_GRAMATURATOTAL;

    if (C_NAOPAGINAESTRUTURA = 'N') then
      suspend;

    P_FILME = '';
  end
  if (C_NAOPAGINAESTRUTURA = 'S') then
  begin
    C_DESCRICAOLAMINACAO = coalesce(C_NOMECOMERCIAL, 'SEM NOME COMERCIAL');
    C_GRAMATURALAMINIACAO = P_GRAMATURATOTAL;
    suspend;
  end

  if (C_NAOPAGINAESTRUTURA = 'N') then
  begin
    C_DESCRICAOLAMINACAO = 'Q?imicos';
    C_CODIGOLAMINACAO = '';
    C_GRAMATURALAMINIACAO = C_GRAMATURAQUIMICOS;
    if (C_GRAMATURALAMINIACAO=0) then C_GRAMATURALAMINIACAO=C_GRAMATURATINTA;
    suspend;

    C_CODIGOLAMINACAO = '';
    C_DESCRICAOLAMINACAO = 'Gramatura Total';
    C_GRAMATURALAMINIACAO = P_GRAMATURATOTAL;
    suspend;
  end

end^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE IMPPED2 TO  SYSDBA;

