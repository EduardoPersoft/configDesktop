select 
    itemestoque.codigo,
    itemestoque.descricao,
    materiallote."DATA",
    materiallote.lote,
    materiallote.QUANTIDADE
FROM
    ITEMESTOQUE
inner JOIN
    materiallote on
        materiallote.filial=1 AND
        materiallote.iditem=itemestoque.CODIGO
inner JOIN
    locallote on
        locallote.FILIAL=materiallote.filial AND
        locallote.iditem=materiallote.iditem AND
        locallote.lote=materiallote.lote
WHERE
    materiallote.quantidade > 0.09 AND
    materiallote."DATA" < '01.01.2021'
order by
    ITEMESTOQUE.codigo