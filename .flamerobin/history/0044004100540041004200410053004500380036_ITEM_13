SET TERM ^ ;
alter PROCEDURE FLUXOCAIXAV
RETURNS (
    FILIAL integer,
    FILIALRAZAO varchar(60),
    VENCIMENTO timestamp,
    CONTACORRENTE integer,
    TIPOTRANSACAO smallint,
    TITULO varchar(10),
    FATURA varchar(2),
    PARCEIRO integer,
    PARCEIRORAZAO varchar(60),
    EMISSAO timestamp,
    RECEBIMENTOS double precision,
    PAGAMENTOS double precision,
    SALDOANTERIOR double precision,
    TIPO varchar(10),
    DESCRICAO varchar(40),
    DATAINICIAL timestamp,
    DATAFINAL timestamp )

AS
declare variable v_vencimentoanterior timestamp;
declare variable v_valoracumulado double precision;
BEGIN

SELECT ESTSIN.ESTABELECIMENTO,ESTSIN.datainicial,ESTSIN.DATAFINAL
FROM ESTSIN
WHERE ESTSIN.RELATORIO='FLUXOCAIXA'
INTO FILIAL,:DATAINICIAL,DATAFINAL ;

FOR SELECT TITULOREC.FILIAL,
        ESTAB.RAZAOSOCIAL AS FILIALRAZAO,
        TITULOREC.vencimento AS VENCIMENTO,
        TITULOREC.CONTACORRENTE,
        TITULOREC.TIPOTRANSACAO,
        TITULOREC.TITULO,
        TITULOREC.FATURA,
        TITULOREC.PARCEIRO,
        CLIFOR.RAZAOSOCIAL AS PARCEIRORAZAO,
        TITULOREC.EMISSAO,
        TITULOREC.VALOREMABERTO AS RECEBIMENTOS,
        CAST(0 AS DOUBLE PRECISION) AS PAGAMENTOS,
        0 AS SALDOANTERIOR,
        'R' AS TIPO,
        ESTSIN.DESCRICAO,
        ESTSIN.DATAINICIAL,
        ESTSIN.DATAFINAL
   FROM TITULOREC
   INNER JOIN ESTSIN ON (ESTSIN.ESTABELECIMENTO=TITULOREC.FILIAL AND
                     (TITULOREC.vencimento BETWEEN ESTSIN.DATAINICIAL AND ESTSIN.DATAFINAL) AND
                      ESTSIN.RELATORIO='FLUXOCAIXA')
   INNER JOIN CADASTROPARCEIROS ESTAB ON (ESTAB.CADASTRO=TITULOREC.FILIAL)
   INNER JOIN CADASTROPARCEIROS CLIFOR ON (TITULOREC.PARCEIRO=CLIFOR.CADASTRO)
   INNER JOIN RCONTACORRENTE ON (RCONTACORRENTE.CONTACORRENTE=TITULOREC.CONTACORRENTE AND
                              RCONTACORRENTE.RELATORIO='FLUXOCAIXA')
   INNER JOIN RTIPOCOBRANCA ON (RTIPOCOBRANCA.TIPOTRANSACAO=TITULOREC.TIPOTRANSACAO AND
                             RTIPOCOBRANCA.RELATORIO='FLUXOCAIXA')
   WHERE TITULOREC.BAIXA IS NULL
 INTO :FILIAL,
      :FILIALRAZAO,
      :VENCIMENTO,
      :CONTACORRENTE,
      :TIPOTRANSACAO,
      :TITULO,
      :FATURA,
      :PARCEIRO,
      :PARCEIRORAZAO,
      :EMISSAO,
      :RECEBIMENTOS,
      :PAGAMENTOS,
      :SALDOANTERIOR,
      :TIPO,
      :DESCRICAO,
      :DATAINICIAL,
      :DATAFINAL
      DO
      SUSPEND;


V_VENCIMENTOANTERIOR=DATAINICIAL-1;

FOR SELECT P1.FILIAL,
           ESTAB.RAZAOSOCIAL AS FILIALRAZAO,
           CAST(P1.VENCIMENTO AS TIMESTAMP) AS VENCIMENTO,
           CAST(0 AS INTEGER) AS CONTACORRENTE,
           CAST(0 AS SMALLINT) AS TIPOTRANSACAO,
           CAST('PREVISĂO ' AS VARCHAR(10)) AS TITULO,
           CAST('' AS VARCHAR(2)) AS FATURA,
           CAST(0 AS INTEGER) AS PARCEIRO,
           CAST('PREVISĂO ' AS VARCHAR(50)) AS PARCEIRORAZAO,
           ESTSIN.DATAINICIAL AS EMISSAO,
           P1.valor,
           CAST(0 AS DOUBLE PRECISION) AS PAGAMENTOS,
           0 AS SALDOANTERIOR, 'R' AS TIPO,
           ESTSIN.DESCRICAO,
           ESTSIN.DATAINICIAL,
           ESTSIN.DATAFINAL

           FROM PROVISAOREC P1
INNER JOIN ESTSIN ON (ESTSIN.ESTABELECIMENTO=PROVISAOREC.FILIAL AND
                     (PROVISAOREC.VENCIMENTO BETWEEN ESTSIN.DATAINICIAL AND ESTSIN.DATAFINAL) AND
                      ESTSIN.RELATORIO='FLUXOCAIXA')
INNER JOIN CADASTROPARCEIROS ESTAB ON (ESTAB.CADASTRO=PROVISAOREC.FILIAL)
INTO :FILIAL,
      :FILIALRAZAO,
      :VENCIMENTO,
      :CONTACORRENTE,
      :TIPOTRANSACAO,
      :TITULO,
      :FATURA,
      :PARCEIRO,
      :PARCEIRORAZAO,
      :EMISSAO,
      :RECEBIMENTOS,
      :PAGAMENTOS,
      :SALDOANTERIOR,
      :TIPO,
      :DESCRICAO,
      :DATAINICIAL,
      :DATAFINAL
      DO begin
    SELECT SUM(TITULOREC.VALOREMABERTO)
         FROM TITULOREC
         INNER JOIN ESTSIN ON (ESTSIN.ESTABELECIMENTO=TITULOREC.FILIAL AND
                     (TITULOREC.vencimento BETWEEN ESTSIN.DATAINICIAL AND ESTSIN.DATAFINAL)
         AND
                      ESTSIN.RELATORIO='FLUXOCAIXA')
         INNER JOIN CADASTROPARCEIROS ESTAB ON (ESTAB.CADASTRO=TITULOREC.FILIAL)
         INNER JOIN CADASTROPARCEIROS CLIFOR ON (TITULOREC.PARCEIRO=CLIFOR.CADASTRO)
         INNER JOIN RCONTACORRENTE ON (RCONTACORRENTE.CONTACORRENTE=TITULOREC.CONTACORRENTE AND
                              RCONTACORRENTE.RELATORIO='FLUXOCAIXA')
         INNER JOIN RTIPOCOBRANCA ON (RTIPOCOBRANCA.TIPOTRANSACAO=TITULOREC.TIPOTRANSACAO AND
                             RTIPOCOBRANCA.RELATORIO='FLUXOCAIXA')
         WHERE TITULOREC.BAIXA IS NULL
         AND TITULOREC.vencimento <=:VENCIMENTO
         AND TITULOREC.vencimento > :V_VENCIMENTOANTERIOR
    INTO :V_VALORACUMULADO;
    if (coalesce(V_VALORACUMULADO,0)<RECEBIMENTOS) then BEGIN
       RECEBIMENTOS=RECEBIMENTOS-V_VALORACUMULADO;
       SUSPEND;
    END
    V_VENCIMENTOANTERIOR=VENCIMENTO;
end


FOR SELECT TITULOPAG.FILIAL,
            ESTAB.RAZAOSOCIAL AS FILIALRAZAO,
            TITULOPAG.vencimento AS VENCIMENTO,
            TITULOPAG.CONTACORRENTE,
            TITULOPAG.TIPOTRANSACAO,
            TITULOPAG.TITULO,
            TITULOPAG.FATURA,
            TITULOPAG.PARCEIRO,
            CLIFOR.RAZAOSOCIAL AS PARCEIRORAZAO,
            TITULOPAG.EMISSAO,
       CAST(0 AS DOUBLE PRECISION) AS RECEBIMENTOS,
            TITULOPAG.VALOREMABERTO AS PAGAMENTOS,
            0 AS SALDOANTERIOR,
            'P' AS TIPO,
            ESTSIN.DESCRICAO,
            ESTSIN.DATAINICIAL,
            ESTSIN.DATAFINAL
       FROM TITULOPAG
       INNER JOIN ESTSIN ON (ESTSIN.ESTABELECIMENTO=TITULOPAG.FILIAL AND
                     (TITULOPAG.vencimento BETWEEN ESTSIN.DATAINICIAL AND ESTSIN.DATAFINAL) AND
                      ESTSIN.RELATORIO='FLUXOCAIXA')
       INNER JOIN CADASTROPARCEIROS ESTAB ON (ESTAB.CADASTRO=TITULOPAG.FILIAL)
       INNER JOIN CADASTROPARCEIROS CLIFOR ON (TITULOPAG.PARCEIRO=CLIFOR.CADASTRO)
       INNER JOIN RCONTACORRENTE ON (RCONTACORRENTE.CONTACORRENTE=TITULOPAG.CONTACORRENTE AND
                              RCONTACORRENTE.RELATORIO='FLUXOCAIXA')
       INNER JOIN RTIPOPAGAMENTO ON (RTIPOPAGAMENTO.TIPOPAGAMENTO=TITULOPAG.TIPOTRANSACAO AND
                              RTIPOPAGAMENTO.RELATORIO = 'FLUXOCAIXA')
       WHERE TITULOPAG.BAIXA IS NULL
       ORDER BY 1,3,14 DESC
       INTO :FILIAL,
      :FILIALRAZAO,
      :VENCIMENTO,
      :CONTACORRENTE,
      :TIPOTRANSACAO,
      :TITULO,
      :FATURA,
      :PARCEIRO,
      :PARCEIRORAZAO,
      :EMISSAO,
      :RECEBIMENTOS,
      :PAGAMENTOS,
      :SALDOANTERIOR,
      :TIPO,
      :DESCRICAO,
      :DATAINICIAL,
      :DATAFINAL DO
       SUSPEND;


--pedidos de compra de mercadorias em aberto com pagamentos no períoodo

FOR SELECT
       FLUXOPEDCOMPRA.FILIAL,
       FLUXOPEDCOMPRA.FILIALRAZAO,
       FLUXOPEDCOMPRA.VENCIMENTO,
       FLUXOPEDCOMPRA.CONTACORRENTE,
       FLUXOPEDCOMPRA.TIPOTRANSACAO,
       FLUXOPEDCOMPRA.TITULO,
       FLUXOPEDCOMPRA.FATURA,
       FLUXOPEDCOMPRA.PARCEIRO,
       FLUXOPEDCOMPRA.PARCEIRORAZAO,
       FLUXOPEDCOMPRA.EMISSAO,
       FLUXOPEDCOMPRA.RECEBIMENTOS,
       SUM (FLUXOPEDCOMPRA.PAGAMENTOS),
       FLUXOPEDCOMPRA.SALDOANTERIOR,
       FLUXOPEDCOMPRA.TIPO,
       FLUXOPEDCOMPRA.DESCRICAO,
       FLUXOPEDCOMPRA.DATAINICIAL,
       FLUXOPEDCOMPRA.DATAFINAL   
       from FLUXOPEDCOMPRA
       where fluxopedcompra.vencimento between :datainicial and :datafinal

       group by

       FLUXOPEDCOMPRA.FILIAL,
       FLUXOPEDCOMPRA.FILIALRAZAO,
       FLUXOPEDCOMPRA.VENCIMENTO,
       FLUXOPEDCOMPRA.CONTACORRENTE,
       FLUXOPEDCOMPRA.TIPOTRANSACAO,
       FLUXOPEDCOMPRA.TITULO,
       FLUXOPEDCOMPRA.FATURA,
       FLUXOPEDCOMPRA.PARCEIRO,
       FLUXOPEDCOMPRA.PARCEIRORAZAO,
       FLUXOPEDCOMPRA.EMISSAO,
       FLUXOPEDCOMPRA.RECEBIMENTOS,
       FLUXOPEDCOMPRA.SALDOANTERIOR,
       FLUXOPEDCOMPRA.TIPO,
       FLUXOPEDCOMPRA.DESCRICAO,
       FLUXOPEDCOMPRA.DATAINICIAL,
       FLUXOPEDCOMPRA.DATAFINAL   

       ORDER BY 1,3,14 DESC
       INTO
      :FILIAL,
      :FILIALRAZAO,
      :VENCIMENTO,
      :CONTACORRENTE,
      :TIPOTRANSACAO,
      :TITULO,
      :FATURA,
      :PARCEIRO,
      :PARCEIRORAZAO,
      :EMISSAO,
      :RECEBIMENTOS,
      :PAGAMENTOS,
      :SALDOANTERIOR,
      :TIPO,
      :DESCRICAO,
      :DATAINICIAL,
      :DATAFINAL
      do begin
         SUSPEND;
       END


--pedidos de compra de serviço em aberto com pagamentos no períoodo

FOR SELECT
       FLUXOPEDCOMPRASERV.FILIAL,
       FLUXOPEDCOMPRASERV.FILIALRAZAO,
       FLUXOPEDCOMPRASERV.VENCIMENTO,
       FLUXOPEDCOMPRASERV.CONTACORRENTE,
       FLUXOPEDCOMPRASERV.TIPOTRANSACAO,
       FLUXOPEDCOMPRASERV.TITULO,
       FLUXOPEDCOMPRASERV.FATURA,
       FLUXOPEDCOMPRASERV.PARCEIRO,
       FLUXOPEDCOMPRASERV.PARCEIRORAZAO,
       FLUXOPEDCOMPRASERV.EMISSAO,
       FLUXOPEDCOMPRASERV.RECEBIMENTOS,
       SUM (FLUXOPEDCOMPRASERV.PAGAMENTOS),
       FLUXOPEDCOMPRASERV.SALDOANTERIOR,
       FLUXOPEDCOMPRASERV.TIPO,
       FLUXOPEDCOMPRASERV.DESCRICAO,
       FLUXOPEDCOMPRASERV.DATAINICIAL,
       FLUXOPEDCOMPRASERV.DATAFINAL   
       from FLUXOPEDCOMPRASERV
       where fluxopedcompraserv.vencimento between :datainicial and :datafinal
       group by

       FLUXOPEDCOMPRASERV.FILIAL,
       FLUXOPEDCOMPRASERV.FILIALRAZAO,
       FLUXOPEDCOMPRASERV.VENCIMENTO,
       FLUXOPEDCOMPRASERV.CONTACORRENTE,
       FLUXOPEDCOMPRASERV.TIPOTRANSACAO,
       FLUXOPEDCOMPRASERV.TITULO,
       FLUXOPEDCOMPRASERV.FATURA,
       FLUXOPEDCOMPRASERV.PARCEIRO,
       FLUXOPEDCOMPRASERV.PARCEIRORAZAO,
       FLUXOPEDCOMPRASERV.EMISSAO,
       FLUXOPEDCOMPRASERV.RECEBIMENTOS,
       FLUXOPEDCOMPRASERV.SALDOANTERIOR,
       FLUXOPEDCOMPRASERV.TIPO,
       FLUXOPEDCOMPRASERV.DESCRICAO,
       FLUXOPEDCOMPRASERV.DATAINICIAL,
       FLUXOPEDCOMPRASERV.DATAFINAL   

       ORDER BY 1,3,14 DESC
       INTO
      :FILIAL,
      :FILIALRAZAO,
      :VENCIMENTO,
      :CONTACORRENTE,
      :TIPOTRANSACAO,
      :TITULO,
      :FATURA,
      :PARCEIRO,
      :PARCEIRORAZAO,
      :EMISSAO,
      :RECEBIMENTOS,
      :PAGAMENTOS,
      :SALDOANTERIOR,
      :TIPO,
      :DESCRICAO,
      :DATAINICIAL,
      :DATAFINAL
      do begin
         SUSPEND;
       END

END
^
SET TERM ; ^

GRANT EXECUTE
 ON PROCEDURE FLUXOCAIXAV TO  SYSDBA;

