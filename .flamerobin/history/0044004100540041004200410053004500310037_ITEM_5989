SELECT
    
    itemestoque.codigo,
    
    itemestoque.descricao,
    
    itemestoque.referencia,
    
    coalesce((select
        sum(m1.quantidade)
     from 
        locallote m1
     inner join 
        local l1 on
            l1.id = m1.local
     where
        m1.filial=materialfilial.filial and
        m1.iditem=materialfilial.iditem and
        substring(l1.descricao from 1 for 2) = 'Z2'),0) as saldototal,
        
    itemestoque.unidade,    
    
    materialfilial.SALDOMINIMO,
    
    materialfilial.saldomaximo - 

    coalesce((select
        sum(m1.quantidade)
     from 
        locallote m1
     inner join 
        local l1 on
            l1.id = m1.local
     where
        m1.filial=materialfilial.filial and
        m1.iditem=materialfilial.iditem and
        substring(l1.descricao from 1 for 2) = 'Z2'),0) as qtd,
        
    m2.quantidade saldoLocal,
        
    l2.descricao local,
    
    (select first 1
        l1.descricao
     from 
        locallote m1
     inner join 
        local l1 on
            l1.id = m1.local
     where
        m1.filial=materialfilial.filial and
        m1.iditem=materialfilial.iditem and
        m1.quantidade>0 and
        substring(l1.descricao from 1 for 2) = 'Z2' 
     order by
        m1.dataLocacao desc)  as destino,
    m2.dataLocacao,
    
    (select sum(MATERIALMOVIMENTOESTOQUE.QUANTIDADE*MATERIALMOVIMENTOESTOQUE.sinal)
     from materialmovimentoestoque
     inner join movimentoestoque on
        movimentoestoque.filial=MATERIALMOVIMENTOESTOQUE.filial and
        movimentoestoque.idmovimento=materialmovimentoestoque.idmovimento
     where materialmovimentoestoque.filial=materialfilial.filial and
     materialmovimentoestoque.IDitem=materialfilial.iditem and
     movimentoestoque.EMISSAO between cast('now' as date)-90 and cast('now' as date)) total  
    
FROM
    materialfilial
inner JOIN
    itemestoque on
        itemestoque.codigo = materialfilial.IDITEM
inner join
    locallote m2 on
        m2.filial=materialfilial.filial and
        m2.iditem=materialfilial.iditem  and
        m2.quantidade>0
inner join
    local l2 on
        l2.id=m2.local and
        (substring(l2.descricao from 1 for 2) = 'Z1' or      
         l2.descricao='Recebimento')
WHERE
    materialfilial.filial=? AND
    materialfilial.saldominimo is not null and
    materialfilial.saldomaximo > 0 and

    coalesce((select
        sum(m1.quantidade)
     from 
        locallote m1
     inner join 
        local l1 on
            l1.id = m1.local
     where
        m1.filial=materialfilial.filial and
        m1.iditem=materialfilial.iditem and
        substring(l1.descricao from 1 for 2) = 'Z2'),0)<=materialfilial.SALDOMINIMO 
order by
    itemestoque.referencia, m2.datalocacao 
