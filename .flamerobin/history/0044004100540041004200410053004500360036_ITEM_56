select 
    movimentoestoque.filial,
    movimentoestoque.emissao,
    movimentoestoque.idmovimento,
    materialmovimentoestoque.IDMOVIMENTOMATERIAL,
    materialmovimentoestoque.iditem,
    coalesce(materialmovimentoestoque.quantidade,0),
    coalesce(materialmovimentoestoque.valor,0),
    materialmovimentoestoque.sinal 
from 
    MOVIMENTOESTOQUE
inner join
    materialmovimentoestoque on
        materialmovimentoestoque.filial=movimentoestoque.filial and
        materialmovimentoestoque.idmovimento=movimentoestoque.idmovimento
inner join
    DOCUMENTOSASSOCIADOS on
        documentosassociados.filial=MATERIALMOVIMENTOESTOQUE.filial and
        DOCUMENTOSASSOCIADOS.IDMOVIMENTOENTRADA=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO and
        documentosassociados.IDMATERIAL=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL

where 
    movimentoestoque.filial=1
    and movimentoestoque.emissao between '01.01.2024' and '31.01.2024'
order by 
    movimentoestoque.emissao,
    DOCUMENTOSASSOCIADOS.filial,
    DOCUMENTOSASSOCIADOS.IDMOVIMENTOENTRADA,
    DOCUMENTOSASSOCIADOS.IDMATERIAL
