SET TERM ^ ;
ALTER TRIGGER C_MOVESTQBLOQUEIAPEDIDO ACTIVE
AFTER insert POSITION 100


AS
BEGIN
   if(new.tipomovimento='13' and new.idpedido is not null and coalesce(new.cancelado,'N')='N') then
    update pedido set pedido.BLOQUEADOLOGISTICA='S' 
    where pedido.filial=new.filial and
    pedido.idnota=new.idpedido;
   
END
^
SET TERM ; ^
