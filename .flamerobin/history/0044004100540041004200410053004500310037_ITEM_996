select 
    ls.lista,
    ls.PRODUTO,
    lc.produto,
    lc.preco*composicaoitem.QUANTIDADE
FROM
    listaprecoproduto ls
inner JOIN  
    COMPOSICAOITEM on
        composicaoitem.IDITEM=ls.PRODUTO
inner JOIN
    listaprecoproduto lc on
        lc.produto=composicaoitem.IDMATERIAL
where 
    ls.produto like '%s'