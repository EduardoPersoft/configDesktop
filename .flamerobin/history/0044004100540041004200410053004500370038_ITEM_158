update
    itemcustodata
set
    custounitario = coalesce((select max(cast(MATERIALMOVIMENTOESTOQUE.valor/materialmovimentoestoque.quantidade as decimal(10,2))
                              from MATERIALMOVIMENTOESTOQUE
                              where MATERIALMOVIMENTOESTOQUE.iditem=itemcustodata.codigo),0)
where 
    datainventario = '30.09.2025'