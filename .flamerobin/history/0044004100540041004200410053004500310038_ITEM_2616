select 
    movimentoestoque.filial,
    movimentoestoque.emissao,
    materialmovimentoestoque.filial,
    materialmovimentoestoque.idmovimento,
    materialmovimentoestoque.IDMOVIMENTOMATERIAL,
    materialmovimentoestoque.iditem,
    materialmovimentoestoque.quantidade*materialmovimentoestoque.sinal
    
from 
    MOVIMENTOESTOQUE
inner join
    materialmovimentoestoque on
        MATERIALMOVIMENTOESTOQUE.filial=movimentoestoque.filial and
        materialmovimentoestoque.idmovimento=movimentoestoque.IDMOVIMENTO
where
    movimentoestoque.filial=? and
    movimentoestoque.emissao between ? and ? and
    ( movimentoestoque.TIPOMOVIMENTO = '08' or
      (movimentoestoque.tipomovimento = '17' and 
      (materialmovimentoestoque.quantidade*materialmovimentoestoque.sinal)>0))
order by by
    movimentoestoque.filial,
    movimentoestoque.emissao,
    materialmovimentoestoque.filial,
    materialmovimentoestoque.idmovimento,
    materialmovimentoestoque.IDMOVIMENTOMATERIAL
