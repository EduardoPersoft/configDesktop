SELECT 
    materialmovimentoestoque.*
FROM 
    MATERIALMOVIMENTOESTOQUE
INNER JOIN 
    MOVIMENTOESTOQUE ON 
        MOVIMENTOESTOQUE.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL AND
        MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
WHERE /*MATERIALMOVIMENTOESTOQUE.FILIAL=MATERIALLOCAL.FILIAL
     AND*/ MATERIALMOVIMENTOESTOQUE.IDITEM='214264'
     AND MATERIALMOVIMENTOESTOQUE.CONCLUIDO='N'
     AND MATERIALMOVIMENTOESTOQUE.SINAL=0
     AND MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO=locallote."LOCAL"
     and materialmovimentoestoque.lote=1440
     /*AND MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO<>-1*/
     AND MOVIMENTOESTOQUE.TIPOMOVIMENTO='13'