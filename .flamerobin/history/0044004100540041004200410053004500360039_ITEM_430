SELECT 
    USUARIO.ID,
    USUARIO.USUARIO,
    COALESCE(USUARIO.PERFIL,usuario.id),
    VENDEDOR.CADASTRO ,
    vendedor.COMISSAOVENDA,
    vendedor.COMISSAORECEBIMENTO,
    USUARIO.PATH,
    COALESCE(USUARIO.ACESSOIPPERMITIDO,'N') acessoSoIp,
    usuario.d
    (SELECT  first 1
        CONFIGURACOESGERAIS.IPSPERMITIDOS
    FROM    
        configuracoesgerais) ipPermitido
FROM 
    USUARIO
LEFT JOIN 
    VENDEDOR ON 
        VENDEDOR.USUARIORELACIONADO = USUARIO.ID
WHERE 
    USUARIO.USUARIO = ?
    AND USUARIO.SENHA = ?
