SELECT 
    titulorec.titulo,
    titulorec.fatura,
    cadastroparceiros.razaosocial,
    cast(titulorec.emissao as date) emissao,
    cast(titulorec.vencimento as date) vencimento,
    titulorec.valortitulo 
FROM 
    TITULOREC 
inner join
    CADASTROPARCEIROS on
        cadastroparceiros.cadastro=titulorec.PARCEIRO
WHERE 
    TITULOREC.FILIAL=5 AND 
    coalesce(titulorec.CODRETORNO,'') <> '' and 
    coalesce(titulorec.LINHADIGITAVEL, '') = '' and
    titulorec.baixa is null