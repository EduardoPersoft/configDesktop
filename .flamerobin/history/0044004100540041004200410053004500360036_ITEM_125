update 
    notacompra pedido
set 
    pedido.VBRUTOFATURA=coalesce((select sum(fatped.VALORFATURA) from FATURASNOTACOMPRA fatped 
                                 where fatped.filial=pedido.FILIAL
                                 and fatped.idnota=pedido.idnota),0),
    pedido.VliquidoFATURA=coalesce((select sum(fatped.VALORFATURA) from FATURASNOTACOMPRA fatped 
                                 where fatped.filial=pedido.FILIAL
                                 and fatped.idnota=pedido.idnota),0);                                 
