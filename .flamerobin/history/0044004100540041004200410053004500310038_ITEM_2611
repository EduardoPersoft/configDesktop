select 
    movimentoestoque.filial,
    movimentoestoque.emissao,
    materialmovimentoestoque.iditem,
    sum(materialmovimentoestoque.quantidade),
    sum(materialmovimentoestoque.valor)
from 
    MOVIMENTOESTOQUE
inner join
    materialmovimentoestoque on
        MATERIALMOVIMENTOESTOQUE.filial=movimentoestoque.filial and
        materialmovimentoestoque.idmovimento=movimentoestoque.IDMOVIMENTO
where
    movimentoestoque.filial=1 and
    movimentoestoque.emissao between '01.06.2024' and '30.06.2024' and
    ( movimentoestoque.TIPOMOVIMENTO in ('01', '02', '05', '15') or
      (movimentoestoque.tipomovimento = '04' and not exists 
       (select
           *
        from
            DOCUMENTOSASSOCIADOS
        where
            DOCUMENTOSASSOCIADOS.filial=movimentoestoque.filial and
            DOCUMENTOSASSOCIADOS.IDMOVIMENTOENTRADA=movimentoestoque.idmovimento)))
group by
    movimentoestoque.emissao,
    MATERIALMOVIMENTOESTOQUE.iditem    

