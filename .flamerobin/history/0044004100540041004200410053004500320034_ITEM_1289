SELECT
    PEDIDO.FILIAL,
    PEDIDO.IDNOTA,
    PEDIDO.IDNOTA,
    PEDIDO.PESOLIQUIDO,
    PEDIDO.PESOBRUTO,
    PEDIDO.QUANTIDADEVOLUME,
    PEDIDO.MARCAVOLUME,
    PEDIDO.CLCTRANSP,
    PEDIDO.CODIGOTRANSP,
    PEDIDO.CODSERVICOENTREGA,
    PEDIDO.DESCRICAOSERVICOENTREGA,
    PEDIDO.ENTREGA,
    PEDIDO.AVISOFATURISTA,
    PEDIDO.AVISOEXPEDICAO
FROM 
    PEDIDO
WHERE
    PEDIDO.FILIAL = 5
    AND PEDIDO.idnota=304
