update 
    TITULOPAG
set
    titulopag.referencia = titulopag.VENCIMENTO-extract(day frm titulopag.vencimento)
where
    titulopag.filial=1 and
    titulopag.VENCIMENTO>'01.01.2026' and
    exists (
    select * from LANTOCONTPAG
    where lantocontpag.filial=titulopag.filial and
    lantocontpag.IDMOVTOBanc=titulopag.IDTITULO and
    lantocontpag.CONTACONTABIL='20302')