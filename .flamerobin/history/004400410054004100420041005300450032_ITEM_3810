SELECT PEDIDO.FILIAL PEDIDO_FILIAL,
       PEDIDO.IDNOTA PEDIDO_IDNOTA,
       PEDIDO.UUID,
       CAST(PEDIDO.DATACADASTRO AS DATE ) PEDIDO_DATACADASTRO , 

       PEDIDO.PROPDESTINATARIO        PROPDEFAULT_PROPDESTINATARIO      ,
       PEDIDO.MODELO                  PROPDEFAULT_MODELO                ,
       PEDIDO.OPERACAO                PROPDEFAULT_OPERACAO              ,        
       PEDIDO.ENTRADASAIDA            PROPDEFAULT_ENTRADASAIDA, 
       PEDIDO.DECIMAISPRECO           PROPDEFAULT_CASASDECIMAIS         ,
       PEDIDO.TIPONOTA                PROPDEFAULT_TIPODOCUMENTO         ,


       PEDIDO.cfop NATUREZAOPERACAO_CFOP,
       PEDIDO.naturezaoperacao NATUREZAOPERACAO_DESCRICAO,
       PEDIDO.zonafranca NATUREZAOPERACAO_ZONAFRANCA,
       PEDIDO.substributaria NATUREZAOPERACAO_SUBSTRIBUTARIA,
       PEDIDO.embutiricms NATUREZAOPERACAO_EMBUTIRICMS,
       PEDIDO.abaterdescontoicms NATUREZAOPERACAO_DESCONTOICMS,
       cast(0 as integer)             PROPDEFAULT_DIASENTREGA ,       
	   PEDIDO.UFESTABELECIMENTO	 PEDIDO_UFESTABELECIMENTO,
       PEDIDO.ICMS               PEDIDO_ICMS,
       PEDIDO.IPI                PEDIDO_IPI,
       PEDIDO.CALCULADA          PEDIDO_CALCULADA,
       PEDIDO.PREDUCAOICMS,
       PEDIDO.REDUCAOICMS,

       CADASTROFILIAL.NOME, 
       CADASTROFILIAL.TIPOPESSOA,
       CASE CADASTROFILIAL.TIPOPESSOA 
           WHEN 'F' THEN SUBSTRING(CADASTROFILIAL.DOCUMENTO FROM 1 FOR 3)||'.'|| 
                         SUBSTRING(CADASTROFILIAL.DOCUMENTO FROM 4 FOR 3)||'.'|| 
                         SUBSTRING(CADASTROFILIAL.DOCUMENTO FROM 7 FOR 3)||'-'||      
                         SUBSTRING(CADASTROFILIAL.DOCUMENTO FROM 10 FOR 2)  
           WHEN 'J' THEN SUBSTRING(CADASTROFILIAL.DOCUMENTO FROM 1 FOR 2)||'.'|| 
                         SUBSTRING(CADASTROFILIAL.DOCUMENTO FROM 3 FOR 3)||'.'|| 
                         SUBSTRING(CADASTROFILIAL.DOCUMENTO FROM 6 FOR 3)||'/'||      
                         SUBSTRING(CADASTROFILIAL.DOCUMENTO FROM 9 FOR 4)||'-'||      
                         SUBSTRING(CADASTROFILIAL.DOCUMENTO FROM 13 FOR 2)  
            else ''
       end CADASTROFILIAL_CPFCNPJ,
       CADASTROFILIAL.INSCESTADUAL, 
       CADASTROFILIAL.web     CADASTROFILIAL_web,    
       CADASTROFILIAL.TELEFONE     CADASTROFILIAL_TELEFONE,    
       CADASTROFILIAL.LOGRADOURO    CADASTROFILIAL_LOGRADOURO,
       CADASTROFILIAL.NUMERO        CADASTROFILIAL_NUMERO,
       CADASTROFILIAL.COMPLEMENTO   CADASTROFILIAL_COMPLEMENTO,
       CADASTROFILIAL.BAIRRO        CADASTROFILIAL_BAIRRO,
       CADASTROFILIAL.CIDADE        CADASTROFILIAL_CIDADE,
       CADASTROFILIAL.UF              CADASTROFILIAL_UF,
       CADASTROFILIAL.CEP           CADASTROFILIAL_CEP,

	   CADASTROCLIENTES.CADASTRO      CADASTROCLIENTES_CADASTRO,
       CADASTROCLIENTES.NOME          CADASTROCLIENTES_NOME,
       CADASTROCLIENTES.DOCUMENTO     CADASTROCLIENTES_DOCUMENTO,
       CADASTROCLIENTES.TIPOPESSOA,
       CASE CADASTROCLIENTES.TIPOPESSOA 
           WHEN 'F' THEN SUBSTRING(CADASTROCLIENTES.DOCUMENTO FROM 1 FOR 3)||'.'|| 
                         SUBSTRING(CADASTROCLIENTES.DOCUMENTO FROM 4 FOR 3)||'.'|| 
                         SUBSTRING(CADASTROCLIENTES.DOCUMENTO FROM 7 FOR 3)||'-'||      
                         SUBSTRING(CADASTROCLIENTES.DOCUMENTO FROM 10 FOR 2)  
           WHEN 'J' THEN SUBSTRING(CADASTROCLIENTES.DOCUMENTO FROM 1 FOR 2)||'.'|| 
                         SUBSTRING(CADASTROCLIENTES.DOCUMENTO FROM 3 FOR 3)||'.'|| 
                         SUBSTRING(CADASTROCLIENTES.DOCUMENTO FROM 6 FOR 3)||'/'||      
                         SUBSTRING(CADASTROCLIENTES.DOCUMENTO FROM 9 FOR 4)||'-'||      
                         SUBSTRING(CADASTROCLIENTES.DOCUMENTO FROM 13 FOR 2)  
            else ''
       end CADASTROCLIENTES_CPFCNPJ,
       CADASTROCLIENTES.INSCESTADUAL, 
       PEDIDO.CONTATO                 CADASTROCLIENTES_CONTATO,
       CADASTROCLIENTES.TELEFONE     CADASTROCLIENTES_TELEFONE,    
	   PEDIDO.EMAIL                   CADASTROCLIENTES_EMAIL,
       CADASTROCLIENTES.LOGRADOURO    CADASTROCLIENTES_LOGRADOURO,
       CADASTROCLIENTES.NUMERO        CADASTROCLIENTES_NUMERO,
       CADASTROCLIENTES.COMPLEMENTO   CADASTROCLIENTES_COMPLEMENTO,
       CADASTROCLIENTES.BAIRRO        CADASTROCLIENTES_BAIRRO,
       CADASTROCLIENTES.CIDADE        CADASTROCLIENTES_CIDADE,
       PEDIDO.UF                      CADASTROCLIENTES_UF,
       CADASTROCLIENTES.CEP           CADASTROCLIENTES_CEP,

       PEDIDO.condicaopagamento MODELODOCTO_CONDICAOPAGTO,
       CONDICAOPAGAMENTO.DESCRICAO MODELODOCTO_CONDICAOPAGTOD,
       PEDIDO.TIPOPAGAMENTO MODELODOCTO_TIPOCOBRANCA,
	   TIPOPAGAMENTO.DESCRICAO    PEDIDO_TIPOCOBRANCADESCRICAO,
       PEDIDO.CONTACORRENTEPAGADORA MODELODOCTO_BANCOCOBRANCA,

       case WHEN PEDIDO.dataaprovacao IS NOT NULL THEN 'S' ELSE 'N' END,
       PEDIDO.dataaprovacao AS PEDIDO_DATAEMISSAO,
       PEDIDO.USUARIOAPROVACAO AS PEDIDO_USUARIOEMISSAO,

	   PEDIDO.CIFFOB PEDIDO_FRETE                  ,
       case when PEDIDO.CIFFOB = 'C' THEN 'CIF' ELSE 'FOB' END PEDIDO_CIFFOB,
	   PEDIDO.FRETEIPI PEDIDO_FRETEIPI,
    
	   PEDIDO.DADOSENTREGA PEDIDO_DADOSENTREGA ,
	   PEDIDO.LOGRADOUROENTREGA CADASTROCLIENTES_LOGENTREGA      ,
	   PEDIDO.NUMEROENTREGA CADASTROCLIENTES_NUMEROENTREGA          ,
	   PEDIDO.COMPLEMENTOENTREGA CADASTROCLIENTES_COMPLENTREGA    ,
	   PEDIDO.BAIRROENTREGA CADASTROCLIENTES_BAIRROENTREGA          ,
	   PEDIDO.CIDADEENTREGA CADASTROCLIENTES_CIDADEENTREGA          ,
	   PEDIDO.UFENTREGA CADASTROCLIENTES_UFENTREGA              ,
	   PEDIDO.CEPENTREGA CADASTROCLIENTES_CEPENTREGA             ,    

       PEDIDO.USUARIO                LOG_USUARIO,
       PEDIDO.DATAALTERACAO          LOG_DATAALTERACAO,
       PEDIDO.HORAALTERACAO          LOG_HORAALTERACAO,

	   CASE CADASTROCLIENTES.AVISOVENDAS WHEN 'S' 
	   THEN CADASTROCLIENTES.AVISOMSG ELSE NULL END CADASTROCLIENTES_AVISOVENDA,

	   PEDIDO.VALORFRETE             PEDIDO_VALORFRETE             ,
	   PEDIDO.VALORSEGURO            PEDIDO_VALORSEGURO            ,
	   PEDIDO.VLROUTDESPACESSORIA    PEDIDO_VLROUTDESPACESSORIA    ,
    
       PEDIDO.TOTBASEICMS             PEDIDO_TOTBASEICMS            ,
       PEDIDO.TOTVALORICMS            PEDIDO_TOTVALORICMS,
       PEDIDO.TOTOUTROSICMS           PEDIDO_TOTOUTROSICMS,
       PEDIDO.TOTISENTOICMS           PEDIDO_TOTISENTOICMS, 
       PEDIDO.VLRBASESUBSTITUTO       PEDIDO_ICMSSTBASE,  
       PEDIDO.VALORICMSSUBST          PEDIDO_ICMSSTVALOR,  
       PEDIDO.VLRICMSRECOLHIDO       PEDIDO_ICMSSTRECOLHIDO,  

       PEDIDO.ipibase                 PEDIDO_IPIBASE,
       PEDIDO.VALORIPI                PEDIDO_VALORIPI,
       PEDIDO.ipioutros               PEDIDO_IPIOUTROS,
       PEDIDO.IPIISENTO               PEDIDO_IPIISENTO,

       PEDIDO.VALORPIS      PEDIDO_VLRPISPASEPMERC,
       0 as basepis,
    
       PEDIDO.VaLoRCOFINS         PEDIDO_VLRCOFINSMERC,
       0 as baseCofins,

       PEDIDO.VLRTOTALMERCADORIAS     PEDIDO_VLRTOTALMERCADORIAS,
       PEDIDO.VLRFINALMERCADORIAS     PEDIDO_VLRFINALMERCADORIAS,    
       PEDIDO.VLRTOTALSERVICOS        PEDIDO_VLRTOTALSERVICOS,
       PEDIDO.VLRFINALSERVICOS        PEDIDO_VLRFINALSERVICOS,    
       PEDIDO.VLRTOTALNOTA            PEDIDO_VLRTOTALNOTA,    

	   PEDIDO.PDESCMERCADORIAS       PEDIDO_PDESCMERCADORIAS       ,
	   PEDIDO.VLRDESCMERCADORIAS     PEDIDO_VLRDESCMERCADORIAS     ,
	   PEDIDO.MSGDESCMERCADORIAS     PEDIDO_MSGDESCMERCADORIAS     ,
	   
       PEDIDO.PACRESCMERC            PEDIDO_PACRESCMERC            ,
	   PEDIDO.VLRACRESCMERCAD        PEDIDO_VLRACRESCMERCAD        ,
	   PEDIDO.MSGACRESCMERCADORIA    PEDIDO_MSGACRESCMERCADORIA    ,	

	   PEDIDO.MSGDADOSADICIONAIS     PEDIDO_MSGDADOSADICIONAIS     ,
	   PEDIDO.MSGDESCRMERCADORIAS    PEDIDO_MSGDESCRMERCADORIAS,
	   PEDIDO.OBSERVACAO             PEDIDO_OBSERVACAO             ,
	   PEDIDO.COMENTARIO             PEDIDO_COMENTARIO             ,    
	   PEDIDO.NRPEDFORNECEDOR       PEDIDO_NUMPEDIDOCLIENTE       ,

	   PEDIDO.ENTREGA              PEDIDO_DATAENTREGA            ,
	   PEDIDO.ENTREGAORIGINAL      PEDIDO_DATAENTREGAORIGINAL    ,
	   PEDIDO.JUSTIFICATIVA        PEDIDO_JUSTIFICATIVAENTREGA    ,
	   PEDIDO.IDORCAMENTO          PEDIDO_IDORCAMENTO  ,
	   COALESCE(PEDIDO.BLOQUEADOFATURAMENTO,'N') PEDIDO_BLOQUEADOFATURAMENTO,

		
	   PEDIDO.CARRINHO           PEDIDO_CARRINHO,
	   PEDIDO.STATUS             PEDIDO_STATUS,
	   PEDIDO.LINKPAGTO          PEDIDO_LINKPAGTO,
	   PEDIDO.IDPAGAMENTO        PEDIDO_IDPAGAMENTO,
	   PEDIDO.IDPREFERENCE       PEDIDO_IDPREFERENCE,
	   TIPOCOBRANCA.DESCRICAO    PEDIDO_TIPOCOBRANCADESCRICAO,
	   CONDICAOPAGAMENTO.DESCRICAO PEDIDO_CONDICAOPGTODESCRICAO	   

FROM 
    PEDIDOCOMPRA PEDIDO
LEFT JOIN 
    CADASTROPARCEIROS CADASTROFILIAL on 
        (CADASTROFILIAL.CADASTRO=PEDIDO.FILIAL)
LEFT JOIN 
    CADASTROPARCEIROS CADASTROCLIENTES on 
        (CADASTROCLIENTES.CADASTRO=PEDIDO.DESTINATARIO)
LEFT JOIN 
    TIPOPAGAMENTO ON 
        TIPOPAGAMENTO.ID=PEDIDO.TIPOPAGAMENTO
LEFT JOIN 
    CONDICAOPAGAMENTO ON 
        CONDICAOPAGAMENTO.ID=PEDIDO.CONDICAOPAGAMENTO

/*
WHERE 
    PEDIDO.FILIAL= ? 
    AND PEDIDO.IDNOTA=?
*/

