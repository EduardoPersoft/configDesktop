select 
    titulorec.titulo,
    titulorec.fatura,
    count(titulorec.IDTITULO)
from 
    TITULOREC
where
    titulorec.filial=5 and
    titulorec.EMISSAO>='01.06.2022' and
    titulorec.TIPOBAIXA is null
group by
    titulorec.titulo,
    titulorec.fatura
having    
    count(titulorec.IDTITULO)>1