select 
    MERCADORIASPEDCOMPRA.IDPEDVEN,
    NOTACOMPRA.NRNOTAFORNECEDOR,
    MERCADORIASNOTACOMPRA.QUANTIDADE,
    MERCADORIASNOTACOMPRA.PRECOUNITARIO,
    MERCADORIASNOTACOMPRA.VLRTOTALMERCAD
from MERCADORIASNOTACOMPRA
INNER JOIN NOTACOMPRA ON
    MERCADORIASPEDCOMPRA.FILIAL=NOTACOMPRA.FILIAL and
    MERCADORIASPEDCOMPRA.IDNOTA=NOTACOMPRA.IDNOTA
INNER JOIN MERCADORIASPEDCOMPRA ON
    MERCADORIASNOTACOMPRA.FILIAL=MERCADORIASPEDCOMPRA.FILIAL and
    MERCADORIASNOTACOMPRA.IDPEDIDO=MERCADORIASPEDCOMPRA.IDNOTA
where MERCADORIASPEDCOMPRA.idpedven in 
(10650, 10560, 10651, 10669, 10468, 10607)
