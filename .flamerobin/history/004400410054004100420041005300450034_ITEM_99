SELECT   LAYOUTREGISTROS.GRUPO,
       LAYOUTREGISTROS.IDLAYOUTREGISTROS,
       LAYOUTREGISTROS.NOME AS NOMEREGISTRO,LAYOUTREGISTROS.DETALHE,
       LAYOUTREGISTROS.ORDEM AS ORDEMREGISTRO, LAYOUTCAMPOS.IDCAMPOS,
       LAYOUTCAMPOS.INICIO,LAYOUTCAMPOS.FIM,LAYOUTCAMPOS.DECIMAIS,
       LAYOUTCAMPOS.TAMANHO,LAYOUTCAMPOS.TIPOCAMPO, 
       LAYOUTCAMPOS.NOME AS NOMECAMPO, LAYOUTCAMPOS.TIPOCONTEUDO,
       LAYOUTCAMPOS.CONTEUDO, LAYOUTCAMPOS.DESCRICAO, 
       LAYOUTCAMPOS.ORDEM AS ORDEMCAMPO,LAYOUTCAMPOS.CONTEUDOBANCO,
       LAYOUTCAMPOS.CONTCORRESPONDENTE,
       LAYOUTCAMPOS.APENASNUMEROLETRAS,
       LAYOUTBANCARIO.* 
FROM LAYOUTREGISTROS,LAYOUTCAMPOS,LAYOUTBANCARIO
WHERE
  LAYOUTBANCARIO.BANCO=:BANCO AND
  LAYOUTCAMPOS.IDREGISTROS=LAYOUTREGISTROS.IDLAYOUTREGISTROS AND  
  LAYOUTCAMPOS.IDLAYOUTBANCARIO=LAYOUTBANCARIO.IDLAYOUTBANCARIO  AND
  LAYOUTREGISTROS.IDLAYOUTBANCARIO=LAYOUTBANCARIO.IDLAYOUTBANCARIO AND
  LAYOUTCAMPOS.IDLAYOUTBANCARIO=LAYOUTCAMPOS.IDLAYOUTBANCARIO
ORDER BY LAYOUTREGISTROS.GRUPO, LAYOUTREGISTROS.ORDEM, LAYOUTCAMPOS.ORDEM