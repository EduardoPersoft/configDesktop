SELECT 
    INVENTARIOESTOQUEDATA.CODIGO,
    INVENTARIOESTOQUEDATA.LOTE,
    INVENTARIOESTOQUEDATA.QUANTIDADE,
    INVENTARIOESTOQUEDATA.QUANTIDADE*ITEMESTOQUE.VALORULTIMACOMPRA TOTAL,
    LOCAL.id LOCAL    
FROM 
    INVENTARIOESTOQUEDATA
INNER join
    itemestoque on
        itemestoque.codigo=inventarioestoquedata.CODIGO
LEFT JOIN 
    MATERIALLOTE ON
        MATERIALLOTE.FILIAL=INVENTARIOESTOQUEDATA.FILIAL and
        MATERIALLOTE.IDITEM=INVENTARIOESTOQUEDATA.CODIGO and
        MATERIALLOTE.LOTE=INVENTARIOESTOQUEDATA.LOTE
LEFT join
    LOCAL ON
        LOCAL.ID=INVENTARIOESTOQUEDATA.LOCAL
WHERE 
    INVENTARIOESTOQUEDATA.DATA='30.09.2023'
ORDER BY
    LOCAL.id,
    ITEMESTOQUE.CODIGO,
    MATERIALLOTE.LOTE,
    INVENTARIOESTOQUEDATA.QUANTIDADE