select 
    itemestoque.codigo,
    itemestoque.referencia,
    itemestoque.descricao,
    familia.id familia,
    familia.descricao descricaoFamilia,
    sum(mercadoriasnota.quantidade) as quantidade
FROM
    NOTAFISCAL
inner join 
    mercadoriasnota on
        notafiscal.filial=mercadoriasnota.filial AND
        notafiscal.idnota=mercadoriasnota.idnota
inner JOIN
    itemestoque on
        itemestoque.codigo=mercadoriasnota.CODIGO
inner JOIN
    familia on
        familia.id=itemestoque.familia
WHERE
    notafiscal.filial=5 AND
    notafiscal.DATAEMISSAO between '01.10.2020' and '31.12.2021' AND
    itemestoque.familia in (3,4)
group by
        itemestoque.codigo,
    itemestoque.referencia,
    itemestoque.descricao,
    familia.id,
    familia.descricao
order by
    sum(mercadoriasped.quantidade)