update 
    LOCALLOTE
set
    quantidade = coalesce((select 
                    sum(materialmovimentoestoque.quantidade*
                        materialmovimentoestoque.sinal)
                  from 
                    MATERIALMOVIMENTOESTOQUE
                  where
                     materialmovimentoestoque.filial=locallote.filial and
                     materialmovimentoestoque.iditem=locallote.iditem and
                     materialmovimentoestoque.LOCALARMAZENAMENTO=locallote."LOCAL" and
                     MATERIALMOVIMENTOESTOQUE.lote=locallote.lote),0)
 