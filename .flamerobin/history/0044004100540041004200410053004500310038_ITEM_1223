select 
    pedido.filial,
    pedido.idnota,
    pedido.DATACADASTRO,
    pedido.DATAREFERENCIA,
    pedido.DATAEMISSAO,
    (select
        max(fatped.DATAVENCIMENTO)
     from
        FATPED
     where
        fatped.filial=pedido.filial and
        fatped.idnota=pedido.idnota),
    pedido.C_DATACOMISSAO
from
    PEDIDO
order by
    idnota desc