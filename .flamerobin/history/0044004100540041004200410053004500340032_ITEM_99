select * from COMPOSICAOOP
where filial=110
and exists (
select * from MATERIALMOVIMENTOESTOQUE
where materialmovimentoestoque.filial=COMPOSICAOOP.filial 
and materialmovimentoestoque.idmovimento=composicaoop.IDMOVIMENTO
and materialmovimentoestoque.IDMOVIMENTOMATERIAL=composicaoop.IDMOVIMENTOMATERIAL
and materialmovimentoestoque.iditem='I01')
order by composicaoop.IDMOVIMENTO desc,idmovimentomaterial,idcomposicao 