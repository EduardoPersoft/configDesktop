select MERCADORIASPED.CODIGO,
                coalesce(SUM(SALDODOPEDIDOMATERIAL.QUANTIDADE), 0)
      from SALDODOPEDIDOMATERIAL(:FILIAL)
      inner join MERCADORIASPED on (SALDODOPEDIDOMATERIAL.FILIAL = MERCADORIASPED.FILIAL and
            SALDODOPEDIDOMATERIAL.IDNOTA = MERCADORIASPED.IDNOTA and
            SALDODOPEDIDOMATERIAL.IDMERCADORIA = MERCADORIASPED.IDMERCADORIA)
      inner join MATERIALFILIAL on (MATERIALFILIAL.FILIAL = MERCADORIASPED.FILIAL and
            MATERIALFILIAL.IDITEM = MERCADORIASPED.CODIGO)

      inner join PEDIDO on (SALDODOPEDIDOMATERIAL.FILIAL = PEDIDO.FILIAL and
            SALDODOPEDIDOMATERIAL.IDNOTA = PEDIDO.IDNOTA)
      where (coalesce(MATERIALFILIAL.TEMPOREPOSICAO, 0) = 0 or SALDODOPEDIDOMATERIAL.DATAENTREGA <= cast('now' as timestamp) + MATERIALFILIAL.TEMPOREPOSICAO)
      and mercadoriasped.codigo='9835010-S' 
      GROUP BY  MERCADORIASPED.CODIGO