select
    CONTASCONTABEIS.DESCRICAO,
    TITULOPAG.TITULO,
    TITULOPAG.FATURA,
    CADFOR.NOME,
    TITULOPAG.EMISSAO,
    TITULOPAG.VENCIMENTO,
    TITULOPAG.BAIXA,

    LANTOCONTPAG.VALOR
from
    TITULOPAG
INNER join
    CADASTROPARCEIROS CADFOR ON
        CADFOR.CADASTRO=TITULOPAG.PARCEIRO
INNER join
    LANTOCONTPAG ON
        TITULOPAG.FILIAL=LANTOCONTPAG.FILIAL and
        TITULOPAG.IDTITULO=LANTOCONTPAG.IDMOVTOBANC
INNER JOIN 
    CONTASCONTABEIS ON
    CONTASCONTABEIS.IDPLANO=4 and
    CONTASCONTABEIS.CONTACONTABIL=LANTOCONTPAG.CONTACONTABIL
where
    TITULOPAG.FILIAL=1 and
    TITULOPAG.BAIXA BETWEEN '01.01.2025' AND '31.12.2025' and
    LANTOCONTPAG.CONTACONTABIL BETWEEN '20402' AND '20402' and
    TITULOPAG.TIPOBAIXA='P'
ORDER BY DESCRICAO,VENCIMENTO,TITULO    