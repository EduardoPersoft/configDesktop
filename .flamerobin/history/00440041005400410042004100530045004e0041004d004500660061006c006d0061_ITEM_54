select 
    itemestoque.codigo,
    itemestoque.descricao,
    itemestoque.unidade,
    mercadoriaspedcompra.quantidade,
    mercadoriaspedcompra.QTDEENTREGUE,
    mercadoriaspedcompra.quantidade/mercadoriaspedcompra.QTDEENTREGUE AS FATOR
from 
    MERCADORIASPEDCOMPRA
inner JOIN
    itemestoque on
        mercadoriaspedcompra.codigo=itemestoque.codigo
WHERE
    mercadoriaspedcompra.baixa='N' AND
    coalesce(mercadoriaspedcompra.QTDEENTREGUE,0)>0
order by 6 desc