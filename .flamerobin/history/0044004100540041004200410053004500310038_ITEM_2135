SET TERM ^ ;
ALTER PROCEDURE C_PEDIDODATAFINCOMFIL (
    ID integer )
RETURNS (
    FILIAL integer,
    IDNOTA integer,
    VENDEDOR integer,
    PARTICIPACAO numeric(12,2),
    "DATA" timestamp,
    SINAL integer,
    TABELA integer )

AS
DECLARE VARIABLE V_QTDLIBERACAO INTEGER;

DECLARE VARIABLE V_DATALIBERACAO DATE;
DECLARE VARIABLE V_DATACOMISSAO DATE;
DECLARE VARIABLE V_DATACADASTRO DATE;
DECLARE VARIABLE V_IDNOTASUBSTITUIDO INTEGER;

DECLARE VARIABLE V_DATALIMITE DATE;
DECLARE VARIABLE V_TABELA INTEGER;

BEGIN

    SELECT C_COMISSOES.DATALIMITE, C_COMISSOES.TABELA
    FROM C_COMISSOES
    WHERE C_COMISSOES.ID = :ID
    INTO V_DATALIMITE, TABELA;

    FOR SELECT VENDEDORESPED.FILIAL,
               VENDEDORESPED.IDNOTA,
               VENDEDORESPED.VENDEDOR,
               VENDEDORESPED.COMISSAOVENDA
    FROM VENDEDORESPED
    INNER JOIN CADASTROPARCEIROS ON (CADASTROPARCEIROS.CADASTRO=VENDEDORESPED.VENDEDOR)
    INNER JOIN PEDIDO ON (VENDEDORESPED.FILIAL=PEDIDO.FILIAL AND VENDEDORESPED.IDNOTA=PEDIDO.IDNOTA)
    WHERE VENDEDORESPED.C_IDCOMISSAO IS null
    AND COALESCE(PEDIDO.CANCELAMENTO,'N') = 'N'
    AND CADASTROPARCEIROS.C_TABELACOMISSAO = :TABELA
    AND exists
    (SELECT * FROM MERCADORIASPED 
     WHERE MERCADORIASPED.FILIAL = VENDEDORESPED.FILIAL     
     AND MERCADORIASPED.IDNOTA = VENDEDORESPED.IDNOTA)
    AND  exists
    (SELECT * FROM C_FATURASPED
     WHERE C_FATURASPED.FILIAL = VENDEDORESPED.FILIAL
     AND C_FATURASPED.IDNOTA = VENDEDORESPED.IDNOTA
     AND C_FATURASPED.LIBERACAO IS NOT NULL)           
    INTO FILIAL, IDNOTA, VENDEDOR, PARTICIPACAO DO begin
    
        sinal = 1;
    
        SELECT PEDIDO.C_DATACOMISSAO, MIN(C_FATURASPED.DATA), PEDIDO.DATACADASTRO, PEDIDO.C_PEDIDOSUBSTITUIDO
        FROM PEDIDO
        INNER JOIN C_FATURASPED ON ( C_FATURASPED.FILIAL = PEDIDO.FILIAL 
                                 AND C_FATURASPED.IDNOTA = PEDIDO.IDNOTA)
        WHERE PEDIDO.FILIAL=:FILIAL
        AND PEDIDO.IDNOTA=:IDNOTA
        GROUP BY PEDIDO.FILIAL,
                 PEDIDO.IDNOTA,
                 PEDIDO.C_DATACOMISSAO, 
                 PEDIDO.DATACADASTRO, 
                 PEDIDO.C_PEDIDOSUBSTITUIDO                         
        INTO V_DATACOMISSAO, V_DATALIBERACAO, V_DATACADASTRO, V_IDNOTASUBSTITUIDO;
        
        DATA = V_DATALIBERACAO;
        
        IF (V_IDNOTASUBSTITUIDO IS NOT NULL) THEN
            DATA = V_DATACADASTRO;
            
        IF (V_DATACOMISSAO IS NOT NULL) THEN
            DATA = V_DATACOMISSAO;
            
        IF (DATA <= V_DATALIMITE) THEN begin            
            suspend;

            if (V_IDNOTASUBSTITUIDO IS NOT NULL) then BEGIN           
                Select MIN(FAT1.DATA),COUNT(FAT1.sequencia) 
                FROM C_FATURASPED FAT1
                WHERE FAT1.FILIAL=:filial AND FAT1.IDNOTA=:V_IDNOTASUBSTITUIDO
                AND FAT1.LIBERACAO IS NOT NULL           
                INTO :DATA,V_QTDLIBERACAO       ;

                IF (COALESCE(V_QTDLIBERACAO,0)>0) THEN BEGIN
                    SELECT 
                        VENDEDORESPED.COMISSAOVENDA
                    from    
                        VENDEDORESPED
                    where
                        VENDEDORESPED.FILIAL=:FILIAL and
                        VENDEDORESPED.IDNOTA=:V_IDNOTASUBSTITUIDO and
                        VENDEDORESPED.VENDEDOR=:VENDEDOR
                    INTO :PARTICIPACAO;
                    IDNOTA = V_IDNOTASUBSTITUIDO;
                    SINAL= -1;                    
                    SUSPEND;
                END                           
            END            
            
        end
        
    
    END 
    
END
^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE C_PEDIDODATAFINCOMFIL TO  SYSDBA;

