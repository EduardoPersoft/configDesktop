SELECT
    ITEMESTOQUE.CODIGO,
    ITEMESTOQUE.DESCRICAO,
    ITEMESTOQUE.CODIGOBARRA,
    ITEMESTOQUE.REFERENCIA,
    ITEMESTOQUE.ITEMBASE,
    ITEMESTOQUE.GRUPO,
    ITEMESTOQUE.FAMILIA,
    ITEMESTOQUE.CLASSIFISCAL,
    ITEMESTOQUE.TRIBUTACAOICMS,
    ITEMESTOQUE.CODIGOTRIBUTACAO,
    ITEMESTOQUE.TIPOPRODUTO,
    ITEMESTOQUE.NOMEARQUIVOIMAGEM,
    ITEM.DISPONIVELECOMMERCE
FROM 
    ITEMESTOQUE ITEM
WHERE
    ITEMESTOQUE.CODIGO = '11843'