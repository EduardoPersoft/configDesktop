    SET TERM ^ ;
ALTER PROCEDURE RECALCULARTOTAISESTOQUE (
    FILIAL integer,
    MATERIALINICIAL varchar(15),
    MATERIALFINAL varchar(15) )

AS
BEGIN
/*
    UPDATE locallote SET LOCALLOTE.quantidade=
    CAST(COALESCE((SELECT SUM(MATERIALMOVIMENTOESTOQUE.QUANTIDADE*MATERIALMOVIMENTOESTOQUE.SINAL)
     FROM MATERIALMOVIMENTOESTOQUE
     WHERE MATERIALMOVIMENTOESTOQUE.FILIAL=LOCALLOTE.FILIAL
     AND MATERIALMOVIMENTOESTOQUE.iditem=LOCALLOTE.iditem
     AND MATERIALMOVIMENTOESTOQUE.localarmazenamento=LOCALLOTE.local
     and MATERIALMOVIMENTOESTOQUE.lote=LOCALLOTE.lote),0) AS DECIMAL(12,3))
     WHERE FILIAL=:FILIAL
     AND IDITEM BETWEEN :MATERIALINICIAL AND :MATERIALFINAL;

    UPDATE MATERIALLOTE SET MATERIALLOTE.QUANTIDADE=
    CAST(COALESCE((SELECT SUM(MATERIALMOVIMENTOESTOQUE.QUANTIDADE*MATERIALMOVIMENTOESTOQUE.SINAL)
     FROM MATERIALMOVIMENTOESTOQUE
     WHERE MATERIALMOVIMENTOESTOQUE.FILIAL=MATERIALLOTE.FILIAL
     AND MATERIALMOVIMENTOESTOQUE.iditem=MATERIALLOTE.iditem
     and MATERIALMOVIMENTOESTOQUE.lote=MATERIALLOTE.lote),0) AS DECIMAL(12,3)),
     MATERIALLOTE.VALOR=
    CAST(COALESCE((SELECT SUM(MATERIALMOVIMENTOESTOQUE.VALOR*MATERIALMOVIMENTOESTOQUE.SINAL)
     FROM MATERIALMOVIMENTOESTOQUE
     WHERE MATERIALMOVIMENTOESTOQUE.FILIAL=MATERIALLOTE.FILIAL
     AND MATERIALMOVIMENTOESTOQUE.iditem=MATERIALLOTE.iditem
     and MATERIALMOVIMENTOESTOQUE.lote=MATERIALLOTE.lote),0) AS DECIMAL(12,2))
     WHERE FILIAL=:FILIAL
     AND IDITEM BETWEEN :MATERIALINICIAL AND :MATERIALFINAL;

*/

    UPDATE MATERIALLOCAL SET MATERIALLOCAL.saldototal=
    CAST(COALESCE((SELECT SUM(MATERIALMOVIMENTOESTOQUE.QUANTIDADE*MATERIALMOVIMENTOESTOQUE.SINAL)
     FROM MATERIALMOVIMENTOESTOQUE
     WHERE MATERIALMOVIMENTOESTOQUE.FILIAL=MATERIALLOCAL.FILIAL
     AND MATERIALMOVIMENTOESTOQUE.iditem=MATERIALLOCAL.iditem
     and MATERIALMOVIMENTOESTOQUE.localarmazenamento=MATERIALLOCAL.idlocal),0) AS DECIMAL(12,3))
     WHERE FILIAL=:FILIAL
     AND IDITEM BETWEEN :MATERIALINICIAL AND :MATERIALFINAL;


    UPDATE MATERIALFILIAL SET MATERIALFILIAL.valortotalestocado=
    CAST(COALESCE((SELECT SUM(MATERIALMOVIMENTOESTOQUE.VALOR*MATERIALMOVIMENTOESTOQUE.SINAL)
     FROM MATERIALMOVIMENTOESTOQUE
     WHERE MATERIALMOVIMENTOESTOQUE.FILIAL=MATERIALFILIAL.FILIAL
     AND MATERIALMOVIMENTOESTOQUE.iditem=MATERIALFILIAL.iditem),0)  AS DECIMAL(12,2))
     WHERE FILIAL=:FILIAL
     AND IDITEM BETWEEN :MATERIALINICIAL AND :MATERIALFINAL;

/*
     UPDATE MATERIALLOTE SET MATERIALLOTE.customedio = MATERIALLOTE.VALOR/
        MATERIALLOTE.QUANTIDADE
     WHERE COALESCE(MATERIALLOTE.QUANTIDADE,0)<>0
     AND FILIAL=:FILIAL
     AND IDITEM BETWEEN :MATERIALINICIAL AND :MATERIALFINAL;

     UPDATE MATERIALFILIAL SET MATERIALFILIAL.CUSTOMEDIO=
        MATERIALFILIAL.valortotalestocado/
        (SELECT SUM(MATERIALLOCAL.saldototal) FROM MATERIALLOCAL
         WHERE MATERIALLOCAL.FILIAL=MATERIALFILIAL.FILIAL
         AND MATERIALLOCAL.IDITEM=MATERIALFILIAL.IDITEM)
     WHERE
        (SELECT SUM(MATERIALLOCAL.saldototal) FROM MATERIALLOCAL
         WHERE MATERIALLOCAL.FILIAL=MATERIALFILIAL.FILIAL
         AND MATERIALLOCAL.IDITEM=MATERIALFILIAL.IDITEM)>0
     AND FILIAL=:FILIAL
     AND IDITEM BETWEEN :MATERIALINICIAL AND :MATERIALFINAL;
*/

END
^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE RECALCULARTOTAISESTOQUE TO  SYSDBA;

