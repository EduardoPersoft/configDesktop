update 
    materiallote
set
    quantidade = cast(coalesce((select 
                    sum(materialmovimentoestoque.quantidade*
                        materialmovimentoestoque.sinal)
                  from 
                    MATERIALMOVIMENTOESTOQUE
                  where
                     materialmovimentoestoque.filial=materiallote.filial and
                     materialmovimentoestoque.iditem=materiallote.iditem and
                     MATERIALMOVIMENTOESTOQUE.lote=materiallote.lote),0) as decimal(12.3)),
     valor = cast(coalesce((select 
                    sum(materialmovimentoestoque.valor*
                        materialmovimentoestoque.sinal)
                  from 
                    MATERIALMOVIMENTOESTOQUE
                  where
                     materialmovimentoestoque.filial=materiallote.filial and
                     materialmovimentoestoque.iditem=materiallote.iditem and
                     MATERIALMOVIMENTOESTOQUE.lote=materiallote.lote),0) as decimal(12,3))