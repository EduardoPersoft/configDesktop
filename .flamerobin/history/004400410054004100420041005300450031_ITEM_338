select
    pedido.idnota,
    pedido.datareferencia,
    cadcli.nome,
    count(mercadoriasped.idmercadoria)
from
    PEDIDO
inner join
    cadastroarceiros cadcli on
        cadcli.cadastro=pedido.DESTINATARIO
inner join
    mercadoriasped on
        mercadoriasped.filial=pedido.filial and
        mercadoriasped.idnota=pedido.IDNOTA
where
    pedido.filial=110