insert into INVENTARIOESTOQUEDATA(filial,codigo,lote,local,data,quantidade, quantidadeestoque)
select
    110,
    itemestoque.codigo,
    materiallote.lote,
    local.id as idLocal,
    '31.01.2024',
    0,
    sum(materialmovimentoestoque.quantidade*MATERIALMOVIMENTOESTOQUE.SINAL)
    
from
    MATERIALMOVIMENTOESTOQUE
inner join
    movimentoestoque on
        movimentoestoque.filial=MATERIALMOVIMENTOESTOQUE.filial and
        movimentoestoque.IDMOVIMENTO=MATERIALMOVIMENTOESTOQUE.idmovimento
inner join
    itemestoque on
        itemestoque.codigo=MATERIALMOVIMENTOESTOQUE.IDITEM
inner join
     itemcustodata on
        itemcustodata.filial=MATERIALMOVIMENTOESTOQUE.filial and
        itemcustodata.codigo=materialmovimentoestoque.iditem 
inner join
    local on
        local.ID=materialmovimentoestoque.LOCALARMAZENAMENTO
inner join
    tipoItemEstoque on
        TIPOITEMESTOQUE.id=itemestoque.TIPOPRODUTO
left join 
    GRUPOMERCADORIA on 
    itemestoque.GRUPO=GRUPOMERCADORIA.GRUPO
left join
    materiallote on
        materiallote.filial=MATERIALMOVIMENTOESTOQUE.filial and
        materiallote.iditem=MATERIALMOVIMENTOESTOQUE.iditem and
        materiallote.lote=materialmovimentoestoque.lote
        
where
    movimentoestoque.filial=110 and
    itemcustodata.DATAINVENTARIO='31.01.2024' and
    movimentoestoque.emissao<=itemcustodata.DATAINVENTARIO and
    not exists (select * from INVENTARIOESTOQUEDATA i2
                where i2.filial=110 and
                i2.codigo=MATERIALMOVIMENTOESTOQUE.iditem and
                i2.lote = MATERIALMOVIMENTOESTOQUE.lote and
                i2."LOCAL"=materialmovimentoestoque.LOCALARMAZENAMENTO and
                i2.data='31.01.2024')
    
group by 
    itemestoque.codigo,
    local.id,
    local.descricao,    
    materiallote.lote
HAVING 
   sum(materialmovimentoestoque.quantidade*MATERIALMOVIMENTOESTOQUE.SINAL)>0.001 
