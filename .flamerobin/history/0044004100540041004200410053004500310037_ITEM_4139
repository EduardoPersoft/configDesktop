

select * from TITULOSANEXADOSdoc TITULOSANEXADOS

where exists (
select * from DOCTOBANCARIOS MOVBANCARIOS
where movbancarios.filial=TITULOSANEXADOS.filial and
MOVBANCARIOS.IDCONTACORRENTE=TITULOSANEXADOS.idcontacorrente and
movbancarios.IDMOVTOBANCARIO=TITULOSANEXADOS.IDMOVTOBANC
and MOVBANCARIOS.PROCESSAMENTO='2025-01-23')

