select
    cadven.cadastro,
    cadven.nome,
    (select 
        count(orcamento.idnota) 
     from
        ORCAMENTO
     where
        orcamento.VENDEDOR=cadven.cadastro and
        orcamento.DATACADASTRO between '24.08.2024' and '24.08.2024') qtdorc
      
from
    VENDEDOR
inner join
    CADASTROPARCEIROS cadven 
        vendedor.cadastro=cadven.CADASTRO
where
    cadven.status=1
    