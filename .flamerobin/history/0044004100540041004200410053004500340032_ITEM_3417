SELECT 

    FORNECEDORESITEM.ID,
    FORNECEDORESITEM.FORNECEDOR, 
    FORNECEDORESITEM.CODIGOFORNEC, 
    FORNECEDORESITEM.INDUSTRIAOUIMPORTADOR,    
    FORNECEDORESITEM.STATUS,    
    CASE WHEN ITEMESTOQUE.FORNECEDORPADRAO = FORNECEDORESITEM.FORNECEDOR THEN 'S' ELSE 'N' END AS FORNECEDORPADRAO,
    
    FORNECEDORESITEM.IDITEM,
    ITEMESTOQUE.DESCRICAO,

    FORNECEDORESITEM.CUSTO,
    FORNECEDORESITEM.PRECO,
    FORNECEDORESITEM.IPI,
    FORNECEDORESITEM.ST,    
    

    FORNECEDORESITEM.DATAATUALIZACAO,
    FORNECEDORESITEM.APROVACAO,
    FORNECEDORESITEM.USUARIOAPROVACAO,
    FORNECEDORESITEM.IDUSUARIO
    

FROM 
    FORNECEDORESITEM
INNER JOIN 
    ITEMESTOQUE ON FORNECEDORESITEM.IDITEM = ITEMESTOQUE.CODIGO
where
    FORNECEDORESITEM.FORNECEDOR = 89
