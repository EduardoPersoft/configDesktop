SELECT
    itemestoque.codigo,
    itemestoque.descricao,
    mercadoriasnota.unidade,
    sum(mercadoriasnota.quantidade) quantidade,
    sum(mercadoriasnota.vlrFinalMercad) / 
         sum(mercadoriasnota.quantidade),
    sum(mercadoriasnota.vlrfinalMercad) as valor,
from
    mercadoriasnota
inner join
    itemestoque on 
        itemestoque.codigo=mercadoriasnota.codigo
where
    mercadoriasnota.filial=? and
    mercadoriasnota.destinatario = ? and
    mercadoriasnota.dataemissao = ?

