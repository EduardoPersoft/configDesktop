select FILIAL,
       IDNOTA, 
       DATACADASTRO,
       DATAAPROVACAO,
       CODIGO ,
       CODIGO as iditem,
       DESREDUZIDA,
       QUANTIDADE,
       UNIDADE,
       DESTINATARIO,
       QTDEENTREGUE,
       SALDO,
       DATAENTREGA,
       NOME,
       TELEFONE,
       VALOR,
       VLRTOTALNOTA,
      COALESCE( (select FIRST 1 mercadoriaspedCOMPRA.IDNOTA from mercadoriaspedCOMPRA
      where mercadoriaspedCOMPRA.filial=followupVENDAS.filial
      and mercadoriaspedCOMPRA.idnota=followupVENDAS.idnota
      and mercadoriaspedcompra.codigo=followupVENDAS.codigo
      and mercadoriaspedCOMPRA.IDPEDVEN is NOT null),-1)AS IDPEDCOMPRA ,
      saldototal,
       case when (cast( 'NOW' as timestamp)>dataentrega) then 255
       else 0 end as P_STATUSCOR,
      POSSUICOMPRAS,
      reservadopedido,
      reservadonota,
      reservadoop,
      reservadoprodterc ,
      reservadoexpedicao,
      TOTALRESERVADO
