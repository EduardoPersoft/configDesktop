update
    COMPOSICAOMERCORC COMPOSICAOMERCPED
set
    COMPOSICAOMERCPED.IDITEM=(SELECT MERCADORIASPED.CODIGO FROM MERCADORIASORC MERCADORIASPED
                             WHERE MERCADORIASPED.FILIAL=COMPOSICAOMERCPED.FILIAL
                             AND MERCADORIASPED.IDNOTA=COMPOSICAOMERCPED.IDNOTA 
                             AND MERCADORIASPED.IDMERCADORIA=COMPOSICAOMERCPED.IDMERCADORIA)
                           