UPDATE
 ITEMESTOQUE
SET ITEMESTOQUE.CODIGOBARRA=:CODIGOBARRA, 
ITEMESTOQUE.CODIGOBARRAVOLUME=:CODIGOBARRAVOLUME,
ITEMESTOQUE.PESOLIQUIDO=:PESOLIQUIDO,
ITEMESTOQUE.DISPONIVELECOMMERCE=:DISPONIVELECOMMERCE,
ITEMESTOQUE.FAMILIA=(SELECT FIRST 1  FAMILIA.ID FROM FAMILIA WHERE
                     FAMILIA.DESCRICAO=:FAMILIA),
ITEMESTOQUE.grupo=(SELECT FIRST 1  GRUPOMERCADORIA.grupo FROM GRUPOMERCADORIA WHERE
                     GRUPOMERCADORIA.DESCRICAO=:GRUPO),
ITEMESTOQUE.C_LOCALIMPORTACAO=(SELECT FIRST 1  c_localimportacao.idlocal FROM c_localimportacao WHERE
                     c_localimportacao.DESCRICAO=:localorigem1),

ITEMESTOQUE.C_CODMOEDA=(SELECT FIRST 1 MOEDA.MOEDA FROM MOEDA WHERE
                     MOEDA.DESCRICAO=:MOEDA),
ITEMESTOQUE.CODIGOTRIBUTACAO=:origemitem,     
itemestoque.C_FORNECEDOR=(SELECT C_FORNECEDORPECA.ID FROM C_FORNECEDORPECA
                          WHERE C_FORNECEDORPECA.DESCRICAO=:FORNECEDOR),
ITEMESTOQUE.C_MRFORNECEDOR=:NUMFORNECEDOR,
ITEMESTOQUE.TRIBUTACAOICMS=(SELECT TRIBUTACAOICMS.ID FROM TRIBUTACAOICMS
                            WHERE TRIBUTACAOICMS.DESCRICAO=:TRIBUTACAOICMS),
                     
ITEMESTOQUE.DeSCRIMINACAO=:DeSCRIMINACAO,
ITEMESTOQUE.NOMECOMERCIAL=:NOMECOMERCIAL
WHERE ITEMESTOQUE.CODIGO=:CODIGO