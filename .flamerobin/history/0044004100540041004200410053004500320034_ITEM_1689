 select 
    itemestoque.codigo,
    itemestoque.descricao produto,
    coalesce('Nr.Original: '||itemestoque.REFERENCIA||, '')||coalesce('APLICAÇÃO / VEÍCULOS COMPATÍVEIS '||itemestoque.DEFINICAO, '')||'GARANTIA

Nossas peças tem garantia de 1 ano para defeito de fabricação.
A garantia não cobre danos na peça decorrentes de mau uso ou instalação errada.



======================= NET TRUCK PARTS ======================

- Tire todas suas dúvidas de compatibilidade desta peça para seu caminhão ou Van no campo perguntas antes de confirmar a compra;
- Emitimos NF para todas as compras efetuadas PF ou PJ;
- Temos os produtos a pronta entrega;
- Compras efetuadas no período da manhã são expedidas no mesmo dia.
================================================================ as descricao,' as descricao,
    itemestoque.itembase,
    grupomercadoria.descricao,    
    familia.descricao,
    cast('' as varchar(2)) as lado,
    'https://erp.persoft.com.br/falma/files/'||itemestoque.codigo||'/'||arq1.NOMEARQUIVO,
    materialfilial.customedio,
    materiallocal.SALDOTOTAL,
    tributacaoicmsuf.LUCROSUBSTITUICAO,
    CLASSIFICACAOFISCAL.descricao,
    
    'Troca', 
    1,
    'ano'    
from 
    estabelecimento
inner join 
    materiallocal on
        materiallocal.filial=estabelecimento.cadastro and
        materiallocal.IDLOCAL=1
inner join
    itemestoque on
        itemestoque.codigo=materiallocal.IDITEM        
inner join
    materialfilial on
        materialfilial.filial=materiallocal.filial and
        materialfilial.iditem=materiallocal.IDITEM       
left join
    CADASTROPARCEIROS cadest on
        cadest.cadastro=ESTABELECIMENTO.CADASTRO
left join
    itemestoquexarquivo arq1 on
        arq1.CODIGO=itemestoque.codigo and
        arq1.ORDEM = (Select
                        min(arq2.ordem)
                      from
                        itemestoquexarquivo arq2
                      where
                        arq1.codigo=arq2.codigo)
                        
left join
    TRIBUTACAOICMSUF on
        tributacaoicmsuf.ID=itemestoque.TRIBUTACAOICMS and
        tributacaoicmsuf.uf=cadest.uf
        
left join
    CLASSIFICACAOFISCAL on
        CLASSIFICACAOFISCAL.CFISCAL=itemestoque.CLASSIFISCAL   
left join
    GRUPOMERCADORIA on
        grupomercadoria.GRUPO = itemestoque.GRUPO
left join
    familia on
        familia.id=itemestoque.FAMILIA
where
    estabelecimento.cadastro = 5  and
    itemestoque.DISPONIVELECOMMERCE ='S' and
    arq1.NOMEARQUIVO is not null

    
