SET TERM ^ ;
ALTER PROCEDURE IMPPEDCOMPRA
RETURNS (
    FILIAL INTEGER,
    RAZAOFILIAL VARCHAR(60),
    IDNOTA INTEGER,
    FORNECEDOR INTEGER,
    NOMEFORNECEDOR VARCHAR(60),
    LOGRADOURO VARCHAR(50),
    NUMERO INTEGER,
    BAIRRO VARCHAR(30),
    COMPLEMENTO VARCHAR(20),
    CIDADE VARCHAR(30),
    UF VARCHAR(2),
    CEP VARCHAR(8),
    DOCUMENTO VARCHAR(14),
    INSCESTADUAL VARCHAR(20),
    INSCMUNICIPAL VARCHAR(20),
    EMAIL VARCHAR(50),
    TELEFONE VARCHAR(20),
    FAX VARCHAR(20),
    PRINCIPALCONTATO VARCHAR(40),
    NRPEDFORNECEDOR VARCHAR(20),
    DATAAPROVACAO TIMESTAMP,
    CFOP INTEGER,
    NATUREZAOPERACAO VARCHAR(30),
    VLRIPITOTAL DOUBLE PRECISION,
    VLRDESPESAS DOUBLE PRECISION,
    VLRZONAFRANCA DOUBLE PRECISION,
    VLRSUBSTRIB DOUBLE PRECISION,
    VLRTOTALNOTA DOUBLE PRECISION,
    OBSERVACAO VARCHAR(400),
    COMENTARIO VARCHAR(140),
    VLRDESCONTO DOUBLE PRECISION,
    VLRACRESCIMO DOUBLE PRECISION,
    TIPOPAGTO VARCHAR(30),
    CONDICAOPAGTO VARCHAR(30),
    TIPODETALHE VARCHAR(15),
    CODIGO VARCHAR(15),
    DESCRICAO BLOB SUB_TYPE 0,
    QUANTIDADE DOUBLE PRECISION,
    UNIDADE VARCHAR(3),
    PRUNITARIO DOUBLE PRECISION,
    VLRIPIMERC DOUBLE PRECISION,
    VLRTOTITEM DOUBLE PRECISION,
    ENTREGA TIMESTAMP,
    VLRPARCIAL DOUBLE PRECISION,
    LOGRADOUROFILIAL VARCHAR(50),
    NUMEROFILIAL INTEGER,
    BAIRROFILIAL VARCHAR(30),
    COMPLEMENTOFILIAL VARCHAR(20),
    CIDADEFILIAL VARCHAR(30),
    UFFILIAL VARCHAR(2),
    CEPFILIAL VARCHAR(8),
    EMAILFILIAL VARCHAR(50),
    TELEFONEFILIAL VARCHAR(20),
    FAXFILIAL VARCHAR(20) )
AS
declare variable p_frete double precision;
declare variable p_seguro double precision;
declare variable p_outras double precision;
declare variable p_acrescmerc double precision;
declare variable p_acrescserv double precision;
declare variable p_descmercped double precision;
declare variable p_descindmerc double precision;
declare variable p_descservped double precision;
declare variable p_descindserv double precision;
declare variable p_zonafranca char(1);
declare variable p_totalicms double precision;
declare variable p_substrib char(1);
declare variable p_recolhido double precision;
declare variable p_id integer;
declare variable v_id integer;
BEGIN
/*$$IBEC$$ 
  FOR SELECT PEDIDOCOMPRA.FILIAL, CADASTROFILIAL.RAZAOSOCIAL,
             PEDIDOCOMPRA.IDNOTA, PEDIDOCOMPRA.DESTINATARIO,
             CADASTROFORNECEDOR.NOME AS NOMEFORNECEDOR,
             CADASTROFORNECEDOR.LOGRADOURO, CADASTROFORNECEDOR.NUMERO,
             CADASTROFORNECEDOR.BAIRRO, CADASTROFORNECEDOR.COMPLEMENTO,
             CADASTROFORNECEDOR.CIDADE, CADASTROFORNECEDOR.UF,
             CADASTROFORNECEDOR.CEP, CADASTROFORNECEDOR.DOCUMENTO,
             CADASTROFORNECEDOR.INSCESTADUAL, CADASTROFORNECEDOR.INSCMUNICIPAL, 
             CADASTROFORNECEDOR.EMAIL,
             CADASTROFORNECEDOR.TELEFONE, CADASTROFORNECEDOR.FAX,
             CADASTROFORNECEDOR.PRINCIPALCONTATO,
             PEDIDOCOMPRA.NRPEDFORNECEDOR, PEDIDOCOMPRA.DATAAPROVACAO,
             PEDIDOCOMPRA.CFOP, PEDIDOCOMPRA.NATUREZAOPERACAO,
             PEDIDOCOMPRA.VALORIPI, 
             PEDIDOCOMPRA.VALORFRETE, PEDIDOCOMPRA.VALORSEGURO,
             PEDIDOCOMPRA.VLROUTDESPACESSORIA, 
             PEDIDOCOMPRA.ZONAFRANCA, PEDIDOCOMPRA.TOTVALORICMS, 
             PEDIDOCOMPRA.SUBSTRIBUTARIA, PEDIDOCOMPRA.VLRICMSRECOLHIDO,
             PEDIDOCOMPRA.VLRTOTALNOTA, PEDIDOCOMPRA.OBSERVACAO,
             PEDIDOCOMPRA.COMENTARIO, 
             PEDIDOCOMPRA.VLRACRESCMERCAD, PEDIDOCOMPRA.VLRACRESCSERVICOS, 
             PEDIDOCOMPRA.VLRDESCINDPRODUTO, PEDIDOCOMPRA.VLRDESCINDSERVICOS, 
             PEDIDOCOMPRA.VLRDESCMERCADORIAS, PEDIDOCOMPRA.VLRDESCSERVICOS,
             TIPOPAGAMENTO.DESCRICAO AS TIPOPAGTO, 
             CONDICAOPAGAMENTO.DESCRICAO AS CONDPAGTO,
             CADASTROFILIAL.LOGRADOURO, CADASTROFILIAL.NUMERO,
             CADASTROFILIAL.BAIRRO, CADASTROFILIAL.COMPLEMENTO,
             CADASTROFILIAL.CIDADE, CADASTROFILIAL.UF,
             CADASTROFILIAL.CEP, CADASTROFILIAL.EMAIL,
             CADASTROFILIAL.TELEFONE, CADASTROFILIAL.FAX
      FROM PEDIDOCOMPRA
      INNER JOIN ESTSIN ON (ESTSIN.RELATORIO='COMPRA' AND
                            PEDIDOCOMPRA.FILIAL=ESTSIN.ESTABELECIMENTO AND
                            PEDIDOCOMPRA.IDNOTA BETWEEN ESTSIN.IDNOTAINICIAL AND
                                                        ESTSIN.IDNOTAFINAL)
      INNER JOIN CADASTROPARCEIROS CADASTROFILIAL ON (PEDIDOCOMPRA.FILIAL=CADASTROFILIAL.CADASTRO)
      INNER JOIN CADASTROPARCEIROS CADASTROFORNECEDOR ON (PEDIDOCOMPRA.DESTINATARIO=CADASTROFORNECEDOR.CADASTRO)
      LEFT JOIN TIPOPAGAMENTO ON (PEDIDOCOMPRA.TIPOPAGAMENTO=TIPOPAGAMENTO.ID)
      LEFT JOIN CONDICAOPAGAMENTO ON (CONDICAOPAGAMENTO.ID=PEDIDOCOMPRA.CONDICAOPAGAMENTO)

       $$IBEC$$*//*
      WHERE NOT (PEDIDOCOMPRA.DATAAPROVACAO IS NULL)
      AND   PEDIDOCOMPRA.DATACANCELAMENTO IS NULL
      *//*$$IBEC$$ 
      ORDER BY PEDIDOCOMPRA.FILIAL, PEDIDOCOMPRA.IDNOTA 
      INTO :FILIAL, :RAZAOFILIAL, :IDNOTA, :FORNECEDOR, :NOMEFORNECEDOR, 
           :LOGRADOURO, :NUMERO, :BAIRRO, :COMPLEMENTO, :CIDADE, :UF, 
           :CEP, :DOCUMENTO, :INSCESTADUAL, :INSCMUNICIPAL, :EMAIL, 
           :TELEFONE, :FAX, :PRINCIPALCONTATO, :NRPEDFORNECEDOR, 
           :DATAAPROVACAO, :CFOP, :NATUREZAOPERACAO, :VLRIPITOTAL, 
           :P_FRETE, :P_SEGURO, :P_OUTRAS,
           :P_ZONAFRANCA, :P_TOTALICMS, :P_SUBSTRIB, :P_RECOLHIDO,
           :VLRTOTALNOTA, :OBSERVACAO, :COMENTARIO, 
           :P_ACRESCMERC, :P_ACRESCSERV, :P_DESCINDMERC, 
           :P_DESCINDSERV, :P_DESCMERCPED, :P_DESCSERVPED, 
           :TIPOPAGTO, :CONDICAOPAGTO,:LOGRADOUROFILIAL,:NUMEROFILIAL,
           :BAIRROFILIAL,:COMPLEMENTOFILIAL,:CIDADEFILIAL,:UFFILIAL,:CEPFILIAL,
           :EMAILFILIAL,:TELEFONEFILIAL,:FAXFILIAL
  DO BEGIN
     IF (:P_DESCINDMERC IS NULL) THEN
        P_DESCINDMERC = 0; 
     IF (:P_DESCINDSERV IS NULL) THEN
        P_DESCINDSERV = 0; 
     IF (:P_DESCMERCPED IS NULL) THEN
        P_DESCMERCPED = 0; 
     IF (:P_DESCSERVPED IS NULL) THEN
        P_DESCSERVPED = 0; 
     IF (:P_ZONAFRANCA = 'S') THEN
        VLRZONAFRANCA = P_TOTALICMS;
     ELSE
        VLRZONAFRANCA = NULL;
     IF (:P_SUBSTRIB = 'S') THEN
        VLRSUBSTRIB = P_RECOLHIDO;
     ELSE
        VLRSUBSTRIB = NULL;
     VLRDESCONTO = NULL;
     VLRACRESCIMO = NULL;
     V_ID = NULL;
     FOR SELECT MERCADORIASPEDCOMPRA.CODIGO, MERCADORIASPEDCOMPRA.DESCRICAO,
                PRAZOMERCPEDCOMPRA.QTDE, MERCADORIASPEDCOMPRA.UNIDADE,
                MERCADORIASPEDCOMPRA.PRECOUNITARIO, MERCADORIASPEDCOMPRA.VALORIPI,
                MERCADORIASPEDCOMPRA.VLRTOTALMERCAD,
                (PRAZOMERCPEDCOMPRA.DIAS+:DATAAPROVACAO) AS ENTREGA,
                MERCADORIASPEDCOMPRA.IDMERCADORIA
         FROM MERCADORIASPEDCOMPRA
         INNER JOIN PRAZOMERCPEDCOMPRA ON (
                    MERCADORIASPEDCOMPRA.FILIAL=PRAZOMERCPEDCOMPRA.FILIAL AND
                    MERCADORIASPEDCOMPRA.IDNOTA=PRAZOMERCPEDCOMPRA.IDNOTA AND
                    MERCADORIASPEDCOMPRA.IDMERCADORIA=PRAZOMERCPEDCOMPRA.IDITEM)
         WHERE MERCADORIASPEDCOMPRA.FILIAL=:FILIAL
         AND   MERCADORIASPEDCOMPRA.IDNOTA=:IDNOTA
         ORDER BY MERCADORIASPEDCOMPRA.IDMERCADORIA
         INTO :CODIGO, :DESCRICAO, :QUANTIDADE, :UNIDADE, :PRUNITARIO, 
             :VLRIPIMERC, :VLRTOTITEM, :ENTREGA, :P_ID
     DO BEGIN
        IF (:P_FRETE IS NULL) THEN
           P_FRETE = 0;
        IF (:P_SEGURO IS NULL) THEN
           P_SEGURO = 0;
        IF (:P_OUTRAS IS NULL) THEN
           P_OUTRAS = 0;
        IF ((:P_DESCINDMERC > 0) OR (:P_DESCMERCPED > 0)) THEN
           VLRDESCONTO = :P_DESCINDMERC+P_DESCMERCPED;
        IF (:P_ACRESCMERC > 0) THEN
           VLRACRESCIMO = :P_ACRESCMERC;
        VLRDESPESAS = :P_FRETE + :P_SEGURO + :P_OUTRAS;
        VLRPARCIAL = :VLRDESPESAS;
        IF (:VLRACRESCIMO IS NOT NULL) THEN
           VLRPARCIAL = VLRPARCIAL+:VLRACRESCIMO;
        IF (:VLRSUBSTRIB IS NOT NULL) THEN
           VLRPARCIAL = :VLRPARCIAL + :VLRSUBSTRIB;
        IF (:VLRIPITOTAL IS NOT NULL) THEN
           VLRPARCIAL = :VLRPARCIAL + :VLRIPITOTAL;
        IF (:VLRZONAFRANCA IS NOT NULL) THEN
           VLRPARCIAL = :VLRPARCIAL - :VLRZONAFRANCA;
        IF (:VLRDESCONTO IS NOT NULL) THEN
           VLRPARCIAL = :VLRPARCIAL - :VLRDESCONTO;
        IF (:P_ZONAFRANCA = 'S') THEN
           VLRIPIMERC = NULL;
        IF (:P_ID = :V_ID) THEN BEGIN
           CODIGO = NULL;
           DESCRICAO = NULL;
           UNIDADE = NULL;
           PRUNITARIO = NULL; 
           VLRIPIMERC = NULL;
           VLRTOTITEM = NULL;
        END
        V_ID = P_ID;
        TIPODETALHE = 'MERCADORIAS';
        IF (:VLRDESPESAS = 0) THEN
           VLRDESPESAS = NULL;
        SUSPEND;
     END 

     VLRIPIMERC = NULL;
     VLRDESCONTO = NULL;
     VLRACRESCIMO = NULL;
     V_ID = NULL;
     FOR SELECT CAST(SERVICOSPEDCOMPRA.CODIGO AS VARCHAR(15)), SERVICOSPEDCOMPRA.DESCRICAO,
                PRAZOSERVPEDCOMPRA.QTDE, SERVICOSPEDCOMPRA.UNIDADE,
                SERVICOSPEDCOMPRA.PRECOUNITARIO, 
                SERVICOSPEDCOMPRA.VLRTOTSERVICO,
                (PRAZOSERVPEDCOMPRA.DIAS+:DATAAPROVACAO) AS ENTREGA,
                SERVICOSPEDCOMPRA.IDSERVICO
         FROM SERVICOSPEDCOMPRA
         INNER JOIN PRAZOSERVPEDCOMPRA ON (
                    SERVICOSPEDCOMPRA.FILIAL=PRAZOSERVPEDCOMPRA.FILIAL AND
                    SERVICOSPEDCOMPRA.IDNOTA=PRAZOSERVPEDCOMPRA.IDNOTA AND
                    SERVICOSPEDCOMPRA.IDSERVICO=PRAZOSERVPEDCOMPRA.IDITEM)
         WHERE SERVICOSPEDCOMPRA.FILIAL=:FILIAL
         AND   SERVICOSPEDCOMPRA.IDNOTA=:IDNOTA
         ORDER BY SERVICOSPEDCOMPRA.CODIGO
         INTO :CODIGO, :DESCRICAO, :QUANTIDADE, :UNIDADE, :PRUNITARIO, 
              :VLRTOTITEM, :ENTREGA, :P_ID
     DO BEGIN
        VLRPARCIAL = 0;
        IF ((:P_DESCINDSERV > 0) OR (:P_DESCSERVPED > 0)) THEN
           VLRDESCONTO = :P_DESCINDSERV+P_DESCSERVPED;
        IF (:P_ACRESCSERV > 0) THEN
           VLRACRESCIMO = :P_ACRESCSERV;
        IF (:VLRACRESCIMO IS NOT NULL) THEN
           VLRPARCIAL = :VLRACRESCIMO;
        IF (:VLRDESCONTO IS NOT NULL) THEN
           VLRPARCIAL = :VLRPARCIAL - :VLRDESCONTO;
        IF (:P_ID = :V_ID) THEN BEGIN
           CODIGO = NULL;
           DESCRICAO = NULL;
           UNIDADE = NULL;
           PRUNITARIO = NULL; 
           VLRTOTITEM = NULL;
        END
        V_ID = P_ID;
        TIPODETALHE = 'SERVI?OS';
        SUSPEND;
     END
  END $$IBEC$$*/
END^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE IMPPEDCOMPRA TO  SYSDBA;

