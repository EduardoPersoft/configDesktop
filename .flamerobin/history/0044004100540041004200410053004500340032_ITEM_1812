update 
    materiallocal
set
    saldototal = coalesce((select 
                    sum(materialmovimentoestoque.quantidade*
                        materialmovimentoestoque.sinal)
                  from 
                    MATERIALMOVIMENTOESTOQUE
                  where
                     materialmovimentoestoque.filial=materiallocal.filial and
                     materialmovimentoestoque.iditem=materiallocal.iditem and
                     MATERIALMOVIMENTOESTOQUE.LOCALARMAZENAMENTO=materiallocal.IDLOCAL),0)