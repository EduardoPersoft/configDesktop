select
    venPed.VENDEDOR indicador,
    cadind.NOME,
    cadind.datacadastro,
    cadInd.c_datanascimento,
    cadInd.dataalteracao,
    cadven.nome,
    cadloja.nome,
    ramoatividade.descricao ramoatividade,
    extract(year from det.DATAreferencia) as ano,
    sum(det.vlrTotalNota*venPed.comissaoVenda/100*case det.idnota when coalesce(master.C_PEDIDOSUBSTITUIDO,-1) then -1 else 1 end) totalAnoAnterior,
     count(case det.idnota when coalesce(master.C_PEDIDOSUBSTITUIDO,-1) then null else det.idnota end) as qtd
    
from  
 PEDIDO MASTER 

inner join 
    pedido det on
    det.filial=master.FILIAL and 
    det.IDNOTA in (master.idnota,master.C_PEDIDOSUBSTITUIDO)

inner join 
    VENDEDORESPED venped on 
    venPed.FILIAL=det.FILIAL and
    venPed.idnota=det.idnota
inner join  
    CADASTROPARCEIROS cadind on 
    venPed.VENDEDOR=cadind.CADASTRO

inner join 
    VENDEDOR indicador on 
    venPed.vendedor=indicador.cadastro
inner join 
    vendedor vend on 
    vend.cadastro=indicador.CANALRELACIONADO
inner join 
    CADASTROPARCEIROS cadven on 
    vend.CADASTRO=cadven.CADASTRO
inner join 
    VENDEDOR loja on 
    vend.CANALRELACIONADO=loja.CADASTRO
inner join 
    CADASTROPARCEIROS cadloja on 
    loja.CADASTRO=cadloja.CADASTRO
left join 
    RAMOATIVIDADE on 
    ramoatividade.ramoatividade=cadind.ramoatividade
where 
    MASTER.FILIAL =1 and
    indicador.TIPOVENDEDOR in (5,6) and
    extract (year from MASTER.DATAreferencia) between '01.01.2025' and '31.12.2025' AND 
    MASTER.c_tipo =0 and 
    MASTER.DATAEMISSAO is not null and
    MASTER.CANCELAMENTO ='N'
group by 
    venPed.VENDEDOR,
    cadind.NOME,
    cadind.DATACADASTRO,
    cadInd.c_datanascimento,
    cadInd.dataalteracao,
    cadven.nome,
    cadloja.nome,
    ramoatividade.descricao,
    extract(year from det.DATAreferencia)
