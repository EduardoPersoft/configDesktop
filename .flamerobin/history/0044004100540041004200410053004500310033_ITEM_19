SET TERM ^ ;
ALTER PROCEDURE C_FATURAMENTOORC (
    PDATAINICIAL TIMESTAMP,
    PDATAFINAL TIMESTAMP,
    PFILIAL INTEGER )
RETURNS (
    CODIGO VARCHAR(15),
    VLRFINALMERCAD NUMERIC(12,3),
    IDNOTA INTEGER,
    IDMERCADORIA INTEGER,
    VENDEDOR INTEGER,
    RAZAOVENDEDOR VARCHAR(60),
    DESTINATARIO INTEGER,
    DATAINICIAL TIMESTAMP,
    DATAFINAL TIMESTAMP,
    FILIAL INTEGER,
    C_COLUNA SMALLINT )
AS
begin

 datainicial=pdatainicial;
 datafinal=pdatafinal;
 filial=pfilial;

 for SELECT
    orcamento.idnota,
    orcamento.DESTINATARIO
 FROM
    ORCAMENTO
 where  
    ORCAMENTO.filial=:PFILIAL
    and ORCAMENTO.DATAEMISSAO IS NOT NULL
    and ORCAMENTO.DATAEMISSAO between :DATAINICIAL and :datafinal
    AND coalesce  (ORCAMENTO.CANCELAMENTO,'N')<>'S'
 into :IDNOTA, :destinatario do BEGIN
    
    
    SELECT
        FIRST 1
        VENDEDORESORC.VENDEDOR,
        CADVEN.RAZAOSOCIAL
    FROM
        VENDEDORESORC
    INNER JOIN
        CADASTROPARCEIROS CADVEN ON
            CADVEN.CADASTRO=VENDEDORESORC.VENDEDOR
    WHERE
        VENDEDORESORC.FILIAL=:FILIAL
        AND VENDEDORESORC.IDNOTA=:IDNOTA
    INTO :VENDEDOR, :RAZAOVENDEDOR;

    
    for SELECT
        MERCADORIASORC.IDMERCADORIA,
        MERCADORIASORC.CODIGO,
        (mercadoriasORC.VLRFINALMERCAD+mercadoriasORC.ACRESCIMONOTA)-mercadoriasORC.DESCONTONOTA,
        COALESCE (GRUPOMERCADORIA.C_COLUNA,0)
    from 
        ORCAMENTO
    LEFT join 
        MERCADORIASORC on 
            (MERCADORIASORC.filial=ORCAMENTO.FILIAL
             and MERCADORIASORC.idnota=ORCAMENTO.idnota)
    LEFT JOIN 
        ITEMESTOQUE ON 
            (ITEMESTOQUE.CODIGO=MERCADORIASORC.CODIGO)
    Left JOIN 
        GRUPOMERCADORIA ON 
            (ITEMESTOQUE.GRUPO=GRUPOMERCADORIA.GRUPO)
    WHERE 
        MERCADORIASORC.FILIAL=:FILIAL 
        AND MERCADORIASORC.IDNOTA=:IDNOTA
    into :IDMERCADORIA, :codigo, :VLRFINALMERCAD , :C_COLUNA DO
        SUSPEND;
 
    FOR SELECT
        SERVICOSORC.IDSERVICO,
        CAST  (SERVICOSORC.CODIGO AS VARCHAR (15)),
        (SERVICOSORC.VLRFINALSERVICO+SERVICOSORC.ACRESCIMONOTA)-SERVICOSORC.DESCONTONOTA,
        COALESCE (GRUPOSERVICO.C_COLUNA,0)
    from ORCAMENTO
    LEFT join 
        SERVICOSORC on 
            (SERVICOSORC.filial=ORCAMENTO.FILIAL
             and SERVICOSORC.idnota=ORCAMENTO.idnota)
    LEFT JOIN 
        SERVICO ON 
            (SERVICO.CODIGO=SERVICOSORC.CODIGO)
    left JOIN 
        GRUPOSERVICO ON 
            (SERVICO.GRUPOSERVICO=GRUPOSERVICO.GRUPO)
    where 
        SERVICOSORC.FILIAL=:FILIAL 
        AND SERVICOSORC.IDNOTA=:IDNOTA
    into :IDMERCADORIA,:codigo, :VLRFINALMERCAD, :C_COLUNA DO
        SUSPEND;
 end
end^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE C_FATURAMENTOORC TO  SYSDBA;

