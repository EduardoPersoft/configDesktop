select
    C_PEDIDOSEMABERTOPRODUCAO.FILIAL,
    C_PEDIDOSEMABERTOPRODUCAO.IDPEDIDO,
    C_PEDIDOSEMABERTOPRODUCAO.IDMERCADORIAPED,
    C_PEDIDOSEMABERTOPRODUCAO.DATAREFERENCIA,
    C_PEDIDOSEMABERTOPRODUCAO.PREVISAOVENDAS,
    C_PEDIDOSEMABERTOPRODUCAO.PREVISAOPRODUCAO,
    C_PEDIDOSEMABERTOPRODUCAO.CLIENTENOME,

    C_PEDIDOSEMABERTOPRODUCAO.CODIGO,
    C_PEDIDOSEMABERTOPRODUCAO.DESCRICAOPRODUTO,
    C_PEDIDOSEMABERTOPRODUCAO.NOVOREPETICAOALTERACAO,
    c_pedidosemabertoproducao.quantidadeproduzir,

    c_pedidosemabertoproducao.unidade,
    C_PEDIDOSEMABERTOPRODUCAO.ARTEOK,

    C_PEDIDOSEMABERTOPRODUCAO.DATAPREVISTAARTE,
    C_PEDIDOSEMABERTOPRODUCAO.CLICHEOK,

    C_PEDIDOSEMABERTOPRODUCAO.DATAPREVISTACLICHE,
    C_PEDIDOSEMABERTOPRODUCAO.OP,

    --C_PEDIDOSEMABERTOPRODUCAO.IMPRESSAOTEM,
    --C_PEDIDOSEMABERTOPRODUCAO.IMPRESSAOCONCLUIDO,
    C_PEDIDOSEMABERTOPRODUCAO.C_STATUSARTE,
    --C_PEDIDOSEMABERTOPRODUCAO.IMPRESSAOID,
    --C_PEDIDOSEMABERTOPRODUCAO.itemImpresso,
    --C_PEDIDOSEMABERTOPRODUCAO.dtmpimpressao,
    C_PEDIDOSEMABERTOPRODUCAO.ESTRUTURA,
    C_PEDIDOSEMABERTOPRODUCAO.ARQUIVO,
    C_PEDIDOSEMABERTOPRODUCAO.ITEMAPROVADO,
    --C_PEDIDOSEMABERTOPRODUCAO.OPATRASADA,

    C_PEDIDOSEMABERTOPRODUCAO.FILIALPEDCLICHE,
    C_PEDIDOSEMABERTOPRODUCAO.IDPEDIDOCLICHE,
    C_PEDIDOSEMABERTOPRODUCAO.IDMERCPEDCLICHE,
    C_PEDIDOSEMABERTOPRODUCAO.VALORCLICHE,
    
    C_PEDIDOSEMABERTOPRODUCAO.FILIALPEDCLICHEVENDA,
    C_PEDIDOSEMABERTOPRODUCAO.IDPEDIDOCLICHEVENDA,
    C_PEDIDOSEMABERTOPRODUCAO.IDMERCPEDCLICHEVENDA,
    C_PEDIDOSEMABERTOPRODUCAO.VALORCLICHEVENDA

from 
    C_PEDIDOSEMABERTOPRODUCAO (?)
where
    C_PEDIDOSEMABERTOPRODUCAO.CLICHEOK<>'0' or
    C_PEDIDOSEMABERTOPRODUCAO.FILIALPEDCLICHE is not null or
    C_PEDIDOSEMABERTOPRODUCAO.FILIALPEDCLICHEVENDA is not null
union  
select
    MERCADORIASPED.FILIAL,
    MERCADORIASPED.IDNOTA IDPEDIDO,
    MERCADORIASPED.IDMERCADORIA IDMERCADORIAPED,
    PEDIDO.DATAREFERENCIA,
    PEDIDO.ENTREGA,
    MOVIMENTOESTOQUE.PREVISAOFIMPRODUCAO,
    CADASTROPARCEIROS.NOME,

    MERCADORIASPED.CODIGO,
    ITEMESTOQUE.descricao DESCRICAOPRODUTO,
    MERCADORIASPED.C_NOVOREPETICAOALTERADO NOVOREPETICAOALTERACAO,
    COALESCE(MATERIALMOVIMENTOESTOQUE.quantidade, mercadoriasped.quantidade) quantidadeproduzir,

    mercadoriasped.unidade,
    coalesce(mercadoriasped.c_arte, 'N') C_ARTEOK,

    mercadoriasped.C_DATAARTE DATAPREVISTAARTE,
    itemestoque.C_CLICHE clicheok,

    itemestoque.C_DATACLICHE DATAPREVISTACLICHE,
    movimentoestoque.idmovimento OP,
    --C_PEDIDOSEMABERTOPRODUCAO.IMPRESSAOTEM,
    --C_PEDIDOSEMABERTOPRODUCAO.IMPRESSAOCONCLUIDO,
    mercadoriasped.C_STATUSARTE ,
    --C_PEDIDOSEMABERTOPRODUCAO.IMPRESSAOID,
    --C_PEDIDOSEMABERTOPRODUCAO.itemImpresso,
    --C_PEDIDOSEMABERTOPRODUCAO.dtmpimpressao,
    itemestoque. itembase ESTRUTURA,
    ITEMESTOQUEXARQUIVO.NOMEARQUIVO ARQUIVO,
    itemestoque.aprovado ITEMAPROVADO,
    --C_PEDIDOSEMABERTOPRODUCAO.OPATRASADA,

    servicospedcompra.C_FILIALPEDVEN FILIALPEDCLICHE,
    servicospedcompra.C_IDPEDVEN IDPEDIDOCLICHE,
    servicospedcompra.C_IDMERCVEN IDMERCPEDCLICHE,
    servicospedcompra.VLRFINALSERVICO VALORCLICHE,
    
    servicosped.C_FILIALPEDVEN FILIALPEDCLICHEVEN,
    servicosped.C_IDPEDVEN IDPEDIDOCLICHEVEN,
    servicosped.C_IDMERCVEN IDMERCPEDCLICHEVEN,
    servicosped.VLRFINALSERVICO VALORCLICHEVEN
from 
    SERVICOSPEDCOMPRA
inner join
    mercadoriasped on
          MERCADORIASPED.filial=SERVICOSPEDCOMPRA.C_FILIALPEDVEN and
          MERCADORIASPED.idnota=SERVICOSPEDCOMPRA.C_IDPEDVEN and
          MERCADORIASPED.IDMERCADORIA=SERVICOSPEDCOMPRA.C_IDMERCVEN
inner join
    pedido on
        pedido.filial=mercadoriasped.filial and
        pedido.idnota=mercadoriasped.idnota
inner join
    CADASTROPARCEIROS on
        CADASTROPARCEIROS.cadastro=pedido.destinatario

inner join 
    ITEMESTOQUE on 
        MERCADORIASPED.CODIGO=ITEMESTOQUE.CODIGO
left join
    ITEMESTOQUEXARQUIVO on
        ITEMESTOQUEXARQUIVO.CODIGO=itemestoque.codigo and
        itemestoquexarquivo.ORDEM=0
        
left join 
    MATERIALMOVIMENTOESTOQUE on
        MATERIALMOVIMENTOESTOQUE.filial=mercadoriasped.filial and
        MATERIALMOVIMENTOESTOQUE.IDPEDIDO=mercadoriasped.idnota and
        MATERIALMOVIMENTOESTOQUE.IDMERCADORIA=mercadoriasped.IDMERCADORIA and
        MATERIALMOVIMENTOESTOQUE.PRODUTO=MATERIALMOVIMENTOESTOQUE.iditem 
 
        
left join 
    MOVIMENTOESTOQUE on 
    MOVIMENTOESTOQUE.filial=MATERIALmovimentoestoque.filial and
    MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALmovimentoestoque.IDMOVIMENTO and
    MOVIMENTOESTOQUE.TIPOMOVIMENTO='12'
 
left join 
    servicosped on 
    servicosped.c_filialpedven = mercadoriasped.filial and   
    servicosped.c_idpedven = mercadoriasped.idnota and  
    servicosped.c_idmercven = mercadoriasped.idmercadoria       
    
where 
    mercadoriasped.FILIAL=? and 
    mercadoriasped.baixa='S' and
    SERVICOSPEDCOMPRA.BAIXA='N' 

union
select
    MERCADORIASPED.FILIAL,
    MERCADORIASPED.IDNOTA IDPEDIDO,
    MERCADORIASPED.IDMERCADORIA IDMERCADORIAPED,
    PEDIDO.DATAREFERENCIA,
    PEDIDO.ENTREGA,
    MOVIMENTOESTOQUE.PREVISAOFIMPRODUCAO,
    CADASTROPARCEIROS.NOME,

    MERCADORIASPED.CODIGO,
    ITEMESTOQUE.descricao DESCRICAOPRODUTO,
    MERCADORIASPED.C_NOVOREPETICAOALTERADO NOVOREPETICAOALTERACAO,
    COALESCE(MATERIALMOVIMENTOESTOQUE.quantidade, mercadoriasped.quantidade) quantidadeproduzir,

    mercadoriasped.unidade,
    coalesce(mercadoriasped.c_arte, 'N') C_ARTEOK,

    mercadoriasped.C_DATAARTE DATAPREVISTAARTE,
    itemestoque.C_CLICHE clicheok,

    itemestoque.C_DATACLICHE DATAPREVISTACLICHE,
    movimentoestoque.idmovimento OP,
    --C_PEDIDOSEMABERTOPRODUCAO.IMPRESSAOTEM,
    --C_PEDIDOSEMABERTOPRODUCAO.IMPRESSAOCONCLUIDO,
    mercadoriasped.C_STATUSARTE ,
    --C_PEDIDOSEMABERTOPRODUCAO.IMPRESSAOID,
    --C_PEDIDOSEMABERTOPRODUCAO.itemImpresso,
    --C_PEDIDOSEMABERTOPRODUCAO.dtmpimpressao,
    itemestoque. itembase ESTRUTURA,
    ITEMESTOQUEXARQUIVO.NOMEARQUIVO ARQUIVO,
    itemestoque.aprovado ITEMAPROVADO,
    --C_PEDIDOSEMABERTOPRODUCAO.OPATRASADA,

    servicospedcompra.filial FILIALPEDCLICHE,
    servicospedcompra.idnota IDPEDIDOCLICHE,
    servicospedcompra.idservico IDMERCPEDCLICHE,
    servicospedcompra.VLRFINALSERVICO VALORCLICHE,
    
    servicosped.filial FILIALPEDCLICHEVEN,
    servicosped.idnota IDPEDIDOCLICHEVEN,
    servicosped.idservico IDMERCPEDCLICHEVEN,
    servicosped.VLRFINALSERVICO VALORCLICHEVEN
from 
    SERVICOSPED
inner join
    mercadoriasped on
          MERCADORIASPED.filial=SERVICOSPED.C_FILIALPEDVEN and
          MERCADORIASPED.idnota=SERVICOSPED.C_IDPEDVEN and
          MERCADORIASPED.IDMERCADORIA=SERVICOSPED.C_IDMERCVEN
inner join
    pedido on
        pedido.filial=mercadoriasped.filial and
        pedido.idnota=mercadoriasped.idnota
inner join
    CADASTROPARCEIROS on
        CADASTROPARCEIROS.cadastro=pedido.destinatario

inner join 
    ITEMESTOQUE on 
        MERCADORIASPED.CODIGO=ITEMESTOQUE.CODIGO
left join
    ITEMESTOQUEXARQUIVO on
        ITEMESTOQUEXARQUIVO.CODIGO=itemestoque.codigo and
        itemestoquexarquivo.ORDEM=0
        
left join 
    MATERIALMOVIMENTOESTOQUE on
        MATERIALMOVIMENTOESTOQUE.filial=mercadoriasped.filial and
        MATERIALMOVIMENTOESTOQUE.IDPEDIDO=mercadoriasped.idnota and
        MATERIALMOVIMENTOESTOQUE.IDMERCADORIA=mercadoriasped.IDMERCADORIA and
        MATERIALMOVIMENTOESTOQUE.PRODUTO=MATERIALMOVIMENTOESTOQUE.iditem 
 
        
left join 
    MOVIMENTOESTOQUE on 
    MOVIMENTOESTOQUE.filial=MATERIALmovimentoestoque.filial and
    MOVIMENTOESTOQUE.IDMOVIMENTO=MATERIALmovimentoestoque.IDMOVIMENTO and
    MOVIMENTOESTOQUE.TIPOMOVIMENTO='12'
 
left join 
    servicospedcompra on 
    servicospedcompra.c_filialpedven = mercadoriasped.filial and   
    servicospedcompra.c_idpedven = mercadoriasped.idnota and  
    servicospedcompra.c_idmercven = mercadoriasped.idmercadoria       
    
where 
    mercadoriasped.filial=? and
    SERVICOSPED.BAIXA='N' and
    mercadoriasped.baixa='S' and
    coalesce(servicospedcompra.baixa, '')<>'N'
   