SELECT
    mercadoriasnotacompra.*
FROM
    NOTAcompra
inner JOIN
    mercadoriasnotacompra on
        mercadoriasnotacompra.filial=notacompra.filial AND
        mercadoriasnotacompra.idnota=notacompra.idnota
WHERE
    notacompra.filial=1 AND
    notacompra.dataemissao between '01.09.2021' and '30.09.2021' AND
    mercadoriasnotacompra.cfop= '5924'