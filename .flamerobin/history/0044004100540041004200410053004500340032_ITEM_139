select
    CONTASCONTABEIS.CONTACONTABIL,
    case when MOVTOBANCARIOLANCAMENTOS.TRANSFERENCIA = 'S' then 'Transferencia' else CONTASCONTABEIS.descricao end,
    sum(VALORMOVIMENTO) valor,
    sum(case MOVTOBANCARIOLANCAMENTOS.CONTACONTABIL when CONTASCONTABEIS.CONTACONTABIL
         then MOVTOBANCARIOLANCAMENTOS.VALORMOVIMENTO else 0 end)
from
    MOVTOBANCARIOLANCAMENTOS(3941, '01.08.2023', '31.08.2023', 'PRIMEFLEX', 4)
left join
    CONTASCONTABEIS on
        CONTASCONTABEIS.idplano=4 and
        MOVTOBANCARIOLANCAMENTOS.contacontabil like CONTASCONTABEIS.CONTACONTABIL||'%'

group by    
    CONTASCONTABEIS.CONTACONTABIL,
    MOVTOBANCARIOLANCAMENTOS.transferencia,
    CONTASCONTABEIS.descricao
