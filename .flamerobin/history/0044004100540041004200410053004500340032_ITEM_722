SELECT RESUMOPERIODO.IDITEM,
       RESUMOPERIODO.DESCRICAOPRODUTO,
       RESUMOPERIODO.UNIDADE,

       CASE WHEN  SUM(RESUMOPERIODO.SALDOQUANTIDADE) +SUM(RESUMOPERIODO.SAIDAQUANTIDADE)                                
-SUM(RESUMOPERIODO.ENTRADAQUANTIDADE) < 0.01 AND
     SUM(RESUMOPERIODO.SALDOQUANTIDADE) +SUM(RESUMOPERIODO.SAIDAQUANTIDADE)                                
-SUM(RESUMOPERIODO.ENTRADAQUANTIDADE) > -0.01  THEN 0
      ELSE
       SUM(RESUMOPERIODO.saldoquantidade) + SUM(RESUMOPERIODO.saidaquantidade) - SUM(RESUMOPERIODO.entradaquantidade) END
           AS InicioQtde,

       CASE WHEN  SUM(RESUMOPERIODO.SALDOVALOR) +SUM(RESUMOPERIODO.SAIDAVALOR)
-SUM(RESUMOPERIODO.ENTRADAVALOR) < 0.01 AND
     SUM(RESUMOPERIODO.SALDOVALOR) +SUM(RESUMOPERIODO.SAIDAVALOR)
-SUM(RESUMOPERIODO.ENTRADAVALOR) > -0.01  THEN 0
      ELSE
       SUM(RESUMOPERIODO.SALDOVALOR) + SUM(RESUMOPERIODO.SAIDAVALOR) - SUM(RESUMOPERIODO.ENTRADAVALOR) END
           AS InicioValor,
           ----
      CASE WHEN  SUM(RESUMOPERIODO.SALDOQUANTIDADE) +SUM(RESUMOPERIODO.SAIDAQUANTIDADE)                                
-SUM(RESUMOPERIODO.ENTRADAQUANTIDADE) < 0.01 AND
     SUM(RESUMOPERIODO.SALDOQUANTIDADE) +SUM(RESUMOPERIODO.SAIDAQUANTIDADE)                                
-SUM(RESUMOPERIODO.ENTRADAQUANTIDADE) > -0.01  THEN 0
      ELSE
      ((SUM(RESUMOPERIODO.SALDOVALOR) + SUM(RESUMOPERIODO.SAIDAVALOR) - SUM(RESUMOPERIODO.ENTRADAVALOR))/
       (SUM(RESUMOPERIODO.saldoquantidade) + SUM(RESUMOPERIODO.saidaquantidade) - SUM(RESUMOPERIODO.entradaquantidade)) )END

           AS valormedioinicio,
               ----
       SUM(RESUMOPERIODO.ENTRADAQUANTIDADE) AS ENTRADAQTDE,
       SUM(RESUMOPERIODO.ENTRADAVALOR) AS ENTRADAVALOR,
       SUM(RESUMOPERIODO.SAIDAQUANTIDADE) AS SAIDAQTDE,
       SUM(RESUMOPERIODO.SAIDAVALOR) AS SAIDAVALOR,

       CASE WHEN SUM(RESUMOPERIODO.SALDOQUANTIDADE) < 0.01 AND  SUM(RESUMOPERIODO.SALDOQUANTIDADE)>-0.01 THEN 0
       ELSE SUM(RESUMOPERIODO.SALDOQUANTIDADE) END AS FimQtde,

       CASE WHEN SUM(RESUMOPERIODO.saldovalor) < 0.01 AND  SUM(RESUMOPERIODO.SALDOVALOR)>-0.01 THEN 0
       ELSE  SUM(RESUMOPERIODO.SALDOVALOR) END AS FimValor,

        CASE WHEN SUM(RESUMOPERIODO.SALDOQUANTIDADE) < 0.01 AND  SUM(RESUMOPERIODO.SALDOQUANTIDADE)>-0.01 THEN 0
       ELSE SUM (RESUMOPERIODO.saldovalor)/SUM(RESUMOPERIODO.SALDOQUANTIDADE) end as valormediofim,
           ---

       CASE WHEN SUM(RESUMOPERIODO.SALDOQUANTIDADE) < 0.01 AND  SUM(RESUMOPERIODO.SALDOQUANTIDADE)>-0.01 THEN 0

WHEN SUM(RESUMOPERIODO.saldovalor) < 0.01 AND  SUM(RESUMOPERIODO.SALDOVALOR)>-0.01 THEN 0

WHEN  SUM(RESUMOPERIODO.SALDOVALOR) +SUM(RESUMOPERIODO.SAIDAVALOR)
-SUM(RESUMOPERIODO.ENTRADAVALOR) < 0.01 AND
     SUM(RESUMOPERIODO.SALDOVALOR) +SUM(RESUMOPERIODO.SAIDAVALOR)
-SUM(RESUMOPERIODO.ENTRADAVALOR) > -0.01  THEN 0

WHEN SUM(RESUMOPERIODO.SALDOQUANTIDADE) < 0.01 AND  SUM(RESUMOPERIODO.SALDOQUANTIDADE)>-0.01 THEN 0

WHEN  SUM(RESUMOPERIODO.SALDOQUANTIDADE) +SUM(RESUMOPERIODO.SAIDAQUANTIDADE)
-SUM(RESUMOPERIODO.ENTRADAQUANTIDADE) < 0.01 AND
     SUM(RESUMOPERIODO.SALDOQUANTIDADE) +SUM(RESUMOPERIODO.SAIDAQUANTIDADE)                                
-SUM(RESUMOPERIODO.ENTRADAQUANTIDADE) > -0.01  THEN 0
else
(
((SUM (RESUMOPERIODO.saldovalor)/SUM(RESUMOPERIODO.SALDOQUANTIDADE))/(((SUM(RESUMOPERIODO.SALDOVALOR) + SUM(RESUMOPERIODO.SAIDAVALOR) - SUM(RESUMOPERIODO.ENTRADAVALOR))/
 (SUM(RESUMOPERIODO.saldoquantidade) + SUM(RESUMOPERIODO.saidaquantidade) - SUM(RESUMOPERIODO.entradaquantidade))))*100) -100)end
       as varmedia,

FROM RESUMOPERIODO
INNER JOIN ITEMESTOQUE ON (RESUMOPERIODO.IDITEM=ITEMESTOQUE.CODIGO AND
                           ITEMESTOQUE.TIPOPRODUTO<>5)
GROUP BY RESUMOPERIODO.FILIAL, RESUMOPERIODO.FILIALRAZAO, RESUMOPERIODO.IDITEM,
         RESUMOPERIODO.DESCRICAOPRODUTO, RESUMOPERIODO.UNIDADE,
         RESUMOPERIODO.MATERIALINICIAL, RESUMOPERIODO.MATERIALFINAL,
         RESUMOPERIODO.DATAINICIAL, RESUMOPERIODO.DATAFINAL, MATERIAPRIMA,
         INDUSTRIALIZADO, CONSUMO, REVENDA, INATIVO
