SELECT DISTINCT 
    ORCAMENTO.uuid,
    ORCAMENTO.FILIAL,
    ORCAMENTO.IDNOTA,
    ORCAMENTO.DATACADASTRO,
    COALESCE(CASE ORCAMENTO.AOSCUIDADOS when '' 
                THEN NULL ELSE ORCAMENTO.AOSCUIDADOS || coalesce('Fone: '||orcamento.TELEFONE,'')||coalesce(' '||orcamento.email,'')
                end, CADCLI.NOME) nome,
    CADCLI.CIDADE,
    CADCLI.UF,
    VENDEDORESORC.VENDEDOR,
    CADVEN.NOME,
    ORCAMENTO.VLRTOTALNOTA,
    CASE WHEN ORCAMENTO.cancelamento ='S' THEN 'Cancelado'
       WHEN EXISTS
       (SELECT * FROM PEDIDO
        WHERE PEDIDO.FILIAL=ORCAMENTO.FILIAL
        AND PEDIDO.IDORCAMENTO=ORCAMENTO.IDNOTA) THEN 'Pedido '||
            (SELECT max(PEDIDO.IDNOTA) FROM PEDIDO
             WHERE PEDIDO.FILIAL=ORCAMENTO.FILIAL
             AND PEDIDO.IDORCAMENTO=ORCAMENTO.IDNOTA)
       WHEN ORCAMENTO.DATAPERDA IS NOT NULL THEN 'Perdido '||coalesce(motivoPerda.descricao, '')
       WHEN ORCAMENTO.dataemissao IS NOT NULL THEN 'Autorizado'
       ELSE case when orcamento.pedirAprovacao='S' then 'Autorizar'
                 when orcamento.pedirLiberacao='S' then 'Financeiro' 
                else 'Rascunho' end
     END AS STATUS,
    CASE WHEN ORCAMENTO.cancelamento ='S' THEN 'red'
       WHEN NOT EXISTS
       (SELECT * FROM MERCADORIASORC
        WHERE MERCADORIASORC.FILIAL=ORCAMENTO.FILIAL
        AND MERCADORIASORC.IDNOTA=ORCAMENTO.IDNOTA
        AND MERCADORIASORC.BAIXA='N') THEN 'grey'
       WHEN EXISTS
       (SELECT * FROM MERCADORIASORC
        WHERE MERCADORIASORC.FILIAL=ORCAMENTO.FILIAL
        AND MERCADORIASORC.IDNOTA=ORCAMENTO.IDNOTA
        AND MERCADORIASORC.BAIXA='S') THEN 'yellow'
       WHEN ORCAMENTO.dataemissao IS NOT NULL THEN 'blak'
       ELSE 'blue' END AS STATUS     
FROM 
    ORCAMENTO 
INNER JOIN 
    CADASTROPARCEIROS CADCLI ON
        CADCLI.CADASTRO = ORCAMENTO.DESTINATARIO
LEFT JOIN
    VENDEDORESORC ON
        VENDEDORESORC.FILIAL= ORCAMENTO.FILIAL AND
        VENDEDORESORC.IDNOTA=ORCAMENTO.IDNOTA 
LEFT JOIN
    CADASTROPARCEIROS CADVEN ON
        VENDEDORESORC.VENDEDOR= CADVEN.CADASTRO
LEFT JOIN 
    CADASTROPARCEIROS CADTRANS ON   
        CADTRANS.CADASTRO = ORCAMENTO.CODIGOTRANSP
LEFT JOIN
    ORCMOTIVOSPERDA motivoPerda ON
        motivoPerda.ID=ORCAMENTO.MOTIVOPERDA
order by
    ORCAMENTO.IDNOTA DESC 
