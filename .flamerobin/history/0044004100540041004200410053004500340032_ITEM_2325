SELECT
        NOTAFISCAL.FILIAL,
        NOTAFISCAL.IDNOTA,
        notafiscal.numeronota,
        notafiscal.dataemissao,
        'NFE' as origem,
        cast(mercadoriasnota.cfop as varchar(4)),
        MERCADORIASNOTA.IDMERCADORIA AS IDMERCSERV,
        EXTRACT(YEAR FROM NOTAFISCAL.DATAEMISSAO) ANO, 
        EXTRACT(MONTH FROM NOTAFISCAL.DATAEMISSAO) MES,
        NOTAFISCAL.DESTINATARIO, ((MERCADORIASNOTA.VLRFINALMERCAD+MERCADORIASNOTA.ACRESCIMONOTA)-MERCADORIASNOTA.DESCONTONOTA) 
        VLRFINALMERCAD,
        MERCADORIASNOTA.CODIGO,
         ITEM.GRUPO,
        ITEM.familia, 
        item.itembase,
        (select item2.descricao from itemestoque item2 where item2.codigo=item.itembase) as itembasedesc, 
        CAST(ITEM.DESCRICAO AS VARCHAR(240)) AS DESCRICAO,
        CLIENTE.NOME, 'PRODUTO' AS TIPO,
        MERCADORIASNOTA.quantidadeestoque, MERCADORIASNOTA.quantidadeestoque*ITEM.QUANTIDADEUNIDADE,
        mercadoriasnota.ICMSSTFCPVALOR,
        mercadoriasnota.frete,
        mercadoriasnota.seguro,
        mercadoriasnota.outdespacessor,
        NOTAFISCAL.VALORIPI,MERCADORIASNOTA.VALORIPI,MERCADORIASNOTA.VALORICMS,
        NOTAFISCAL.ZONAFRANCA, MERCADORIASNOTA.VLRICMSSUBST,NOTAFISCAL.DATAEMISSAO,
        NATUREZAOPERACAO.estatisticaestoque,notafiscal.substributaria,MERCADORIASNOTA.VLRICMSRECOLHIDO,
        NATUREZAOPERACAO.FATURA, 1 AS SINAL, notafiscal.uf,
        mercadoriasnota.IDNOTASAIDA,
        'N'

FROM  
    NOTAFISCAL
INNER JOIN 
    MERCADORIASNOTA ON 
        (NOTAFISCAL.FILIAL = MERCADORIASNOTA.FILIAL
         AND   NOTAFISCAL.IDNOTA = MERCADORIASNOTA.IDNOTA)
INNER JOIN 
    ITEMESTOQUE ITEM ON 
        (MERCADORIASNOTA.CODIGO = ITEM.CODIGO)
INNER JOIN 
    CADASTROPARCEIROS CLIENTE ON 
        (NOTAFISCAL.DESTINATARIO = CLIENTE.CADASTRO)
INNER JOIN
    NATUREZAOPERACAO ON 
        (NOTAFISCAL.OPERACAO = NATUREZAOPERACAO.ID)


WHERE
    NOTAFISCAL.DATAEMISSAO BETWEEN '01.05.2024' AND '31.05.2024' AND   
    --((:CONSOLIDADO = 2) OR (NOTAFISCAL.FILIAL = :ESTABELECIMENTO)) AND   
    (NATUREZAOPERACAO.FATURA = 'S' or naturezaoperacao.estatisticaestoque='S' or mercadoriasnota.cfop in ('5116','6116','5117','6117')) AND
    --MERCADORIASNOTA.CODIGO BETWEEN :MATERIALINICIAL AND :MATERIALFINAL AND
    ((NOTAFISCAL.CANCELAMENTO = 'N') OR (NOTAFISCAL.CANCELAMENTO IS NULL)) AND
    (NATUREZAOPERACAO.ENTRADASAIDA='S') AND (NOT NOTAFISCAL.DEVOLUCAO='S') AND
    MERCADORIASNOTA.CFOP NOT IN ('5949','6949','5922','6922','5902','6902','5903','6903' )
