SET TERM ^ ;
ALTER PROCEDURE IMP_NFE_MERCADORIAS (
    FILIAL INTEGER,
    IDNOTA INTEGER,
    INDFINAL SMALLINT,
    ITEMCODREFNFE CHAR(1),
    NCONTRIBUINTEINTER CHAR(1),
    SIMPLES CHAR(1),
    DEVOLUCAO CHAR(1),
    IDDEST SMALLINT,
    PTIPONOTA CHAR(1),
    UF CHAR(2),
    VRETPIS DOUBLE PRECISION,
    VRETCOFINS DOUBLE PRECISION,
    VRETCSLL DOUBLE PRECISION,
    CFOP INTEGER,
    VEANNFE CHAR(1),
    VBCIRRF DOUBLE PRECISION,
    VBCRETPREV DOUBLE PRECISION,
    VIRRF DOUBLE PRECISION,
    VLRZONAFRANCA DOUBLE PRECISION,
    VREMONTADESCRICAO CHAR(1),
    VRETPREV DOUBLE PRECISION )
RETURNS (
    IDITEM INTEGER,
    CODIGO VARCHAR(15),
    DESCRICAO VARCHAR(4596),
    DESCRICAOREDUZIDA VARCHAR(50),
    QUANTIDADE DOUBLE PRECISION,
    UNIDADE VARCHAR(3),
    PRUNITARIO DOUBLE PRECISION,
    PIPIMERC DOUBLE PRECISION,
    VLRIPIMERC DOUBLE PRECISION,
    VLRTOTITEM DOUBLE PRECISION,
    PICMS DOUBLE PRECISION,
    PCREDSN DOUBLE PRECISION,
    VCREDICMSSN DOUBLE PRECISION,
    ICMSBASE DOUBLE PRECISION,
    SITUACAOTRIBUT VARCHAR(4),
    VALORICMS_PROD DOUBLE PRECISION,
    CFOP_PROD CHAR(4),
    EAN CHAR(13),
    NFCI CHAR(36),
    EANTRIBUTAVEL CHAR(13),
    UNIDADETRIBUTAVEL VARCHAR(3),
    QUANTIDADETRIBUTAVEL DOUBLE PRECISION,
    VALORUNITARIOTRIBUTAVEL DOUBLE PRECISION,
    FRETEPRODUTO DOUBLE PRECISION,
    SEGUROPRODUTO DOUBLE PRECISION,
    DESCONTOPRODUTO DOUBLE PRECISION,
    VOUTRO DOUBLE PRECISION,
    ORIGEM INTEGER,
    CTICMS VARCHAR(3),
    MODBC INTEGER,
    PREDBC DOUBLE PRECISION,
    MODBCST INTEGER,
    PMVAST DOUBLE PRECISION,
    PREDBCST DOUBLE PRECISION,
    VBCST DOUBLE PRECISION,
    PICMSST DOUBLE PRECISION,
    VICMSST DOUBLE PRECISION,
    IPIBASE_PROD DOUBLE PRECISION,
    PISALIQUOTA DOUBLE PRECISION,
    IPICST INTEGER,
    PISCST INTEGER,
    PISBASE DOUBLE PRECISION,
    PISVALOR DOUBLE PRECISION,
    COFINSCST INTEGER,
    COFINSBASECALCULO DOUBLE PRECISION,
    COFINSALIQUOTA DOUBLE PRECISION,
    COFINSVALOR DOUBLE PRECISION,
    NDI VARCHAR(12),
    DDI TIMESTAMP,
    XLOCDESEMB VARCHAR(60),
    UFDI VARCHAR(2),
    DDESEMB TIMESTAMP,
    CEXPORTADOR VARCHAR(60),
    NADICAO INTEGER,
    CFABRICANTE VARCHAR(60),
    VDESCDI DOUBLE PRECISION,
    VBASEIMPORTAMERC DOUBLE PRECISION,
    VDESPADUMERC DOUBLE PRECISION,
    VIMPORTOIMPORTACAOMERC DOUBLE PRECISION,
    VIOFMERC DOUBLE PRECISION,
    PREDIPI DOUBLE PRECISION,
    IDMERCADORIAPEDIDO INTEGER,
    IDPEDIDO INTEGER,
    INFADPROD VARCHAR(500),
    VTOTTRIB DECIMAL(10,2),
    PFCUFDEST NUMERIC(5,4),
    PICMSUFDEST NUMERIC(5,4),
    PICMSINTER NUMERIC(5,4),
    VFCPUFDEST NUMERIC(12,2),
    VICMSUFDEST NUMERIC(12,2),
    VICMSUFREMET NUMERIC(12,2),
    VTOTTRIBEST DECIMAL(12,2),
    CENQ VARCHAR(3),
    INDESCALA VARCHAR(1),
    ORIGEMPRODUTO DOUBLE PRECISION,
    CNPJFAB VARCHAR(14),
    ICMSORIGEMFCP NUMERIC(6,3),
    ICMSORIGEMFCPVALOR NUMERIC(12,2),
    ICMSSTFCP NUMERIC(6,3),
    ICMSSTFCPVALOR NUMERIC(12,2),
    ICMSALIQUOTACF NUMERIC(6,3),
    ICMSALIQUOTASIMPLES NUMERIC(6,3),
    ICMSVALORSIMPLES NUMERIC(12,2),
    PRLISTA DOUBLE PRECISION,
    VBCUFDEST NUMERIC(12,2),
    CODCF CHAR(3),
    VTOTTRIBFED DECIMAL(12,2),
    VIPIDEVOLITEM NUMERIC(12,2),
    VIPIDEVOLTOT NUMERIC(12,2),
    PDEVOL NUMERIC(6,3),
    CBENEF VARCHAR(10),
    P_VALORRETIDO DOUBLE PRECISION,
    CTICMSSIMPLES VARCHAR(3),
    NRE VARCHAR(12),
    NSEQADIC INTEGER,
    PICMSINTERESTADUAL DOUBLE PRECISION,
    ORDEM INTEGER,
    XPED CHAR(20),
    CEST VARCHAR(7),
    CF VARCHAR(12),
    NVE VARCHAR(8),
    DETALHEITENS CHAR(1),
    NITEMPED SMALLINT,
    VICMSDESONERADO DOUBLE PRECISION,
    ICMSPART INTEGER,
    PST DOUBLE PRECISION,
    VBCFCPST DOUBLE PRECISION,
    PFCPST DOUBLE PRECISION,
    VBCSTRET NUMERIC(13,2),
    VICMSSUBSTITUTO NUMERIC(13,2),
    VICMSSTRET NUMERIC(13,2),
    CPRODANP VARCHAR(9),
    DESCANP VARCHAR(95),
    PGLP DOUBLE PRECISION,
    PGNN DOUBLE PRECISION,
    PGNI DOUBLE PRECISION,
    VPART NUMERIC(13,2) )

AS
declare variable VLOTE varchar(4096);
declare variable VLOTEDSC varchar(12);
declare variable NSEQADICCONTAGEM integer;
declare variable PQTDITEM integer;
declare variable NADICAOANTES integer;
declare variable PXPED char(20);
declare variable PVLRTOTAL double precision;
declare variable VQUANTIDADELOTE varchar(20);
begin

pdevol=0;
PQTDITEM =0;
NADICAOANTES=0;
ORDEM=0;
PVLRTOTAL=0;
VICMSDESONERADO=null;
icmspart=0;
VIPIDEVOLtot=0;
VIPIDEVOlitem=0;


 for select
     MERCADORIASNOTA.IDMERCADORIA,
     MERCADORIASNOTA.CODIGO,
     case
       when :ITEMCODREFNFE = 'S' then substring(coalesce(ITEMESTOQUE.REFERENCIA, '') || ' ' || coalesce(substring(MERCADORIASNOTA.DESCRICAO from 1 for 120), '') from 1 for 120)
       --|| ' ' || coalesce(MERCADORIASNOTA.INFADPROD, '')
       else coalesce(substring(MERCADORIASNOTA.DESCRICAO from 1 for 4096), '')
       -- || ' ' || coalesce(MERCADORIASNOTA.INFADPROD, '')
     end,
     MERCADORIASNOTA.DESREDUZIDA/*,
     MERCADORIASNOTA.QUANTIDADE,
     MERCADORIASNOTA.UNIDADE,
     coalesce(MERCADORIASNOTA.PRECOLISTA,
     MERCADORIASNOTA.PRECOUNITARIO),
     MERCADORIASNOTA.PRECOLISTA,
     case
       when MERCADORIASNOTA.VALORIPI > 0 then MERCADORIASNOTA.PIPI
       else 0
     end,
     MERCADORIASNOTA.VALORIPI,
     MERCADORIASNOTA.VLRTOTALMERCAD,
     case :NCONTRIBUINTEINTER
       when 'N' then case
             when :SIMPLES = 'S' and MERCADORIASNOTA.VLRICMSRECOLHIDO = 0 and :DEVOLUCAO = 'N' and substring(MERCADORIASNOTA.CFOP from 1 for 1) <> 3 then 0
             else MERCADORIASNOTA.icmsorigemaliquota
           end
       else MERCADORIASNOTA.ICMSORIGEMALIQUOTA
     end,
     case
       when :SIMPLES = 'S' and substring(MERCADORIASNOTA.CFOP from 1 for 1) <> 3 then MERCADORIASNOTA.ALIQUOTAICMS
       else 0
     end,
     case
       when :SIMPLES = 'S' and substring(MERCADORIASNOTA.CFOP from 1 for 1) <> 3 then MERCADORIASNOTA.VALORICMS
       else 0
     end,
     MERCADORIASNOTA.CLASSIFISCAL,
     case :NCONTRIBUINTEINTER
       when 'N' then case
             when :SIMPLES = 'S' and MERCADORIASNOTA.VLRICMSRECOLHIDO = 0 and :DEVOLUCAO = 'N' and substring(MERCADORIASNOTA.CFOP from 1 for 1) <> 3 then 0
             else MERCADORIASNOTA.ICMSBASE
           end
       else MERCADORIASNOTA.ICMSORIGEMBASE
     end,
     MERCADORIASNOTA.SITUACAOTRIBUT,
     case :NCONTRIBUINTEINTER
       when 'N' then case
             when :SIMPLES = 'S' and MERCADORIASNOTA.VLRICMSRECOLHIDO = 0 and :DEVOLUCAO = 'N' and substring(MERCADORIASNOTA.CFOP from 1 for 1) <> 3 then 0
             else MERCADORIASNOTA.icmsorigemvalor
           end
       else MERCADORIASNOTA.ICMSORIGEMVALOR
     end,
     MERCADORIASNOTA.CFOP,
     ITEMESTOQUE.CODIGOBARRA,
     ITEMESTOQUE.FCI,
     case coalesce(ITEMESTOQUE.CEANTRIB, '')
       when '' then ITEMESTOQUE.CODIGOBARRA
       else ITEMESTOQUE.CEANTRIB
     end,
     coalesce(itemestoque.UNIDADEPADRAO, itemestoque.UNIDADE) as unidadetributavel,
     
     MERCADORIASNOTA.QUANTIDADE * coalesce(itemestoque.FATORUNIDADEPADRAO,1),

     coalesce(MERCADORIASNOTA.PRECOLISTA, MERCADORIASNOTA.PRECOUNITARIO) / COALESCE(itemestoque.FATORUNIDADEPADRAO,1),

     MERCADORIASNOTA.FRETE,
     MERCADORIASNOTA.SEGURO,
     coalesce(MERCADORIASNOTA.OUTDESPACESSOR, 0) + coalesce(MERCADORIASNOTA.ACRESCIMONOTA, 0)
     +coalesce(MERCADORIASNOTA.JUROSMULTAIMPOSTOS, 0)
     + coalesce(MERCADORIASNOTA.VLRDESPADUANEIRAS, 0) + coalesce(MERCADORIASNOTA.VLRTAXASISCOMEX, 0),
     coalesce(MERCADORIASNOTA.VLRDESCPRODUTO, 0) + coalesce(MERCADORIASNOTA.DESCONTONOTA, 0),
     substring(MERCADORIASNOTA.SITUACAOTRIBUT from 1 for 1),
     substring(MERCADORIASNOTA.SITUACAOTRIBUT from 2 for 3),
     3,
     MERCADORIASNOTA.REDUCAOICMS,
     case
       when MERCADORIASNOTA.VLRICMSSUBST > 0 then 4
       else null
     end,
     MERCADORIASNOTA.PLUCRO,
     MERCADORIASNOTA.PREDUCAO,
     MERCADORIASNOTA.VLRBASESUBST,
     MERCADORIASNOTA.ALIQUOTASUBSTITUTO,
     MERCADORIASNOTA.VLRICMSRECOLHIDO,
     MERCADORIASNOTA.IPIBASE,
     MERCADORIASNOTA.PPIS,
     coalesce(MERCADORIASNOTA.CSTIPI, 0),
     MERCADORIASNOTA.CSTPIS,
     MERCADORIASNOTA.BASEPIS,
     MERCADORIASNOTA.VLRPISPASEP,
     MERCADORIASNOTA.PCOFINS,
     MERCADORIASNOTA.CSTCOFINS,
     MERCADORIASNOTA.BASECOFINS,
     MERCADORIASNOTA.VLRCOFINS,
     case coalesce(MERCADORIASNOTA.DI, '')
       when '' then NOTAFISCAL.DI
       else MERCADORIASNOTA.DI
     end,
     coalesce(MERCADORIASNOTA.DDI, NOTAFISCAL.DDI),
     case coalesce(MERCADORIASNOTA.XLOCDESEMB, '')
       when '' then NOTAFISCAL.XLOCDESEMB
       else MERCADORIASNOTA.XLOCDESEMB
     end,
     case coalesce(MERCADORIASNOTA.UFDI, '')
       when '' then NOTAFISCAL.UFDI
       else MERCADORIASNOTA.UFDI
     end,
     coalesce(MERCADORIASNOTA.DATADESEMB, NOTAFISCAL.DATADESEMB),
     case coalesce(MERCADORIASNOTA.CEXPORTADOR, '')
       when '' then NOTAFISCAL.CEXPORTADOR
       else MERCADORIASNOTA.CEXPORTADOR
     end,
     coalesce(MERCADORIASNOTA.NADICAO, 0),
     MERCADORIASNOTA.NSEQADICAO,
     MERCADORIASNOTA.CFABRICANTE,
     coalesce(MERCADORIASNOTA.VDESCDI, 0),
     MERCADORIASNOTA.BASEII,
     coalesce(MERCADORIASNOTA.VLRDESPADUANEIRAS, 0),
     MERCADORIASNOTA.VLRIMPOSTOIMPORT,
     0,
     NOTAFISCAL.PREDUCAOIPI,
     MERCADORIASNOTA.IDMERCPEDIDO,
     MERCADORIASNOTA.IDPEDIDO,
     MERCADORIASNOTA.INFADPROD,
     MERCADORIASNOTA.VTOTTRIB,
     MERCADORIASNOTA.ICMSBASE,
     MERCADORIASNOTA.ICMSDESTINOFCP,
     MERCADORIASNOTA.ICMSDESTINOALIQUOTA,
     MERCADORIASNOTA.ICMSORIGEMALIQUOTA,
     MERCADORIASNOTA.ICMSDESTINOFCPVALOR,
     MERCADORIASNOTA.ICMSDESTINOVALOR,
     MERCADORIASNOTA.ICMSORIGEMVALORINTERESTADUAL,
     MERCADORIASNOTA.VTOTTRIBFED,
     MERCADORIASNOTA.VTOTTRIBEST,
     coalesce(MERCADORIASNOTA.CENQ, '999'),
     case(coalesce(ITEMESTOQUE.INDESCALA, ''))
        when '' then null
        else ITEMESTOQUE.INDESCALA END,
     ITEMESTOQUE.CODIGOTRIBUTACAO,
     case(coalesce(ITEMESTOQUE.INDESCALA, ''))
       when 'N' then CADFAB.DOCUMENTO
       else null
     end,
     MERCADORIASNOTA.ICMSORIGEMFCP,
     MERCADORIASNOTA.ICMSORIGEMFCPVALOR,

     MERCADORIASNOTA.ICMSSTFCP,
     MERCADORIASNOTA.ICMSSTFCPVALOR,
     MERCADORIASNOTA.ICMSALIQUOTACF,

     case MERCADORIASNOTA.ICMSSTFCP
          WHEN 0 then 0
          else MERCADORIASNOTA.VLRBASESUBST end,
     MERCADORIASNOTA.ICMSSTFCP,

     MERCADORIASNOTA.ICMSALIQUOTASIMPLES,
     MERCADORIASNOTA.ICMSVALORSIMPLES,
     MERCADORIASNOTA.VIPIDEVOLVITEM,
     MERCADORIASNOTA.cProdANP,
     MERCADORIASNOTA.descANP,
     MERCADORIASNOTA.pGLP,
     MERCADORIASNOTA.pGNn,
     MERCADORIASNOTA.pGNi,
     MERCADORIASNOTA.vPart
     */
     from
         MERCADORIASNOTA
     inner join
           NOTAFISCAL
                     on (NOTAFISCAL.FILIAL = MERCADORIASNOTA.FILIAL
                     and NOTAFISCAL.IDNOTA = MERCADORIASNOTA.IDNOTA)
     inner join
           NATUREZAOPERACAO
                           on (NATUREZAOPERACAO.ID = NOTAFISCAL.OPERACAO)
     inner join
           ESTABELECIMENTO
                          on (NOTAFISCAL.FILIAL = ESTABELECIMENTO.CADASTRO)
     left join
          ITEMESTOQUE
                     on (MERCADORIASNOTA.CODIGO = ITEMESTOQUE.CODIGO)
     left join
          CADASTROPARCEIROS CADFAB
                            on (CADFAB.CADASTRO = ITEMESTOQUE.FABRICANTE)
     where
          MERCADORIASNOTA.FILIAL = :FILIAL and
          MERCADORIASNOTA.IDNOTA = :IDNOTA
    order by
          MERCADORIASNOTA.IDMERCADORIA

    into :IDITEM, :CODIGO, :DESCRICAO, :DESCRICAOREDUZIDA/*, :QUANTIDADE, :UNIDADE, :PRUNITARIO, :PRLISTA, :PIPIMERC,
         :VLRIPIMERC, :VLRTOTITEM, :PICMS, :PCREDSN, :VCREDICMSSN, :CODCF, :ICMSBASE, :SITUACAOTRIBUT,
         :VALORICMS_PROD, :CFOP_PROD, :EAN, :NFCI, :EANTRIBUTAVEL, :UNIDADETRIBUTAVEL, :QUANTIDADETRIBUTAVEL,
         :VALORUNITARIOTRIBUTAVEL, :FRETEPRODUTO, :SEGUROPRODUTO, :VOUTRO, :DESCONTOPRODUTO, :ORIGEM, :CTICMS,
         :MODBC, :PREDBC, :MODBCST, :PMVAST, :PREDBCST, :VBCST, :PICMSST, :VICMSST, :IPIBASE_PROD, :PISALIQUOTA,
         :IPICST, :PISCST, :PISBASE, :PISVALOR, :COFINSALIQUOTA, :COFINSCST, :COFINSBASECALCULO, :COFINSVALOR, :NDI,
         :DDI, :XLOCDESEMB, :UFDI, :DDESEMB, :CEXPORTADOR, :NADICAO, :NSEQADIC, :CFABRICANTE, :VDESCDI,
         :VBASEIMPORTAMERC, :VDESPADUMERC, :VIMPORTOIMPORTACAOMERC, :VIOFMERC, :PREDIPI, :IDMERCADORIAPEDIDO,
         :IDPEDIDO, :INFADPROD, :VTOTTRIB, :VBCUFDEST, :PFCUFDEST, :PICMSUFDEST, :PICMSINTER, :VFCPUFDEST,
         :VICMSUFDEST, :VICMSUFREMET, :VTOTTRIBFED, :VTOTTRIBEST, :CENQ, :INDESCALA, :ORIGEMPRODUTO, :CNPJFAB,
         :ICMSORIGEMFCP, :ICMSORIGEMFCPVALOR, :ICMSSTFCP, :ICMSSTFCPVALOR, :ICMSALIQUOTACF,
         :vBCFCPST, :pFCPST ,
         :ICMSALIQUOTASIMPLES, :ICMSVALORSIMPLES, :VIPIDEVOLITEM,
         :cProdANP, :descANP, :pGLP, :pGNn, :pGNi, :vPart*/
    do begin

      --if (:vicmsst>0 and :indfinal=1 and :iddest=2) then icmspart=1;
        VIPIDEVOLtot=VIPIDEVOLTOT+VIPIDEVOLITEM;
        
      pDevol=PIPIMERC;
     -- if (VIPIDEVOLITEM>0) then pDevol= (VIPIDEVOLITEM/VIPIDEVOLTOT)*100;

      select CBENEF
      from ITEMESTOQUE
      inner join TRIBUTACAOICMS on (ITEMESTOQUE.TRIBUTACAOICMS = TRIBUTACAOICMS.ID)
      inner join TRIBUTACAOICMSUF on (TRIBUTACAOICMSUF.ID = TRIBUTACAOICMS.ID)
      where ITEMESTOQUE.CODIGO = :CODIGO and TRIBUTACAOICMSUF.UF = :UF
      into :CBENEF;


      if (:CTICMS IN ( '60', '500')) then begin
         PST=NULL;
         pst=COALESCE (PICMS,0)+ COALESCE ( PFCUFDEST,0);
      END

      if (:CTICMS = '60' and :VALORICMS_PROD = 0) then begin
        PICMS = null;
      end
      P_VALORRETIDO = coalesce(VRETPIS, 0) + coalesce(VRETCOFINS, 0) + coalesce(VRETCSLL, 0) + coalesce(VBCIRRF, 0) + coalesce(VIRRF, 0) + coalesce(VBCRETPREV, 0) + coalesce(VRETPREV, 0);
      if (substring(:CFOP from 1 for 1) = '7') then begin
        NRE = NDI;
        NDI = '';
      end

      select distinct NUMPEDIDOCLIENTE
      from PEDIDO
      where FILIAL = :FILIAL and
            IDNOTA = :IDPEDIDO
      into :PXPED;
      XPED = substring(PXPED from 1 for 15);

      select ITEMPEDCOMPRA
      from MERCADORIASPED
      where FILIAL = :FILIAL and IDNOTA = :IDPEDIDO and IDMERCADORIA = :IDMERCADORIAPEDIDO
      into :NITEMPED;

      CTICMSSIMPLES = '';
      if (CTICMS in (102, 103, 300, 400)) then CTICMSSIMPLES = 102;
      if (CTICMS in (202, 203)) then CTICMSSIMPLES = 202;

      if (VLRZONAFRANCA > 0) then
      begin
        DESCONTOPRODUTO = DESCONTOPRODUTO + VALORICMS_PROD;
        VICMSDESONERADO = VALORICMS_PROD;
      end

      if (VREMONTADESCRICAO = 'S') then
      begin
        VLOTE = '';
        for select LOTE, cast(QUANTIDADE as decimal)
            from COMPOSICAOMERCNOTA
            where FILIAL = :FILIAL and
                  IDNOTA = :IDNOTA and
                  IDMERCADORIA = :IDITEM and
                  LOTE <> '.'
            into :VLOTEDSC, :VQUANTIDADELOTE
        do
        begin
          VLOTEDSC = case VLOTEDSC
                       when substring(VLOTEDSC from 1 for 1) then substring(VLOTEDSC from 1 for 1)
                       when substring(VLOTEDSC from 1 for 2) then substring(VLOTEDSC from 1 for 2)
                       when substring(VLOTEDSC from 1 for 3) then substring(VLOTEDSC from 1 for 3)
                       when substring(VLOTEDSC from 1 for 4) then substring(VLOTEDSC from 1 for 4)
                       when substring(VLOTEDSC from 1 for 5) then substring(VLOTEDSC from 1 for 5)
                       when substring(VLOTEDSC from 1 for 6) then substring(VLOTEDSC from 1 for 6)
                       when substring(VLOTEDSC from 1 for 7) then substring(VLOTEDSC from 1 for 7)
                       when substring(VLOTEDSC from 1 for 8) then substring(VLOTEDSC from 1 for 8)
                       when substring(VLOTEDSC from 1 for 9) then substring(VLOTEDSC from 1 for 9)
                       when substring(VLOTEDSC from 1 for 10) then substring(VLOTEDSC from 1 for 10)
                       when substring(VLOTEDSC from 1 for 11) then substring(VLOTEDSC from 1 for 11)
                       else VLOTEDSC
                     end;
          VLOTE = VLOTE || substring(VLOTEDSC from 1 for 12) || '(' || VQUANTIDADELOTE || ') ';
        end
        if (VLOTE <> '') then
          DESCRICAO = DESCRICAO || ' LOTE(s): ' || VLOTE;
      end

--      REFERENCIADESCRICAO = null;

      if (PREDBC = 100) then
      begin
        PICMS = 0;
        ICMSBASE = 0;
        PREDBC = 0;
        VALORICMS_PROD = 0;
      end

      if (PREDIPI = 100) then
      begin
        PIPIMERC = 0;
        PREDIPI = 0;
      end

      if (coalesce(NADICAO, 0) = 0) then
        NADICAO = 1;

      if (NADICAO <> NADICAOANTES) then
      begin
        NSEQADICCONTAGEM = 1;
        NADICAOANTES = NADICAO;
      end
      else
        NSEQADICCONTAGEM = NSEQADICCONTAGEM + 1;

      if (coalesce(NSEQADIC, 0) = 0) then begin
        NSEQADIC = NSEQADICCONTAGEM;
      end

      if (not(coalesce(CFABRICANTE, '') > '')) then CFABRICANTE = :IDITEM;
      if (coalesce(PISCST, 0) = 0) then PISCST = 1;
      if (coalesce(COFINSCST, 0) = 0) then COFINSCST = 1;

      if (VEANNFE = 'N' or EAN = CODIGO) then begin
        -- EAN = null; EANTRIBUTAVEL = null;
         EAN = 'SEM GTIN'; EANTRIBUTAVEL = 'SEM GTIN';
      end

      select DESCRICAO, CEST, NVE
      from CLASSIFICACAOFISCAL
      where CFISCAL = :CODCF
      into :CF, :CEST, NVE;

      PVLRTOTAL = PVLRTOTAL + VLRTOTITEM;
      PQTDITEM = PQTDITEM + 1;
      DETALHEITENS = 'S';
      ORDEM = ORDEM + 1;

      if (:SIMPLES = 'S') then
      begin
        if (:DEVOLUCAO = 'N') then
        begin
          if (substring(:CFOP from 1 for 1) <> 3) then
          begin
            PICMS = 0;
            ICMSBASE = 0;
            PREDBC = 0;
            VALORICMS_PROD = 0;
          end
        end
        --VBCUFDEST = 0;
        --PFCUFDEST = 0;
        --PICMSUFDEST = 0;
        --VFCPUFDEST = 0;
        --VICMSUFDEST = 0;
        --VICMSUFREMET = 0;
        PICMSINTER = 0;

        select PICMSINTERESTADUAL
        from ESTADO
        where ESTADO = :UF
        into :PICMSINTERESTADUAL;

        if (:ORIGEMPRODUTO in (1, 2, 3, 8)) then
          PICMSINTER = 4;
        else
          PICMSINTER = PICMSINTERESTADUAL;
      end

      if (cticms='60') then begin    
        select  
            VBCSTRET,
            VICMSSUBSTITUTO,
            VICMSSTRET 
        from IMP_NFEITEMSTANTERIOR(:filial, :idnota, :iditem)
        into VBCSTRET,
            VICMSSUBSTITUTO,
            VICMSSTRET ;
 
      end 

      
      suspend;
    end
  end
^
