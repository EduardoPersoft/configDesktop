SELECT 
       C_CREDITOS.FILIAL,
       CADASTROPARCEIROS.CADASTRO,
       CADASTROPARCEIROS.NOME,
       SUM(VALOR) AS CREDITO
FROM CLIENTES
INNER JOIN CADASTROPARCEIROS ON (CADASTROPARCEIROS.CADASTRO=CLIENTES.CADASTRO)
LEFT JOIN C_CREDITOS ON (C_CREDITOS.CADASTRO=CADASTROPARCEIROS.CADASTRO)
GROUP BY C_CREDITOS.FILIAL,CADASTROPARCEIROS.CADASTRO,CADASTROPARCEIROS.NOME
