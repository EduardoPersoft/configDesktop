update 
    itemestoque Ifinal
set
    ifinal.VALORULTIMACOMPRA = (select 
                                    ibase.valorultimacompra
                                from
                                    itemestoque ibase
                                where
                                    ibase.codigo=ifinal.itembase)
where
    ifinal.CODIGO BETWEEN 'PE-' AND 'PE-ZZZZZZ' and
    IFINAL.VALORULTIMACOMPRA IS NULL
                                                                    
                
    
