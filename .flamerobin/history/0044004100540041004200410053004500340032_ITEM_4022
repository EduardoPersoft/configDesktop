select
    PEDIDO.IDNOTA,
    PEDIDO.DATAREFERENCIA,
    PEDIDO.DATAEMISSAO,
    CADCLI.NOME,
    TIPOCOBRANCA.DESCRICAO,
    PEDIDO.C_FOMENTO,   
    PEDIDO.VLRTOTALNOTA,
    CAST('N' AS CHAR(1)) AS P_CHECK
from
    PEDIDO
INNER join
    CADASTROPARCEIROS CADCLI ON
        CADCLI.CADASTRO=PEDIDO.DESTINATARIO
INNER JOIN         
    TIPOCOBRANCA ON
        TIPOCOBRANCA.TIPOCOBRANCA=PEDIDO.TIPOCOBRANCA
where
    PEDIDO.FILIAL=110 and
    PEDIDO.DATAREFERENCIA BETWEEN '01.01.2025' AND '31.12.2025' and
    PEDIDO.DATACANCELAMENTO IS NULL and
    PEDIDO.DATAEMISSAO IS NOT NULL and 
    EXISTS (
        SELECT * FROM MERCADORIASPED
        WHERE MERCADORIASPED.FILIAL=PEDIDO.FILIAL
        AND MERCADORIASPED.IDNOTA=PEDIDO.IDNOTA 
        AND MERCADORIASPED.BAIXA = 'N')