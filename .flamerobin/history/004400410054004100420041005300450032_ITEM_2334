select 
    itemestoque.codigo,
    itemestoque.referencia,
    itemestoque.descricao,
    grupomercadoria.grupo,
    GRUPOMERCADORIA.descricao descricaoGrupo,
    sum(mercadoriasnota.quantidade)
FROM
    NOTAFISCAL
inner join 
    mercadoriasnota on
        notafiscal.filial=mercadoriasnota.filial AND
        notafiscal.idnota=mercadoriasnota.idnota
inner JOIN
    itemestoque on
        itemestoque.codigo=mercadoriasnota.CODIGO
inner JOIN
    GRUPOMERCADORIA on
        GRUPOMERCADORIA.grupo=itemestoque.GRUPO
WHERE
    notafiscal.filial=5 AND
    notafiscal.DATAEMISSAO between '01.10.2020' and '31.12.2021'
    