select 
    mercadoriasped.filial filial,
    mercadoriasped.idnota,
    mercadoriasped.idmercadoria,
    pedido.datacadastro,
    cadastroparceiros.nome,
    mercadoriasped.quantidade
FROM
    mercadoriasped
inner JOIN
    pedido on
        mercadoriasped.filial=pedido.filial and 
        mercadoriasped.idnota=pedido.IDNOTA
inner JOIN
    cadastroparceiros on
        cadastroparceiros.cadastro = pedido.destinatario
WHERE
    mercadoriasped.filial=? AND
    mercadoriasped.baixa = 'N' AND
    mercadoriasped.codigo = ?