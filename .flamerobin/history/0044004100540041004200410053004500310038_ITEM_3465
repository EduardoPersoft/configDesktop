select
     (select first 1
         arquiteto.VENDEDOR
      from
         VENDEDORESORC arquiteto
      inner join
         VENDEDOR  on
              vendedor.cadastro=arquiteto.VENDEDOR
      where
        arquiteto.filial=orcamento.FILIAL and
        arquiteto.idnota=orcamento.idnota and
        vendedor.TIPOVENDEDOR>=5) as arquiteto,
     orcamento.*
from
    orcamento