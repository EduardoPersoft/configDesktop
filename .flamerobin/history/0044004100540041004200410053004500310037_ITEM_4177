update 
    mercadoriasorc
set
    mercadoriasorc.DESCRICAO=mercadoriasorc.DESREDUZIDA
where exists
    (select
        *
     from 
        ORCAMENTO
     where
        mercadoriasorc.filial=orcamento.filial and
        mercadoriasorc.idnota=orcamento.idnota and
        orcamento.DATACADASTRO='2025-01-23')