SELECT
    ITEMESTOQUESALDO.CODIGO,
    case when (SELECT SUM(MATERIALLOCAL.SALDOTOTAL)
     FROM MATERIALLOCAL
     WHERE MATERIALLOCAL.IDITEM=substring(ITEMESTOQUESALDO.codigo from 1 for 7))-
     coalesce((select 
         SUM(MERCADORIASPED.QUANTIDADE -
             COALESCE(MERCADORIASPED.QTDEENVIADA,0))
      FROM
         MERCADORIASPED
      INNER JOIN
        PEDIDO ON 
            PEDIDO.FILIAL = MERCADORIASPED.FILIAL AND PEDIDO.IDNOTA =  MERCADORIASPED.IDNOTA WHERE MERCADORIASPED.CODIGO=ITEMESTOQUESALDO.CODIGO AND
         MERCADORIASPED.BAIXA='N' AND
         PEDIDO.DATAEMISSAO IS NOT NULL AND
         PEDIDO.DATACANCELAMENTO IS NULL),0)>0 THEN
      (SELECT SUM(MATERIALLOCAL.SALDOTOTAL)
     FROM MATERIALLOCAL
     WHERE MATERIALLOCAL.IDITEM=ITEMESTOQUESALDO.CODIGO)-
           coalesce((select 
         SUM(MERCADORIASPED.QUANTIDADE -
             COALESCE(MERCADORIASPED.QTDEENVIADA,0))
      FROM
         MERCADORIASPED
      INNER JOIN
        PEDIDO ON 
            PEDIDO.FILIAL = MERCADORIASPED.FILIAL AND
            PEDIDO.IDNOTA =  MERCADORIASPED.IDNOTA
      WHERE
         MERCADORIASPED.CODIGO=ITEMESTOQUESALDO.CODIGO AND
         MERCADORIASPED.BAIXA='N' AND
         PEDIDO.DATAEMISSAO IS NOT NULL AND
         PEDIDO.DATACANCELAMENTO IS NULL),0)
      else 0 end,
    C_LOGSALDOECOMMERCE.INCLUSAO,
    C_LOGSALDOECOMMERCE.ENVIADO,
    C_LOGSALDOECOMMERCE.STATUS_CODE,
    substring(C_LOGSALDOECOMMERCE.CONTENT  from 1 for 100)
FROM
    C_LOGSALDOECOMMERCE
INNER JOIN    
    ITEMESTOQUE ITEMESTOQUEORIGINAL ON
       C_LOGSALDOECOMMERCE.CODIGO = ITEMESTOQUEORIGINAL.CODIGO
INNER JOIN    
    ITEMESTOQUE ITEMESTOQUESALDO ON
       ITEMESTOQUESALDO.CODIGO = coalesce(ITEMESTOQUEORIGINAL.ITEMBASE, ITEMESTOQUEORIGINAL.CODIGO)
WHERE
  COALESCE(C_LOGSALDOECOMMERCE.STATUS_CODE,'') NOT IN ('200', '201')
  
