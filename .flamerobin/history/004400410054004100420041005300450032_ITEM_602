SELECT
    DISTINCT
    objeto.id,
    objeto.tipo,
    objeto.descricao
FROM
    USUARIO
inner JOIN
    GRUPOXUSUARIO on
        grupoxusuario.IDUSUARIO=usuario.id
inner JOIN
    USUARIOXOBJETO ON
        USUARIOXOBJETO.IDUSUARIO=GRUPOXUSUARIO.IDGRUPO
INNER JOIN 
    OBJETO ON
        OBJETO.ID=USUARIOXOBJETO.IDOBJETO
where 
    usuario.id=39