select
    1 as id,
    min(cast('now' as timestamp)) momento,
    SUM((COALESCE(MOVIMENTOESTOQUE.SAIDAPRODUCAO, CAST('NOW' AS TIMESTAMP)) -
    MOVIMENTOESTOQUE.ENTRADAPRODUCAO)*24*60)/COUNT(MOVIMENTOESTOQUE.IDMOVIMENTO) AS PICKING,
    
    
    SUM((COALESCE(NOTAFISCAL.datahoraemissao, CAST('NOW' AS TIMESTAMP)) -
    MOVIMENTOESTOQUE.SAIDAPRODUCAO)*24*60)/COUNT(MOVIMENTOESTOQUE.IDMOVIMENTO) AS NF,
    

    SUM((COALESCE(movimentoestoque.COLETADATA, CAST('NOW' AS TIMESTAMP)) -
    NOTAFISCAL.datahoraemissao)*24*60)/COUNT(MOVIMENTOESTOQUE.IDMOVIMENTO) AS Shipping    
    
    SUM((COALESCE(movimentoestoque.COLETADATA, CAST('NOW' AS TIMESTAMP)) -
    NOTAFISCAL.datahoraemissao)*24*60)/COUNT(MOVIMENTOESTOQUE.IDMOVIMENTO) AS Shipping    ,
    
    sum(cast((coalesce(coalesce(notafiscal.datahoraEntrega, 
                            movimentoestoque.dataEntrega),
                   CAST('NOW' AS TIMESTAMP))-
          coalesce(movimentoestoque.COLETADATA, 
                   coalesce(notafiscal.datahoraEntrega, 
                            coalesce(movimentoestoque.dataEntrega,
                                     CAST('NOW' AS TIMESTAMP)
                                     )
                            ))
                   )*24*60 as integer)) /COUNT(MOVIMENTOESTOQUE.IDMOVIMENTO) AS delivery    
from
    MOVIMENTOESTOQUE
INNER join
    PEDIDO ON
        MOVIMENTOESTOQUE.FILIAL=PEDIDO.FILIAL and
        MOVIMENTOESTOQUE.IDPEDIDO=PEDIDO.IDNOTA
left join        
    NOTAFISCAL on
        notafiscal.filial=movimentoestoque.filial and
        notafiscal.idnota=movimentoestoque.IDNOTAEXPEDICAO
where
    MOVIMENTOESTOQUE.EMISSAO = cast('now' as date) and
    MOVIMENTOESTOQUE.TIPOMOVIMENTO='13' and
    MOVIMENTOESTOQUE.transportadora=15154