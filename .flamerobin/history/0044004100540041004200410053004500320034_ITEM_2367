SELECT
    itemestoque.codigo,
    itemestoque.descricao,
    materiallocal.saldototal,
    materialfilial.CONSUMOMEDIO,
    (materialfilial.consumomedio/20) mediadias,
    materiallocal.saldototal/(materialfilial.consumomedio/20) diasprazerar,
    notacompra.NRNOTAFORNECEDOR,
    CADASTROPARCEIROS.nome
FROM
    materiallocal    
inner JOIN
    materialfilial on
        materialfilial.filial=materiallocal.filial AND
        materialfilial.iditem=materiallocal.iditem
inner JOIN
    itemestoque on
        itemestoque.codigo=materialfilial.iditem
left JOIN
    mercadoriasnotacompra on
        mercadoriasnotacompra.filial=materialfilial.filial AND
        mercadoriasnotacompra.iditem=materialfilial.iditem AND
        mercadoriasnotacompra.baixa='N'
left JOIN
    notacompra on
        notacompra.filial=mercadoriasnotacompra.filial AND
        notacompra.idnota=mercadoriasnotacompra.IDNOTA
left JOIN
    cadastroparceiros on
        cadastroparceiros.cadastro=notacompra.destinatario
        
WHERE
    materialfilial.filial=5 and
    materiallocal.idlocal=1 and
    materialfilial.consumomedio>0 and consumomedio<10000
order by 
    materialfilial.consumomedio desc