SELECT T_LOTESNULOS.*,locallote.quantidade,
(select max(movimentoestoque.emissao)
from MATERIALMOVIMENTOESTOQUE
inner join movimentoestoque on
movimentoestoque.filial=materialmovimentoestoque.filial and
movimentoestoque.idmovimento=MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
where 
materialmovimentoestoque.filial=locallote.filial and
materialmovimentoestoque.iditem=locallote.iditem and
materialmovimentoestoque.LOCALARMAZENAMENTO=locallote."LOCAL" and 
materialmovimentoestoque.lote=locallote.lote )
FROM T_LOTESNULOS
INNER JOIN LOCALLOTE on
LOCALLOTE.FILIAL=110
AND LOCALLOTE.IDITEM=T_LOTESNULOS.IDITEM
ANd locallote.lote=t_lotesnulos.LOTE
and locallote."LOCAL"=t_lotesnulos.localarmazenamento
and locallote.quantidade<>0