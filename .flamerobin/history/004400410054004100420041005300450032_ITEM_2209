--UPDATE
--    mercadoriaspedcompra
--SET
--    minimo = quantidade
    
    
update
    MERCADORIASPEDCOMPRA
SET
    mercadoriaspedcompra.MINIMOBAIXA=mercadoriaspedcompra.quantidade,
    mercadoriaspedcompra.qtdeentregue=
    (select 
        sum(mercadoriasnotacompra.quantidade)
     FROM   
        MERCADORIASNOTACOMPRA
     where 
        mercadoriasnotacompra.filial=mercadoriaspedcompra.filial AND
        mercadoriasnotacompra.idpedido=mercadoriaspedcompra.idnota AND
        mercadoriasnotacompra.IDMERCPEDIDO=mercadoriaspedcompra.IDMERCADORIA)
WHERE   
    exists 
        (select
            *
         FROM
            T_MERCADORIABAIXA 
         where 
            t_mercadoriabaixa.filial=mercadoriaspedcompra.filial AND
            t_mercadoriabaixa.idnota=mercadoriaspedcompra.idnota AND
            t_mercadoriabaixa.idmercadoria=mercadoriaspedcompra.IDMERCADORIA)