INSERT INTO ITEMCUSTODATA(
    FILIAL,
    DATAINVENTARIO,
    CODIGO,
    CUSTOUNITARIO,
    QUANTIDADE,
    CUSTOTOTAL)
SELECT 
    FILIAL,
    '31.01.2024',
    CODIGO,
    CUSTOUNITARIO,
    QUANTIDADE,
    ITEMCUSTODATA.CUSTOTOTAL
FROM 
    ITEMCUSTODATA 
WHERE 
    CODIGO LIKE  'MPS%' AND 
    DATAINVENTARIO='31.12.2023'
