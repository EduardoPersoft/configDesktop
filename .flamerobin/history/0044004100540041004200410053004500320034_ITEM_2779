delete from MATERIALMOVIMENTOESTOQUE
where materialmovimentoestoque.filial=5 and
MATERIALMOVIMENTOESTOQUE.CONCLUIDO='N' and
exists (
    select 
        * 
    from 
        movimentoestoque 
    where 
        materialmovimentoestoque.filial=movimentoestoque.filial and 
        materialmovimentoestoque.idmovimento=movimentoestoque.idmovimento and
        movimentoestoque.TIPOMOVIMENTO='13' and
        movimentoestoque.emissao<'01.07.2022'
        )
order by
    materialmovimentoestoque.idmovimento