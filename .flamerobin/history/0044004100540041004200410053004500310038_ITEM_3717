SET TERM ^ ;
ALTER PROCEDURE C_LISTAORCCANAL (
    PFILIAL integer,
    PPARCEIRO integer )
RETURNS (
    FILIAL integer,
    IDNOTA integer,
    DATACADASTRO timestamp,
    DATAEMISSAO timestamp,
    NUMERONOTA integer,
    DESTINATARIO integer,
    EMAIL varchar(50),
    TELEFONE varchar(30),
    NOME varchar(50),
    DOCUMENTO varchar(14),
    NOME_LOJA varchar(50),
    VLRTOTALNOTA double precision,
    STATUS varchar(30),
    VENDEDOR varchar(60),
    TIPO varchar(30),
    AGENTENOME varchar(60),
    uuid varchar(36))

AS
DECLARE V_TIPOAGENTE INTEGER;
DECLARE V_CANALRELACIONADO INTEGER;
DECLARE V_PRINCIPAL INTEGER;
DECLARE V_CLIENTE INTEGER;
DECLARE V_CLIENTEPESQUISA INTEGER;
BEGIN

  V_TIPOAGENTE = NULL;
  V_PRINCIPAL = NULL;
  V_CLIENTE = NULL;

  SELECT VENDEDOR.CANALRELACIONADO,VENDEDOR.TIPOVENDEDOR FROM VENDEDOR WHERE CADASTRO=:PPARCEIRO
  INTO V_CANALRELACIONADO,V_TIPOAGENTE;
  
  V_PRINCIPAL = PPARCEIRO;
  IF (V_TIPOAGENTE=6) then
      V_PRINCIPAL=V_cANALRELACIONADO;
  
    
  
  FOR SELECT VENDEDOR.CADASTRO, CADASTROPARCEIROS.NOME FROM VENDEDOR   
  INNER JOIN CADASTROPARCEIROS ON VENDEDOR.CADASTRO=CADASTROPARCEIROS.CADASTRO
  WHERE VENDEDOR.CANALRELACIONADO=:V_PRINCIPAL 
  UNION 
  SELECT VENDEDOR.CADASTRO, CADASTROPARCEIROS.NOME FROM VENDEDOR   
  INNER JOIN CADASTROPARCEIROS ON VENDEDOR.CADASTRO=CADASTROPARCEIROS.CADASTRO  
  WHERE VENDEDOR.CADASTRO=:V_PRINCIPAL
  INTO  :V_CLIENTEPESQUISA, AGENTENOME DO 
    FOR SELECT PED2.FILIAL,
       PED2.IDNOTA,
       PED2.DATACADASTRO,
       PED2.DATAEMISSAO,
       PED2.NUMERONOTA,
       PED2.DESTINATARIO,
       PED2.EMAIL,
       PED2.TELEFONE,
       PED2.VLRTOTALNOTA,
       case ped2.cadastrar when 'S' then ped2.AOSCUIDADOS
       else CADCLI.NOME END AS AOSCUIDADOS,
       CADCLI.DOCUMENTO,
       CADLOJA.NOME AS NOME_LOJA,

       CASE when ped2.dataemissao IS NULL THEN 'SEM APROVAÇĂO'
       WHEN EXISTS (SELECT * FROM PEDIDO
                    WHERE PEDIDO.FILIAL=ped2.FILIAL
                    AND PEDIDO.IDORCAMENTO=ped2.IDNOTA)
                or EXISTS (SELECT * FROM PEDIDO
                    WHERE PEDIDO.FILIAL=ped2.FILIAL
                    AND PEDIDO.IDORCAMENTO=ped2.idrelacao)  THEN 'FECHADO'
       ELSE
        CASE COALESCE(ped2.c_status,0) WHEN 0 THEN 'ABERTO'
        WHEN 1 THEN 'ABERTO' WHEN 2 THEN 'SUSPENSO' WHEN 3 THEN 'PERDIDO'
        WHEN 4 THEN 'FECHADO' END
      END STATUS ,      
      (select FIRST 1 cadven.NOME FROM vendedoresPED
       INNER JOIN CADASTROPARCEIROS CADVEN ON (CADVEN.cadastro=VENDEDORESPED.vendedor)
       WHERE VENDEDORESPED.filial=PED2.FILIAL
       AND VENDEDORESPED.idnota=PED2.IDNOTA) VENDEDOR,
       ped2.uuid

    FROM VENDEDORESORC 
    INNER JOIN ORCAMENTO PED2 ON (VENDEDORESORC.FILIAL=PED2.FILIAL AND VENDEDORESORC.IDNOTA=PED2.IDNOTA)
    INNER JOIN CADASTROPARCEIROS cadcli ON (CADCLI.CADASTRO = PED2.DESTINATARIO)
    LEFT JOIN CADASTROPARCEIROS CADLOJA ON (CADLOJA.CADASTRO = PED2.c_loja) 
    WHERE VENDEDORESORC.FILIAL=:pFILIAL
    AND VENDEDORESORC.VENDEDOR =:V_CLIENTEPESQUISA
    INTO FILIAL,IDNOTA,DATACADASTRO,DATAEMISSAO,NUMERONOTA,DESTINATARIO,EMAIL,TELEFONE,VLRTOTALNOTA,NOME,
         DOCUMENTO,NOME_LOJA,STATUS,VENDEDOR, uuid DO
        SUSPEND;
END
^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE C_LISTAORCCANAL TO  SYSDBA;

