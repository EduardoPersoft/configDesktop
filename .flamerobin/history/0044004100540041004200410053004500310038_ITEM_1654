select * from c_comissaopedidopaga
where not exists 

(select * from VENDEDORESPED
where vendedoresped.filial=c_comissaopedidopaga.filial and
vendedoresped.idnota=c_comissaopedidopaga.idnota and
vendedoresped.VENDEDOR=c_comissaopedidopaga.vendedor and
vendedoresped.C_IDCOMISSAO=C_COMISSAOPEDIDOPAGA.id)
order by id desc