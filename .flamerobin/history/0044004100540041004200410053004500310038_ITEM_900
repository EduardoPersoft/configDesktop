
SELECT
    MATERIALLOTE.FILIAL,
    MATERIALLOTE.IDITEM,
    MATERIALLOTE.LOTE,
    CAST(COALESCE((SELECT SUM(MATERIALMOVIMENTOESTOQUE.QUANTIDADE*MATERIALMOVIMENTOESTOQUE.SINAL)
     FROM MATERIALMOVIMENTOESTOQUE
     WHERE MATERIALMOVIMENTOESTOQUE.FILIAL=MATERIALLOTE.FILIAL
     AND MATERIALMOVIMENTOESTOQUE.iditem=MATERIALLOTE.iditem
     and MATERIALMOVIMENTOESTOQUE.lote=MATERIALLOTE.lote),0) AS DECIMAL(15,3)),
     
    CAST(COALESCE((SELECT SUM(MATERIALMOVIMENTOESTOQUE.VALOR*MATERIALMOVIMENTOESTOQUE.SINAL)
     FROM MATERIALMOVIMENTOESTOQUE
     WHERE MATERIALMOVIMENTOESTOQUE.FILIAL=MATERIALLOTE.FILIAL
     AND MATERIALMOVIMENTOESTOQUE.iditem=MATERIALLOTE.iditem
     and MATERIALMOVIMENTOESTOQUE.lote=MATERIALLOTE.lote),0) AS DECIMAL(15,2))
FROM      
    MATERIALLOTE
WHERE
     WHERE FILIAL=1
     AND IDITEM BETWEEN '01.' AND '09.99.9999'

