SET TERM ^ ;
ALTER TRIGGER ATITEMPEDCOMPRA_INSERT ACTIVE
BEFORE INSERT POSITION 0
AS
BEGIN
  UPDATE MERCADORIASPEDCOMPRA SET QTDEENTREGUE= case when mercadoriaspedcompra.unidade in ('PC', 'UN') and new.unidade = 'MIL' then QTDEENTREGUE+(NEW.QUANTIDADE*1000)
                                                     when mercadoriaspedcompra.unidade in ('PC', 'UN') and new.unidade IN ('CT', 'CEN') then QTDEENTREGUE+(NEW.QUANTIDADE*100) 
                                                     ELSE (QTDEENTREGUE+NEW.QUANTIDADE) end
  
  WHERE MERCADORIASPEDCOMPRA.FILIAL=NEW.FILIAL
  AND MERCADORIASPEDCOMPRA.IDNOTA=NEW.IDPEDIDO
  AND MERCADORIASPEDCOMPRA.IDMERCADORIA=NEW.IDMERCPEDIDO;
  
  
  UPDATE MERCADORIASPED SET QTDEENVIADA=QTDEENVIADA-NEW.QUANTIDADE
  WHERE MERCADORIASPED.FILIAL=NEW.FILIAL
  AND MERCADORIASPED.IDNOTA=NEW.IDPEDVENDEV
  AND MERCADORIASPED.IDMERCADORIA=NEW.IDPEDVENMERCDEV;
END^
SET TERM ; ^
