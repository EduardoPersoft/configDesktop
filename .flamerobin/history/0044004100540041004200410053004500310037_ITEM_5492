SELECT
    locallote.local,
    locallote.IDITEM,
    ITEMESTOQUE.CODIGOBARRA,
    ITEMESTOQUE.UNIDADE,
    ITEMESTOQUE.DESCRICAO,
    locallote.FILIAL,
    locallote.QUANTIDADE
FROM
    LOCALLOTE
INNER JOIN
    ITEMESTOQUE ON
        LOCALLOTE.IDITEM=ITEMESTOQUE.CODIGO
WHERE
    LOCALLOTE.QUANTIDADE>0
ORDER BY
    LOCALLOTE.LOCAL