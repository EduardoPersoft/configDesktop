SET TERM ^;

CREATE TRIGGER c_movEstqBloqueiaPedido FOR MOVIMENTOESTOQUE
ACTIVE BEFORE INSERT POSITION 100
AS
BEGIN
   if(new.tipomovimento='13' and new.idpedido is not null) then
    update pedido set pedido.BLOQUEADOLOGISTICA='S' 
    where pedido.filial=new.filial and
    pedido.idnota=new.idpedido;
   
END^

SET TERM ;^
