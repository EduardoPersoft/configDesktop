SET TERM ^ ;
ALTER TRIGGER C_LOGECOMMERCEED ACTIVE
BEFORE UPDATE POSITION 991


AS 
 DECLARE VARIABLE CODIGO INTEGER;   
BEGIN 
    FOR 
        SELECT 
            MERCADORIASPED.CODIGO
         FROM
            MERCADORIASPED
         WHERE 
            MERCADORIASPED.FILIAL=NEW.FILIAL AND
            MERCADORIASPED.IDNOTA=NEW.IDNOTA
        INTO :CODIGO DO 
            EXECUTE PROCEDURE C_LOGECOMMERCESALDO(:CODIGO);

    execute procedure C_LOGECOMMERCEPEDIDO(new.filial, new.idnota);
    
END
^
SET TERM ; ^
