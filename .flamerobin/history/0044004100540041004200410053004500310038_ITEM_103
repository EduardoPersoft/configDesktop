SELECT
    MOVIMENTOESTOQUE.FILIAL,
    MOVIMENTOESTOQUE.IDMOVIMENTO,
    MOVIMENTOESTOQUE.PROCESSAMENTO,
    MOVIMENTOESTOQUE.TIPOMOVIMENTO,
    TIPOMOVIMENTOESTOQUE.DESCRICAO AS TIPOMOVIMENTODESCRICAO,
    MOVIMENTOESTOQUE.PRIORIDADE,
    MOVIMENTOESTOQUE.MERCADORIASERVICO,
    MOVIMENTOESTOQUE.DOCUMENTO,
    MOVIMENTOESTOQUE.IDPEDIDO,
    cast(MOVIMENTOESTOQUE.EMISSAO as date) EMISSAO,
    MOVIMENTOESTOQUE.LOCALARMAZENAMENTO,
    LOCALMOVIMENTO.DESCRICAO AS LOCALDESCRICAO,
    MOVIMENTOESTOQUE.LOCALTRANSFERENCIA,
    LOCALTRANSFERENCIA.DESCRICAO AS LOCALDESCRICAOTRANSFERENCIA,
    MOVIMENTOESTOQUE.IDMOVTOTRANSFERENCIA,
    MOVIMENTOESTOQUE.IDOP,
    MOVIMENTOESTOQUE.IDOPITEM,
    MOVIMENTOESTOQUE.QUANTIDADE,
    MOVIMENTOESTOQUE.IDITEMESTOQUE,
    MOVIMENTOESTOQUE.previsaoFimProducao,
    MOVIMENTOESTOQUE.IDNOTAEXPEDICAO,
    NOTAFISCAL.NUMERONOTA,
    NOTAFISCAL.DATAEMISSAO AS EMISSAONOTA,
    NOTAFISCAL.VLRTOTALNOTA AS VALRTOTALNOTA,
    MOVIMENTOESTOQUE.PESOLIQUIDO,
    MOVIMENTOESTOQUE.PESOBRUTO,
    MOVIMENTOESTOQUE.QUANTIDADEVOLUMES,
    MOVIMENTOESTOQUE.MARCAVOLUME,
    MOVIMENTOESTOQUE.CALCULAVOLUME,
    MOVIMENTOESTOQUE.TRANSPORTADORA,
    CADTRANS.NOME,
    CADTRANS.TELEFONE,
    CADTRANS.EMAIL,
    MOVIMENTOESTOQUE.CODSERVICOENTREGA,
    MOVIMENTOESTOQUE.DESCRICAOSERVICOENTREGA,
    MOVIMENTOESTOQUE.PLACAINTINERARIO,
    MOVIMENTOESTOQUE.COLETA,
    MOVIMENTOESTOQUE.COLETADATA,
    MOVIMENTOESTOQUE.DATAENTREGA,
    MOVIMENTOESTOQUE.OBSERVACAONOTAFISCAL,
    MOVIMENTOESTOQUE.OBSERVACAOEXPEDICAO,
    MOVIMENTOESTOQUE.OBSERVACAO,
    CADCLI.CADASTRO CADCLI,
    CADCLI.NOME CADNOME,
    CASE COALESCE(PEDIDO.LOGRADOUROENTREGA, '') WHEN '' 
    THEN CADCLI.LOGRADOURO ELSE PEDIDO.LOGRADOUROENTREGA END, 
    CASE COALESCE(PEDIDO.LOGRADOUROENTREGA, '') WHEN '' 
    THEN CADCLI.NUMERO ELSE PEDIDO.NUMEROENTREGA END, 
    CASE COALESCE(PEDIDO.COMPLEMENTOENTREGA, '') WHEN '' 
    THEN CADCLI.COMPLEMENTO ELSE PEDIDO.COMPLEMENTOENTREGA END, 
    CASE COALESCE(PEDIDO.BAIRROENTREGA, '') WHEN '' 
    THEN CADCLI.BAIRRO ELSE PEDIDO.BAIRROENTREGA END, 
    CASE COALESCE(PEDIDO.CIDADEENTREGA, '') WHEN '' 
    THEN CADCLI.CIDADE ELSE PEDIDO.CIDADEENTREGA END, 
    CASE COALESCE(PEDIDO.UFENTREGA, '') WHEN '' 
    THEN CADCLI.UF ELSE PEDIDO.UFENTREGA END, 
    CASE COALESCE(PEDIDO.CEPENTREGA, '') WHEN '' 
    THEN CADCLI.CEP ELSE PEDIDO.CEPENTREGA END,
    PEDIDO.CONTATOENTREGA,
    PEDIDO.TELEFONEENTREGA,
    PEDIDO.EMAIL,
    PEDIDO.ENTREGA,
    MOVIMENTOESTOQUE.IDSEPARADOR,
    SEPARADOR.NOME,   
    MOVIMENTOESTOQUE.IDCONFERENTE,
    conferente.NOMECOMPLETO,
    MOVIMENTOESTOQUE.ORIGEM,
    MOVIMENTOESTOQUE.USUARIO,
    MOVIMENTOESTOQUE.DATAALTERACAO,
    MOVIMENTOESTOQUE.HORAALTERACAO
FROM 
    MOVIMENTOESTOQUE
INNER JOIN
    TIPOMOVIMENTOESTOQUE ON
        TIPOMOVIMENTOESTOQUE.ID=MOVIMENTOESTOQUE.TIPOMOVIMENTO
INNER JOIN
    LOCAL LOCALMOVIMENTO ON
        LOCALMOVIMENTO.ID = MOVIMENTOESTOQUE.LOCALARMAZENAMENTO
LEFT JOIN
    LOCAL LOCALTRANSFERENCIA ON
        LOCALTRANSFERENCIA.ID = MOVIMENTOESTOQUE.LOCALTRANSFERENCIA
LEFT JOIN
    NOTAFISCAL ON
        NOTAFISCAL.FILIAL = MOVIMENTOESTOQUE.FILIAL
        AND NOTAFISCAL.IDNOTA = MOVIMENTOESTOQUE.IDNOTAEXPEDICAO
LEFT JOIN
    NOTACOMPRA ON
        NOTACOMPRA.FILIAL = MOVIMENTOESTOQUE.FILIAL
        AND NOTACOMPRA.IDNOTA = MOVIMENTOESTOQUE.IDNOTAEXPEDICAO
LEFT JOIN
    CADASTROPARCEIROS CADTRANS ON
        CADTRANS.CADASTRO=MOVIMENTOESTOQUE.TRANSPORTADORA
LEFT JOIN 
    PEDIDO ON
        PEDIDO.FILIAL = MOVIMENTOESTOQUE.FILIAL
        AND PEDIDO.IDNOTA = MOVIMENTOESTOQUE.IDPEDIDO 
LEFT JOIN
    CADASTROPARCEIROS CADCLI ON
        CADCLI.CADASTRO=PEDIDO.DESTINATARIO
LEFT JOIN
    CADASTROPARCEIROS SEPARADOR ON
        SEPARADOR.CADASTRO=MOVIMENTOESTOQUE.IDSEPARADOR
LEFT JOIN
    USUARIO CONFERENTE ON
        conferente.id=movimentoestoque.IDCONFERENTE
WHERE
    MOVIMENTOESTOQUE.FILIAL = 1
    AND MOVIMENTOESTOQUE.IDMOVIMENTO=1720
