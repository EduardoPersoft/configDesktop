select
    itemestoque.codigo,
    itemestoque.descricao,
    GRUPOMERCADORIA.descricao,
    CADASTROPARCEIROS.nome fornecedor,
    itemestoque.C_NOMENOFORNECEDOR descricao_fornecedor,
    itemestoque.C_DETALHES detalhes,
    itemestoque.C_DIMENSOES dimensoes,
    C_LISTACUSTO.DESCRICAO especificacao,
    C_LISTACUSTO.CUSTO custo
from
    ITEMESTOQUE
inner join
    GRUPOMERCADORIA on
        GRUPOMERCADORIA.grupo=itemestoque.GRUPO
inner join
    CADASTROPARCEIROS on
        CADASTROPARCEIROS.cadastro=ITEMESTOQUE.FABRICANTE
INNER join
    C_LISTACUSTO ON
        C_LISTACUSTO.IDITEM=ITEMESTOQUE.CODIGO