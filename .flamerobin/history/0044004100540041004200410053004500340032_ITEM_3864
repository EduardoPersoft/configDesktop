select 
    CADFIL.NOME AS FILIAL,
    SERVICOSPED.IDNOTA IDPEDIDO,
    PEDIDOCLICHE.DATACADASTRO,
    SERVICOSPED.IDSERVICO AS ITEMPEDCOM,
    SERVICOSPED.C_CODIGO PRODUTO,
    SERVICOSPED.DESREDUZIDA,
    SERVICOSPED.VLRFINALSERVICO,
    PEDIDOPRODUTO.IDNOTA IDPEDIDOVENDA,
    SERVICOSPED.C_IDMERCVEN ITEMPDVEN,
    PEDIDOPRODUTO.DATAREFERENCIA
    
from 
    SERVICOSPED
INNER join
    CADASTROPARCEIROS CADFIL ON
            CADFIL.CADASTRO=SERVICOSPED.FILIAL
INNER join
    PEDIDO PEDIDOCLICHE ON
        PEDIDOCLICHE.FILIAL=SERVICOSPED.FILIAL and
        PEDIDOCLICHE.IDNOTA=SERVICOSPED.IDNOTA
LEFT join
    PEDIDO PEDIDOPRODUTO ON 
        PEDIDOPRODUTO.FILIAL=SERVICOSPED.C_FILIALPEDVEN and
        PEDIDOPRODUTO.IDNOTA=SERVICOSPED.C_IDPEDVEN 
where  
SERVICOSPED.filial in (110,3941)
and SERVICOSPED.baixa='N'
and SERVICOSPED.C_ITEMESTOQUE  is not null
ORDER BY
    PEDIDOCLICHE.FILIAL,
    PEDIDOCLICHE.IDNOTA