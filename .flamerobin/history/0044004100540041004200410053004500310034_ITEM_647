select
    CENTROCUSTOSITEM.IDITEM,
    centrocustositem.SEQUENCIA,
    CENTROCUSTOSITEM.IDCENTROCUSTO,
    CENTROCUSTOS.DESCRICAO,
    CENTROCUSTOS.CUSTOPRODUCAO,
    CENTROCUSTOS.C_VELOCIDADEDEFAULT,
    CENTROCUSTOS.C_SETUP
    
from 
    CENTROCUSTOSITEM
inner join
    ESTABELECIMENTO ON 
    ESTABELECIMENTO.CADASTRO=CENTROCUSTOSITEM.FILIAL
inner join 
CENTROCUSTOS on 

    centroCustos.idplano=estabelecimento.planoCentroCustos and
    centrocustos.centroCusto=centrocustositem.idcentrocusto
inner join 
    itemestoque on 
    CENTROCUSTOSITEM.IDITEM=itemestoque.CODIGO
    /*
    
    
INNER JOIN 
    cadastroparceiros E_CADASTROPARCEIROS ON 
    (E_CADASTROPARCEIROS.CADASTRO=?)
left JOIN 
    CADASTROPARCEIROS C_CADASTROPARCEIROS ON 
    (C_CADASTROPARCEIROS.CADASTRO=?)
LEFT JOIN 
    NATUREZAOPERACAO ON 
    (NATUREZAOPERACAO.ID=?)
LEFT JOIN 
    LISTAPRECOPRODUTO LP1 ON (LP1.LISTA=?
AND 
    LP1.PRODUTO=CENTROCUSTOSITEM.IDITEM) 
*/
where
    CENTROCUSTOSITEM.IDITEM='I3-11M2WM' 
order by 
     CENTROCUSTOSITEM.IDITEM