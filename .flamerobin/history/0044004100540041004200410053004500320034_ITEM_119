SELECT
    pedidocompra.idnota,
    pedidocompra.datacadastro,
    cadastroparceiros.nome,
    CONDICAOPAGAMENTO.DESCRICAO,
    pedidocompra.VLRTOTALNOTA,
    pedidocompra.usuario
from
    pedidocompra 
inner JOIN
    cadastroparceiros on
        cadastroparceiros.cadastro=pedidocompra.DESTINATARIO
left JOIN
    CONDICAOPAGAMENTO on    
        condicaopagamento.id=pedidocompra.CONDICAOPAGAMENTO
where 
    pedidocompra.filial=5 AND
    pedidocompra.DATACADASTRO = '13.10.2021'