select distinct idmovimento from materialmovimentoestoque
where MATERIALMOVIMENTOESTOQUE.CONCLUIDO='N'
and exists (
select * from composicaoop
where MATERIALMOVIMENTOESTOQUE.filial=composicaoop.filial and
materialmovimentoestoque.idmovimento=COMPOSICAOOP.idmovimento and
substring(COMPOSICAOop.CODIGO from 1 for 2)='M-')
and exists (
select * from movimentoestoque
where MOVIMENTOestoque.filial=MATERIALMOVIMENTOESTOQUE.filial and
movimentoestoque.idmovimento=MATERIALMOVIMENTOESTOQUE.idmovimento and
movimentoestoque.tipomovimento='12')