update
    orcamento principal
set 
    principal.c_status=2
where
    principal.c_status<2 and
    exists(select 
        * 
     from 
        orcamento alternativo
     where 
        alternativo.filial=principal.FILIAL and
        alternativo.IDRELACAO=principal.IDNOTA and
        alternativo.c_status=2)
 order by principal.idnota   
