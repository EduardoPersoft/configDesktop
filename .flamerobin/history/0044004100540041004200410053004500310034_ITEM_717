select 
    C_COMPOSICAOMERCORC.FILIAL,
    C_COMPOSICAOMERCORC.IDNOTA,
    C_COMPOSICAOMERCORC.IDMERCADORIA,
    C_COMPOSICAOMERCORC.SEQUENCIA,
    C_COMPOSICAOMERCORC.IDMATERIAL,
    ITEMESTOQUE.DESCRICAO,
    ITEMESTOQUE.UNIDADE,
    C_COMPOSICAOMERCORC.tipomateriaprima,
    C_COMPOSICAOMERCORC.aproveitamento,
    C_COMPOSICAOMERCORC.CUSTO,
    C_COMPOSICAOMERCORC.PARTICIPACAO,
    C_COMPOSICAOMERCORC.gramatura,
    C_COMPOSICAOMERCORC.quantidade,
    C_COMPOSICAOMERCORC.CustoTotal
    
    
from 
    C_COMPOSICAOMERCORC
left join 
    ITEMESTOQUE on 
        ITEMESTOQUE.CODIGO=C_COMPOSICAOMERCORC.idmaterial
where
    C_COMPOSICAOMERCORC.FILIAL=110 and 
    C_COMPOSICAOMERCORC.IDNOTA=24 
ORDER BY
    C_COMPOSICAOMERCORC.FILIAL,
    C_COMPOSICAOMERCORC.IDNOTA,
    C_COMPOSICAOMERCORC.IDMERCADORIA