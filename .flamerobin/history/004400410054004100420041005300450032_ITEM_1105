UPDATE
    ITEMESTOQUE
SET
    itemestoque.TRIBUTACAOICMS = 2

SELECT
    *
FROM
    ITEMESTOQUE
WHERE
    exists (
        SELECT
            *
        from 
            CLASSIFICACAOFISCAL
        WHERE
            classificacaofiscal.CFISCAL = itemestoque.CLASSIFISCAL
            and COALESCE(CLASSIFICACAOFISCAL.C_TRIBUTACAOICMS,0)=2)