insert into C_PEDIDOITENSESTIMADO
select 
    mercadoriasped.filial,
    mercadoriasped.idnota,
    mercadoriasped.idmercadoria
from
    PEDIDO
inner join
    mercadoriasped on
        mercadoriasped.filial=pedido.filial and
        mercadoriasped.idnota=pedido.idnota 
where 
    pedido.filial=110 and
    pedido.datacadastro <= '31.01.2025' and
    pedido.dataemissao is not null and
    pedido.DATACANCELAMENTO is null and
    mercadoriasped.baixa='S' and 
    exists (
        select
            *
        from 
            mercadoriasnota
        inner join 
            notafiscal on   
                NOTAFISCAL.filial=mercadoriasnota.filial and
                notafiscal.idnota=mercadoriasnota.idnota
        where
            mercadoriasnota.filial=mercadoriasped.filial and
            mercadoriasnota.IDpedido=mercadoriasped.idnota and
            mercadoriasnota.IDMERCPEDIDO=mercadoriasped.IDMERCADORIA and
            notafiscal.DATACANCELAMENTO is null and
            notafiscal.dataemissao>'31.01.2025'          
    )