    SELECT
        C_PEDIDODATAFIN.FILIAL,
        C_PEDIDODATAFIN.IDNOTA,
        C_PEDIDODATAFIN.VENDEDOR,
        cast(C_PEDIDODATAFIN.PARTICIPACAO as numeric(12,3))
    FROM
        C_PEDIDODATAFINCOMFIL(?) C_PEDIDODATAFIN
    INNER JOIN
        VENDEDOR ON
            (VENDEDOR.CADASTRO=C_PEDIDODATAFIN.VENDEDOR)
    WHERE
        COALESCE(C_PEDIDODATAFIN.PARTICIPACAO,0)>0
