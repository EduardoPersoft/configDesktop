SELECT 
    MOVIMENTOESTOQUE.FILIAL,
    MOVIMENTOESTOQUE.IDMOVIMENTO,
    MOVIMENTOESTOQUE.IDPEDIDO,
    CADFIL.NOME NOMEFILIAL,
    CADFIL.TELEFONE,
    CADFIL.WEB,
    NOTAFISCAL.NUMERONOTA,
    NOTAFISCAL.DATAEMISSAO
 FROM 
    MOVIMENTOESTOQUE
 INNER JOIN 
    CADASTROPARCEIROS CADFIL ON
        CADFIL.CADASTRO=MOVIMENTOESTOQUE.FILIAL
INNER JOIN
    PEDIDO ON
    PEDIDO.FILIAL=MOVIMENTOESTOQUE.FILIAL AND 
    PEDIDO.IDNOTA=MOVIMENTOESTOQUE.IDPEDIDO
INNER JOIN
    CADASTROPARCEIROS cadcli on
        cadcli.cadastro=pedido.destinatario
LEFT JOIN 
    NOTAFISCAL ON
        notafiscal.filial=movimentoestoque.filial and
        notafiscal.idnota=movimentoestoque.IDNOTAEXPEDICAO