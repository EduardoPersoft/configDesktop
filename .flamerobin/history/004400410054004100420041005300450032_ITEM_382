SELECT
    PEDIDO.IDNOTA,
    PEDIDO.IDNOTA,
    PEDIDO.IDNOTA, 
    PEDIDO.PESOLIQUIDO,
    PEDIDO.PESOBRUTO,
    PEDIDO.QUANTIDADEVOLUME,
    PEDIDO.MARCAVOLUME,
    PEDIDO.CALCULAVOLUMES,
    PEDIDO.TRANSPORTADORA,
    PEDIDO.CODSERVICOENTREGA,
    PEDIDO.DESCRICAOSERVICOENTREGA,
    PEDIDO.ENTREGA
FROM 
    PEDIDO
WHERE
    PEDIDO.FILIAL = 5
    AND PEDIDO.IDNOTA= 31
