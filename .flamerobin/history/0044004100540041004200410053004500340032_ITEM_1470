
SELECT 
    FILIAL,
    DATAINVENTARIO,
    CODIGO,
    CUSTOUNITARIO,
    QUANTIDADE,
    ITEMCUSTODATA.CUSTOTOTAL,
    CASE WHEN ITEMCUSTODATA.QUANTIDADE>0 THEN ITEMCUSTODATA.CUSTOTOTAL/ITEMCUSTODATA.QUANTIDADE
    ELSE 0 END
FROM 
    ITEMCUSTODATA 
WHERE 
    CODIGO LIKE  'MPP%' AND 
    DATAINVENTARIO='31.01.2024'