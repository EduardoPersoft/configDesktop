select 
    filial,
    idnota,
    dataemissao,
    datacadastro,
    numeronota,
    tipocobranca,
    notafiscal.CONTACORRENTECOBRAN,
    condicaopagamento ,
    bandeiracartao,
    notafiscal.IDVENDACARTAO
from 
    NOTAFISCAL
where 
filial=1
and dataemissao>='01.03.2025'
order by dataemissao desc,numeronota desc