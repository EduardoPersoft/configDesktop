select pedido.idnota pedido,
       pedido.DATACADASTRO,        
       CADASTROPARCEIROS.nome,
       PEDIDO.VLRTOTALNOTA,
       pedido.CANCELAMENTO,
       ENDERECOENTREGA.LOGRADOURO,
       ENDERECOENTREGA.NUMERO,
       ENDERECOENTREGA.COMPLEMENTO
from PEDIDO
INNER JOIN 
    CADASTROPARCEIROS on
        CADASTROPARCEIROS.cadastro=pedido.destinatario
inner join 
    ENDERECOENTREGA ON
        ENDERECOENTREGA.CADASTRO=PEDIDO.DESTINATARIO
where (pedido.destinatario=29096 and pedido.APELIDOENTREGA='Gi' and enderecoentrega.numero=215) or 
    (pedido.destinatario=33279 and pedido.APELIDOENTREGA='VANESSA' and enderecoentrega.numero=215)
and exists (
select * from vendedoresped 
where vendedoresped.filial=pedido.filial and
vendedoresped.idnota=pedido.idnota and
vendedoresped.vendedor in (10568,14917))

