select COALESCE(SPEDFISCAL_C.UF,'SP') ,
             sum(CASE WHEN SPEDFISCAL_C.IND_OPER = 1 THEN SPEDFISCAL_C.VL_FCP_UF_DEST ELSE 0 END), 
             sum(CASE WHEN SPEDFISCAL_C.IND_OPER = 1 THEN SPEDFISCAL_C.VL_ICMS_UF_DEST ELSE 0 END),
             sum(CASE WHEN SPEDFISCAL_C.IND_OPER = 1 THEN SPEDFISCAL_C.VL_ICMS_UF_REM ELSE 0 END),
             sum(CASE WHEN SPEDFISCAL_C.IND_OPER = 0 THEN SPEDFISCAL_C.VL_FCP_UF_DEST ELSE 0 END), 
             sum(CASE WHEN SPEDFISCAL_C.IND_OPER = 0 THEN SPEDFISCAL_C.VL_ICMS_UF_DEST ELSE 0 END),
             sum(CASE WHEN SPEDFISCAL_C.IND_OPER = 0 THEN SPEDFISCAL_C.VL_ICMS_UF_REM ELSE 0 END)
      from SPEDFISCAL_C
      group by 1