SELECT DISTINCT 
       cast('N' as char(1)) as P_MARCA,
       MOVIMENTOESTOQUE.FILIAL,
       MOVIMENTOESTOQUE.IDMOVIMENTO,
       MOVIMENTOESTOQUE.DOCUMENTO,
       PEDIDO.UUID,
       MOVIMENTOESTOQUE.EMISSAO,
       CADCLI.CADASTRO,
       CADCLI.RAZAOSOCIAL,
       CADCLI.NOME AS NOMECLI,
       CASE COALESCE(PEDIDO.LOGRADOUROENTREGA, '') WHEN '' 
       THEN CADCLI.LOGRADOURO ELSE PEDIDO.LOGRADOUROENTREGA END, 
       CASE COALESCE(PEDIDO.LOGRADOUROENTREGA, '') WHEN '' 
       THEN CADCLI.NUMERO ELSE PEDIDO.NUMEROENTREGA END, 
       CASE COALESCE(PEDIDO.LOGRADOUROENTREGA, '') WHEN '' 
       THEN CADCLI.COMPLEMENTO ELSE PEDIDO.COMPLEMENTOENTREGA END, 
       CASE 
         when COALESCE(transp.LOGRADOURO, '') <> '' then coalesce(TRANSP.BAIRROENTREGA,'')||' '||coalesce(TRANSP.CIDADEENTREGA, '')||' - '||coalesce(TRANSP.UFENTREGA,'')||' - CEP '||coalesce(TRANSP.CEPENTREGA,'')
         when COALESCE(pedido.LOGRADOUROENTREGA, '') <> '' then coalesce(PEDIDO.BAIRROENTREGA,'')||' '||coalesce(PEDIDO.CIDADEENTREGA, '')||' - '||coalesce(PEDIDO.UFENTREGA, '')||' - CEP '||coalesce(PEDIDO.CEPENTREGA, '')
         else coalesce(CADCLI.BAIRRO, '') ||' '||coalesce(CADCLI.CIDADE, '')||' - '||coalesce(CADCLI.UF,'')||' - CEP '||coalesce(CADCLI.CEP , '')
       end as localizacao,
       MOVIMENTOESTOQUE.motorista,
       coalesce(notafiscal.codigotransp,MOVIMENTOESTOQUE.TRANSPORTADORA),
       TRANSP.nome,
       MOVIMENTOESTOQUE.QUANTIDADEVOLUMES,
       MOVIMENTOESTOQUE.coleta,
       MOVIMENTOESTOQUE.coletadata,    
       MOVIMENTOESTOQUE.VALORFRETE,
       MODELODOCTO.MODELO,
       NOTAFISCAL.NUMERONOTA,
       NOTAFISCAL.uuid,
       movimentoestoque.idnotaexpedicao,
       COALESCE(MOVIMENTOESTOQUE.DATAENTREGA,notafiscal.datahoraEntrega) as dataEntrega,
       CASE WHEN EXISTS (SELECT * FROM MATERIALMOVIMENTOESTOQUE
                WHERE MATERIALMOVIMENTOESTOQUE.filial = MOVIMENTOESTOQUE.filial
                AND MATERIALMOVIMENTOESTOQUE.idmovimento = MOVIMENTOESTOQUE.idmovimento
                AND MATERIALMOVIMENTOESTOQUE.concluido = 'N') THEN 'N'
            ELSE 'S' END CONCLUIDO, 
        TIPOCOBRANCA.DESCRICAO,
        MOVIMENTOESTOQUE.MSGLIBERACAO,
    case nfectrl.idresultado when 100 then 'N' else 'S' end, 
    coalesce(notafiscal.VLRICMSRECOLHIDO,0)+
    coalesce(notafiscal.ICMSDESTINOVALOR,0)

FROM
    MOVIMENTOESTOQUE
INNER JOIN 
    TIPOMOVIMENTOESTOQUE ON 
        (TIPOMOVIMENTOESTOQUE.ID = MOVIMENTOESTOQUE.TIPOMOVIMENTO)
LEFT JOIN
    PEDIDO ON PEDIDO.FILIAL=MOVIMENTOESTOQUE.FILIAL AND PEDIDO.IDNOTA=MOVIMENTOESTOQUE.IDPEDIDO
LEFT JOIN 
    MATERIALMOVIMENTOESTOQUE ON
        MATERIALMOVIMENTOESTOQUE.FILIAL=MOVIMENTOESTOQUE.FILIAL
        AND MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO=MOVIMENTOESTOQUE.IDMOVIMENTO
LEFT JOIN
    CADASTROPARCEIROS CADCLI ON
        CADCLI.CADASTRO=PEDIDO.DESTINATARIO
LEFT JOIN 
    NOTAFISCAL ON 
        NOTAFISCAL.FILIAL=MOVIMENTOESTOQUE.FILIAL 
         and notafiscal.idnota=movimentoestoque.idnotaexpedicao
        AND NOTAFISCAL.DATACANCELAMENTO IS NULL LEFT JOIN 
    MERCADORIASNOTA ON
        MERCADORIASNOTA.FILIAL=NOTAFISCAL.FILIAL
        AND MERCADORIASNOTA.IDNOTA=NOTAFISCAL.IDNOTA
LEFT JOIN 
    CADASTROPARCEIROS TRANSP ON 
     (TRANSP.CADASTRO = coalesce(notafiscal.codigotransp,MOVIMENTOESTOQUE.transportadora))

LEFT JOIN
    MODELODOCTO ON
        MODELODOCTO.ID = NOTAFISCAL.MODELO
left join 
    TIPOCOBRANCA ON 
    pedido.TIPOCOBRANCA=TIPOCOBRANCA.TIPOCOBRANCA
left join 
    NFECTRL on 
     notafiscal.filial=nfectrl.filial and
    notafiscal.idnota=nfectrl.idnota
where 
movimentoestoque.COLETA='0876'
ORDER BY 
    movimentoestoque.idmovimento desc

