SELECT
    itemestoque.codigo,
    itemestoque.descricao,
    materiallocal.SALDOTOTAL,
    materialfilial.CONSUMOMEDIO
FROM
    MATERIALLOCAL
INNER JOIN
    MATERIALFILIAL ON
        MATERIALFILIAL.FILIAL=MATERIALLOCAL.FILIAL AND
        MATERIALFILIAL.IDITEM=MATERIALLOCAL.IDITEM
INNER JOIN
    ITEMESTOQUE ON
        ITEMESTOQUE.CODIGO=MATERIALFILIAL.IDITEM
where 
    MATERIALLOCAL.FILIAL=5 AND
    MATERIALLOCAL.IDLOCAL=1 and
    MATERIALLOCAL.SALDOTOTAL=0 AND
    itemestoque.itembase is null
ORDER BY
    coalesce(MATERIALFILIAL.CONSUMOMEDIO, 0) desc
    