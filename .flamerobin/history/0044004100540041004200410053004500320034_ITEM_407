SELECT  
    notafiscal.filial,
    notafiscal.idnota,
    notafiscal.NUMERONOTA,
    notafiscal.VLRTOTALNOTA,
    mercadoriasnota.codigo,
    mercadoriasnota.quantidade,
    mercadoriasnota.precolista
FROM    
    NOTAFISCAL
inner join
    mercadoriasnota on
        mercadoriasnota.filial=notafiscal.filial AND
        mercadoriasnota.idnota= notariscal.idnota
WHERE
    notafiscal.filial=1 AND
    notariscal.idnota=108
    