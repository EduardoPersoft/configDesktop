select
    materialmovimentoestoque.filial,
    materialmovimentoestoque.idmovimento,
    materialmovimentoestoque.idmovimentomaterial,
    materialmovimentoestoque.iditem,
    materialmovimentoestoque.idpedido
from
    materialmovimentoestoque
where
    exists (
        Select 
            *
        from
            mercadoriasped
        inner join
            movimentoestoque on
                MATERIALMOVIMENTOESTOQUE.filial=movimentoestoque.filial and
                materialmovimentoestoque.idmovimento=movimentoestoque.IDMOVIMENTO and
                movimentoestoque.tipomovimento='12'                
        where     
            mercadoriasped.filial=materialmovimentoestoque.filial and
            mercadoriasped.idnota=materialmovimentoestoque.idpedido and
            mercadoriasped.IDMERCADORIA=materialmovimentoestoque.IDMERCADORIA and
            mercadoriasped.baixa='S'            
where
    materialmovimentoestoque.filial=110 and 
    coalesce(materialmovimentoestoque.concluido, 'N')='N' 
    