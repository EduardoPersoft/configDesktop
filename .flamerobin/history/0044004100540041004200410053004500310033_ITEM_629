SET TERM ^ ;
ALTER PROCEDURE POSICAOESTOQUERESERVA2 (
    FILIAL integer )
RETURNS (
    CODIGO varchar(15),
    SALDOTOTAL double precision,
    VALORTOTALESTOCADO double precision,
    CUSTOMEDIO double precision,
    RESERVAPEDIDO double precision,
    RESERVANOTA double precision,
    RESERVAOP double precision,
    RESERVAPEDIDOCOMPRA double precision,
    ESTABELECIMENTO integer,
    RAZAOSOCIAL varchar(60) )

AS
begin

  SALDOTOTAL = 0;
  VALORTOTALESTOCADO = 0;
  CUSTOMEDIO = 0;
  RESERVAPEDIDO = 0;
  RESERVANOTA = 0;
  RESERVAOP = 0;
  RESERVAPEDIDOCOMPRA = 0;

  select cadastroparceiros.cadastro, cadastroparceiros.razaosocial
  from cadastroparceiros
  where cadastroparceiros.cadastro=:filial
  into :estabelecimento, :razaosocial;

  for select ITEMESTOQUE.CODIGO
      from ITEMESTOQUE

      into :CODIGO
  do
  begin

    suspend;
  end

  --- ESTOQUE

  for select
  locallote.iditem,
  coalesce (LOCALLOTE.quantidade,0)
  from LOCALLOTE
  where LOCALLOTE.FILIAL = :FILIAL
  into :codigo,  :SALDOTOTAL
  do
  begin
    suspend;
  end



  SALDOTOTAL = 0;
  VALORTOTALESTOCADO = 0;
  CUSTOMEDIO = 0;
  RESERVAPEDIDO = 0;
  RESERVANOTA = 0;
  RESERVAOP = 0;
  RESERVAPEDIDOCOMPRA = 0;

  --custos
    for select
    materialfilial.iditem,
    MATERIALFILIAL.VALORTOTALESTOCADO,
    MATERIALFILIAL.customedio
    from materialfilial
    where materialfilial.filial=:filial
    into :codigo, :valortotalestocado, :customedio
    do begin
       suspend;
    end
 
  SALDOTOTAL = 0;
  VALORTOTALESTOCADO = 0;
  CUSTOMEDIO = 0;
  RESERVAPEDIDO = 0;
  RESERVANOTA = 0;
  RESERVAOP = 0;
  RESERVAPEDIDOCOMPRA = 0;
  --reserva dos pedidos
  for select SALDODOPEDIDOMATERIAL.IDITEM, 
                coalesce(SUM(SALDODOPEDIDOMATERIAL.QUANTIDADE), 0)
      from SALDODOPEDIDOMATERIAL(:FILIAL)
      inner join MATERIALFILIAL on (MATERIALFILIAL.FILIAL = SALDODOPEDIDOCOMPOSICAO.FILIAL and
            MATERIALFILIAL.IDITEM = SALDODOPEDIDOMATERIAL.IDITEM)
      inner join PEDIDO on (SALDODOPEDIDOMATERIAL.FILIAL = PEDIDO.FILIAL and
            SALDODOPEDIDOMATERIAL.IDNOTA = PEDIDO.IDNOTA)
      where (coalesce(MATERIALFILIAL.TEMPOREPOSICAO, 0) = 0 or SALDODOPEDIDOMATERIAL.DATAENTREGA <= cast('now' as timestamp) + MATERIALFILIAL.TEMPOREPOSICAO)
      GROUP BY  SALDODOPEDIDOMATERIAL.IDITEM
      into :CODIGO, :RESERVAPEDIDO
  do
  begin

    suspend;
  end
  SALDOTOTAL = 0;
  VALORTOTALESTOCADO = 0;
  CUSTOMEDIO = 0;
  RESERVAPEDIDO = 0;
  RESERVANOTA = 0;
  RESERVAOP = 0;
  RESERVAPEDIDOCOMPRA = 0;

  --reserva das notas fiscais não emitidas

  for select COMPOSICAOMERCNOTA.IDITEM, coalesce(COMPOSICAOMERCNOTA.QUANTIDADE, 0)
      from COMPOSICAOMERCNOTA
      inner join NOTAFISCAL on (NOTAFISCAL.FILIAL = COMPOSICAOMERCNOTA.FILIAL and
            NOTAFISCAL.IDNOTA = COMPOSICAOMERCNOTA.IDNOTA)
      inner join NATUREZAOPERACAO on (NOTAFISCAL.OPERACAO = NATUREZAOPERACAO.ID)

      where COMPOSICAOMERCNOTA.FILIAL = :FILIAL and
            NOTAFISCAL.DATAEMISSAO is null and
            NOTAFISCAL.DATACANCELAMENTO is null and
            NOTAFISCAL.ENTRADASAIDA = 'S' and
            NOTAFISCAL.DEVOLUCAO = 'N' and
            NATUREZAOPERACAO.ESTOQUE = 'S' and
            NATUREZAOPERACAO.ENTRADASAIDA = 'S'
      into :CODIGO, :RESERVANOTA
  do
  begin

    suspend;
  end
  SALDOTOTAL = 0;
  VALORTOTALESTOCADO = 0;
  CUSTOMEDIO = 0;
  RESERVAPEDIDO = 0;
  RESERVANOTA = 0;
  RESERVAOP = 0;
  RESERVAPEDIDOCOMPRA = 0;

  --reserva da ordem de produção

  for select COMPOSICAOOP.CODIGO, coalesce(COMPOSICAOOP.QUANTIDADE -
       coalesce((select MATERIALMOVIMENTOESTOQUE.QUANTIDADE
      from MOVIMENTOESTOQUE
      inner join MATERIALMOVIMENTOESTOQUE on (MOVIMENTOESTOQUE.FILIAL = MATERIALMOVIMENTOESTOQUE.FILIAL and
                 MOVIMENTOESTOQUE.IDMOVIMENTO = MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO)
      where MOVIMENTOESTOQUE.FILIAL = COMPOSICAOOP.FILIAL and
      MOVIMENTOESTOQUE.IDMOVIMENTO = COMPOSICAOOP.IDMOVIMENTO and
       MOVIMENTOESTOQUE.IDOPITEM = COMPOSICAOOP.IDMOVIMENTOMATERIAL and
       MOVIMENTOESTOQUE.TIPOMOVIMENTO = '09' and
       MATERIALMOVIMENTOESTOQUE.IDITEM = COMPOSICAOOP.CODIGO and
       MATERIALMOVIMENTOESTOQUE.LOTE = COMPOSICAOOP.LOTE), 0), 0)
      from COMPOSICAOOP

      where COMPOSICAOOP.FILIAL = :FILIAL and
            exists(select MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO
                   from MATERIALMOVIMENTOESTOQUE
                   where MATERIALMOVIMENTOESTOQUE.FILIAL = COMPOSICAOOP.FILIAL and
                         MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO = COMPOSICAOOP.IDMOVIMENTO and
                         MATERIALMOVIMENTOESTOQUE.IDMOVIMENTOMATERIAL = COMPOSICAOOP.IDMOVIMENTOMATERIAL and
                         MATERIALMOVIMENTOESTOQUE.CONCLUIDO = 'N')
      into :CODIGO, :RESERVAOP
  do
  begin

    suspend;
  end
  SALDOTOTAL = 0;
  VALORTOTALESTOCADO = 0;
  CUSTOMEDIO = 0;
  RESERVAPEDIDO = 0;
  RESERVANOTA = 0;
  RESERVAOP = 0;
  RESERVAPEDIDOCOMPRA = 0;

  ---RESERVA DO PEDIDO DE COMPRA NÃO TOTALMENTE BAIXADO
  for select MERCADORIASPEDCOMPRA.CODIGO,
             coalesce(MERCADORIASPEDCOMPRA.QUANTIDADE - coalesce(MERCADORIASPEDCOMPRA.QTDEENTREGUE, 0), 0)
      from MERCADORIASPEDCOMPRA
      inner join PEDIDOCOMPRA on (PEDIDOCOMPRA.FILIAL = MERCADORIASPEDCOMPRA.FILIAL and
            PEDIDOCOMPRA.IDNOTA = MERCADORIASPEDCOMPRA.IDNOTA)
      inner join NATUREZAOPERACAO on (PEDIDOCOMPRA.OPERACAO = NATUREZAOPERACAO.ID)

      where MERCADORIASPEDCOMPRA.FILIAL = :FILIAL and
            --MERCADORIASPEDCOMPRA.CODIGO = :CODIGO and
            PEDIDOCOMPRA.DATAAPROVACAO is not null and
            PEDIDOCOMPRA.DATACANCELAMENTO is null and
            PEDIDOCOMPRA.ENTRADASAIDA = 'E' and
            NATUREZAOPERACAO.ESTOQUE = 'S' and
            NATUREZAOPERACAO.ENTRADASAIDA = 'E'
AND MERCADORIASPEDCOMPRA.BAIXA='N'
      into :CODIGO, :RESERVAPEDIDOCOMPRA
  do
  begin

    suspend;
  end

end
^
SET TERM ; ^


GRANT EXECUTE
 ON PROCEDURE POSICAOESTOQUERESERVA2 TO  SYSDBA;

