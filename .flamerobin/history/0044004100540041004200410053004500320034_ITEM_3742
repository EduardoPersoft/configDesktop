select 
    * 
from 
    faturasnotacompra
where 
    exists (
        select 
            *
        from
            NOTACOMPRA
        where
            notacompra.filial=faturasnotacompra.filial and
            notacompra.idnota=faturasnotacompra.idnota
            notafiscal.DATAEMISSAO between '01.01.2022' and '31.12.2022')