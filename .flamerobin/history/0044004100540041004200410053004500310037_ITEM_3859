UPDATE
 ITEMESTOQUE
SET ITEMESTOQUE.CODIGOBARRA=:CODIGOBARRA, 
ITEMESTOQUE.CODIGOBARRAVOLUME=:CODIGOBARRAVOLUME,
ITEMESTOQUE.PESOLIQUIDO=:PESOLIQUIDO,
ITEMESTOQUE.DISPONIVELECOMMERCE=:DISPONIVELECOMMERCE,
ITEMESTOQUE.FAMILIA=(SELECT FAMILIA.ID FROM FAMILIA WHERE
                     FAMILIA.DESCRICAO=:FAMILIA),
ITEMESTOQUE.grupo=(SELECT GRUPOMERCADORIA.grupo FROM GRUPOMERCADORIA WHERE
                     GRUPOMERCADORIA.DESCRICAO=:GRUPO),
ITEMESTOQUE.C_LOCALIMPORTACAO=(SELECT c_localimportacao.idlocal FROM c_localimportacao WHERE
                     c_localimportacao.DESCRICAO=:localorigem1),
ITEMESTOQUE.CLASSIFISCAL=(select CLASSIFICACAOFISCAL.CFISCAL from CLASSIFICACAOFISCAL
                                where CLASSIFICACAOFISCAL.DESCRICAO=:classificacaofiscal)      ,
ITEMESTOQUE.NOMECOMERCIAL=:NOMECOMERCIAL               
WHERE ITEMESTOQUE.CODIGO=:CODIGO