select
    MOVBANCARIOS.filial,
    MOVBANCARIOS.idcontacorrente,
    contacorrente.DESCRICAOCONTA,
    movbancarios.DATAEXTRATO,
    movbancarios.VALORMOVIMENTO*case movbancarios.TIPOMOVIMENTO when 'C' then 1 else -1 end as valor,
    movbancarios.tipomovimento
from
    MOVBANCARIOS
inner join
    contacorrente on 
        contacorrente.filial=movbancarios.filial and
        contacorrente.codigo=movbancarios.idcontacorrente
where 
    MOVBANCARIOS.filial=1 and
    MOVBANCARIOS.IDCONTACORRENTE = 341 and
    MOVBANCARIOS.DATAEXTRATO between '01.01.2022' and '31.01.2022'