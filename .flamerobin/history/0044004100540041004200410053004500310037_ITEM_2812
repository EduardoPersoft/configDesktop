SELECT                         
    *
    /*

      RELMOVPAGOPAG.FILIAL,
      RELMOVPAGOPAG.RAZAOSOCIAL,
      RELMOVPAGOPAG.PARCEIRO,
      RELMOVPAGOPAG.NOME,
      RELMOVPAGOPAG.IDTITULO,
      RELMOVPAGOPAG.TITULO,
      RELMOVPAGOPAG.FATURA,
      RELMOVPAGOPAG.EMISSAO,
      RELMOVPAGOPAG.VENCIMENTO,
      RELMOVPAGOPAG.BAIXA,
      SUM((LANTOCONTPAG.VALOR / TITULOPAG.VALORTITULO *( RELMOVPAGOPAG.VALORTITULO +
           RELMOVPAGOPAG.TOTALJUROS - RELMOVPAGOPAG.TOTALDESCONTO))) AS VALOR,
      RELMOVPAGOPAG.DATAINICIAL,
      RELMOVPAGOPAG.DATAFINAL,
      CONTASCONTABEIS.CONTACONTABIL,
      CONTASCONTABEIS.DESCRICAO, 
      ESTSIN.CONTACONTABILI,
      ESTSIN.CONTACONTABILF,
      ESTSIN.CENTROCUSTOI,
      ESTSIN.CENTROCUSTOF
*/
FROM RELMOVPAGOPAG
INNER JOIN ESTSIN ON (ESTSIN.RELATORIO = 'PMOVPAGOS')
INNER JOIN TITULOPAG ON (TITULOPAG.FILIAL = RELMOVPAGOPAG.FILIAL AND
                         TITULOPAG.IDTITULO = RELMOVPAGOPAG.IDTITULO)
INNER JOIN LANTOCONTPAG ON (LANTOCONTPAG.FILIAL = RELMOVPAGOPAG.FILIAL AND
                         LANTOCONTPAG.IDMOVTOBANC = RELMOVPAGOPAG.IDTITULO )
INNER JOIN ESTABELECIMENTO ON (RELMOVPAGOPAG.FILIAL = ESTABELECIMENTO.CADASTRO)

LEFT JOIN CONTASCONTABEIS ON (CONTASCONTABEIS.IDPLANO = ESTABELECIMENTO.PLANOCONTAS AND
                              LANTOCONTPAG.CONTACONTABIL=CONTASCONTABEIS.CONTACONTABIL)

WHERE LANTOCONTPAG.CONTACONTABIL BETWEEN ESTSIN.CONTACONTABILI AND ESTSIN.CONTACONTABILF
/*  AND LANTOCONTPAG.CENTROCUSTO   BETWEEN ESTSIN.CENTROCUSTOI   AND ESTSIN.CENTROCUSTOF
/*
GROUP BY
      RELMOVPAGOPAG.FILIAL,
      RELMOVPAGOPAG.RAZAOSOCIAL,
      RELMOVPAGOPAG.PARCEIRO,
      RELMOVPAGOPAG.NOME,
      RELMOVPAGOPAG.IDTITULO,
      RELMOVPAGOPAG.TITULO,
      RELMOVPAGOPAG.FATURA,
      RELMOVPAGOPAG.EMISSAO,
      RELMOVPAGOPAG.VENCIMENTO,
      RELMOVPAGOPAG.BAIXA,
      RELMOVPAGOPAG.DATAINICIAL,
      RELMOVPAGOPAG.DATAFINAL,
      CONTASCONTABEIS.CONTACONTABIL,
      CONTASCONTABEIS.DESCRICAO,
      ESTSIN.CONTACONTABILI,
      ESTSIN.CONTACONTABILF,
      ESTSIN.CENTROCUSTOI,
      ESTSIN.CENTROCUSTOF
HAVING SUM(RELMOVPAGOPAG.TOTAL)<>0
*/