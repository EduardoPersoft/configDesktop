SELECT 
    0 AS VOLUME,
    MOVIMENTOESTOQUE.QUANTIDADEVOLUMES,
    MOVIMENTOESTOQUE.FILIAL,
    MOVIMENTOESTOQUE.IDMOVIMENTO,
    MOVIMENTOESTOQUE.IDPEDIDO,
    CADFIL.NOME NOMEFILIAL,
    CADFIL.TELEFONE,
    CADFIL.WEB,
    NOTAFISCAL.NUMERONOTA,
    NOTAFISCAL.DATAEMISSAO,
    cadcli.nome NOMECLIENTE,
    CADSEPARADOR.NOME,
    CADCONFERENTE.NOME
    
 FROM 
    MOVIMENTOESTOQUE
 INNER JOIN 
    CADASTROPARCEIROS CADFIL ON
        CADFIL.CADASTRO=MOVIMENTOESTOQUE.FILIAL
INNER JOIN
    PEDIDO ON
    PEDIDO.FILIAL=MOVIMENTOESTOQUE.FILIAL AND 
    PEDIDO.IDNOTA=MOVIMENTOESTOQUE.IDPEDIDO
INNER JOIN
    CADASTROPARCEIROS cadcli on
        cadcli.cadastro=pedido.destinatario
LEFT JOIN 
    NOTAFISCAL ON
        notafiscal.filial=movimentoestoque.filial and
        notafiscal.idnota=movimentoestoque.IDNOTAEXPEDICAO
LEFT join
    CADASTROPARCEIROS CADSEPARADOR ON
        CADSEPARADOR.CADASTRO=MOVIMENTOESTOQUE.IDSEPARADOR
LEFT join
    CADASTROPARCEIROS CADCONFERENTE ON
        CADCONFERENTE.CADASTRO=MOVIMENTOESTOQUE.IDCONFERENTE
where
    MOVIMENTOESTOQUE.FILIAL=1 AND 
    MOVIMENTOESTOQUE.IDMOVIMENTO=59684