SELECT
    (SELECT
        PRAZOMERCPEDCOMPRA.QTDE
     FROM
        PRAZOMERCPEDCOMPRA
     WHERE 
        PRAZOMERCPEDCOMPRA.FILIAL=MERCADORIASPEDCOMPRA.FILIAL  AND
        PRAZOMERCPEDCOMPRA.IDNOTA=MERCADORIASPEDCOMPRA.IDNOTA AND
        PRAZOMERCPEDCOMPRA.IDITEM=MERCADORIASPEDCOMPRA.IDMERCADORIA),
    MERCADORIASPEDCOMPRA.QUANTIDADE,
    MERCADORIASPEDCOMPRA.QTDEENTREGUE,
    MERCADORIASPEDCOMPRA.VLRFINALMERCAD/CASE WHEN COALESCE(MERCADORIASPEDCOMPRA.PRECOUNITARIO,0) =0 THEN 1 ELSE MERCADORIASPEDCOMPRA.PRECOUNITARIO END,
    MERCADORIASPEDCOMPRA.*
FROM
    MERCADORIASPEDCOMPRA
WHERE
    MERCADORIASPEDCOMPRA.FILIAL=5 AND
    MERCADORIASPEDCOMPRA.BAIXA='N' AND
    MERCADORIASPEDCOMPRA.QUANTIDADE<>MERCADORIASPEDCOMPRA.VLRFINALMERCAD/CASE WHEN COALESCE(MERCADORIASPEDCOMPRA.PRECOUNITARIO,0) =0 THEN 1 ELSE MERCADORIASPEDCOMPRA.PRECOUNITARIO END AND
    MERCADORIASPEDCOMPRA.QTDEENTREGUE IS NULL