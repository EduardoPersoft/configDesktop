select
    itemestoque.codigo,
    itemestoque.referencia,
    itemestoque.descricao,
    cast(listaprecoproduto.preco*0.72 as decimal(12,2))
from
    LISTAPRECOPRODUTO
inner join
    itemestoque on
        itemestoque.codigo=LISTAPRECOproduto.PRODUTO
where 
    listaprecoproduto.lista =1 and
    coalesce(listaprecoproduto.preco,0)>0
order by
    itemestoque.codigo