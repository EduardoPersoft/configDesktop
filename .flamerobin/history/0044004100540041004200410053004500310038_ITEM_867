select 
       C_ORDEMSERVICO.IDPEDIDO,
       C_ORDEMSERVICO.AGENDADAPARA,
       C_ORDEMSERVICO.IDORDEM,
       C_ORDEMSERVICO.REALIZADO,
       CADCli.NOME,
       C_SERVICOSORDEMSERVICO.SERVICO,
       SERVICO.DESCRICAO,
       C_SERVICOSORDEMSERVICO.QUANTIDADE,
       C_SERVICOSORDEMSERVICO.QUANTIDADEEXECUTADA,
       SERVICO.UNIDADE,
       LISTAPRECOSERVICO.PRECO,
       cast(COALESCE ( LISTAPRECOSERVICO.PRECO,0)*COALESCE (C_SERVICOSORDEMSERVICO.QUANTIDADEEXECUTADA, 0) as double precision) AS TOTALSERVICO
from 
    C_ORDEMSERVICO
INNER JOIN 
    C_SERVICOSORDEMSERVICO on
        C_SERVICOSORDEMSERVICO.filial = c_ordemservico.filial and 
        C_SERVICOSORDEMSERVICO.IDORDEM = C_ORDEMSERVICO.IDORDEM
INNER JOIN
     CADASTROPARCEIROS CADCLI ON
        (CADCLI.CADASTRO=C_ORDEMSERVICO.CLIENTE)
INNER JOIN
      SERVICO ON
         SERVICO.CODIGO=C_SERVICOSORDEMSERVICO.SERVICO
LEFT JOIN
      LISTAPRECOSERVICO ON
         LISTAPRECOSERVICO.SERVICO=C_SERVICOSORDEMSERVICO.SERVICO
where 
    C_SERVICOSORDEMSERVICO.QUANTIDADEEXECUTADA is not null AND
    LISTAPRECOSERVICO.LISTA=179 AND
    C_ORDEMSERVICO.AGENDADAPARA BETWEEN '01.08.2022' AND '31.08.2022' and
    coalesce(c_ordemservico.comissao,'N') = 'S'
union
   select 
       C_ORDEMSERVICO.IDPEDIDO,
       C_ORDEMSERVICO.AGENDADAPARA,
       C_ORDEMSERVICO.IDORDEM,
       C_ORDEMSERVICO.REALIZADO,
       CADCLI.NOME,
       cast(null as integer),
       cast('Valor Minimo' as varchar(240)),
       cast(null as numeric(12,3)),
       cast(null as numeric(12,3)),
       cast(null as varchar(3)),
       cast(null as double precision),
       cast(coalesce(C_ORDEMSERVICO.VALORMINIMO,0)-sum(COALESCE ( LISTAPRECOSERVICO.PRECO,0)*COALESCE (C_SERVICOSORDEMSERVICO.QUANTIDADEEXECUTADA, 0))  as double precision) AS TOTALSERVICO
from 
    C_ORDEMSERVICO
INNER JOIN 
    C_SERVICOSORDEMSERVICO on
        C_SERVICOSORDEMSERVICO.filial = c_ordemservico.filial and 
        C_SERVICOSORDEMSERVICO.IDORDEM = C_ORDEMSERVICO.IDORDEM
INNER JOIN
     CADASTROPARCEIROS CADCLI ON
        (CADCLI.CADASTRO=C_ORDEMSERVICO.CLIENTE)
INNER JOIN
      SERVICO ON
         SERVICO.CODIGO=C_SERVICOSORDEMSERVICO.SERVICO
LEFT JOIN
      LISTAPRECOSERVICO ON
         LISTAPRECOSERVICO.SERVICO=C_SERVICOSORDEMSERVICO.SERVICO
where 
    C_SERVICOSORDEMSERVICO.QUANTIDADEEXECUTADA is not null AND
    LISTAPRECOSERVICO.LISTA=179 AND
    C_ORDEMSERVICO.AGENDADAPARA BETWEEN '01.08.2022' AND '31.08.2022' and    

    coalesce(c_ordemservico.comissao,'N') = 'S' 
GROUP BY    
       C_ORDEMSERVICO.IDPEDIDO,
       C_ORDEMSERVICO.AGENDADAPARA,
       C_ORDEMSERVICO.IDORDEM,
       C_ORDEMSERVICO.REALIZADO,
       CADcli.NOME,
       C_ORDEMSERVICO.VALORMINIMO 
having
   sum(COALESCE ( LISTAPRECOSERVICO.PRECO,0)*COALESCE (C_SERVICOSORDEMSERVICO.QUANTIDADEEXECUTADA, 0))<coalesce(C_ORDEMSERVICO.VALORMINIMO,0)
union
   select 
       C_ORDEMSERVICO.IDPEDIDO,
       C_ORDEMSERVICO.AGENDADAPARA,
       C_ORDEMSERVICO.IDORDEM,
       C_ORDEMSERVICO.REALIZADO,
       CADcli.NOME,
       cast(null as integer),
       cast('Adicional Noturno' as varchar(240)),
       cast(null as numeric(12,3)),
       cast(null as numeric(12,3)),
       cast(null as varchar(3)),
       cast(null as double precision),
       cast(c_ordemservico.PADICIONAL*
                    case WHEN sum(COALESCE ( LISTAPRECOSERVICO.PRECO,0)*COALESCE (C_SERVICOSORDEMSERVICO.QUANTIDADEEXECUTADA, 0))>coalesce(C_ORDEMSERVICO.VALORMINIMO,0)
                    THEN sum(COALESCE ( LISTAPRECOSERVICO.PRECO,0)*COALESCE (C_SERVICOSORDEMSERVICO.QUANTIDADEEXECUTADA, 0))
                    ELSE C_ORDEMSERVICO.VALORMINIMO 
                    END/100 AS double precision)  AS TOTALSERVICO
from 
    C_ORDEMSERVICO
INNER JOIN 
    C_SERVICOSORDEMSERVICO on
        C_SERVICOSORDEMSERVICO.filial = c_ordemservico.filial and 
        C_SERVICOSORDEMSERVICO.IDORDEM = C_ORDEMSERVICO.IDORDEM
INNER JOIN
     CADASTROPARCEIROS CADCLI ON
        (CADCLI.CADASTRO=C_ORDEMSERVICO.CLIENTE)
INNER JOIN
      SERVICO ON
         SERVICO.CODIGO=C_SERVICOSORDEMSERVICO.SERVICO
LEFT JOIN
      LISTAPRECOSERVICO ON
         LISTAPRECOSERVICO.SERVICO=C_SERVICOSORDEMSERVICO.SERVICO
where 
    C_SERVICOSORDEMSERVICO.QUANTIDADEEXECUTADA is not null AND
    LISTAPRECOSERVICO.LISTA=179 AND
    C_ORDEMSERVICO.AGENDADAPARA BETWEEN '01.08.2022' AND '31.08.2022' and
    coalesce(c_ordemservico.comissao,'N') = 'S' AND
    coalesce(C_ORDEMSERVICO.padicional,0)>0
GROUP BY    
       C_ORDEMSERVICO.IDPEDIDO,
       C_ORDEMSERVICO.AGENDADAPARA,
       C_ORDEMSERVICO.IDORDEM,
       C_ORDEMSERVICO.REALIZADO,
       CADcli.NOME,
       c_ordemservico.PADICIONAL,
       C_ORDEMSERVICO.VALORMINIMO 