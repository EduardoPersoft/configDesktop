SELECT
    DISTINCT
    PEDIDO.uuid,
    PEDIDO.FILIAL,
    PEDIDO.IDNOTA,
    PEDIDO.DATAREFERENCIA,
    PEDIDO.ENTREGA,
    PEDIDO.NUMPEDIDOCLIENTE,
    CADCLI.NOME,
    COUNT(MERCADORIASPED.IDMERCADORIA) AS QTDMERC,
    SUM(CASE MERCADORIASPED.BAIXA WHEN 'S' THEN  1 ELSE 0 END) AS QTDBAIXADA,
    PEDIDO.BLOQUEADOFATURAMENTO,
    PEDIDO.BLOQUEADOLOGISTICA,
    PEDIDO.BLOQUEADOCOMPRAS,
    (SELECT FIRST 1
        CADVEN.NOME
     FROM
        VENDEDORESPED
     INNER JOIN
        CADASTROPARCEIROS CADVEN ON
            CADVEN.CADASTRO=VENDEDORESPED.VENDEDOR
     WHERE
        VENDEDORESPED.FILIAL=PEDIDO.FILIAL AND
        VENDEDORESPED.IDNOTA=PEDIDO.IDNOTA) AS NOMEVENDEDOR,
        
    CASE 
       WHEN PEDIDO.cancelamento ='S' THEN 'Cancelado'
	   WHEN PEDIDO.BLOQUEADOFATURAMENTO = 'S' THEN 'Bloqueado'
	   WHEN COUNT(MERCADORIASPED.IDMERCADORIA)=SUM(CASE MERCADORIASPED.BAIXA WHEN 'S' THEN  1 ELSE 0 END) then 'Baixado'
      
      
      
       when SUM(CASE MERCADORIASPED.BAIXA WHEN 'S' THEN  1 ELSE 0 END)>0 then 'Parcial'
       WHEN PEDIDO.dataemissao IS NOT NULL THEN 'Aprovação'
       ELSE 'Rascunho' END AS STATUS,
    CASE WHEN PEDIDO.cancelamento ='S' THEN 'red'
       WHEN NOT EXISTS
       (SELECT * FROM MERCADORIASPED
        WHERE MERCADORIASPED.FILIAL=PEDIDO.FILIAL
        AND MERCADORIASPED.IDNOTA=PEDIDO.IDNOTA
        AND MERCADORIASPED.BAIXA='N'
        plan JOIN (MERCADORIASPED INDEX (RDB$PRIMARY37))) THEN 'grey'
       WHEN EXISTS
       (SELECT * FROM MERCADORIASPED
        WHERE MERCADORIASPED.FILIAL=PEDIDO.FILIAL
        AND MERCADORIASPED.IDNOTA=PEDIDO.IDNOTA
        AND MERCADORIASPED.BAIXA='S'
        plan JOIN (MERCADORIASPED INDEX (RDB$PRIMARY37))) THEN 'yellow'
       WHEN PEDIDO.dataemissao IS NOT NULL THEN 'blak'
       ELSE 'blue' END AS STATUS
FROM 
    PEDIDO 
INNER JOIN 
    CADASTROPARCEIROS CADCLI ON
        CADCLI.CADASTRO = PEDIDO.DESTINATARIO
LEFT JOIN
    MERCADORIASPED ON
        MERCADORIASPED.FILIAL=MERCADORIASNOTA.FILIAL AND
        MERCADORIASPED.IDNOTA=MERCADORIASNOTA.IDNOTA
LEFT JOIN 
    CADASTROPARCEIROS CADTRANS ON   
        CADTRANS.CADASTRO = PEDIDO.CODIGOTRANSP
WHERE
    PEDIDO.FILIAL=1 AND 
    PEDIDO.CANCELAMENTO = 'N' AND
    exists 
       (SELECT * FROM MERCADORIASPED
        WHERE MERCADORIASPED.FILIAL=PEDIDO.FILIAL
        AND MERCADORIASPED.IDNOTA=PEDIDO.IDNOTA
        AND MERCADORIASPED.BAIXA='N')
order by
    PEDIDO.IDNOTA DESC
