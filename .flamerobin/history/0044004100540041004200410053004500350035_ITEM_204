select
    itemestoque.codigo,
    itemestoque.descricao,
    GRUPOMERCADORIA.grupo,
    c_especificacoes.DESCRICAO
from 
    ITEMESTOQUE
INNER join
    GRUPOMERCADORIA ON
        GRUPOMERCADORIA.GRUPO=ITEMESTOQUE.GRUPO
left join
    C_ESPECIFICACOES ON
        C_eSPECIFICACOES.IDITEM=ITEMESTOQUE.CODIGO

WHERE 
    UPPER(C_eSPECIFICACOES.DESCRICAO)='MEDIDAS'