SELECT DISTINCT 
       MOVIMENTOESTOQUE.FILIAL,
       MOVIMENTOESTOQUE.IDMOVIMENTO,
       MOVIMENTOESTOQUE.DOCUMENTO,
       CLIENTE.CADASTRO CADCLI,
       CLIENTE.NOME NOMECLI,
       MOVIMENTOESTOQUE.OBSERVACAONOTAFISCAL,
       CADTRANS.NOME NOMETRANS,
       COALESCE(MOVIMENTOESTOQUE.MERCADORIASERVICO, 'M') AS MERCADORIASERVICO
FROM MOVIMENTOESTOQUE
INNER JOIN MATERIALMOVIMENTOESTOQUE ON (MATERIALMOVIMENTOESTOQUE.FILIAL=MOVIMENTOESTOQUE.FILIAL
                                    AND MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO=MOVIMENTOESTOQUE.IDMOVIMENTO)
INNER JOIN PEDIDO ON (PEDIDO.FILIAL=MATERIALMOVIMENTOESTOQUE.FILIAL
                  AND PEDIDO.IDNOTA=MATERIALMOVIMENTOESTOQUE.IDPEDIDO)
INNER JOIN CADASTROPARCEIROS CLIENTE ON (Pedido.destinatario=CLIENTE.CADASTRO)
LEFT JOIN CADASTROPARCEIROS CADTRANS ON (CADTRANS.CADASTRO=MOVIMENTOESTOQUE.TRANSPORTADORA)
WHERE MOVIMENTOESTOQUE.IDNOTAEXPEDICAO IS null
AND MOVIMENTOESTOQUE.TIPOMOVIMENTO='13'
and MATERIALMOVIMENTOESTOQUE.concluido ='S'
AND MOVIMENTOESTOQUE.FILIAL=1
AND NOT exists
(SELECT * FROM MATERIALMOVIMENTOESTOQUE
WHERE MATERIALMOVIMENTOESTOQUE.FILIAL=MOVIMENTOESTOQUE.FILIAL
AND MATERIALMOVIMENTOESTOQUE.IDMOVIMENTO=MOVIMENTOESTOQUE.IDMOVIMENTO
AND coalesce(MATERIALMOVIMENTOESTOQUE.CONCLUIDO, 'N')='N')
PLAN JOIN ( MOVIMENTOESTOQUE  INDEX (I_MOVESTOUE_IDNOTAEXPEDICAO),
            MATERIALMOVIMENTOESTOQUE INDEX(FK_MATERIALMOVIMENTOESTOQUE_1),
            PEDIDO INDEX (RDB$PRIMARY50),
            CLIENTE INDEX (RDB$PRIMARY790),
            CADTRANS INDEX (RDB$PRIMARY790))
UNION
SELECT DISTINCT 
       MOVIMENTOESTOQUE.FILIAL,
       MOVIMENTOESTOQUE.IDMOVIMENTO,
       MOVIMENTOESTOQUE.DOCUMENTO,
       CLIENTE.CADASTRO CADCLI,
       CLIENTE.NOME NOMECLI,
       MOVIMENTOESTOQUE.OBSERVACAONOTAFISCAL,
       CADTRANS.NOME NOMETRANS,
       COALESCE(MOVIMENTOESTOQUE.MERCADORIASERVICO, 'M') AS MERCADORIASERVICO
FROM MOVIMENTOESTOQUE
INNER JOIN PEDIDO ON (PEDIDO.FILIAL=MOVIMENTOESTOQUE.FILIAL
                  AND PEDIDO.IDNOTA=MOVIMENTOESTOQUE.IDPEDIDO)
INNER JOIN CADASTROPARCEIROS CLIENTE ON (Pedido.destinatario=CLIENTE.CADASTRO)
LEFT JOIN CADASTROPARCEIROS CADTRANS ON (CADTRANS.CADASTRO=MOVIMENTOESTOQUE.TRANSPORTADORA)
WHERE MOVIMENTOESTOQUE.IDNOTAEXPEDICAO IS null
AND MOVIMENTOESTOQUE.TIPOMOVIMENTO='13'
AND MOVIMENTOESTOQUE.FILIAL=1
PLAN JOIN ( MOVIMENTOESTOQUE  INDEX (I_MOVESTOUE_IDNOTAEXPEDICAO),            
            PEDIDO INDEX (RDB$PRIMARY50),
            CLIENTE INDEX (RDB$PRIMARY790),
            CADTRANS INDEX (RDB$PRIMARY790))


